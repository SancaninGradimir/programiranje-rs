{"componentChunkName":"component---src-templates-challenges-generic-show-tsx","path":"/learn/b1-english-for-developers/learn-how-to-talk-about-past-activities/dialogue-3-progress-and-change","result":{"data":{"challengeNode":{"challenge":{"assignments":["<p>Gledaj video.</p>"],"bilibiliIds":null,"block":"learn-how-to-talk-about-past-activities","challengeType":21,"description":"<section id=\"description\">\n<p>Pogledajte video dole/ispod kako biste razumeli kontekst predstojećih lekcija.</p>\n</section>","nodules":null,"explanation":null,"helpCategory":"English","instructions":"","fields":{"slug":"/learn/b1-english-for-developers/learn-how-to-talk-about-past-activities/dialogue-3-progress-and-change"},"questions":[],"scene":{"setup":{"background":"interview-room3.png","characters":[{"character":"James","position":{"x":-25,"y":0,"z":1},"opacity":null},{"character":"Linda","position":{"x":125,"y":0,"z":1},"opacity":null}],"audio":{"filename":"B1_3-3.mp3","startTime":1,"startTimestamp":null,"finishTimestamp":null},"alwaysShowDialogue":true},"commands":[{"background":null,"character":"James","position":{"x":25,"y":0,"z":1},"opacity":null,"startTime":0,"finishTime":null,"dialogue":null},{"background":null,"character":"Linda","position":{"x":70,"y":0,"z":1},"opacity":null,"startTime":0.5,"finishTime":null,"dialogue":null},{"background":null,"character":"James","position":null,"opacity":null,"startTime":1,"finishTime":4.82,"dialogue":{"text":"Linda, looking back, how long have we been collaborating on these updates?","align":"left"}},{"background":null,"character":"Linda","position":null,"opacity":null,"startTime":5.34,"finishTime":9.6,"dialogue":{"text":"It's been over a year now. We've really come a long way since that first feedback came in.","align":"right"}},{"background":null,"character":"Linda","position":null,"opacity":null,"startTime":10.1,"finishTime":16,"dialogue":{"text":"I've been part of the design team for three years and the changes we've made in just this last year have had a great impact.","align":"right"}},{"background":null,"character":"James","position":null,"opacity":null,"startTime":16.54,"finishTime":20.46,"dialogue":{"text":"Agreed. I've learned so much about user interface design in the process.","align":"left"}},{"background":null,"character":"James","position":null,"opacity":null,"startTime":20.7,"finishTime":24.86,"dialogue":{"text":"Before this, I hadn't focused much on the User Experience aspect of development.","align":"left"}},{"background":null,"character":"Linda","position":null,"opacity":null,"startTime":25.4,"finishTime":29.28,"dialogue":{"text":"That's true. You've been integrating UX into your work more than ever before.","align":"right"}},{"background":null,"character":"James","position":null,"opacity":null,"startTime":30.28,"finishTime":35.34,"dialogue":{"text":"It's interesting to think about it. I used to just write code without thinking much about the end user,","align":"left"}},{"background":null,"character":"James","position":null,"opacity":null,"startTime":35.52,"finishTime":40.7,"dialogue":{"text":"but now ensuring a positive User Experience has become a central part of my development process.","align":"left"}},{"background":null,"character":"Linda","position":null,"opacity":null,"startTime":41.78,"finishTime":44.64,"dialogue":{"text":"Exactly. And remember when we rolled out that major update last month?","align":"right"}},{"background":null,"character":"Linda","position":null,"opacity":null,"startTime":45.08,"finishTime":47.3,"dialogue":{"text":"The feedback we've received has been super positive.","align":"right"}},{"background":null,"character":"James","position":null,"opacity":null,"startTime":47.7,"finishTime":53.08,"dialogue":{"text":"I'm happy to hear that. After all, we're proactively enhancing the platform based on what we've learned.","align":"left"}},{"background":null,"character":"Linda","position":{"x":125,"y":0,"z":1},"opacity":null,"startTime":53.58,"finishTime":null,"di