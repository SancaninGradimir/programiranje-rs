cover new artists.</p>\n      </div>\n      <div>\n        <a href=\"#\">\n          Learn more\n        </a>\n        <a href=\"#\">\n          Start listening\n        </a>\n      </div>\n    </div>\n  </body>\n</html>","head":null,"tail":null,"editableRegionBoundaries":[16,23],"history":["index.html"]}],"saveSubmissionToDB":null,"tests":[{"text":"<p>Tvoj prvi anker element mora imati servisnu klasu <code>bg-white</code>.</p>","testString":"const anchorEls = document.querySelectorAll(\"a\");\nassert.isTrue(anchorEls[0].classList.contains(\"bg-white\"));"},{"text":"<p>Tvoj prvi jangkorni element treba da ima servisnu klasu <code>hover:bg-gray-100</code>.</p>","testString":"const anchorEls = document.querySelectorAll(\"a\");\nassert.isTrue(anchorEls[0].classList.contains(\"hover:bg-gray-100\"));"},{"text":"<p>Vaš prvi anker element treba da ima servisnu klasu <code>text-indigo-600</code>.</p>","testString":"const anchorEls = document.querySelectorAll(\"a\");\nassert.isTrue(anchorEls[0].classList.contains(\"text-indigo-600\"));"},{"text":"<p>Tvoj drugi anker element bi trebalo da ima servisnu klasu od <code>bg-pink-500</code>.</p>","testString":"const anchorEls = document.querySelectorAll(\"a\");\nassert.isTrue(anchorEls[1].classList.contains(\"bg-pink-500\"));"},{"text":"<p>Vaš drugi ankorni element treba da ima servisnu klasu <code>hover:bg-pink-600</code>.</p>","testString":"const anchorEls = document.querySelectorAll(\"a\");\nassert.isTrue(anchorEls[1].classList.contains(\"hover:bg-pink-600\"));"},{"text":"<p>Tvoj drugi anker element mora imati servisnu klasu od <code>text-white</code>.</p>","testString":"const anchorEls = document.querySelectorAll(\"a\");\nassert.isTrue(anchorEls[1].classList.contains(\"text-white\"));"}]}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/front-end-development-libraries-v9/#workshop-tailwind-cta-component","dashedName":"step-15","certification":"front-end-development-libraries-v9","disableLoopProtectTests":false,"disable