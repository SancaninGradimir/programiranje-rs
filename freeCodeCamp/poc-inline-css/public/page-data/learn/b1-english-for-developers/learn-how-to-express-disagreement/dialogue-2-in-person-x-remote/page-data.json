{"componentChunkName":"component---src-templates-challenges-generic-show-tsx","path":"/learn/b1-english-for-developers/learn-how-to-express-disagreement/dialogue-2-in-person-x-remote","result":{"data":{"challengeNode":{"challenge":{"assignments":["<p>Gledaj video.</p>"],"bilibiliIds":null,"block":"learn-how-to-express-disagreement","challengeType":21,"description":"<section id=\"description\">\n<p>Pogledajte video ispod da biste razumeli kontekst sledećih lekcija.</p>\n</section>","nodules":null,"explanation":null,"helpCategory":"English","instructions":"","fields":{"slug":"/learn/b1-english-for-developers/learn-how-to-express-disagreement/dialogue-2-in-person-x-remote"},"questions":[],"scene":{"setup":{"background":"interview-room3.png","characters":[{"character":"David","position":{"x":-25,"y":0,"z":1},"opacity":null},{"character":"Anna","position":{"x":125,"y":0,"z":1},"opacity":null}],"audio":{"filename":"B1_11-2.mp3","startTime":1,"startTimestamp":null,"finishTimestamp":null},"alwaysShowDialogue":true},"commands":[{"background":null,"character":"David","position":{"x":25,"y":0,"z":1},"opacity":null,"startTime":0,"finishTime":null,"dialogue":null},{"background":null,"character":"Anna","position":{"x":70,"y":0,"z":1},"opacity":null,"startTime":0.5,"finishTime":null,"dialogue":null},{"background":null,"character":"David","position":null,"opacity":null,"startTime":1,"finishTime":4.94,"dialogue":{"text":"Anna, I heard your company is embracing 100% remote work.","align":"left"}},{"background":null,"character":"David","position":null,"opacity":null,"startTime":5.38,"finishTime":9.8,"dialogue":{"text":"I'm not sure that's the best approach. Doesn't it create a disconnect among team members?","align":"left"}},{"background":null,"character":"Anna","position":null,"opacity":null,"startTime":10.54,"finishTime":14.86,"dialogue":{"text":"I see where you're coming from, David. But we found that asynchronous remote work offers flexibility.","align":"right"}},{"background":null,"character":"Anna","position":null,"opacity":null,"startTime":15.28,"finishTime":18.7,"dialogue":{"text":"It allows people to work in a way that suits their productivity and personal life.","align":"right"}},{"background":null,"character":"David","position":null,"opacity":null,"startTime":19.16,"finishTime":25.5,"dialogue":{"text":"I understand. But isn't it challenging to manage communication and collaboration with everyone working at different times?","align":"left"}},{"background":null,"character":"David","position":null,"opacity":null,"startTime":25.82,"finishTime":29.84,"dialogue":{"text":"It seems like it could lead to a lot of delays and miscommunication.","align":"left"}},{"background":null,"character":"Anna","position":null,"opacity":null,"startTime":29.84,"finishTime":34.94,"dialogue":{"text":"That's a valid point. However, we've been using collaboration tools to keep everyone connected.","align":"right"}},{"background":null,"character":"Anna","position":null,"opacity":null,"startTime":35.38,"finishTime":38.7,"dialogue":{"text":"It takes some adjustment, but once people get used to it, it works quite well.","align":"right"}},{"background":null,"character":"David","position":null,"opacity":null,"startTime":39.2,"finishTime":43.28,"dialogue":{"text":"I see your perspective, but I still think there's value in having everyone in the office.","align":"left"}},{"background":null,"character":"David","position":null,"opacity":null,"startTime":43.72,"finishTime":46.7,"dialogue":{"text":"It builds team spirit and makes problem solving easier.","align":"left"}},{"background":null,"character":"Anna","position":null,"opacity":null,"startTime":47.26,"finishTime":50.22,"dialogue":{"text":"True, but the office isn't the only place to build team spirit.","align":"right"}},{"background":null,"character":"Anna","position":null,"opacity":null,"startTime":50.7,"finishTime":53.94,"dialogue":{"text":"We've found that virtual team building activities can be just as effective.","align":"right"}},{"background":null,"character":"Anna","position":null,"opacity":null,"startTime":54.36,"finishTime":56.28,"dialogue":{"text":"How about trying some of those in your company?","align":"right"}},{"background":null,"character":"David","position":null,"opacity":null,"startTime":56.28,"finishTime":61.96,"dialogue":{"text":"That's a good suggestion, but I'm not sure I'd find much support for implementing it. Thanks for the idea, though.","align":"left"}},{"background":null,"character":"Anna","position":null,"opacity":null,"startTime":62.34,"finishTime":64.52,"dialogue":{"text":"Don't mention it. We have to do our best with what we have.","align":"right"}},{"background":null,"character":"Anna","position":{"x":125,"y":0,"z":1},"opacity":null,"startTime":65.02,"finishTime":null,"dialogue":null},{"background":null,"character":"David","position":{"x":-25,"y":0,"z":1},"opacity":null,"startTime":65.52,"finishTime":null,"dialogue":null}]},"superBlock":"b1-english-for-developers","tests":[],"title":"Dijalog 2: U osobi x Na daljinu","transcript":null,"translationPending":false,"videoId":null,"videoLocaleIds":null}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/b1-english-for-developers/#learn-how-to-express-disagreement","dashedName":"dialogue-2-in-person-x-remote","certification":"b1-english-for-developers","disableLoopProtectTests":false,"disableLoopProtectPreview":false,"superBlock":"b1-english-for-developers","chapter":null,"module":null,"block":"learn-how-to-express-disagreement","isFirstStep":false,"template":null,"required":[],"isLastChallengeInBlock":false,"nextChallengePath":"/learn/b1-english-for-developers/learn-how-to-express-disagreement/task-49","prevChallengePath":"/learn/b1-english-for-developers/learn-how-to-express-disagreement/task-48","id":"67af1528c5b6a20ec8a5b7da","saveSubmissionToDB":null},"projectPreview":{"challengeData":{"challengeType":19,"challengeFiles":[]}},"id":"/learn/b1-english-for-developers/learn-how-to-express-disagre