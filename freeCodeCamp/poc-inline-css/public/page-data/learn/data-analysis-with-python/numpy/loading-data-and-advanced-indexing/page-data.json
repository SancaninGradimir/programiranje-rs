{"componentChunkName":"component---src-templates-challenges-generic-show-tsx","path":"/learn/data-analysis-with-python/numpy/loading-data-and-advanced-indexing","result":{"data":{"challengeNode":{"challenge":{"assignments":[],"bilibiliIds":{"aid":720524642,"bvid":"BV1xQ4y1r7mu","cid":409027117},"block":"numpy","challengeType":11,"description":"","nodules":null,"explanation":null,"helpCategory":"Python","instructions":"","fields":{"slug":"/learn/data-analysis-with-python/numpy/loading-data-and-advanced-indexing"},"questions":[{"text":"<p>Ako postoji fajl pod nazivom <code>data.txt</code> koji sadrži sledeće:</p>\n<pre>\n29,97,32,100,45\n15,88,5,75,22\n</pre>\n<p>Koji kod bi generisao sledeći red podataka?</p>\n<pre><code class=\"language-py\">[29. 32. 45. 15.  5. 22.]\n</code></pre>","answers":[{"answer":"<pre><code class=\"language-py\">filedata = np.genfromtxt('data.txt', delimiter=',')\noutput = np.any(filedata &#x3C; 50)\n\nprint(output)\n</code></pre>","feedback":null,"audioId":null},{"answer":"<pre><code class=\"language-py\">filedata = np.genfromtxt('data.txt', delimiter=',')\noutput = np.all(filedata &#x3C; 50, axis=1)\n\nprint(output)\n</code></pre>","feedback":null,"audioId":null},{"answer":"<pre><code class=\"language-py\">filedata = np.genfromtxt('data.txt', delimiter=',')\noutput = filedata[filedata &#x3C; 50]\n\nprint(output)\n</code></pre>","feedback":null,"audioId":null}],"solution":3}],"scene":null,"superBlock":"data-analysis-with-python","tests":[],"title":"Učitavanje podataka sa naprednim modelom","transcript":null,"translationPending":false,"videoId":"tUdBZ7pF8Jg","videoLocaleIds":null}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/data-analysis-with-python/#numpy","dashedName":"loading-data-and-advanced-indexing","certification":"data-analysis-with-python","disableLoopProtectTests":false,"disableLoopProtectPreview":false,"superBlock":"data-analysis-with-python","chapter":null,"module":null,"block":"numpy","isFirstStep":false,"template