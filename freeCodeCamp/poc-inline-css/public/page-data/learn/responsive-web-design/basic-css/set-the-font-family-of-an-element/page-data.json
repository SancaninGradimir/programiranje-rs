{"componentChunkName":"component---src-templates-challenges-classic-show-tsx","path":"/learn/responsive-web-design/basic-css/set-the-font-family-of-an-element","result":{"data":{"challengeNode":{"challenge":{"block":"basic-css","demoType":null,"title":"Postavi Font Familiju Elementa","description":"<section id=\"description\">\n<p>Mozete odrediti koji font element treba da koristi pomocu svojstva <code>font-family</code>.</p>\n<p>Na primer, ako zelite da font <code>h2</code> elementa bude <code>sans-serif</code>, koristili biste sledeci CSS:</p>\n<pre><code class=\"language-css\">h2 {\n  font-family: sans-serif;\n}\n</code></pre>\n</section>","id":"bad87fee1348bd9aede08807","hasEditableBoundaries":false,"instructions":"<section id=\"instructions\">\n<p>Neka svi <code>p</code> elementi koriste <code>monospace</code> font.</p>\n</section>","notes":null,"challengeType":0,"helpCategory":"HTML-CSS","videoUrl":"https://scrimba.com/c/c3bvpCg","superBlock":"responsive-web-design","translationPending":false,"forumTopicId":18278,"hooks":null,"fields":{"slug":"/learn/responsive-web-design/basic-css/set-the-font-family-of-an-element"},"required":[],"usesMultifileEditor":false,"challengeFiles":[{"fileKey":"indexhtml","ext":"html","name":"index","contents":"<style>\n  .red-text {\n    color: red;\n  }\n\n  p {\n    font-size: 16px;\n  }\n</style>\n\n<h2 class=\"red-text\">CatPhotoApp</h2>\n<main>\n  <p class=\"red-text\">Click here to view more <a href=\"#\">cat photos</a>.</p>\n\n  <a href=\"#\"><img src=\"https://cdn.freecodecamp.org/curriculum/cat-photo-app/relaxing-cat.jpg\" alt=\"A cute orange cat lying on its back.\"></a>\n\n  <div>\n    <p>Things cats love:</p>\n    <ul>\n      <li>catnip</li>\n      <li>laser pointers</li>\n      <li>lasagna</li>\n    </ul>\n    <p>Top 3 things cats hate:</p>\n    <ol>\n      <li>flea treatment</li>\n      <li>thunder</li>\n      <li>other cats</li>\n    </ol>\n  </div>\n\n  <form action=\"https://freecatphotoapp.com/submit-cat-photo\">\n    <label><input type=\"radio\" name=\"indoor-outdoor\" checked> Indoor</label>\n    <label><input type=\"radio\" name=\"indoor-outdoor\"> Outdoor</label><br>\n    <label><input type=\"checkbox\" name=\"personality\" checked> Loving</label>\n    <label><input type=\"checkbox\" name=\"personality\"> Lazy</label>\n    <label><input type=\"checkbox\" name=\"personality\"> Energetic</label><br>\n    <input type=\"text\" placeholder=\"cat photo URL\" required>\n    <button type=\"submit\">Submit</button>\n  </form>\n</main>","head":null,"tail":null,"editableRegionBoundaries":[],"history":["index.html"]}],"saveSubmissionToDB":null,"tests":[{"text":"<p>Vasi <code>p</code> elementi treba da koriste <code>monospace</code> font.</p>","testString":"const notRed = document.querySelector('p:not(.red-text)');\nconst fontFamily = window.getComputedStyle(notRed)['font-family']; \nassert.match(fontFamily, /monospace/i);"}]}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/responsive-web-design/#basic-css","dashedName":"set-the-font-family-of-an-element","certification":"responsive-web-design","disableLoopProtectTests":false,"disableLoopProtectPreview":false,"superBlock":"responsive-web-design","chapter":null,"module":null,"block":"basic-css","isFirstStep":false,"template":null,"required":[],"isLastChallengeInBlock":false,"nextChallengePath":"/learn/responsive-web-design/basic-css/import-a-google-font","prevChallengePath":"/learn/responsive-web-design/basic-css/change-the-font-size-of-an-element","id":"bad87fee1348bd9aede08807","saveSubmissionToDB":null},"projectPreview":{"challengeData":{"challengeType":0,"challengeFiles":[{"name":"index","ext":"html","contents":"<style>@media (max-width: 350px) {:root {--penguin-size: 200px; --penguin-skin: black;}}</style>","history":["index.html"],"fileKey":"indexhtml"}]}},"id":"/learn/responsive-web-design/basic-css/set-the-font-family-of-an-element"}},"staticQueryHashes":["3858520367"],"slicesMap":{}}