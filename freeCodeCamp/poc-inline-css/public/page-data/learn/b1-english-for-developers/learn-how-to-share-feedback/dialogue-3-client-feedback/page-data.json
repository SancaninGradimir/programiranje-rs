{"componentChunkName":"component---src-templates-challenges-generic-show-tsx","path":"/learn/b1-english-for-developers/learn-how-to-share-feedback/dialogue-3-client-feedback","result":{"data":{"challengeNode":{"challenge":{"assignments":["<p>Gledaj video</p>"],"bilibiliIds":null,"block":"learn-how-to-share-feedback","challengeType":21,"description":"<section id=\"description\">\n<p>Pogledajte video dole/ispod kako biste razumeli kontekst predstojećih lekcija.</p>\n</section>","nodules":null,"explanation":null,"helpCategory":"English","instructions":"","fields":{"slug":"/learn/b1-english-for-developers/learn-how-to-share-feedback/dialogue-3-client-feedback"},"questions":[],"scene":{"setup":{"background":"company1-boardroom.png","characters":[{"character":"Maria","position":{"x":-25,"y":0,"z":1},"opacity":null},{"character":"James","position":{"x":125,"y":0,"z":1},"opacity":null}],"audio":{"filename":"B1_8-3.mp3","startTime":1,"startTimestamp":null,"finishTimestamp":null},"alwaysShowDialogue":true},"commands":[{"background":null,"character":"Maria","position":{"x":25,"y":0,"z":1},"opacity":null,"startTime":0,"finishTime":null,"dialogue":null},{"background":null,"character":"James","position":{"x":70,"y":0,"z":1},"opacity":null,"startTime":0.5,"finishTime":null,"dialogue":null},{"background":null,"character":"Maria","position":null,"opacity":null,"startTime":1,"finishTime":3.3,"dialogue":{"text":"Hi, James. I just got an email from a client.","align":"left"}},{"background":null,"character":"Maria","position":null,"opacity":null,"startTime":3.54,"finishTime":6.46,"dialogue":{"text":"He's not happy with our latest update and I'm not sure why.","align":"left"}},{"background":null,"character":"Maria","position":null,"opacity":null,"startTime":6.62,"finishTime":7.94,"dialogue":{"text":"Did you hear anything about this?","align":"left"}},{"background":null,"character":"James","position":null,"opacity":null,"startTime":8.28,"finishTime":11.64,"dialogue":{"text":"No, I didn't. What did he say? Is it something serious?","align":"right"}},{"background":null,"character":"Maria","position":null,"opacity":null,"startTime":12.18,"finishTime":14.8,"dialogue":{"text":"He mentioned that some features aren't working as expected.","align":"left"}},{"background":null,"character":"James","position":null,"opacity":null,"startTime":15.62,"finishTime":18.32,"dialogue":{"text":"Which features did he mention? Do you think it's a coding issue?","align":"right"}},{"background":null,"character":"Maria","position":null,"opacity":null,"startTime":19.3,"finishTime":22.88,"dialogue":{"text":"He pointed out that the search function is slow and some buttons aren't responding.","align":"left"}},{"background":null,"character":"Maria","position":null,"opacity":null,"startTime":23.32,"finishTime":26.3,"dialogue":{"text":"If we don't fix these, it could impact customer satisfaction.","align":"left"}},{"background":null,"character":"James","position":null,"opacity":null,"startTime":27,"finishTime":29.74,"dialogue":{"text":"Absolutely. Do you think we need to update the software again?","align":"right"}},{"background":null,"character":"James","position":null,"opacity":null,"startTime":30.02,"finishTime":32.46,"dialogue":{"text":"If we do, it might delay other projects.","align":"right"}},{"background":null,"character":"Maria","position":null,"opacity":null,"startTime":33.06,"finishTime":36,"dialogue":{"text":"We need to find a solution without causing too much disruption.","align":"left"}},{"background":null,"character":"Maria","position":null,"opacity":null,"startTime":36.5,"finishTime":38.56,"dialogue":{"text":"Can you look into it and see what's causing the problem?","align":"left"}},{"background":null,"character":"James","position":null,"opacity":null,"startTime":39.04,"finishTime":43.26,"dialogue":{"text":"Sure. I'll check it out. If it's a simple fix, I can work on it right away.","align":"right"}},{"background":null,"character":"Maria","position":null,"opacity":null,"startTime":44.18,"finishTime":47.94,"dialogue":{"text":"Yes, but let's make sure we understand the full scope of the issue before making changes.","align":"left"}},{"background":null,"character":"Maria","position":null,"opacity":null,"startTime":48.08,"finishTime":50,"dialogue":{"text":"If we rush, it could lead to more problems.","align":"left"}},{"background":null,"character":"James","position":null,"opacity":null,"startTime":50.28,"finishTime":57.02,"dialogue":{"text":"You're right. I'll take a closer look and let you know what I find. If there's anything critical, I'll update you immediately.","align":"right"}},{"background":null,"character":"Maria","position":null,"opacity":null,"startTime":57.56,"finishTime":61.98,"dialogue":{"text":"Sounds good. Also, let's keep the client informed so they know we're working on it.","align":"left"}},{"background":null,"character":"Maria","position":null,"opacity":null,"startTime":62.2,"finishTime":65.1,"dialogue":{"text":"If we keep them in the loop, it might help ease their frustration, right?","align":"left"}},{"background":null,"character":"James","position":null,"opacity":null,"startTime":65.56,"finishTime":70.26,"dialogue":{"text":"Exactly. I'll send you an update once I've investigated. Let's hope it's an easy fix.","align":"right"}},{"background":null,"character":"James","position":{"x":125,"y":0,"z":1},"opacity":null,"startTime":70.76,"finishTime":null,"dialogue":null},{"background":null,"character":"Maria","position":{"x":-25,"y":0,"z":1},"opacity":null,"startTime":71.26,"finishTime":null,"dialogue":null}]},"superBlock":"b1-english-for-developers","tests":[],"title":"Dialog 3: Povratne informacije klijenta","transcript":null,"translationPending":false,"videoId":null,"videoLocaleIds":null}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/b1-english-for-developers/#learn-how-to-share-feedback","dashedName":"dialogue-3-client-feedback","certification":"b1-english-for-developers","disableLoopProtectTests":fa