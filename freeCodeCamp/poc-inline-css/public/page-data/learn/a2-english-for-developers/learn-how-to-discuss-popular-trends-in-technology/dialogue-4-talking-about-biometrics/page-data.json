{"componentChunkName":"component---src-templates-challenges-generic-show-tsx","path":"/learn/a2-english-for-developers/learn-how-to-discuss-popular-trends-in-technology/dialogue-4-talking-about-biometrics","result":{"data":{"challengeNode":{"challenge":{"assignments":["<p>Gledaj video.</p>"],"bilibiliIds":null,"block":"learn-how-to-discuss-popular-trends-in-technology","challengeType":21,"description":"<section id=\"description\">\n<p>Pogledajte video ispod da biste razumeli kontekst sledećih lekcija.</p>\n</section>","nodules":null,"explanation":null,"helpCategory":"English","instructions":"","fields":{"slug":"/learn/a2-english-for-developers/learn-how-to-discuss-popular-trends-in-technology/dialogue-4-talking-about-biometrics"},"questions":[],"scene":{"setup":{"background":"company2-breakroom.png","characters":[{"character":"Tom","position":{"x":-25,"y":0,"z":1},"opacity":null},{"character":"Alice","position":{"x":125,"y":0,"z":1},"opacity":null}],"audio":{"filename":"4.2-4.mp3","startTime":1,"startTimestamp":null,"finishTimestamp":null},"alwaysShowDialogue":true},"commands":[{"background":null,"character":"Tom","position":{"x":25,"y":0,"z":1},"opacity":null,"startTime":0,"finishTime":null,"dialogue":null},{"background":null,"character":"Alice","position":{"x":70,"y":0,"z":1},"opacity":null,"startTime":0.5,"finishTime":null,"dialogue":null},{"background":null,"character":"Tom","position":null,"opacity":null,"startTime":1.7,"finishTime":4.1,"dialogue":{"text":"Alice, what's the deal with biometrics?","align":"left"}},{"background":null,"character":"Tom","position":null,"opacity":null,"startTime":4.4,"finishTime":7.4,"dialogue":{"text":"I keep hearing about facial recognition and fingerprint scanning.","align":"left"}},{"background":null,"character":"Alice","position":null,"opacity":null,"startTime":8.1,"finishTime":11.5,"dialogue":{"text":"Biometrics is the use of physical or behavioral traits for security.","align":"right"}},{"background":null,"character":"Alice","position":null,"opacity":null,"startTime":12.1,"finishTime":13.6,"dialogue":{"text":"It's used for access control,","align":"right"}},{"background":null,"character":"Alice","position":null,"opacity":null,"startTime":13.8,"finishTime":15.9,"dialogue":{"text":"like unlocking your phone with your face or fingerprint.","align":"right"}},{"background":null,"character":"Alice","position":null,"opacity":null,"startTime":16.4,"finishTime":18.3,"dialogue":{"text":"Also, it's used for identity verification","align":"right"}},{"background":null,"character":"Alice","position":null,"opacity":null,"startTime":18.3,"finishTime":20,"dialogue":{"text":"at airports and secure facilities.","align":"right"}},{"background":null,"character":"Tom","position":null,"opacity":null,"startTime":20.5,"finishTime":21.5,"dialogue":{"text":"Is it safe?","align":"left"}},{"background":null,"character":"Alice","position":null,"opacity":null,"startTime":22,"finishTime":24.6,"dialogue":{"text":"It's generally secure, but like any technology,","align":"right"}},{"background":null,"character":"Alice","position":null,"opacity":null,"startTime":24.7,"finishTime":26.9,"dialogue":{"text":"it has its challenges and privacy concerns.","align":"right"}},{"background":null,"character":"Alice","position":null,"opacity":null,"startTime":27.3,"finishTime":31.2,"dialogue":{"text":"It's necessary to keep biometric data protected to maintain its security.","align":"right"}},{"background":null,"character":"Tom","position":null,"opacity":null,"startTime":31.7,"finishTime":34.4,"dialogue":{"text":"What are people studying in biometrics these days?","align":"left"}},{"background":null,"character":"Alice","position":null,"opacity":null,"startTime":35.2,"finishTime":38.2,"dialogue":{"text":"Researchers are exploring biometrics beyond traditional methods.","align":"right"}},{"background":null,"character":"Alice","position":null,"opacity":null,"startTime":38.7,"finishTime":41.8,"dialogue":{"text":"For example, they're experimenting with palm vein recognition","align":"right"}},{"background":null,"character":"Alice","position":null,"opacity":null,"startTime":41.8,"finishTime":44.9,"dialogue":{"text":"and even behavioral biometrics like typing patterns","align":"right"}},{"background":null,"character":"Alice","position":null,"opacity":null,"startTime":44.9,"finishTime":45.9,"dialogue":{"text":"to enhance security.","align":"right"}},{"background":null,"character":"Alice","position":{"x":125,"y":0,"z":1},"opacity":null,"startTime":46.4,"finishTime":null,"dialogue":null},{"background":null,"character":"Tom","position":{"x":-25,"y":0,"z":1},"opacity":null,"startTime":46.9,"finishTime":null,"dialogue":null}]},"superBlock":"a2-english-for-developers","tests":[],"title":"Dijalog 4: Razgovor o biometriji","transcript":null,"translationPending":false,"videoId":null,"videoLocaleIds":null}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/a2-english-for-developers/#learn-how-to-discuss-popular-trends-in-technology","dashedName":"dialogue-4-talking-about-biometrics","certification":"a2-english-for-developers","disableLoopProtectTests":false,"disableLoopProtectPreview":false,"superBlock":"a2-english-for-developers","chapter":null,"module":null,"block":"learn-how-to-discuss-popular-trends-in-technology","isFirstStep":false,"template":null,"required":[],"isLastChallengeInBlock":false,"nextChallengePath":"/learn/a2-english-for-developers/learn-how-to-discuss-popular-trends-in-technology/task-62","prevChallengePath":"/learn/a2-english-for-developers/learn-how-to-discuss-popular-trends-in-technology/task-61","id":"65fdcfcd986a305a20de5e57","saveSubmissionToDB":null},"projectPreview":{"challengeData":{"challengeType":22,"challengeFiles":[]}},"id":"/learn/a2-english-for-developers/learn-how-to-discuss-popular-trends-in-technology/dialogue-4-talking-about-biometrics"}},"staticQueryHashes":["3858520367"],"slicesMap":{}}