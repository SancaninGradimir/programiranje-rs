    {
      "text": "<p>Tvoj kod treba da ima oznaku otvaranja <code>section</code>.</p>",
      "testString": "assert.match(code, /<section.*>/i);"
    },
    {
      "text": "<p>Vaš kod bi trebalo da ima zatvarajući tag od <code>section</code>.</p>",
      "testString": "assert.match(code, /<\\/section>/i);"
    },
    {
      "text": "<p>Element vašeg <code>section</code> treba da ima <code>id</code> postavljen na <code>\"posts\"</code>.</p>",
      "testString": "assert.match(code, /<section.*id=\"posts\".*>/i);"
    },
    {
      "text": "<p>Element vašeg <code>section</code> treba biti unutar elementa vašeg <code>main</code>.</p>",
      "testString": "const sectionElement = document.getElementById('posts');\nassert.strictEqual(sectionElement?.parentElement.tagName, 'MAIN');"
    },
    {
      "text": "<p>Tvoj element za <code>h2</code> treba da bude unutar elementa <code>section</code>.</p>",
      "testString": "const h2Element = document.querySelector('#posts h2');\nassert.strictEqual(h2Element?.parentElement.tagName, 'SECTION');"
