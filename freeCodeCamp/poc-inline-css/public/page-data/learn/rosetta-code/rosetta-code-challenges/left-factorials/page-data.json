{"componentChunkName":"component---src-templates-challenges-classic-show-tsx","path":"/learn/rosetta-code/rosetta-code-challenges/left-factorials","result":{"data":{"challengeNode":{"challenge":{"block":"rosetta-code-challenges","demoType":null,"title":"Fabrika sa leve strane","description":"<section id=\"description\">\n<p><strong>Faktorijal sa leve strane</strong>, $ !n $, može značiti <em>subfaktorijal</em> ili <em>zbir faktorijala</em>. Taj isti simbol može se koristiti na zbunjujući način u dva različita značenja. Ponekad, <em>subfaktorijali</em> (takođe poznati kao <em>derangementi</em>) mogu koristiti jedan od ovih simbola:</p>\n<ul>\n  <li>$!n`$</li>\n  <li>$!n$</li>\n  <li>$n¡$</li>\n</ul>\n<p>(Možda nije očigledno golim okom, ali poslednji primer koristi usmeren znak uzvika.) Ova vežba će koristiti ovu formulu za <strong>faktoria ya kushoto</strong>:</p>\n<p>$ !n = \\sum_{k=0}^{n-1} k! $</p>\n<p>gde je $!0 = 0$</p>\n</section>","id":"5a23c84252665b21eecc7ee0","hasEditableBoundaries":false,"instructions":"<section id=\"instructions\">\n<p>Napišite funkciju koja računa faktorijel datevenog broja.</p>\n</section>","notes":null,"challengeType":1,"helpCategory":"Rosetta","videoUrl":null,"superBlock":"rosetta-code","translationPending":false,"forumTopicId":302302,"hooks":null,"fields":{"slug":"/learn/rosetta-code/rosetta-code-challenges/left-factorials"},"required":[],"usesMultifileEditor":false,"challengeFiles":[{"fileKey":"scriptjs","ext":"js","name":"script","contents":"function leftFactorial(n) {\n\n}","head":null,"tail":null,"editableRegionBoundaries":[],"history":["script.js"]}],"saveSubmissionToDB":null,"tests":[{"text":"<p><code>leftFactorial</code> Trebalo bi da bude funkcija.</p>","testString":"assert(typeof leftFactorial == 'function');"},{"text":"<p><code>leftFactorial(0)</code> trebalo bi da vrati broj.</p>","testString":"assert(typeof leftFactorial(0) == 'number');"},{"text":"<p><code>leftFactorial(0)</code> treba da vrati <code>0</code>.</p>","testString":"assert.equal(leftFactorial(0), 0);"},{"text":"<p><code>leftFactorial(1)</code> trebalo bi da vrati <code>1</code>.</p>","testString":"assert.equal(leftFactorial(1), 1);"},{"text":"<p><code>leftFactorial(2)</code> treba da vrati <code>2</code>.</p>","testString":"assert.equal(leftFactorial(2), 2);"},{"text":"<p><code>leftFactorial(3)</code> trebalo bi da vrati <code>4</code>.</p>","testString":"assert.equal(leftFactorial(3), 4);"},{"text":"<p><code>leftFactorial(10)</code> inapaswa kurudisha <code>409114</code>.</p>","testString":"assert.equal(leftFactorial(10), 409114);"},{"text":"<p><code>leftFactorial(17)</code> inapaswa kurudisha <code>22324392524314</code>.</p>","testString":"assert.equal(leftFactorial(17), 22324392524314);"},{"text":"<p><code>leftFactorial(19)</code> treba da vrati <code>6780385526348314</code>.</p>","testString":"assert.equal(leftFactorial(19), 6780385526348314);"}]}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/rosetta-code/#rosetta-code-challenges","dashedName":"left-factorials","certification":"rosetta-code","disableLoopProtectTests":true,"disableLoopProtectPreview":false,"superBlock":"rosetta-code","chapter":null,"module":null,"block":"rosetta-code-challenges","isFirstStep":false,"template":null,"required":[],"isLastChallengeInBlock":false,"nextChallengePath":"/learn/rosetta-code/rosetta-code-challenges/letter-frequency","prevChallengePath":"/learn/rosetta-code/rosetta-code-challenges/least-common-multiple","id":"5a23c84252665b21eecc7ee0","saveSubmissionToDB":null},"projectPreview":{"challengeData":{"challengeType":1,"challengeFiles":[{"name":"script","ext":"js","contents":"function ZigZagMatrix(n) {\n  const mtx = [];\n  for (let i = 0; i < n; i++) {\n    mtx[i] = [];\n  }\n\n  let i = 1;\n  let j = 1;\n  for (let e = 0; e < n * n; e++) {\n    mtx[i - 1][j - 1] = e;\n    if ((i + j) % 2 === 0) {\n      // Even stripes\n      if (j < n) j++;\n      else i += 2;\n      if (i > 1) i--;\n    } else {\n      // Odd stripes\n      if (i < n) i++;\n      else j += 2;\n      if (j > 1) j--;\n    }\n  }\n  return mtx;\n}","history":["script.js"],"fileKey":"scriptjs"}]}},"id":"/learn/rosetta-code/rosetta-code-challenges/left-factorials"}},"staticQueryHashes":["3858520367"],"slicesMap":{}}