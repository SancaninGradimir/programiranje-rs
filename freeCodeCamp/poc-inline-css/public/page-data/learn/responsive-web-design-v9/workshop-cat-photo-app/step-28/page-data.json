{"componentChunkName":"component---src-templates-challenges-classic-show-tsx","path":"/learn/responsive-web-design-v9/workshop-cat-photo-app/step-28","result":{"data":{"challengeNode":{"challenge":{"block":"workshop-cat-photo-app","demoType":null,"title":"Korak 28","description":"<section id=\"description\">\n<p>Nakon elementa <code>figure</code>, dodajte drugi element od <code>h3</code> sa tekstom:</p>\n<p><code>Top 3 things cats hate:</code></p>\n</section>","id":"5ef9b03c81a63668521804d1","hasEditableBoundaries":true,"instructions":"","notes":null,"challengeType":0,"helpCategory":"HTML-CSS","videoUrl":null,"superBlock":"responsive-web-design-v9","translationPending":false,"forumTopicId":null,"hooks":null,"fields":{"slug":"/learn/responsive-web-design-v9/workshop-cat-photo-app/step-28"},"required":[],"usesMultifileEditor":true,"challengeFiles":[{"fileKey":"indexhtml","ext":"html","name":"index","contents":"<html>\n  <body>\n    <main>\n      <h1>CatPhotoApp</h1>\n      <section>\n        <h2>Cat Photos</h2>\n        <p>Everyone loves <a href=\"https://cdn.freecodecamp.org/curriculum/cat-photo-app/running-cats.jpg\">cute cats</a> online!</p>\n        <p>See more <a target=\"_blank\" href=\"https://freecatphotoapp.com\">cat photos</a> in our gallery.</p>\n        <a href=\"https://freecatphotoapp.com\"><img src=\"https://cdn.freecodecamp.org/curriculum/cat-photo-app/relaxing-cat.jpg\" alt=\"A cute orange cat lying on its back.\"></a>\n      </section>\n      <section>\n        <h2>Cat Lists</h2>\n        <h3>Things cats love:</h3>\n        <ul>\n          <li>catnip</li>\n          <li>laser pointers</li>\n          <li>lasagna</li>\n        </ul>\n        <figure>\n          <img src=\"https://cdn.freecodecamp.org/curriculum/cat-photo-app/lasagna.jpg\" alt=\"A slice of lasagna on a plate.\">\n          <figcaption>Cats <em>love</em> lasagna.</figcaption>  \n        </figure>\n        \n      </section>\n    </main>\n  </body>\n</html>","head":null,"tail":null,"editableRegionBoundaries":[22,24],"history":["index.html"]}],"saveSubmissionToDB":null,"tests":[{"text":"<p>Element <code>h3</code> bi trebalo da bude iznad zatvarajuće oznake elementa <code>section</code>. Proverite da ima otvorenu i zatvorenu oznaku.</p>","testString":"assert.equal(\n  document.querySelectorAll('main > section')[1]?.lastElementChild.nodeName,\n    'H3'\n);\nassert.lengthOf(code.match(/<\\/h3\\>/g),  2);"},{"text":"<p>Nova funkcija za <code>h3</code> treba da ima tekst od <code>Top 3 things cats hate:</code>. Uverite se da uključite vertikalnu tačku na kraju teksta.</p>","testString":"assert.equal(\n  document\n    .querySelectorAll('main > section')[1]\n    ?.lastElementChild.innerText?.trim().toLowerCase()\n    .replace(/\\s+/g, ' '), 'top 3 things cats hate:'\n);"},{"text":"<p>Element <code>figure</code> bi trebalo da bude iznad novog elementa <code>h3</code>. Verovatno ste slučajno obrisali/uklonili element <code>figure</code>.</p>","testString":"const secondSectionLastElemNode = document.querySelectorAll('main > section')[1]\n  ?.lastElementChild;\nassert.equal(secondSectionLastElemNode?.nodeName, 'H3');\nassert.equal(secondSectionLastElemNode.previousElementSibling.nodeName, 'FIGURE');"}]}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/responsive-web-design-v9/#workshop-cat-photo-app","dashedName":"step-28","certification":"responsive-web-design-v9","disableLoopProtectTests":false,"disableLoopProtectPreview":false,"superBlock":"responsive-web-design-v9","chapter":"html","module":"basic-html","block":"workshop-cat-photo-app","isFirstStep":false,"template":null,"required":[],"isLastChallengeInBlock":false,"nextChallengePath":"/learn/responsive-web-design-v9/workshop-cat-photo-app/step-29","prevChallengePath":"/learn/responsive-web-design-v9/workshop-cat-photo-app/step-27","id":"5ef9b03c81a63668521804d1","saveSubmissionToDB":null},"projectPreview":{"challengeData":{"challengeType":0,"challengeFiles":[{"name":"index","ext":"html","contents":"<!DOCTYPE html>\n<html lang=\"en\">\n  <head>\n    <meta charset=\"UTF-8\">\n    <title>CatPhotoApp</title>\n  </head>\n  <body>\n    <main>\n      <h1>CatPhotoApp</h1>\n      <section>\n        <h2>Cat Photos</h2>\n        <p>Everyone loves <a href=\"https://cdn.freecodecamp.org/curriculum/cat-photo-app/running-cats.jpg\">cute cats</a> online!</p>\n        <p>See more <a target=\"_blank\" href=\"https://freecatphotoapp.com\">cat photos</a> in our gallery.</p>\n        <a href=\"https://freecatphotoapp.com\"><img src=\"https://cdn.freecodecamp.org/curriculum/cat-photo-app/relaxing-cat.jpg\" alt=\"A cute orange cat lying on its back.\"></a>\n      </section>\n      <section>\n        <h2>Cat Lists</h2>\n        <h3>Things cats love:</h3>\n        <ul>\n          <li>catnip</li>\n          <li>laser pointers</li>\n          <li>lasagna</li>\n        </ul>\n        <figure>\n          <img src=\"https://cdn.freecodecamp.org/curriculum/cat-photo-app/lasagna.jpg\" alt=\"A slice of lasagna on a plate.\">\n          <figcaption>Cats <em>love</em> lasagna.</figcaption>  \n        </figure>\n        <h3>Top 3 things cats hate:</h3>\n        <ol>\n          <li>flea treatment</li>\n          <li>thunder</li>\n          <li>other cats</li>\n        </ol>\n        <figure>\n          <img src=\"https://cdn.freecodecamp.org/curriculum/cat-photo-app/cats.jpg\" alt=\"Two tabby kittens sleeping together on a couch.\">\n          <figcaption>Cats <strong>hate</strong> other cats.</figcaption>  \n        </figure>\n      </section>\n    </main>\n    <footer>\n      <p>\n        No Copyright - <a href=\"https://www.freecodecamp.org\">freeCodeCamp.org</a>\n      </p>\n    </footer>\n  </body>\n</html>","history":["index.html"],"fileKey":"indexhtml"}]}},"id":"/learn/responsive-web-design-v9/workshop-cat-photo-app/step-28"}},"staticQueryHashes":["3858520367"],"slicesMap":{}}