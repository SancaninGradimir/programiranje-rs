{"componentChunkName":"component---src-templates-challenges-generic-show-tsx","path":"/learn/b1-english-for-developers/learn-how-to-share-your-opinion/dialogue-3-selecting-a-cloud-platform","result":{"data":{"challengeNode":{"challenge":{"assignments":["<p>Gledaj video.</p>"],"bilibiliIds":null,"block":"learn-how-to-share-your-opinion","challengeType":21,"description":"<section id=\"description\">\n<p>Pogledajte video dole/ispod kako biste razumeli kontekst predstojećih lekcija.</p>\n</section>","nodules":null,"explanation":null,"helpCategory":"English","instructions":"","fields":{"slug":"/learn/b1-english-for-developers/learn-how-to-share-your-opinion/dialogue-3-selecting-a-cloud-platform"},"questions":[],"scene":{"setup":{"background":"company2-boardroom.png","characters":[{"character":"Bob","position":{"x":-25,"y":0,"z":1},"opacity":null},{"character":"Lisa","position":{"x":125,"y":0,"z":1},"opacity":null}],"audio":{"filename":"B1_9-3.mp3","startTime":1,"startTimestamp":null,"finishTimestamp":null},"alwaysShowDialogue":true},"commands":[{"background":null,"character":"Bob","position":{"x":25,"y":0,"z":1},"opacity":null,"startTime":0,"finishTime":null,"dialogue":null},{"background":null,"character":"Lisa","position":{"x":70,"y":0,"z":1},"opacity":null,"startTime":0.5,"finishTime":null,"dialogue":null},{"background":null,"character":"Bob","position":null,"opacity":null,"startTime":1,"finishTime":6.54,"dialogue":{"text":"Lisa, we're thinking of using a cloud platform for our next project. Do you have any suggestions?","align":"left"}},{"background":null,"character":"Lisa","position":null,"opacity":null,"startTime":7.44,"finishTime":12.92,"dialogue":{"text":"Well, it could be a good idea to use AWS. It's quite popular and there's a lot of documentation for it.","align":"right"}},{"background":null,"character":"Bob","position":null,"opacity":null,"startTime":13.14,"finishTime":17.1,"dialogue":{"text":"I see, but I'm not sure if AWS is the best option for us.","align":"left"}},{"background":null,"character":"Bob","position":null,"opacity":null,"startTime":17.22,"finishTime":19.66,"dialogue":{"text":"It might be a bit complex for some of our team members.","align":"left"}},{"background":null,"character":"Lisa","position":null,"opacity":null,"startTime":20.16,"finishTime":24.92,"dialogue":{"text":"That's true. It seems like Google Cloud might be easier to use, especially for smaller projects.","align":"right"}},{"background":null,"character":"Lisa","position":null,"opacity":null,"startTime":25.32,"finishTime":27.46,"dialogue":{"text":"It could be a better fit if we're looking for simplicity.","align":"right"}},{"background":null,"character":"Bob","position":null,"opacity":null,"startTime":27.98,"finishTime":30.38,"dialogue":{"text":"Maybe. I think Azure could work too,","align":"left"}},{"background":null,"character":"Bob","position":null,"opacity":null,"startTime":30.76,"finishTime":35.4,"dialogue":{"text":"since it integrates well with other Microsoft products and we already use those. What do you think?","align":"left"}},{"background":null,"character":"Lisa","position":null,"opacity":null,"startTime":36.04,"finishTime":39.94,"dialogue":{"text":"It might work, but I'm not sure if Azure has the same level of support as AWS.","align":"right"}},{"background":null,"character":"Lisa","position":null,"opacity":null,"startTime":40.52,"finishTime":42.84,"dialogue":{"text":"I've heard that their customer service isn't as responsive.","align":"right"}},{"background":null,"character":"Bob","position":null,"opacity":null,"startTime":43.32,"finishTime":46.64,"dialogue":{"text":"I guess that's something to consider. We could try asking around","align":"left"}},{"background":null,"character":"Bob","position":null,"opacity":null,"startTime":46.64,"finishTime":50.64,"dialogue":{"text":"to see what other teams have experienced with these platforms. Would that be a good idea?","align":"left"}},{"background":null,"character":"Lisa","position":null,"opacity":null,"startTime":51.1,"finishTime":54.5,"dialogue":{"text":"That might be the best approach. It could help us make a more informed decision.","align":"right"}},{"background":null,"character":"Bob","position":null,"opacity":null,"startTime":55.24,"finishTime":59.04,"dialogue":{"text":"I'll ask on the team channel. I might even create a poll and see the votes.","align":"left"}},{"background":null,"character":"Bob","position":null,"opacity":null,"startTime":59.6,"finishTime":61.58,"dialogue":{"text":"This might be fun. Thank you for your help.","align":"left"}},{"background":null,"character":"Lisa","position":{"x":125,"y":0,"z":1},"opacity":null,"startTime":62.08,"finishTime":null,"dialogue":null},{"background":null,"character":"Bob","position":{"x":-25,"y":0,"z":1},"opacity":null,"startTime":62.58,"finishTime":null,"dialogue":null}]},"superBlock":"b1-english-for-developers","tests":[],"title":"Dialog 3: Izbor platforme u oblaku","transcript":null,"translationPending":false,"videoId":null,"videoLocaleIds":null}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/b1-english-for-developers/#learn-how-to-share-your-opinion","dashedName":"dialogue-3-selecting-a-cloud-platform","certification":"b1-english-for-developers","disableLoopProtectTests":false,"disableLoopProtectPreview":false,"superBlock":"b1-english-for-developers","chapter":null,"module":null,"block":"learn-how-to-share-your-opinion","isFirstStep":false,"template":null,"required":[],"isLastChallengeInBlock":false,"nextChallengePath":"/learn/b1-english-for-developers/learn-how-to-share-your-opinion/task-76","prevChallengePath":"/learn/b1-english-for-developers/learn-how-to-share-your-opinion/task-75","id":"678f05c97f4f1fe9a1cc32a0","saveSubmissionToDB":null},"projectPreview":{"challengeData":{"challengeType":19,"challengeFiles":[]}},"id":"/learn/b1-english-for-developers/learn-how-to-share-your-opinion/dialogue-3-selecting-a-cloud-platform"}},"staticQueryHashes":["3858520367"],"slicesMap":{}}