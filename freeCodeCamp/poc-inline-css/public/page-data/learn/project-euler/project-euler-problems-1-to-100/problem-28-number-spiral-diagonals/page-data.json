t.js"]}],"saveSubmissionToDB":null,"tests":[{"text":"<p><code>spiralDiagonals(101)</code> treba da vrati broj.</p>","testString":"assert(typeof spiralDiagonals(101) === 'number');"},{"text":"<p><code>spiralDiagonals(101)</code> trebalo bi da vrati 692101.</p>","testString":"assert(spiralDiagonals(101) == 692101);"},{"text":"<p><code>spiralDiagonals(303)</code> trebalo bi da vrati 18591725.</p>","testString":"assert(spiralDiagonals(303) == 18591725);"},{"text":"<p><code>spiralDiagonals(505)</code> treba da vrati 85986601.</p>","testString":"assert(spiralDiagonals(505) == 85986601);"},{"text":"<p><code>spiralDiagonals(1001)</code> trebalo bi da vrati 669171001.</p>","testString":"assert(spiralDiagonals(1001) == 669171001);"}]}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/project-euler/#project-euler-problems-1-to-100","dashedName":"problem-28-number-spiral-diagonals","certification":"project-euler","disableLoopProtectTests":true,"disableLoopProtectPreview":false,"superBlock":"project-euler","chapter":null,"module":null,"block":"project-euler-problems-1-to-100","isFirstStep":false,"template":null,"required":[],"isLastChallengeInBlock":false,"nextChallengePath":"/learn/project-euler/project-euler-problems-1-to-100/problem-29-distinct-powers","prevChallengePath":"/learn/project-euler/project-euler-problems-1-to-100/problem-27-quadratic-primes","id":"5900f3881000cf542c50fe9b","saveSubmissionToDB":null},"projectPreview":{"challengeData":{"challengeType":1,"challengeFiles":[{"name":"script","ext":"js","contents":"function arrangedProbability(limit) {\n  // Based on https://www.mathblog.dk/project-euler-100-blue-discs-two-blue/\n  let blue = 15;\n  let discs = 21;\n\n  while (discs < limit) {\n    const nextBlue = 3 * blue + 2 * discs - 2;\n    const nextDiscs = 4 * blue + 3 * discs - 3;\n\n    blue = nextBlue;\n    discs = nextDiscs;\n  }\n  return blue;\n}","history":["script.js"],"fileKey":"scriptjs"}]}},"id":"/learn/project-euler/project-euler-problems-1-to-