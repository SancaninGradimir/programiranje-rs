{"componentChunkName":"component---src-templates-challenges-generic-show-tsx","path":"/learn/b1-english-for-developers/learn-how-to-use-adjectives-in-conversations/dialogue-2-rehearsing-pitch","result":{"data":{"challengeNode":{"challenge":{"assignments":["<p>Gledaj video.</p>"],"bilibiliIds":null,"block":"learn-how-to-use-adjectives-in-conversations","challengeType":21,"description":"<section id=\"description\">\n<p>Pogledajte video dole/ispod kako biste razumeli kontekst predstojećih lekcija.</p>\n</section>","nodules":null,"explanation":null,"helpCategory":"English","instructions":"","fields":{"slug":"/learn/b1-english-for-developers/learn-how-to-use-adjectives-in-conversations/dialogue-2-rehearsing-pitch"},"questions":[],"scene":{"setup":{"background":"interview-room3.png","characters":[{"character":"Jake","position":{"x":-25,"y":0,"z":1},"opacity":null},{"character":"Alice","position":{"x":125,"y":0,"z":1},"opacity":null}],"audio":{"filename":"B1_19-2.mp3","startTime":1,"startTimestamp":null,"finishTimestamp":null},"alwaysShowDialogue":true},"commands":[{"background":null,"character":"Jake","position":{"x":25,"y":0,"z":1},"opacity":null,"startTime":0,"finishTime":null,"dialogue":null},{"background":null,"character":"Alice","position":{"x":70,"y":0,"z":1},"opacity":null,"startTime":0.5,"finishTime":null,"dialogue":null},{"background":null,"character":"Jake","position":null,"opacity":null,"startTime":1,"finishTime":4.18,"dialogue":{"text":"All right, Alice, here's how I plan to start the pitch.","align":"left"}},{"background":null,"character":"Jake","position":null,"opacity":null,"startTime":4.96,"finishTime":13.68,"dialogue":{"text":"In today's fast evolving digital landscape, startups require a robust, cost-effective cybersecurity solution.","align":"left"}},{"background":null,"character":"Jake","position":null,"opacity":null,"startTime":14.1,"finishTime":20.74,"dialogue":{"text":"Guardian Tech offers just that, an innovative and flexible suite that grows with your business.","align":"left"}},{"background":null,"character":"Alice","position":null,"opacity":null,"startTime":20.74,"finishTime":27.42,"dialogue":{"text":"That sounds really good, Jake. You used 'robust' and 'cost-effective', which highlights the most important qualities right away.","align":"right"}},{"background":null,"character":"Alice","position":null,"opacity":null,"startTime":27.92,"finishTime":30.8,"dialogue":{"text":"Maybe consider emphasizing how essential these features are?","align":"right"}},{"background":null,"character":"Jake","position":null,"opacity":null,"startTime":31.24,"finishTime":33.82,"dialogue":{"text":"Hmm... Okay. How about this?","align":"left"}},{"background":null,"character":"Jake","position":null,"opacity":null,"startTime":33.82,"finishTime":42.24,"dialogue":{"text":"Guardian Tech isn't just helpful. It's essential for protecting against the wide array of digital threats facing startups today.","align":"left"}},{"background":null,"character":"Jake","position":null,"opacity":null,"startTime":42.76,"finishTime":50.78,"dialogue":{"text":"Our solution is not only adaptable but also incredibly easy to integrate into any existing infrastructure.","align":"left"}},{"background":null,"character":"Alice","position":null,"opacity":null,"startTime":51.94,"finishTime":55.94,"dialogue":{"text":"Yes, that's clearer. You're showing the urgency and ease of integration well.","align":"right"}},{"background":null,"character":"Alice","position":null,"opacity":null,"startTime":55.94,"finishTime":59.42,"dialogue":{"text":"When you talk about integration, maybe specify what makes it easy?","align":"right"}},{"background":null,"character":"Jake","position":null,"opacity":null,"startTime":60.06,"finishTime":61.14,"dialogue":{"text":"Good point. I'll add:","align":"left"}},{"background":null,"character":"Jake","position":null,"opacity":null,"startTime":61.7,"finishTime":68.76,"dialogue":{"text":"With its plug-and-play design, GuardianTech is a user-friendly option that requires minimal setup time.","align":"left"}},{"background":null,"character":"Jake","position":null,"opacity":null,"startTime":69.48,"finishTime":75.3,"dialogue":{"text":"This seamless integration makes it an ideal choice for startups with limited IT resources.","align":"left"}},{"background":null,"character":"Alice","position":null,"opacity":null,"startTime":76.28,"finishTime":81.42,"dialogue":{"text":"Perfect! That part about 'minimal setup time' really clarifies it. How will you conclude the pitch?","align":"right"}},{"background":null,"character":"Jake","position":null,"opacity":null,"startTime":82.24,"finishTime":84.52,"dialogue":{"text":"I was thinking of finishing with a focus on the future. Like:","align":"left"}},{"background":null,"character":"Jake","position":null,"opacity":null,"startTime":85.5,"finishTime":95.66,"dialogue":{"text":"As your startup grows, GuardianTech scales effortlessly to meet increasing demands ensuring a secure, sustainable digital environment.","align":"left"}},{"background":null,"character":"Alice","position":null,"opacity":null,"startTime":96.6,"finishTime":100.92,"dialogue":{"text":"That's a strong ending. It reassures that the product is a long-term solution.","align":"right"}},{"background":null,"character":"Alice","position":null,"opacity":null,"startTime":100.92,"finishTime":108.3,"dialogue":{"text":"Just make sure to slow down a bit when you get to 'secure, sustainable digital environment' to let those adjectives sink in.","align":"right"}},{"background":null,"character":"Jake","position":null,"opacity":null,"startTime":109.14,"finishTime":111.58,"dialogue":{"text":"Definitely. I'll make a note of that. Thanks for the feedback, Alice.","align":"left"}},{"background":null,"character":"Jake","position":null,"opacity":null,"startTime":111.6,"finishTime":115.59,"dialogue":{"text":"I feel much more confident about delivering this pitch now.","align":"left"}},{"background":null,"character":"Alice","position":{"x":125,"y":0,"z":1},"opacity":null,"startTime":116.08,"finishTime":null,"dialogue":null},{"background":null,"character":"Jake","position":{"x":-25,"y":0,"z":1},"opacity":null,"startTime":116.58,"finishTime":null,"dialogue":null}]},"superBlock":"b1-english-for-developers","tests":[],"title":"Dialog 2: Vežbanje prezentacije","transcript":null,"translationPending":false,"videoId":null,"videoLocaleIds":null}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/b1-english-for-developers/#learn-how-to-use-adjectives-in-conversations","dashedName":"dialogue-2-rehearsing-pitch","certification":"b1-english-for-developers","disableLoopProtectTests":false,"disableLoopProtectPreview":false,"superBlock":"b1-english-for-developers","chapter":null,"module":null,"block":"learn-how-to-use-adjectives-in-conversations","isFirstStep":false,"template":null,"required":[],"isLastChallengeInBlock":false,"nextChallengePath":"/learn/b1-english-for-developers/learn-how-to-use-adjectives-in-conversations/task-56","prevChallengePath":"/learn/b1-english-for-developers/learn-how-to-use-adjectives-in-conversations/task-55","id":"6810d008957707fd9cf42612","saveSubmissionToDB":null},"projectPreview":{"challengeData":{"challengeType":19,"challengeFiles":[]}},"id":"/learn/b1-english-for-developers/learn-how-to-use-adjectives-in-conversations/dialogue-2-rehearsing-pitch"}},"staticQueryHashes":["3858520367"],"slicesMap":{}}