{"componentChunkName":"component---src-templates-challenges-classic-show-tsx","path":"/learn/project-euler/project-euler-problems-1-to-100/problem-31-coin-sums","result":{"data":{"challengeNode":{"challenge":{"block":"project-euler-problems-1-to-100","demoType":null,"title":"Vežba 31: Rečenica o valuti","description":"<section id=\"description\">\n<p>U Velikoj Britaniji valuta se sastoji od punja, £, i penija, p, a postoji osam valuta koje se uobičajeno koriste:</p>\n<div style='margin-left: 4em;'>1p, 2p, 5p, 10p, 20p, 50p, £1 (100p) i £2 (200p).</div>\n<p>Moguće je zaraditi 2 funte na sledeći način:</p>\n<div style='margin-left: 4em;'>1×£1 + 1×50p + 2×20p + 1×5p + 1×2p + 3×1p</div>\n<p>Koliko različitih načina se može koristiti za izradu <code>n</code> centi koristeći bilo koji broj novčića?</p>\n</section>","id":"5900f38b1000cf542c50fe9e","hasEditableBoundaries":false,"instructions":"","notes":null,"challengeType":1,"helpCategory":"Euler","videoUrl":null,"superBlock":"project-euler","translationPending":false,"forumTopicId":301965,"hooks":null,"fields":{"slug":"/learn/project-euler/project-euler-problems-1-to-100/problem-31-coin-sums"},"required":[],"usesMultifileEditor":false,"challengeFiles":[{"fileKey":"scriptjs","ext":"js","name":"script","contents":"function coinSums(n) {\n\n  return n;\n}\n\ncoinSums(200);","head":null,"tail":null,"editableRegionBoundaries":[],"history":["script.js"]}],"saveSubmissionToDB":null,"tests":[{"text":"<p><code>coinSums(50)</code> Trebalo bi da vrati broj.</p>","testString":"assert(typeof coinSums(50) === 'number');"},{"text":"<p><code>coinSums(50)</code> treba da vrati 451.</p>","testString":"assert(coinSums(50) == 451);"},{"text":"<p><code>coinSums(100)</code> treba da vrati 4563.</p>","testString":"assert(coinSums(100) == 4563);"},{"text":"<p><code>coinSums(150)</code> trebalo bi da vrati 21873.</p>","testString":"assert(coinSums(150) == 21873);"},{"text":"<p><code>coinSums(200)</code> treba da vrati 73682.</p>","testString":"assert(coinSums(200) == 73682);"}]}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/project-euler/#project-euler-problems-1-to-100","dashedName":"problem-31-coin-sums","certification":"project-euler","disableLoopProtectTests":true,"disableLoopProtectPreview":false,"superBlock":"project-euler","chapter":null,"module":null,"block":"project-euler-problems-1-to-100","isFirstStep":false,"template":null,"required":[],"isLastChallengeInBlock":false,"nextChallengePath":"/learn/project-euler/project-euler-problems-1-to-100/problem-32-pandigital-products","prevChallengePath":"/learn/project-euler/project-euler-problems-1-to-100/problem-30-digit-n-powers","id":"5900f38b1000cf542c50fe9e","saveSubmissionToDB":null},"projectPreview":{"challengeData":{"challengeType":1,"challengeFiles":[{"name":"script","ext":"js","contents":"function arrangedProbability(limit) {\n  // Based on https://www.mathblog.dk/project-euler-100-blue-discs-two-blue/\n  let blue = 15;\n  let discs = 21;\n\n  while (discs < limit) {\n    const nextBlue = 3 * blue + 2 * discs - 2;\n    const nextDiscs = 4 * blue + 3 * discs - 3;\n\n    blue = nextBlue;\n    discs = nextDiscs;\n  }\n  return blue;\n}","history":["script.js"],"fileKey":"scriptjs"}]}},"id":"/learn/project-euler/project-euler-problems-1-to-100/problem-31-coin-sums"}},"staticQueryHashes":["3858520367"],"slicesMap":{}}