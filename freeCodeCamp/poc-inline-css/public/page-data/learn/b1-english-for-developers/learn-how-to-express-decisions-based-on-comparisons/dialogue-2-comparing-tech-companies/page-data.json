{"componentChunkName":"component---src-templates-challenges-generic-show-tsx","path":"/learn/b1-english-for-developers/learn-how-to-express-decisions-based-on-comparisons/dialogue-2-comparing-tech-companies","result":{"data":{"challengeNode":{"challenge":{"assignments":["<p>Gledaj video.</p>"],"bilibiliIds":null,"block":"learn-how-to-express-decisions-based-on-comparisons","challengeType":21,"description":"<section id=\"description\">\n<p>Pogledajte video ispod da biste razumeli kontekst sledećih lekcija.</p>\n</section>","nodules":null,"explanation":null,"helpCategory":"English","instructions":"","fields":{"slug":"/learn/b1-english-for-developers/learn-how-to-express-decisions-based-on-comparisons/dialogue-2-comparing-tech-companies"},"questions":[],"scene":{"setup":{"background":"company2-center.png","characters":[{"character":"Alice","position":{"x":-25,"y":0,"z":1},"opacity":null},{"character":"Tom","position":{"x":125,"y":0,"z":1},"opacity":null}],"audio":{"filename":"B1_13-2.mp3","startTime":1,"startTimestamp":null,"finishTimestamp":null},"alwaysShowDialogue":true},"commands":[{"background":null,"character":"Alice","position":{"x":25,"y":0,"z":1},"opacity":null,"startTime":0,"finishTime":null,"dialogue":null},{"background":null,"character":"Tom","position":{"x":70,"y":0,"z":1},"opacity":null,"startTime":0.5,"finishTime":null,"dialogue":null},{"background":null,"character":"Alice","position":null,"opacity":null,"startTime":1,"finishTime":5.26,"dialogue":{"text":"Hey, Tom. I'm considering switching jobs and I'm looking at a few tech companies.","align":"left"}},{"background":null,"character":"Alice","position":null,"opacity":null,"startTime":5.7,"finishTime":9.62,"dialogue":{"text":"You've been in the industry longer than I have. Which company do you think is the best to work for?","align":"left"}},{"background":null,"character":"Tom","position":null,"opacity":null,"startTime":9.88,"finishTime":15.56,"dialogue":{"text":"Well, Alice, it depends on what you're looking for. In terms of work-life balance, TechCorp is probably the best.","align":"right"}},{"background":null,"character":"Tom","position":null,"opacity":null,"startTime":15.64,"finishTime":19.18,"dialogue":{"text":"They offer the most flexible hours and the most generous leave policy.","align":"right"}},{"background":null,"character":"Alice","position":null,"opacity":null,"startTime":19.72,"finishTime":25.24,"dialogue":{"text":"That's interesting. I'm also interested in career growth. Which company offers the most opportunities for advancement?","align":"left"}},{"background":null,"character":"Tom","position":null,"opacity":null,"startTime":25.68,"finishTime":34.2,"dialogue":{"text":"I'd say Innovate X is best for career growth. They have the most structured training programs and a clear path for promotions.","align":"right"}},{"background":null,"character":"Alice","position":null,"opacity":null,"startTime":35,"finishTime":38.8,"dialogue":{"text":"Good to know. What about compensation? Which company pays the highest salaries?","align":"left"}},{"background":null,"character":"Tom","position":null,"opacity":null,"startTime":39.26,"finishTime":42.48,"dialogue":{"text":"In terms of pay, TechCorp usually offers the highest salaries.","align":"right"}},{"background":null,"character":"Tom","position":null,"opacity":null,"startTime":42.66,"finishTime":49.26,"dialogue":{"text":"However, Innovate X has the best bonuses in stock options, which can be even more lucrative in the long run.","align":"right"}},{"background":null,"character":"Alice","position":null,"opacity":null,"startTime":49.7,"finishTime":54.6,"dialogue":{"text":"I see. What about company culture? I don't want to work somewhere that's too rigid or formal.","align":"left"}},{"background":null,"character":"Alice","position":null,"opacity":null,"startTime":54.9,"finishTime":57,"dialogue":{"text":"Which company has the most relaxed atmosphere?","align":"left"}},{"background":null,"character":"Tom","position":null,"opacity":null,"startTime":57,"finishTime":65.04,"dialogue":{"text":"Oh, that's definitely Startup Labs. They have the most laid-back culture with a casual dress code and a fun work environment.","align":"right"}},{"background":null,"character":"Tom","position":null,"opacity":null,"startTime":65.32,"finishTime":69.02,"dialogue":{"text":"It's a great place to work if you value creativity and innovation.","align":"right"}},{"background":null,"character":"Alice","position":null,"opacity":null,"startTime":69.88,"finishTime":72.68,"dialogue":{"text":"Thanks for all the information, Tom. This gives me a lot to think about.","align":"left"}},{"background":null,"character":"Tom","position":null,"opacity":null,"startTime":73.62,"finishTime":77.28,"dialogue":{"text":"No problem, Alice. If you have any more questions, just let me know.","align":"right"}},{"background":null,"character":"Tom","position":null,"opacity":null,"startTime":77.54,"finishTime":80.94,"dialogue":{"text":"I can also introduce you to a few people in these companies if you'd like.","align":"right"}},{"background":null,"character":"Alice","position":null,"opacity":null,"startTime":81.42,"finishTime":83.1,"dialogue":{"text":"That would be great. I appreciate it, Tom.","align":"left"}},{"background":null,"character":"Tom","position":{"x":125,"y":0,"z":1},"opacity":null,"startTime":83.6,"finishTime":null,"dialogue":null},{"background":null,"character":"Alice","position":{"x":-25,"y":0,"z":1},"opacity":null,"startTime":84.1,"finishTime":null,"dialogue":null}]},"superBlock":"b1-english-for-developers","tests":[],"title":"Dialog 2: Poređenje tehnoloških kompanija","transcript":null,"translationPending":false,"videoId":null,"videoLocaleIds":null}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/b1-english-for-developers/#learn-how-to-express-decisions-based-on-comparisons","dashedName":"dialogue-2-comparing-tech-companies","certification":"b1-english-for-developers","disableLoopProtectTests":false,"disableL