ll,"tests":[{"text":"<p><code>arrToObj</code> Trebalo bi da bude funkcija.</p>","testString":"assert(typeof arrToObj === 'function');"},{"text":"<p><code>arrToObj([1, 2, 3, 4, 5], [\"a\", \"b\", \"c\", \"d\", \"e\"])</code> trebalo bi da vrati <code>{ 1: \"a\", 2: \"b\", 3: \"c\", 4: \"d\", 5: \"e\" }</code></p>","testString":"assert.deepEqual(arrToObj(...testCases[0]), res[0]);"},{"text":"<p><code>arrToObj([1, 2, 3, 4, 5], [\"a\", \"b\", \"c\", \"d\"])</code> trebalo bi da vrati <code>{ 1: \"a\", 2: \"b\", 3: \"c\", 4: \"d\", 5: undefined }</code></p>","testString":"assert.deepEqual(arrToObj(...testCases[1]), res[1]);"},{"text":"<p><code>arrToObj([1, 2, 3], [\"a\", \"b\", \"c\", \"d\", \"e\"])</code> trebalo bi da vrati <code>{ 1: \"a\", 2: \"b\", 3: \"c\" }</code></p>","testString":"assert.deepEqual(arrToObj(...testCases[2]), res[2]);"},{"text":"<p><code>arrToObj([\"a\", \"b\", \"c\", \"d\", \"e\"], [1, 2, 3, 4, 5])</code> treba da vrati <code>{ \"a\": 1, \"b\": 2, \"c\": 3 , \"d\": 4, \"e\": 5 }</code></p>","testString":"assert.deepEqual(arrToObj(...testCases[3]), res[3]);"},{"text":"<p><code>arrToObj([\"a\", \"b\", \"c\", \"d\", \"e\"], [1, 2, 3, 4])</code> trebalo bi da vrati <code>{ \"a\": 1, \"b\": 2, \"c\": 3 , \"d\": 4, \"e\": undefined }</code></p>","testString":"assert.deepEqual(arrToObj(...testCases[4]), res[4]);"},{"text":"<p><code>arrToObj([\"a\", \"b\", \"c\"], [1, 2, 3, 4, 5])</code> treba da vrati <code>{ \"a\": 1, \"b\": 2, \"c\": 3 }</code></p>","testString":"assert.deepEqual(arrToObj(...testCases[5]), res[5]);"}]}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/rosetta-code/#rosetta-code-challenges","dashedName":"hash-from-two-arrays","certification":"rosetta-code","disableLoopProtectTests":true,"disableLoopProtectPreview":false,"superBlock":"rosetta-code","chapter":null,"module":null,"block":"rosetta-code-challenges","isFirstStep":false,"template":null,"required":[],"isLastChallengeInBlock":false,"nextChallengePath":"/learn/rosetta-code/rosetta-code-challenges/hash-join","prevChallengePath":"/learn/rosetta-code/rosetta-code-challenges/harshad-or-niven-series","id":"595671d4d2cdc305f0d5b36f","saveSubmissionToDB":null},"projectPreview":{"challengeData":{"challengeType":1,"challengeFiles":[{"name":"script","ext":"js","contents":"function ZigZagMatrix(n) {\n  const mtx = [];\n  for (let i = 0; i < n; i++) {\n    mtx[i] = [];\n  }\n\n  let i = 1;\n  let j = 1;\n  for (let e = 0; e < n * n; e++) {\n    mtx[i - 1][j - 1] = e;\n    if ((i + j) % 2 === 0) {\n      // Even stripes\n      if (j < n) j++;\n      else i += 2;\n      if (i > 1) i--;\n    } else {\n      // Odd stripes\n      if (i < n) i++;\n      else j += 2;\n      if (j > 1) j--;\n    }\n  }\n  return mtx;\n}","history":["script.js"],"fileKey":"scriptjs"}]}},"id":"/learn/rosetta-code/rosetta-code-challenges/hash-from-two-arrays"}},"staticQueryHashes":["3858520367"],"slicesMap":{}}