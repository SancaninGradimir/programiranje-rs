    {
      "text": "<p>Vrednost <code>box-shadow</code> svojstva treba da bude 25px za <code>offset-x</code>, 10px za <code>offset-y</code>, 0 za <code>blur-radius</code>, 0 za <code>spread-radius</code> i na kraju <code>blue</code> za <code>color</code>.</p>",
      "testString": "assert.match(code,/box-shadow:\\s*?25px\\s+?10px\\s+?0(px)?\\s+?0(px)?\\s+?blue\\s*?;/gi);"
