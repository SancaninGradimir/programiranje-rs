        "fileKey": "scriptjs",
        "contents": "function convertToRoman(num) {\r\n  var ref = [['M', 1000], ['CM', 900], ['D', 500], ['CD', 400], ['C', 100], ['XC', 90], ['L', 50], ['XL', 40], ['X', 10], ['IX', 9], ['V', 5], ['IV', 4], ['I', 1]];\r\n  var res = [];\r\n  ref.forEach(function(p) {\r\n    while (num >= p[1]) {\r\n      res.push(p[0]);\r\n      num -= p[1];\r\n    }\r\n  });\r\n  return res.join('');\r\n}",
        "error": null,
        "seed": "function convertToRoman(num) {\r\n  var ref = [['M', 1000], ['CM', 900], ['D', 500], ['CD', 400], ['C', 100], ['XC', 90], ['L', 50], ['XL', 40], ['X', 10], ['IX', 9], ['V', 5], ['IV', 4], ['I', 1]];\r\n  var res = [];\r\n  ref.forEach(function(p) {\r\n    while (num >= p[1]) {\r\n      res.push(p[0]);\r\n      num -= p[1];\r\n    }\r\n  });\r\n  return res.join('');\r\n}"
      }
    ]
