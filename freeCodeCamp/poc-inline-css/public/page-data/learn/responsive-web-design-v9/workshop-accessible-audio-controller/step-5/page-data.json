{"componentChunkName":"component---src-templates-challenges-classic-show-tsx","path":"/learn/responsive-web-design-v9/workshop-accessible-audio-controller/step-5","result":{"data":{"challengeNode":{"challenge":{"block":"workshop-accessible-audio-controller","demoType":null,"title":"Korak 5","description":"<section id=\"description\">\n<p>Sledeće, morate dodati element <code>input</code> sa svojstvom elementa <code>type</code> postavljeno na <code>range</code> ili kreirati audio sampler. Postavite svojstvo elementa <code>min</code> na <code>0</code>, svojstvo elementa <code>max</code> na <code>100</code>, i svojstvo elementa <code>value</code> na <code>50</code> ili definišite osnovni nivo zvuka.</p>\n</section>","id":"68ed3a96e0ebcc36565b39e5","hasEditableBoundaries":true,"instructions":"","notes":null,"challengeType":0,"helpCategory":"HTML-CSS","videoUrl":null,"superBlock":"responsive-web-design-v9","translationPending":false,"forumTopicId":null,"hooks":null,"fields":{"slug":"/learn/responsive-web-design-v9/workshop-accessible-audio-controller/step-5"},"required":[],"usesMultifileEditor":true,"challengeFiles":[{"fileKey":"indexhtml","ext":"html","name":"index","contents":"<!DOCTYPE html>\n<html lang=\"en\">\n  <head>\n    <meta charset=\"UTF-8\">\n    <title>Accessible Controls</title>\n  </head>\n  <body>\n\n    <h1>Audio Controls</h1>\n\n    <button type=\"button\">Play</button>\n\n    <div>\n      <span id=\"volume-label\">Volume</span>\n      <span id=\"volume-description\">Adjust the sound level</span>\n    \n    </div>\n\n  </body>\n</html>","head":null,"tail":null,"editableRegionBoundaries":[15,17],"history":["index.html"]}],"saveSubmissionToDB":null,"tests":[{"text":"<p>Trebalo bi da imaš element <code>input</code> ispod svog drugog elementa <code>span</code>.</p>","testString":"const inputEl = document.querySelector('div > span:nth-of-type(2) + input');\nassert.exists(inputEl);"},{"text":"<p>Vaše polje za <code>input</code> treba da ima svojstvo elementa od <code>type</code>.</p>","testString":"const inputEl = document.querySelector('div > span:nth-of-type(2) + input');\nassert.isTrue(inputEl?.hasAttribute('type'));"},{"text":"<p>Vaš element <code>input</code> mora imati atribut elementa <code>type</code> sa vrednošću <code>range</code>.</p>","testString":"const inputEl = document.querySelector('div > span:nth-of-type(2) + input');\nassert.equal(inputEl?.getAttribute('type'), 'range');"},{"text":"<p>Vaše polje <code>input</code> mora imati svojstvo elementa <code>min</code>.</p>","testString":"const inputEl = document.querySelector('div > span:nth-of-type(2) + input');\nassert.exists(inputEl?.getAttribute('min'));"},{"text":"<p>Element vašeg <code>input</code> treba da ima svojstvo elementa <code>min</code> sa vrednošću <code>0</code>.</p>","testString":"const inputEl = document.querySelector('div > span:nth-of-type(2) + input');\nassert.equal(inputEl?.getAttribute('min'), '0');"},{"text":"<p>Vaš element <code>input</code> mora imati svojstvo elemenata/komponente <code>max</code>.</p>","testString":"const inputEl = document.querySelector('div > span:nth-of-type(2) + input');\nassert.isTrue(inputEl?.hasAttribute('max'));"},{"text":"<p>Vaš element <code>input</code> mora imati svojstvo elemenata <code>max</code> sa vrednošću <code>100</code>.</p>","testString":"const inputEl = document.querySelector('div > span:nth-of-type(2) + input');\nassert.equal(inputEl?.getAttribute('max'), '100');"},{"text":"<p>Vaš element za <code>input</code> mora imati svojstvo elementa <code>value</code>.</p>","testString":"const inputEl = document.querySelector('div > span:nth-of-type(2) + input');\nassert.isTrue(inputEl?.hasAttribute('value'));"},{"text":"<p>Vaš element <code>input</code> mora imati svojstvo polja <code>value</code> sa vrednošću <code>50</code>.</p>","testString":"const inputEl = document.querySelector('div > span:nth-of-type(2) + input');\nassert.equal(inputEl?.getAttribute('value'), '50');"}]}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/responsive-web-design-v9/#workshop-accessible-audio-controller","dashedName":"step-5","certification":"responsive-web-design-v9","disableLoopProtectTests":false,"disableLoopProtectPreview":false,"superBlock":"responsive-web-design-v9","chapter":"html","module":"html-and-accessibility","block":"workshop-accessible-audio-controller","isFirstStep":false,"template":null,"required":[],"isLastChallengeInBlock":false,"nextChallengePath":"/learn/responsive-web-design-v9/workshop-accessible-audio-controller/step-6","prevChallengePath":"/learn/responsive-web-design-v9/workshop-accessible-audio-controller/step-4","id":"68ed3a96e0ebcc36565b39e5","saveSubmissionToDB":null},"projectPreview":{"challengeData":{"challengeType":0,"challengeFiles":[{"name":"index","ext":"html","contents":"<!DOCTYPE html>\n<html lang=\"en\">\n  <head>\n    <meta charset=\"UTF-8\">\n    <title>Accessible Controls</title>\n  </head>\n  <body>\n\n    <h1>Audio Controls</h1>\n\n    <button type=\"button\">Play</button>\n\n    <div>\n      <span id=\"volume-label\">Volume</span>\n      <span id=\"volume-description\">Adjust the sound level</span>\n      <input type=\"range\" min=\"0\" max=\"100\" value=\"50\"\n             aria-labelledby=\"volume-label volume-description\">\n    </div>\n\n    <button type=\"button\">Mute</button>\n\n  </body>\n</html>","history":["index.html"],"fileKey":"indexhtml"}]}},"id":"/learn/responsive-web-design-v9/workshop-accessible-audio-controller/step-5"}},"staticQueryHashes":["3858520367"],"slicesMap":{}}