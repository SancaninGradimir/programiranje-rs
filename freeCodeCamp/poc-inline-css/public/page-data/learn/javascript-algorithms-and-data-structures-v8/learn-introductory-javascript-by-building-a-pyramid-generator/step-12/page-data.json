{"componentChunkName":"component---src-templates-challenges-classic-show-tsx","path":"/learn/javascript-algorithms-and-data-structures-v8/learn-introductory-javascript-by-building-a-pyramid-generator/step-12","result":{"data":{"challengeNode":{"challenge":{"block":"learn-introductory-javascript-by-building-a-pyramid-generator","demoType":null,"title":"Korak 12","description":"<section id=\"description\">\n<p>Sada ste spremni da objavite svoj drugi parametar. Uklonite oba izjave od <code>console.log</code>, i opseg vrednosti za <code>character</code>.</p>\n<p>Takođe uklonite vaš parametar za <code>secondCharacter</code>, ali ostavite aktivaciju za <code>character</code> nepromenjenom.</p>\n</section>","id":"660ef55dd468079679ee0092","hasEditableBoundaries":true,"instructions":"","notes":null,"challengeType":1,"helpCategory":"JavaScript","videoUrl":null,"superBlock":"javascript-algorithms-and-data-structures-v8","translationPending":false,"forumTopicId":null,"hooks":null,"fields":{"slug":"/learn/javascript-algorithms-and-data-structures-v8/learn-introductory-javascript-by-building-a-pyramid-generator/step-12"},"required":[],"usesMultifileEditor":true,"challengeFiles":[{"fileKey":"scriptjs","ext":"js","name":"script","contents":"let character = 'Hello';\nconsole.log(character);\ncharacter = \"World\";\nlet secondCharacter;\nsecondCharacter = character;\nconsole.log(secondCharacter);","head":null,"tail":null,"editableRegionBoundaries":[0,7],"history":["script.js"]}],"saveSubmissionToDB":null,"tests":[{"text":"<p>Nemojte imati nikakvu izjave od <code>console.log()</code> u vašem kodu.</p>","testString":"assert.notMatch(__helpers.removeJSComments(code), /console/);"},{"text":"<p>Ne smete da postavite ponovnu vrednost za <code>character</code>.</p>","testString":"assert.isAtMost(__helpers.removeJSComments(code).match(/character\\s*=/g).length, 1);"},{"text":"<p>Tvoj parametar za <code>character</code> mora imati vrednost <code>\"Hello\"</code>.</p>","testString":"assert.equal(character, \"Hello\");"},{"text":"<p>Ne bi trebalo da ima parametar <code>secondCharacter</code>.</p>","testString":"assert.notMatch(__helpers.removeJSComments(code), /secondCharacter/);"}]}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/javascript-algorithms-and-data-structures-v8/#learn-introductory-javascript-by-building-a-pyramid-generator","dashedName":"step-12","certification":"javascript-algorithms-and-data-structures-v8","disableLoopProtectTests":false,"disableLoopProtectPreview":false,"superBlock":"javascript-algorithms-and-data-structures-v8","chapter":null,"module":null,"block":"learn-introductory-javascript-by-building-a-pyramid-generator","isFirstStep":false,"template":null,"required":[],"isLastChallengeInBlock":false,"nextChallengePath":"/learn/javascript-algorithms-and-data-structures-v8/learn-introductory-javascript-by-building-a-pyramid-generator/step-13","prevChallengePath":"/learn/javascript-algorithms-and-data-structures-v8/learn-introductory-javascript-by-building-a-pyramid-generator/step-11","id":"660ef55dd468079679ee0092","saveSubmissionToDB":null},"projectPreview":{"challengeData":{"challengeType":1,"challengeFiles":[{"name":"script","ext":"js","contents":"const character = \"!\";\nconst count = 10;\nconst rows = [];\nlet inverted = false;\n\nfunction padRow(rowNumber, rowCount) {\n  return \" \".repeat(rowCount - rowNumber) + character.repeat(2 * rowNumber - 1) + \" \".repeat(rowCount - rowNumber);\n}\n\nfor (let i = 1; i <= count; i++) {\n  if (inverted) {\n    rows.unshift(padRow(i, count));\n  } else {\n    rows.push(padRow(i, count));\n  }\n}\n\nlet result = \"\"\n\nfor (const row of rows) {\n  result = result + row + \"\\n\";\n}\n\nconsole.log(result);","history":["script.js"],"fileKey":"scriptjs"}]}},"id":"/learn/javascript-algorithms-and-data-structures-v8/learn-introductory-javascript-by-building-a-pyramid-generator/step-12"}},"staticQueryHashes":["3858520367"],"slicesMap":{}}