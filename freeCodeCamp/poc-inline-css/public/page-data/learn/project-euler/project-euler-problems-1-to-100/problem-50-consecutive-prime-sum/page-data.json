{"componentChunkName":"component---src-templates-challenges-classic-show-tsx","path":"/learn/project-euler/project-euler-problems-1-to-100/problem-50-consecutive-prime-sum","result":{"data":{"challengeNode":{"challenge":{"block":"project-euler-problems-1-to-100","demoType":null,"title":"Vežba 50: Zbir uzastopnih brojeva","description":"<section id=\"description\">\n<p>Broj 41, može se napisati kao zbir šest uzastopnih brojeva:</p>\n<div style='text-align: center;'>41 = 2 + 3 + 5 + 7 + 11 + 13</div>\n<p>Ovo je najveći zbir uzastopnih premijnih brojeva koji uključuje premijne brojeve manji od stotinu.</p>\n<p>Najduža suma uzastopnih prostih brojeva ispod hiljadu, koja uključuje proste brojeve, ima 21 član i jednaka je 953.</p>\n<p>Koji broj, ispod miliona, može se zapisati kao zbir mnogih uzastopnih brojeva?</p>\n</section>","id":"5900f39e1000cf542c50feb1","hasEditableBoundaries":false,"instructions":"","notes":null,"challengeType":1,"helpCategory":"Euler","videoUrl":null,"superBlock":"project-euler","translationPending":false,"forumTopicId":302161,"hooks":null,"fields":{"slug":"/learn/project-euler/project-euler-problems-1-to-100/problem-50-consecutive-prime-sum"},"required":[],"usesMultifileEditor":false,"challengeFiles":[{"fileKey":"scriptjs","ext":"js","name":"script","contents":"function consecutivePrimeSum(limit) {\n\n  return true;\n}\n\nconsecutivePrimeSum(1000000);","head":null,"tail":null,"editableRegionBoundaries":[],"history":["script.js"]}],"saveSubmissionToDB":null,"tests":[{"text":"<p><code>consecutivePrimeSum(1000)</code> trebalo bi da vrati broj.</p>","testString":"assert(typeof consecutivePrimeSum(1000) === 'number');"},{"text":"<p><code>consecutivePrimeSum(1000)</code> treba da vrati 953.</p>","testString":"assert.strictEqual(consecutivePrimeSum(1000), 953);"},{"text":"<p><code>consecutivePrimeSum(1000000)</code> trebalo bi da vrati 997651.</p>","testString":"assert.strictEqual(consecutivePrimeSum(1000000), 997651);"}]}}},"pageContext":{"challengeMe