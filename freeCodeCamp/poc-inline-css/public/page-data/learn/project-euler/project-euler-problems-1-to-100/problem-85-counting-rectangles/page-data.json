{"componentChunkName":"component---src-templates-challenges-classic-show-tsx","path":"/learn/project-euler/project-euler-problems-1-to-100/problem-85-counting-rectangles","result":{"data":{"challengeNode":{"challenge":{"block":"project-euler-problems-1-to-100","demoType":null,"title":"Izazov 85: Računanje pravougaonika","description":"<section id=\"description\">\n<p>Pažljivim računanjem, izgleda da pravougaonična mreža dimenzija 3 na 2 ima osamnaest pravougaonika:</p>\n<img alt=\"dijagram različitih pravougaonika unutar pravougaone mreže dimenzija 3 × 2\" src=\"https://cdn-media-1.freecodecamp.org/project-euler/counting-rectangles.png\" style=\"background-color: white; padding: 10px; display: block; margin-right: auto; margin-left: auto; margin-bottom: 1.2rem;\">\n<p>Iako možda ne postoji pravougaona mreža koja sadrži tačno <code>n</code> pravougaonika, pronađi površinu mreže čije je rešenje najbliže toj vrednosti.</p>\n</section>","id":"5900f3c11000cf542c50fed4","hasEditableBoundaries":false,"instructions":"","notes":null,"challengeType":1,"helpCategory":"Euler","videoUrl":null,"superBlock":"project-euler","translationPending":false,"forumTopicId":302199,"hooks":null,"fields":{"slug":"/learn/project-euler/project-euler-problems-1-to-100/problem-85-counting-rectangles"},"required":[],"usesMultifileEditor":false,"challengeFiles":[{"fileKey":"scriptjs","ext":"js","name":"script","contents":"function countingRectangles(n) {\n\n  return true;\n}\n\ncountingRectangles(18);","head":null,"tail":null,"editableRegionBoundaries":[],"history":["script.js"]}],"saveSubmissionToDB":null,"tests":[{"text":"<p><code>countingRectangles(18)</code> treba da vrati broj.</p>","testString":"assert(typeof countingRectangles(18) === 'number');"},{"text":"<p><code>countingRectangles(18)</code> inapaswa kurudisha <code>6</code>.</p>","testString":"assert.strictEqual(countingRectangles(18), 6);"},{"text":"<p><code>countingRectangles(250)</code> inapaswa kurudisha <code>22</code>.</p>","testString":"assert.strictEqual(countingRectangles(250), 22);"},{"text":"<p><code>countingRectangles(50000)</code> inapaswa kurudisha <code>364</code>.</p>","testString":"assert.strictEqual(countingRectangles(50000), 364);"},{"text":"<p><code>countingRectangles(1000000)</code> treba da vrati <code>1632</code>.</p>","testString":"assert.strictEqual(countingRectangles(1000000), 1632);"},{"text":"<p><code>countingRectangles(2000000)</code> inapaswa kurudisha <code>2772</code>.</p>","testString":"assert.strictEqual(countingRectangles(2000000), 2772);"}]}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/project-euler/#project-euler-problems-1-to-100","dashedName":"problem-85-counting-rectangles","certification":"project-euler","disableLoopProtectTests":true,"disableLoopProtectPreview":false,"superBlock":"project-euler","chapter":null,"module":null,"block":"project-euler-problems-1-to-100","isFirstStep":false,"template":null,"required":[],"isLastChallengeInBlock":false,"nextChallengePath":"/learn/project-euler/project-euler-problems-1-to-100/problem-86-cuboid-route","prevChallengePath":"/learn/project-euler/project-euler-problems-1-to-100/problem-84-monopoly-odds","id":"5900f3c11000cf542c50fed4","saveSubmissionToDB":null},"projectPreview":{"challengeData":{"challengeType":1,"challengeFiles":[{"name":"script","ext":"js","contents":"function arrangedProbability(limit) {\n  // Based on https://www.mathblog.dk/project-euler-100-blue-discs-two-blue/\n  let blue = 15;\n  let discs = 21;\n\n  while (discs < limit) {\n    const nextBlue = 3 * blue + 2 * discs - 2;\n    const nextDiscs = 4 * blue + 3 * discs - 3;\n\n    blue = nextBlue;\n    discs = nextDiscs;\n  }\n  return blue;\n}","history":["script.js"],"fileKey":"scriptjs"}]}},"id":"/learn/project-euler/project-euler-problems-1-to-100/problem-85-counting-rectangles"}},"staticQueryHashes":["3858520367"],"slicesMap":{}}