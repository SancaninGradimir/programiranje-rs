  "tests": [
    {
      "text": "<p>Tvoj četvrti element <code>tr</code> treba da sadrži element <code>th</code>.</p>",
      "testString": "assert.exists(\n  document\n    .querySelector('tbody')\n    ?.querySelectorAll('tr')?.[3]\n    ?.querySelector('th')\n);"
    },
    {
      "text": "<p>Vaše polje za <code>th</code> treba da ima tekst od <code>Total Assets</code>.</p>",
      "testString": "const tableRow = document.querySelector('tbody')?.querySelectorAll('tr')?.[3];\nconst tableHeader = tableRow.querySelector('th');\nassert.strictEqual(tableHeader.innerText.trim(), 'Total Assets');"
    },
    {
      "text": "<p>Treba da obuhvatiš tekst <code>Assets</code> elementom <code>span</code>.</p>",
      "testString": "const tableRow = document.querySelector('tbody')?.querySelectorAll('tr')?.[3];\nconst span = tableRow.querySelector('th > span');\nassert.strictEqual(span.textContent.trim(), 'Assets');"
    },
    {
      "text": "<p>Vaš element <code>span</code> mora imati svojstvo elementa <code>class</code> postavljeno na <code>sr-only</code>.</p>",
      "testString": "const tableRow = document.querySelector('tbody')?.querySelectorAll('tr')?.[3];\nconst span = tableRow.querySelector('th > span');\nassert.isTrue(span?.classList?.contains('sr-only'));"
    },
    {
      "text": "<p>Treba da imaš tri elementa <code>td</code>.</p>",
      "testString": "const tableRow = document.querySelector('tbody')?.querySelectorAll('tr')?.[3];\nconst tableDatas = tableRow.querySelectorAll('td');\nassert.lengthOf(tableDatas, 3);"
    },
    {
      "text": "<p>Tvoj prvi element <code>td</code> treba da sadrži tekst <code>$579</code>.</p>",
      "testString": "const tableRow = document.querySelector('tbody')?.querySelectorAll('tr')?.[3];\nconst tableData = tableRow.querySelectorAll('td')?.[0];\nassert.strictEqual(tableData?.textContent.trim(), '$579');"
    },
    {
      "text": "<p>Vaš drugi element za <code>td</code> mora imati tekst od <code>$736</code>.</p>",
      "testString": "const tableRow = document.querySelector('tbody')?.querySelectorAll('tr')?.[3];\nconst tableData = tableRow.querySelectorAll('td')?.[1];\nassert.strictEqual(tableData?.textContent.trim(), '$736');"
    },
