{"componentChunkName":"component---src-templates-challenges-classic-show-tsx","path":"/learn/project-euler/project-euler-problems-1-to-100/problem-51-prime-digit-replacements","result":{"data":{"challengeNode":{"challenge":{"block":"project-euler-problems-1-to-100","demoType":null,"title":"Vežba 51: Alternativa osnovnom broju","description":"<section id=\"description\">\n<p>Promenom prve cifre broja 2 * 3, blijkt da šest od devet mogućih vrednosti: 13, 23, 43, 53, 73 i 83, su sve premij prime brojevi.</p>\n<p>Promenom trećeg i četvrtog cifre broja 56**3 u istu brojku, ovaj petocifreni broj je prvi primer sa sedam osnovnih brojeva od deset generisanih, stvarajući porodicu: 56003, 56113, 56333, 56443, 56663, 56773, i 56993. Stoga, 56003, kao prvi član ove porodice, je najmanji osnovni broj sa ovom karakteristikom.</p>\n<p>Pronađi najmanji osnovni broj koji, menjanjem dela broja (ne moraju biti susedne cifre) na isti broj, je deo porodice osnovnih brojeva <code>n</code>.</p>\n</section>","id":"5900f39f1000cf542c50feb2","hasEditableBoundaries":false,"instructions":"","notes":null,"challengeType":1,"helpCategory":"Euler","videoUrl":null,"superBlock":"project-euler","translationPending":false,"forumTopicId":302162,"hooks":null,"fields":{"slug":"/learn/project-euler/project-euler-problems-1-to-100/problem-51-prime-digit-replacements"},"required":[],"usesMultifileEditor":false,"challengeFiles":[{"fileKey":"scriptjs","ext":"js","name":"script","contents":"function primeDigitReplacements(n) {\n\n  return true;\n}\n\nprimeDigitReplacements(6);","head":null,"tail":null,"editableRegionBoundaries":[],"history":["script.js"]}],"saveSubmissionToDB":null,"tests":[{"text":"<p><code>primeDigitReplacements(6)</code> Trebalo bi da vrati broj.</p>","testString":"assert(typeof primeDigitReplacements(6) === 'number');"},{"text":"<p><code>primeDigitReplacements(6)</code> treba da vrati <code>13</code>.</p>","testString":"assert.strictEqual(primeDigitReplacements(6), 13);"},{"text":"<p><code>primeDigitReplacements(7)</code> treba da vrati <code>56003</code>.</p>","testString":"assert.strictEqual(primeDigitReplacements(7), 56003);"},{"text":"<p><code>primeDigitReplacements(8)</code> trebalo bi da vrati <code>121313</code>.</p>","testString":"assert.strictEqual(primeDigitReplacements(8), 121313);"}]}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/project-euler/#project-euler-problems-1-to-100","dashedName":"problem-51-prime-digit-replacements","certification":"project-euler","disableLoopProtectTests":true,"disableLoopProtectPreview":false,"superBlock":"project-euler","chapter":null,"module":null,"block":"project-euler-problems-1-to-100","isFirstStep":false,"template":null,"required":[],"isLastChallengeInBlock":false,"nextChallengePath":"/learn/project-euler/project-euler-problems-1-to-100/problem-52-permuted-multiples","prevChallengePath":"/learn/project-euler/project-euler-problems-1-to-100/problem-50-consecutive-prime-sum","id":"5900f39f1000cf542c50feb2","saveSubmissionToDB":null},"projectPreview":{"challengeData":{"challengeType":1,"challengeFiles":[{"name":"script","ext":"js","contents":"function arrangedProbability(limit) {\n  // Based on https://www.mathblog.dk/project-euler-100-blue-discs-two-blue/\n  let blue = 15;\n  let discs = 21;\n\n  while (discs < limit) {\n    const nextBlue = 3 * blue + 2 * discs - 2;\n    const nextDiscs = 4 * blue + 3 * discs - 3;\n\n    blue = nextBlue;\n    discs = nextDiscs;\n  }\n  return blue;\n}","history":["script.js"],"fileKey":"scriptjs"}]}},"id":"/learn/project-euler/project-euler-problems-1-to-100/problem-51-prime-digit-replacements"}},"staticQueryHashes":["3858520367"],"slicesMap":{}}