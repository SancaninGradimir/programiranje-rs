    {
      "text": "<p>Sva radio dugmad treba da budu grupisana unutar jednog <code>div</code> sa klasom <code>row</code>.</p>",
      "testString": "const radioButtons = document.querySelectorAll(`div.row input[type=radio]`); \r\nassert.lengthOf(radioButtons , 2);"
    },
    {
      "text": "<p>Svako vaše radio dugme treba da bude grupisano unutar <code>div</code>-a sa klasom <code>col-xs-6</code>.</p>",
      "testString": "const radioButtons = document.querySelectorAll(`div.col-xs-6 input[type=radio]`); \r\nassert.lengthOf(radioButtons , 2);"
    },
    {
      "text": "<p>Svi <code>div</code> elementi bi trebalo da imaju zatvarajuće oznake.</p>",
      "testString": "assert.match(code,/<\\/div>/);\r\nassert.match(code,/<div/g);\r\nassert.equal(code.match(/<\\/div>/g).length,code.match(/<div/g).length);"
    }
