{"componentChunkName":"component---src-templates-challenges-generic-show-tsx","path":"/learn/b1-english-for-developers/learn-about-adverbial-phrases/dialogue-1-optimizing-daily-huddle-meetings","result":{"data":{"challengeNode":{"challenge":{"assignments":["<p>Gledaj video.</p>"],"bilibiliIds":null,"block":"learn-about-adverbial-phrases","challengeType":21,"description":"<section id=\"description\">\n<p>Pogledajte video ispod da biste razumeli kontekst sledećih lekcija.</p>\n</section>","nodules":null,"explanation":null,"helpCategory":"English","instructions":"","fields":{"slug":"/learn/b1-english-for-developers/learn-about-adverbial-phrases/dialogue-1-optimizing-daily-huddle-meetings"},"questions":[],"scene":{"setup":{"background":"company2-boardroom.png","characters":[{"character":"Bob","position":{"x":-25,"y":0,"z":1},"opacity":null},{"character":"Sarah","position":{"x":125,"y":0,"z":1},"opacity":null}],"audio":{"filename":"B1_18-1.mp3","startTime":1,"startTimestamp":null,"finishTimestamp":null},"alwaysShowDialogue":true},"commands":[{"background":null,"character":"Bob","position":{"x":25,"y":0,"z":1},"opacity":null,"startTime":0,"finishTime":null,"dialogue":null},{"background":null,"character":"Sarah","position":{"x":70,"y":0,"z":1},"opacity":null,"startTime":0.5,"finishTime":null,"dialogue":null},{"background":null,"character":"Bob","position":null,"opacity":null,"startTime":1,"finishTime":7.16,"dialogue":{"text":"Today, I want to focus on optimizing our daily huddle meetings to ensure we're using our time effectively.","align":"left"}},{"background":null,"character":"Bob","position":null,"opacity":null,"startTime":7.66,"finishTime":11.24,"dialogue":{"text":"First off, let's discuss the frequency of our updates.","align":"left"}},{"background":null,"character":"Bob","position":null,"opacity":null,"startTime":11.92,"finishTime":16.2,"dialogue":{"text":"Sarah, can you tell me how often the team currently discusses back-end development?","align":"left"}},{"background":null,"character":"Sarah","position":null,"opacity":null,"startTime":17.1,"finishTime":20,"dialogue":{"text":"Currently we meet every morning to review progress and issues.","align":"right"}},{"background":null,"character":"Sarah","position":null,"opacity":null,"startTime":20.32,"finishTime":24.62,"dialogue":{"text":"But to be honest, we often end up talking about details that haven't changed from the day before.","align":"right"}},{"background":null,"character":"Bob","position":null,"opacity":null,"startTime":25.36,"finishTime":28.76,"dialogue":{"text":"That's a valid concern. Let's think about reducing redundancy.","align":"left"}},{"background":null,"character":"Bob","position":null,"opacity":null,"startTime":28.76,"finishTime":34.26,"dialogue":{"text":"How about we switch to biweekly detailed updates unless there's a significant development?","align":"left"}},{"background":null,"character":"Bob","position":null,"opacity":null,"startTime":34.72,"finishTime":37.76,"dialogue":{"text":"For daily meetings, a quick status check should be enough.","align":"left"}},{"background":null,"character":"Sarah","position":null,"opacity":null,"startTime":38.42,"finishTime":40.14,"dialogue":{"text":"That sounds like a good approach to me.","align":"right"}},{"background":null,"character":"Sarah","position":null,"opacity":null,"startTime":40.3,"finishTime":45.1,"dialogue":{"text":"Limiting our full team updates to twice a week, we can concentrate on changes or urgent issues.","align":"right"}},{"background":null,"character":"Sarah","position":null,"opacity":null,"startTime":45.62,"finishTime":50.14,"dialogue":{"text":"We might also consider having weekly updates for part of the project where changes are less frequent.","align":"right"}},{"background":null,"character":"Bob","position":null,"opacity":null,"startTime":50.86,"finishTime":55.64,"dialogue":{"text":"I like that approach. You know what? We should set specific times for these updates.","align":"left"}},{"background":null,"character":"Bob","position":null,"opacity":null,"startTime":56,"finishTime":62.14,"dialogue":{"text":"How about scheduling the detailed biweekly meetings for Tuesdays and Thursdays at 9 a.m.?","align":"left"}},{"background":null,"character":"Sarah","position":null,"opacity":null,"startTime":62.14,"finishTime":67.58,"dialogue":{"text":"That works perfectly. I'll keep track of how these changes impact our workflow and compile a report by the end of the month.","align":"right"}},{"background":null,"character":"Bob","position":null,"opacity":null,"startTime":68.18,"finishTime":72.08,"dialogue":{"text":"Excellent, Sarah. We'll review your report and feedback from the team","align":"left"}},{"background":null,"character":"Bob","position":null,"opacity":null,"startTime":72.08,"finishTime":77.1,"dialogue":{"text":"to see if these adjustments meet our needs or if further modifications are necessary.","align":"left"}},{"background":null,"character":"Bob","position":null,"opacity":null,"startTime":77.66,"finishTime":81.14,"dialogue":{"text":"It's crucial that our meetings are as productive as possible.","align":"left"}},{"background":null,"character":"Sarah","position":{"x":125,"y":0,"z":1},"opacity":null,"startTime":81.64,"finishTime":null,"dialogue":null},{"background":null,"character":"Bob","position":{"x":-25,"y":0,"z":1},"opacity":null,"startTime":82.14,"finishTime":null,"dialogue":null}]},"superBlock":"b1-english-for-developers","tests":[],"title":"Dijalog 1: Optimizacija dnevnih kratkih sastanaka","transcript":null,"translationPending":false,"videoId":null,"videoLocaleIds":null}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/b1-english-for-developers/#learn-about-adverbial-phrases","dashedName":"dialogue-1-optimizing-daily-huddle-meetings","certification":"b1-english-for-developers","disableLoopProtectTests":false,"disableLoopProtectPreview":false,"superBlock":"b1-english-for-developers","chapter":null,"module":null,"block":"learn-about-adverbial-phrases"