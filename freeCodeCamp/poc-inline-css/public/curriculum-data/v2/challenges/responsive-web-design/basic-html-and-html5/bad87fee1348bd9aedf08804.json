  "tests": [
    {
      "text": "<p>Vas <code>h1</code> element treba da bude zakomentarisan tako da ne bude vidljiv na stranici.</p>",
      "testString": "assert.isEmpty(document.querySelectorAll('h1'));"
    },
    {
      "text": "<p>Vas <code>h2</code> element ne treba da bude zakomentarisan kako bi bio vidljiv na stranici.</p>",
      "testString": "assert.isNotEmpty(document.querySelectorAll('h2'));"
    },
    {
      "text": "<p>Vas <code>p</code> element treba da bude zakomentarisan tako da ne bude vidljiv na stranici.</p>",
      "testString": "assert.isEmpty(document.querySelectorAll('p'));"
    },
    {
      "text": "<p>Svaki vas komentar treba da bude zatvoren sa <code>--></code>.</p>",
      "testString": "assert.isAbove(code.match(/[^fc]-->/g).length, 1);"
    },
    {
      "text": "<p>Ne treba da menjate redosled <code>h1</code>, <code>h2</code> i <code>p</code> elemenata u kodu.</p>",
      "testString": "assert.strictEqual(code.match(/<([a-z0-9]){1,2}>/g)[0],'<h1>');\nassert.strictEqual(code.match(/<([a-z0-9]){1,2}>/g)[1],'<h2>');\nassert.strictEqual(code.match(/<([a-z0-9]){1,2}>/g)[2],'<p>');"
    }
  ],
  "description": "<section id=\"description\">\n<p>Zapamtite da za pocetak komentara koristite <code>&#x3C;!--</code>, a za kraj komentara <code>--></code>.</p>\n<p>Ovde je potrebno da zatvorite komentar pre nego sto pocne vas <code>h2</code> element.</p>\n</section>",
  "instructions": "<section id=\"instructions\">\n<p>Zakomentarisite svoj <code>h1</code> i svoj <code>p</code> element, ali nemojte zakomentarisati <code>h2</code> element.</p>\n</section>",
