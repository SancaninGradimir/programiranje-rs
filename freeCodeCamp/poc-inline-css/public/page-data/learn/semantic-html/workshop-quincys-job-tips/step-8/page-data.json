{"componentChunkName":"component---src-templates-challenges-classic-show-tsx","path":"/learn/semantic-html/workshop-quincys-job-tips/step-8","result":{"data":{"challengeNode":{"challenge":{"block":"workshop-quincys-job-tips","demoType":null,"title":"Korak 8","description":"<section id=\"description\">\n<p>Upravo kao što je slučaj sa ugrađenim citatom, možete dodati i atribut <code>cite</code> na blok citat.</p>\n<p>Evo primera bloka cita sa atributom <code>cite</code>:</p>\n<pre><code class=\"language-html\">&#x3C;blockquote cite=\"https://www.freecodecamp.org/news/is-college-worth-it/\">\n  The first thing you should consider about education is this is an economic decision.\n&#x3C;/blockquote>\n</code></pre>\n<p>Sada dodajte atribut <code>cite</code> na blok citat sa URL-om <code>https://www.freecodecamp.org/news/learn-to-code-book/</code>.</p>\n</section>","id":"68ea9d23318b6481ac3de777","hasEditableBoundaries":true,"instructions":"","notes":null,"challengeType":0,"helpCategory":"HTML-CSS","videoUrl":null,"superBlock":"semantic-html","translationPending":false,"forumTopicId":null,"hooks":null,"fields":{"slug":"/learn/semantic-html/workshop-quincys-job-tips/step-8"},"required":[],"usesMultifileEditor":true,"challengeFiles":[{"fileKey":"indexhtml","ext":"html","name":"index","contents":"<!DOCTYPE html>\n<html lang=\"en\">\n  <head>\n    <meta charset=\"UTF-8\" />\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" />\n    <title>Quincy's Tips for Getting a Developer Job</title>\n  </head>\n  <body>\n    <h1>Quincy's Tips for Getting a Developer Job</h1>\n    <p>\n      Learning to code is hard, but as Quincy Larson says,\n      <q cite=\"https://www.freecodecamp.org/news/learn-to-code-book/\">You can become a developer.</q>\n    </p>\n\n    <main>\n      <section>\n        <h2>Envisioning Success</h2>\n        <blockquote>\n          Can you imagine what it would be like to be a successful developer? To have built software systems that people rely upon?\n        </blockquote>\n      </section>\n      <section>\n\n      </section>\n      <section>\n\n      </section>\n    </main>\n  </body>\n</html>","head":null,"tail":null,"editableRegionBoundaries":[17,19],"history":["index.html"]}],"saveSubmissionToDB":null,"tests":[{"text":"<p>Your <code>blockquote</code> element should have a <code>cite</code> attribute.</p>","testString":"const firstBlockquoteEl = document.querySelector('section:first-of-type > h2 + blockquote');\nassert.exists(firstBlockquoteEl?.getAttribute('cite'));"},{"text":"<p>The <code>cite</code> attribute should have the value <code>https://www.freecodecamp.org/news/learn-to-code-book/</code>.</p>","testString":"const firstBlockquoteEl = document.querySelector('section:first-of-type > h2 + blockquote');\nassert.equal(firstBlockquoteEl?.getAttribute('cite'), 'https://www.freecodecamp.org/news/learn-to-code-book/');"}]}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/semantic-html/#workshop-quincys-job-tips","dashedName":"step-8","certification":"semantic-html","disableLoopProtectTests":false,"disableLoopProtectPreview":false,"superBlock":"semantic-html","chapter":null,"module":null,"block":"workshop-quincys-job-tips","isFirstStep":false,"template":null,"required":[],"isLastChallengeInBlock":false,"nextChallengePath":"/learn/semantic-html/workshop-quincys-job-tips/step-9","prevChallengePath":"/learn/semantic-html/workshop-quincys-job-tips/step-7","id":"68ea9d23318b6481ac3de777","saveSubmissionToDB":null},"projectPreview":{"challengeData":{"challengeType":0,"challengeFiles":[{"name":"index","ext":"html","contents":"<!DOCTYPE html>\n<html lang=\"en\">\n  <head>\n    <meta charset=\"UTF-8\" />\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" />\n    <title>Quincy's Tips for Getting a Developer Job</title>\n  </head>\n  <body>\n    <h1>Quincy's Tips for Getting a Developer Job</h1>\n    <p>\n      Learning to code is hard, but as Quincy Larson says,\n      <q cite=\"https://www.freecodecamp.org/news/learn-to-code-book/\">You can become a developer.</q>\n    </p>\n\n    <main>\n      <section>\n        <h2>Envisioning Success</h2>\n        <blockquote cite=\"https://www.freecodecamp.org/news/learn-to-code-book/\">\n          Can you imagine what it would be like to be a successful developer? To have built software systems that people rely upon?\n        </blockquote>\n        <p>\n          &mdash;Quincy Larson, <cite>How to Learn to Code and Get a Developer Job [Full Book]</cite>\n        </p>\n      </section>\n\n      <section>\n        <h2>Importance of Networking</h2>\n        <blockquote cite=\"https://www.freecodecamp.org/news/learn-to-code-book/\">\n          <p>So much of getting a job is who you know.</p>\n          <p>It's OK to be an introvert, but you do need to push your boundaries.</p>\n          <p>Create GitHub, Twitter, LinkedIn, and Discord accounts.</p>\n          <p>Go to tech meetups and conferences. Travel if you have to.</p>\n        </blockquote>\n      </section>\n\n      <section>\n        <h2>Importance of Building a Reputation</h2>\n        <blockquote cite=\"https://www.freecodecamp.org/news/learn-to-code-book/\">\n          <p>Share short video demos of your projects.</p>\n          <p>Keep applying to speak at bigger and bigger conferences.</p>\n          <p>Hang out at hackerspaces and help people who are even newer to coding than you.</p>\n        </blockquote>\n      </section>\n    </main>\n  </body>\n</html>","history":["index.html"],"fileKey":"indexhtml"}]}},"id":"/learn/semantic-html/workshop-quincys-job-tips/step-8"}},"staticQueryHashes":["3858520367"],"slicesMap":{}}