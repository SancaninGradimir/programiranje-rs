      "text": "<p>Vas <code>form</code> treba da sadrzi <code>button</code>.</p>",
      "testString": "const form = document.querySelector('form');\nconst children = form.querySelectorAll(`:scope ${\"button\"}`); \nassert.isNotEmpty(children); "
    },
    {
      "text": "<p>Vase submit dugme treba da ima <code>type</code> atribut postavljen na <code>submit</code>.</p>",
      "testString": "assert.strictEqual(document.querySelector('button').getAttribute('type'), 'submit');"
    },
    {
      "text": "<p>Vase submit dugme treba da ima samo tekst <code>Submit</code>.</p>",
      "testString": "const text = document.querySelector('button').textContent;\nassert.match(text,/^\\s*submit\\s*$/gi);"
    },
    {
      "text": "<p>Vas <code>button</code> element treba da ima zatvarajuci tag.</p>",
      "testString": "assert.match(code,/<\\/button>/g);\nassert.match(code,/<button/g);\nassert.strictEqual(code.match(/<\\/button>/g).length,code.match(/<button/g).length);"
    }
