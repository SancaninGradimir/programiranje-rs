{"componentChunkName":"component---src-templates-challenges-generic-show-tsx","path":"/learn/b1-english-for-developers/learn-how-to-use-modal-verbs/dialogue-2-software-development-outcomes","result":{"data":{"challengeNode":{"challenge":{"assignments":["<p>Gledaj video.</p>"],"bilibiliIds":null,"block":"learn-how-to-use-modal-verbs","challengeType":21,"description":"<section id=\"description\">\n<p>Pogledajte video dole/ispod kako biste razumeli kontekst predstojećih lekcija.</p>\n</section>","nodules":null,"explanation":null,"helpCategory":"English","instructions":"","fields":{"slug":"/learn/b1-english-for-developers/learn-how-to-use-modal-verbs/dialogue-2-software-development-outcomes"},"questions":[],"scene":{"setup":{"background":"interview-room3.png","characters":[{"character":"Sophie","position":{"x":-25,"y":0,"z":1},"opacity":null},{"character":"James","position":{"x":125,"y":0,"z":1},"opacity":null}],"audio":{"filename":"B1_14-2.mp3","startTime":1,"startTimestamp":null,"finishTimestamp":null},"alwaysShowDialogue":true},"commands":[{"background":null,"character":"Sophie","position":{"x":25,"y":0,"z":1},"opacity":null,"startTime":0,"finishTime":null,"dialogue":null},{"background":null,"character":"James","position":{"x":70,"y":0,"z":1},"opacity":null,"startTime":0.5,"finishTime":null,"dialogue":null},{"background":null,"character":"Sophie","position":null,"opacity":null,"startTime":1,"finishTime":4.96,"dialogue":{"text":"Hi, James. We're discussing some of the possible outcomes of our next software release.","align":"left"}},{"background":null,"character":"Sophie","position":null,"opacity":null,"startTime":5.28,"finishTime":10.1,"dialogue":{"text":"I have a few questions about what might happen if we run into issues. Can you help me understand the possibilities?","align":"left"}},{"background":null,"character":"James","position":null,"opacity":null,"startTime":10.6,"finishTime":12.3,"dialogue":{"text":"Sure, Sophie. What do you want to know?","align":"right"}},{"background":null,"character":"Sophie","position":null,"opacity":null,"startTime":12.94,"finishTime":17.82,"dialogue":{"text":"Well, I'm concerned about the deployment process. It could go smoothly, or we might face some bugs.","align":"left"}},{"background":null,"character":"Sophie","position":null,"opacity":null,"startTime":18.08,"finishTime":19.58,"dialogue":{"text":"What do you think is most likely?","align":"left"}},{"background":null,"character":"James","position":null,"opacity":null,"startTime":19.96,"finishTime":25.6,"dialogue":{"text":"It's hard to say. We could have a smooth deployment, but there's always a chance that a few bugs might pop up.","align":"right"}},{"background":null,"character":"James","position":null,"opacity":null,"startTime":25.7,"finishTime":27.7,"dialogue":{"text":"It depends on how well we've tested everything.","align":"right"}},{"background":null,"character":"Sophie","position":null,"opacity":null,"startTime":28.16,"finishTime":32.46,"dialogue":{"text":"That makes sense. If we find bugs during deployment, what would be the immediate response?","align":"left"}},{"background":null,"character":"James","position":null,"opacity":null,"startTime":33.2,"finishTime":37.96,"dialogue":{"text":"If we find critical bugs, we'll probably have to roll back the deployment and fix them before trying again.","align":"right"}},{"background":null,"character":"James","position":null,"opacity":null,"startTime":38.26,"finishTime":42.06,"dialogue":{"text":"It might delay the release, but it's better than having a broken product.","align":"right"}},{"background":null,"character":"Sophie","position":null,"opacity":null,"startTime":42.9,"finishTime":45.54,"dialogue":{"text":"I agree. Another thing I'm curious about is performance.","align":"left"}},{"background":null,"character":"Sophie","position":null,"opacity":null,"startTime":46.04,"finishTime":49.2,"dialogue":{"text":"Do you think our servers might struggle with high traffic after the release?","align":"left"}},{"background":null,"character":"James","position":null,"opacity":null,"startTime":49.52,"finishTime":54.8,"dialogue":{"text":"It's possible. If we get a lot of users at once, the servers could get overwhelmed.","align":"right"}},{"background":null,"character":"James","position":null,"opacity":null,"startTime":55.08,"finishTime":57.52,"dialogue":{"text":"We may need to scale up to handle the load.","align":"right"}},{"background":null,"character":"Sophie","position":null,"opacity":null,"startTime":57.82,"finishTime":60.98,"dialogue":{"text":"Thanks for the insight. It sounds like we need to prepare for different scenarios.","align":"left"}},{"background":null,"character":"James","position":{"x":125,"y":0,"z":1},"opacity":null,"startTime":61.48,"finishTime":null,"dialogue":null},{"background":null,"character":"Sophie","position":{"x":-25,"y":0,"z":1},"opacity":null,"startTime":61.98,"finishTime":null,"dialogue":null}]},"superBlock":"b1-english-for-developers","tests":[],"title":"Dijalog 2: Rezultati razvoja softvera","transcript":null,"translationPending":false,"videoId":null,"videoLocaleIds":null}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/b1-english-for-developers/#learn-how-to-use-modal-verbs","dashedName":"dialogue-2-software-development-outcomes","certification":"b1-english-for-developers","disableLoopProtectTests":false,"disableLoopProtectPreview":false,"superBlock":"b1-english-for-developers","chapter":null,"module":null,"block":"learn-how-to-use-modal-verbs","isFirstStep":false,"template":null,"required":[],"isLastChallengeInBlock":false,"nextChallengePath":"/learn/b1-english-for-developers/learn-how-to-use-modal-verbs/task-55","prevChallengePath":"/learn/b1-english-for-developers/learn-how-to-use-modal-verbs/task-54","id":"67d573b75910633b5ae187fd","saveSubmissionToDB":null},"projectPreview":{"challengeData":{"challengeType":19,"challengeFiles":[]}},"id":"/learn/b1-english-for-developers/learn-how-to-use-modal-verbs/dialogue-2-software