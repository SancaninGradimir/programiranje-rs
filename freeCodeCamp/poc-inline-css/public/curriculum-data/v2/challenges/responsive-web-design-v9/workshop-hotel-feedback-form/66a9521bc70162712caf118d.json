    {
      "text": "<p>Your <code>radio</code> button should have an <code>id</code> attribute set to <code>\"yes-option\"</code>.</p>",
      "testString": "assert.strictEqual(document.querySelector('fieldset:nth-of-type(2) legend + input[type=\"radio\"]')?.id, 'yes-option');"
    },
    {
      "text": "<p>Your <code>radio</code> button should have a <code>name</code> attribute set to <code>\"hotel-stay\"</code>.</p>",
      "testString": "assert.strictEqual(document.querySelector('fieldset:nth-of-type(2) legend + input[type=\"radio\"]')?.name, 'hotel-stay');"
    },
    {
      "text": "<p>Your radio button should have a <code>value</code> attribute set to <code>\"yes\"</code>.</p>",
      "testString": "assert.strictEqual(\n  document.querySelector('fieldset:nth-of-type(2) legend + input[type=\"radio\"]')?.value,\n  'yes'\n);"
