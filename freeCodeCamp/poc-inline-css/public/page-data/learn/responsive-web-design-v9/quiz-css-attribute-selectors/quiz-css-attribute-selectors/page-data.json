u za restoran i želiš primeniti stil na sve elemente koji imaju klasu stvari <code>menu-item</code> a koji imaju atribut <code>data-special</code>?</p>","answer":"<pre><code class=\"language-css\">.menu-item[data-special] { background-color: blue; }\n</code></pre>","audioData":null}]}],"tests":[],"translationPending":false}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/responsive-web-design-v9/#quiz-css-attribute-selectors","dashedName":"quiz-css-attribute-selectors","certification":"responsive-web-design-v9","disableLoopProtectTests":false,"disableLoopProtectPreview":false,"superBlock":"responsive-web-design-v9","chapter":"css","module":"attribute-selectors","block":"quiz-css-attribute-selectors","isFirstStep":true,"template":null,"required":[],"isLastChallengeInBlock":true,"nextChallengePath":"/learn/responsive-web-design-v9/lab-book-inventory-app/build-a-book-inventory-app","prevChallengePath":"/learn/responsive-web-design-v9/review-css-attribute-selectors/review-css-attribute-selectors","id":"66ed8fd0f45ce3ece4053eaf","saveSubmissionToDB":null},"projectPreview":{"challengeData":{"challengeType":8,"challengeFiles":[]}},"id":"/learn/responsive-web-design-v9/quiz-css-attribute-selectors/quiz-css-attribute-selectors"}},"staticQueryHashes":["3858520367"],"slicesMap":{}}