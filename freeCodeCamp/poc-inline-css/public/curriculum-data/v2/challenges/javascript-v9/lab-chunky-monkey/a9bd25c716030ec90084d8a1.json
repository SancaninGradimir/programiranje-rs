        "fileKey": "scriptjs",
        "contents": "function chunkArrayInGroups(arr, size) {\r\n  let out = [];\r\n\r\n  for (let i = 0; i < arr.length; i += size) {\r\n    out.push(arr.slice(i, i + size));\r\n  }\r\n\r\n  return out;\r\n}\r\n\r\nchunkArrayInGroups(['a', 'b', 'c', 'd'], 2);",
