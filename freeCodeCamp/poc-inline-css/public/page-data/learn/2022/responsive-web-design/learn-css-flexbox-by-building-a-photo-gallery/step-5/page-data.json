y')?.querySelectorAll('div')?.length >= 1);"},{"text":"<p>Vaš novi element za <code>div</code> mora imati <code>class</code> sa vrednošću od <code>gallery</code>.</p>","testString":"assert(document.querySelector('body')?.querySelector('.gallery'));"},{"text":"<p>Vaš novi element za <code>div</code> treba da dođe nakon vašeg elementa za <code>.header</code>.</p>","testString":"assert(document.querySelector('header')?.nextElementSibling?.classList?.contains('gallery'));"},{"text":"<p>Vaš deo <code>.gallery</code> treba da sadrži devet elemenata <code>img</code>.</p>","testString":"assert(document.querySelector('.gallery')?.querySelectorAll('img')?.length === 9);"}]}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/2022/responsive-web-design/#learn-css-flexbox-by-building-a-photo-gallery","dashedName":"step-5","certification":"responsive-web-design","disableLoopProtectTests":false,"disableLoopProtectPreview":false,"superBlock":"2022/responsive-web-design","chapter":null,"module":null,"block":"learn-css-flexbox-by-building-a-photo-gallery","isFirstStep":false,"template":null,"required":[],"isLastChallengeInBlock":false,"nextChallengePath":"/learn/2022/responsive-web-design/learn-css-flexbox-by-building-a-photo-gallery/step-6","prevChallengePath":"/learn/2022/responsive-web-design/learn-css-flexbox-by-building-a-photo-gallery/step-4","id":"61537c9eecea6a335db6da79","saveSubmissionToDB":null},"projectPreview":{"challengeData":{"challengeType":0,"challengeFiles":[{"name":"index","ext":"html","contents":"<!DOCTYPE html>\r\n<html lang=\"en\">\r\n  <head>\r\n    <meta charset=\"utf-8\">\r\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\r\n    <title>Photo Gallery</title>\r\n    <link rel=\"stylesheet\" href=\"./styles.css\">\r\n  </head>\r\n  <body>\r\n    <header class=\"header\">\r\n      <h1>css flexbox photo gallery</h1>\r\n    </header>\r\n    <div class=\"gallery\">\r\n      <img src=\"https://cdn.freecodecamp.org/curriculum/css-