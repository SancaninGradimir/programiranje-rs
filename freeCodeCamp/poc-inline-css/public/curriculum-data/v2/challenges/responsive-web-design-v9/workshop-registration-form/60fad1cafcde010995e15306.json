    {
      "text": "<p>Trebalo bi mu dati <code>input</code> očekivano ime prvog atributa <code>name</code>. <em>PS Izabrao bih <code>first-name</code></em></p>",
      "testString": "assert.isNotEmpty(document.querySelector('fieldset:nth-child(1) > label:nth-child(1) > input')?.name);"
    },
    {
      "text": "<p>Trebalo bi mu dati <code>input</code> očekivano zadnje ime svojstvo elementa <code>name</code>. <em>PS Izabrao bih <code>last-name</code></em></p>",
      "testString": "assert.isNotEmpty(document.querySelector('fieldset:nth-child(1) > label:nth-child(2) > input')?.name);"
    },
    {
      "text": "<p>Trebalo bi mu dati osobinu elementa <code>email</code> sa svojstvom <code>name</code>. <em>PS Izabrao bih <code>email</code></em></p>",
      "testString": "assert.isNotEmpty(document.querySelector('input[type=\"email\"]')?.name);"
    },
    {
      "text": "<p>Trebalo bi mu dati atribut elementa <code>password</code> sa svojstvom <code>name</code>. <em>PS Izabrao bih <code>password</code></em></p>",
      "testString": "assert.isNotEmpty(document.querySelector('input[type=\"password\"]')?.name);"
    },
    {
      "text": "<p>Treba da mu daš atribut elementa <code>checkbox</code> sa svojstvom <code>name</code>. <em>PS Izabrao bih <code>terms</code></em></p>",
      "testString": "assert.isNotEmpty(document.querySelector('input[type=\"checkbox\"]')?.name);"
    },
    {
      "text": "<p>Trebalo bi mu dati atribut elementa <code>file</code> sa svojstvom <code>name</code>. <em>PS Izabrao bih <code>file</code></em></p>",
      "testString": "assert.isNotEmpty(document.querySelector('input[type=\"file\"]')?.name);"
    },
