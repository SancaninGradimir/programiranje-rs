{"componentChunkName":"component---src-templates-challenges-classic-show-tsx","path":"/learn/html-and-accessibility/workshop-accessible-audio-controller/step-7","result":{"data":{"challengeNode":{"challenge":{"block":"workshop-accessible-audio-controller","demoType":null,"title":"Korak 7","description":"<section id=\"description\">\n<p>Kontrola glasa za pristupnost je skoro gotova, ali postoji nešto poslednje što treba dodati.</p>\n<p>Dodajte element <code>button</code> koji ima atribut elementa <code>type</code> postavljen na <code>button</code> i sa tekstom <code>Mute</code> ispod elementa <code>div</code>.</p>\n<p>Sa tim promenama, završili ste ovaj radionicu!</p>\n</section>","id":"68ed488821845990c911a223","hasEditableBoundaries":true,"instructions":"","notes":null,"challengeType":0,"helpCategory":"HTML-CSS","videoUrl":null,"superBlock":"html-and-accessibility","translationPending":false,"forumTopicId":null,"hooks":null,"fields":{"slug":"/learn/html-and-accessibility/workshop-accessible-audio-controller/step-7"},"required":[],"usesMultifileEditor":true,"challengeFiles":[{"fileKey":"indexhtml","ext":"html","name":"index","contents":"<!DOCTYPE html>\n<html lang=\"en\">\n  <head>\n    <meta charset=\"UTF-8\">\n    <title>Accessible Controls</title>\n  </head>\n  <body>\n\n    <h1>Audio Controls</h1>\n\n    <button type=\"button\">Play</button>\n\n    <div>\n      <span id=\"volume-label\">Volume</span>\n      <span id=\"volume-description\">Adjust the sound level</span>\n      <input type=\"range\" min=\"0\" max=\"100\" value=\"50\"\n           aria-labelledby=\"volume-label volume-description\">\n    </div>\n    \n\n  </body>\n</html>","head":null,"tail":null,"editableRegionBoundaries":[18,20],"history":["index.html"]}],"saveSubmissionToDB":null,"tests":[{"text":"<p>Trebalo bi da imaš element <code>button</code> ispod elementa <code>div</code>.</p>","testString":"const buttonEl = document.querySelector('div + button');\nassert.exists(buttonEl);"},{"text":"<p>Tvoj element za <code>button</code> treba da ima svojstvo elementa <code>type</code>.</p>","testString":"const buttonEl = document.querySelector('div + button');\nassert.isTrue(buttonEl?.hasAttribute('type'));"},{"text":"<p>Vaš element za <code>button</code> mora imati svojstvo elementa <code>type</code> sa vrednošću <code>button</code>.</p>","testString":"const buttonEl = document.querySelector('div + button');\nassert.equal(buttonEl?.getAttribute('type'), 'button');"},{"text":"<p>Element za <code>button</code> treba da ima tekst od <code>Mute</code>.</p>","testString":"const buttonEl = document.querySelector('div + button');\nassert.equal(buttonEl?.innerText.trim(), 'Mute');"}]}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/html-and-accessibility/#workshop-accessible-audio-controller","dashedName":"step-7","certification":"html-and-accessibility","disableLoopProtectTests":false,"disableLoopProtectPreview":false,"superBlock":"html-and-accessibility","chapter":null,"module":null,"block":"workshop-accessible-audio-controller","isFirstStep":false,"template":null,"required":[],"isLastChallengeInBlock":true,"nextChallengePath":"/learn/html-and-accessibility/lecture-accessible-media-elements/when-is-the-alt-attribute-needed","prevChallengePath":"/learn/html-and-accessibility/workshop-accessible-audio-controller/step-6","id":"68ed488821845990c911a223","saveSubmissionToDB":null},"projectPreview":{"challengeData":{"challengeType":0,"challengeFiles":[{"name":"index","ext":"html","contents":"<!DOCTYPE html>\n<html lang=\"en\">\n  <head>\n    <meta charset=\"UTF-8\">\n    <title>Accessible Controls</title>\n  </head>\n  <body>\n\n    <h1>Audio Controls</h1>\n\n    <button type=\"button\">Play</button>\n\n    <div>\n      <span id=\"volume-label\">Volume</span>\n      <span id=\"volume-description\">Adjust the sound level</span>\n      <input type=\"range\" min=\"0\" max=\"100\" value=\"50\"\n             aria-labelledby=\"volume-label volume-description\">\n    </div>\n\n    <button type=\"button\">Mute</button>\n\n  </body>\n</html>","history":["index.html"],"fileKey":"indexhtml"}]}},"id":"/learn/html-and-accessibility/workshop-accessible-audio-controller/step-7"}},"staticQueryHashes":["3858520367"],"slicesMap":{}}