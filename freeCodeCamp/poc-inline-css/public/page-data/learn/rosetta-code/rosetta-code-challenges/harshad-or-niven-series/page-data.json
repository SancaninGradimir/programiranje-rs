{"componentChunkName":"component---src-templates-challenges-classic-show-tsx","path":"/learn/rosetta-code/rosetta-code-challenges/harshad-or-niven-series","result":{"data":{"challengeNode":{"challenge":{"block":"rosetta-code-challenges","demoType":null,"title":"Niz Haršad ili Niven","description":"<section id=\"description\">\n<p>Harshad ili Niven brojevi su pozitivni ceo brojevi ≥ 1 koji se mogu podeliti sa zbirom svojih cifara bez ostatka.</p>\n<p>Na primer, <code>42</code> je Harshad broj jer <code>42</code> je deljiv sa <code>(4 + 2)</code> bez ostataka.</p>\n<p>Pretpostavlja se da je sekvenca definisana kao broj u rastućem redosledu.</p>\n</section>","id":"595668ca4cfe1af2fb9818d4","hasEditableBoundaries":false,"instructions":"<section id=\"instructions\">\n<p>Implementirati funkciju koja generiše članove Harshad sekvence.</p>\n<p>Korišćenje za vraćanje reda podataka sa deset uzastopnih članova, počevši od prvog Haršad broja koji prelazi <code>n</code>.</p>\n</section>","notes":null,"challengeType":1,"helpCategory":"Rosetta","videoUrl":null,"superBlock":"rosetta-code","translationPending":false,"forumTopicId":302281,"hooks":null,"fields":{"slug":"/learn/rosetta-code/rosetta-code-challenges/harshad-or-niven-series"},"required":[],"usesMultifileEditor":false,"challengeFiles":[{"fileKey":"scriptjs","ext":"js","name":"script","contents":"function isHarshadOrNiven(n) {\n  const res = [];\n\n  return res;\n}","head":null,"tail":null,"editableRegionBoundaries":[],"history":["script.js"]}],"saveSubmissionToDB":null,"tests":[{"text":"<p><code>isHarshadOrNiven</code> Trebalo bi da bude funkcija.</p>","testString":"assert(typeof isHarshadOrNiven === 'function');"},{"text":"<p><code>isHarshadOrNiven(10)</code> trebalo bi da vrati <code>[12, 18, 20, 21, 24, 27, 30, 36, 40, 42]</code></p>","testString":"assert.deepEqual(isHarshadOrNiven(10), [12, 18, 20, 21, 24, 27, 30, 36, 40, 42]);"},{"text":"<p><code>isHarshadOrNiven(400)</code> trebalo bi da vrati <code>[402, 405, 407, 408, 410, 414, 420, 423, 432, 440]</code></p>","testString":"assert.deepEqual(isHarshadOrNiven(400), [402, 405, 407, 408, 410, 414, 420, 423, 432, 440]);"},{"text":"<p><code>isHarshadOrNiven(1000)</code> treba da vrati <code>[1002, 1008, 1010, 1011, 1012, 1014, 1015, 1016, 1017, 1020]</code></p>","testString":"assert.deepEqual(isHarshadOrNiven(1000), [1002, 1008, 1010, 1011, 1012, 1014, 1015, 1016, 1017, 1020]);"}]}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/rosetta-code/#rosetta-code-challenges","dashedName":"harshad-or-niven-series","certification":"rosetta-code","disableLoopProtectTests":true,"disableLoopProtectPreview":false,"superBlock":"rosetta-code","chapter":null,"module":null,"block":"rosetta-code-challenges","isFirstStep":false,"template":null,"required":[],"isLastChallengeInBlock":false,"nextChallengePath":"/learn/rosetta-code/rosetta-code-challenges/hash-from-two-arrays","prevChallengePath":"/learn/rosetta-code/rosetta-code-challenges/happy-numbers","id":"595668ca4cfe1af2fb9818d4","saveSubmissionToDB":null},"projectPreview":{"challengeData":{"challengeType":1,"challengeFiles":[{"name":"script","ext":"js","contents":"function ZigZagMatrix(n) {\n  const mtx = [];\n  for (let i = 0; i < n; i++) {\n    mtx[i] = [];\n  }\n\n  let i = 1;\n  let j = 1;\n  for (let e = 0; e < n * n; e++) {\n    mtx[i - 1][j - 1] = e;\n    if ((i + j) % 2 === 0) {\n      // Even stripes\n      if (j < n) j++;\n      else i += 2;\n      if (i > 1) i--;\n    } else {\n      // Odd stripes\n      if (i < n) i++;\n      else j += 2;\n      if (j > 1) j--;\n    }\n  }\n  return mtx;\n}","history":["script.js"],"fileKey":"scriptjs"}]}},"id":"/learn/rosetta-code/rosetta-code-challenges/harshad-or-niven-series"}},"staticQueryHashes":["3858520367"],"slicesMap":{}}