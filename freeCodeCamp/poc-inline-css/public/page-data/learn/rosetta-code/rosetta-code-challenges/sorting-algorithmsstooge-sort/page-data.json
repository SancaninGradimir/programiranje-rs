{"componentChunkName":"component---src-templates-challenges-classic-show-tsx","path":"/learn/rosetta-code/rosetta-code-challenges/sorting-algorithmsstooge-sort","result":{"data":{"challengeNode":{"challenge":{"block":"rosetta-code-challenges","demoType":null,"title":"Algoritmi za kupanga/stooge sort","description":"<section id=\"description\">\n<p>Napišite funkciju koja implementira Stooge Sort na niz podataka celih brojeva. Funkcija treba da vrati sortirani niz podataka.</p>\n<p>Algoritam Stooge Sort-a je sledeći:</p>\n<pre><b>algorithm</b> stoogesort(<b>array</b> L, i = 0, j = <b>length</b>(L)-1)\n  <b>if</b> L[j] &#x3C; L[i] <b>then</b>\n    L[i] <b>↔</b> L[j]\n  <b>if</b> j - i > 1 <b>then</b>\n    t <b>:=</b> (j - i + 1)/3\n    stoogesort(L, i , j-t)\n    stoogesort(L, i+t, j )\n    stoogesort(L, i , j-t)\n  <b>return</b> L\n</pre>\n</section>","id":"5a23c84252665b21eecc8012","hasEditableBoundaries":false,"instructions":"","notes":null,"challengeType":1,"helpCategory":"Rosetta","videoUrl":null,"superBlock":"rosetta-code","translationPending":false,"forumTopicId":302318,"hooks":null,"fields":{"slug":"/learn/rosetta-code/rosetta-code-challenges/sorting-algorithmsstooge-sort"},"required":[],"usesMultifileEditor":false,"challengeFiles":[{"fileKey":"scriptjs","ext":"js","name":"script","contents":"function stoogeSort(arr) {\n\n}","head":null,"tail":null,"editableRegionBoundaries":[],"history":["script.js"]}],"saveSubmissionToDB":null,"tests":[{"text":"<p><code>stoogeSort</code> To treba da bude funkcija.</p>","testString":"assert(typeof stoogeSort == 'function');"},{"text":"<p><code>stoogeSort([25, 32, 12, 7, 20])</code> Trebalo bi da vrati red podataka.</p>","testString":"assert(Array.isArray(stoogeSort([25, 32, 12, 7, 20])));"},{"text":"<p><code>stoogeSort([25, 32, 12, 7, 20])</code> treba da vrati <code>[7, 12, 20, 25, 32]</code>.</p>","testString":"assert.deepEqual(stoogeSort([25, 32, 12, 7, 20]), [7, 12, 20, 25, 32]);"},{"text":"<p><code>stoogeSort([38, 45, 35, 8, 13])</code> treba da vrati <code>[8, 13, 35, 38, 45]</code>.</p>","testString":"assert.deepEqual(stoogeSort([38, 45, 35, 8, 13]), [8, 13, 35, 38, 45]);"},{"text":"<p><code>stoogeSort([43, 36, 20, 34, 24])</code> treba da vrati <code>[20, 24, 34, 36, 43]</code>.</p>","testString":"assert.deepEqual(stoogeSort([43, 36, 20, 34, 24]), [20, 24, 34, 36, 43]);"},{"text":"<p><code>stoogeSort([12, 33, 26, 18, 1, 16, 38])</code> bi trebalo da vrati <code>[1, 12, 16, 18, 26, 33, 38]</code>.</p>","testString":"assert.deepEqual(stoogeSort([12, 33, 26, 18, 1, 16, 38]), [\n  1,\n  12,\n  16,\n  18,\n  26,\n  33,\n  38\n]);"},{"text":"<p><code>stoogeSort([3, 39, 48, 16, 1, 4, 29])</code> treba vratiti <code>[1, 3, 4, 16, 29, 39, 48]</code>.</p>","testString":"assert.deepEqual(stoogeSort([3, 39, 48, 16, 1, 4, 29]), [\n  1,\n  3,\n  4,\n  16,\n  29,\n  39,\n  48\n]);"}]}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/rosetta-code/#rosetta-code-challenges","dashedName":"sorting-algorithmsstooge-sort","certification":"rosetta-code","disableLoopProtectTests":true,"disableLoopProtectPreview":false,"superBlock":"rosetta-code","chapter":null,"module":null,"block":"rosetta-code-challenges","isFirstStep":false,"template":null,"required":[],"isLastChallengeInBlock":false,"nextChallengePath":"/learn/rosetta-code/rosetta-code-challenges/sorting-algorithmsstrand-sort","prevChallengePath":"/learn/rosetta-code/rosetta-code-challenges/sorting-algorithmsshell-sort","id":"5a23c84252665b21eecc8012","saveSubmissionToDB":null},"projectPreview":{"challengeData":{"challengeType":1,"challengeFiles":[{"name":"script","ext":"js","contents":"function ZigZagMatrix(n) {\n  const mtx = [];\n  for (let i = 0; i < n; i++) {\n    mtx[i] = [];\n  }\n\n  let i = 1;\n  let j = 1;\n  for (let e = 0; e < n * n; e++) {\n    mtx[i - 1][j - 1] = e;\n    if ((i + j) % 2 === 0) {\n      // Even stripes\n      if (j < n) j++;\n      else i += 2;\n      if (i > 1) i--;\n    } else {\n      // Odd stripes\n      if (i < n) i++;\n      else j += 2;\n      if (j > 1) j--;\n    }\n  }\n  return mtx;\n}","history":["script.js"],"fileKey":"scriptjs"}]}},"id":"/learn/rosetta-code/rosetta-code-challenges/sorting-algorithmsstooge-sort"}},"staticQueryHashes":["3858520367"],"slicesMap":{}}