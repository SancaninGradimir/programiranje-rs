  "tests": [
    {
      "text": "<p><code>steamrollArray([[[\"a\"]], [[\"b\"]]])</code> treba vratiti <code>[\"a\", \"b\"]</code>.</p>",
      "testString": "assert.deepEqual(steamrollArray([[['a']], [['b']]]), ['a', 'b']);"
    },
    {
      "text": "<p><code>steamrollArray([1, [2], [3, [[4]]]])</code> treba vratiti <code>[1, 2, 3, 4]</code>.</p>",
      "testString": "assert.deepEqual(steamrollArray([1, [2], [3, [[4]]]]), [1, 2, 3, 4]);"
    },
    {
      "text": "<p><code>steamrollArray([1, [], [3, [[4]]]])</code> trebalo bi da vrati <code>[1, 3, 4]</code>.</p>",
      "testString": "assert.deepEqual(steamrollArray([1, [], [3, [[4]]]]), [1, 3, 4]);"
    },
