{"componentChunkName":"component---src-templates-challenges-generic-show-tsx","path":"/learn/b1-english-for-developers/learn-determiners-and-advanced-use-of-articles/dialogue-3-balancing-projects","result":{"data":{"challengeNode":{"challenge":{"assignments":["<p>Gledaj video.</p>"],"bilibiliIds":null,"block":"learn-determiners-and-advanced-use-of-articles","challengeType":21,"description":"<section id=\"description\">\n<p>Pogledajte video ispod da biste razumeli kontekst sledećih lekcija.</p>\n</section>","nodules":null,"explanation":null,"helpCategory":"English","instructions":"","fields":{"slug":"/learn/b1-english-for-developers/learn-determiners-and-advanced-use-of-articles/dialogue-3-balancing-projects"},"questions":[],"scene":{"setup":{"background":"company2-boardroom.png","characters":[{"character":"Maria","position":{"x":-25,"y":0,"z":1},"opacity":null},{"character":"James","position":{"x":125,"y":0,"z":1},"opacity":null}],"audio":{"filename":"B1_20-3.mp3","startTime":1,"startTimestamp":null,"finishTimestamp":null},"alwaysShowDialogue":true},"commands":[{"background":null,"character":"Maria","position":{"x":25,"y":0,"z":1},"opacity":null,"startTime":0,"finishTime":null,"dialogue":null},{"background":null,"character":"James","position":{"x":70,"y":0,"z":1},"opacity":null,"startTime":0.5,"finishTime":null,"dialogue":null},{"background":null,"character":"Maria","position":null,"opacity":null,"startTime":1,"finishTime":8.52,"dialogue":{"text":"As we look at the quarter ahead, we need to distribute our resources carefully. All of our projects need some attention, but we can't cover everything at once.","align":"left"}},{"background":null,"character":"James","position":null,"opacity":null,"startTime":8.84,"finishTime":15.46,"dialogue":{"text":"I agree. How about we allocate half of our server capacity to the main project, since it's crucial for our yearly goals?","align":"right"}},{"background":null,"character":"James","position":null,"opacity":null,"startTime":15.7,"finishTime":18.92,"dialogue":{"text":"We could give the other half to support both of our smaller initiatives.","align":"right"}},{"background":null,"character":"Maria","position":null,"opacity":null,"startTime":19.68,"finishTime":24.24,"dialogue":{"text":"That sounds reasonable, but none of the smaller projects should get advanced analytics tools yet.","align":"left"}},{"background":null,"character":"Maria","position":null,"opacity":null,"startTime":24.42,"finishTime":31.44,"dialogue":{"text":"They're not ready for that level of integration. Maybe we could allocate another two developers to them instead to help speed up the basic development.","align":"left"}},{"background":null,"character":"James","position":null,"opacity":null,"startTime":31.94,"finishTime":37.2,"dialogue":{"text":"I see your point, but we have no extra developers available until next month. It's a tight situation.","align":"right"}},{"background":null,"character":"James","position":null,"opacity":null,"startTime":37.66,"finishTime":44.32,"dialogue":{"text":"We can't hire anyone new right now either. Perhaps we could slightly extend our current team's hours?","align":"right"}},{"background":null,"character":"Maria","position":null,"opacity":null,"startTime":45.02,"finishTime":51.82,"dialogue":{"text":"We might face some pushback there. Neither the developers nor the project managers want longer hours. It could lead to burnout.","align":"left"}},{"background":null,"character":"Maria","position":null,"opacity":null,"startTime":52.3,"finishTime":58,"dialogue":{"text":"Why don't we consider using either part-time contractors or spreading tasks among existing projects?","align":"left"}},{"background":null,"character":"James","position":null,"opacity":null,"startTime":58.36,"finishTime":68.24,"dialogue":{"text":"That's a good option. Let's also ensure that any changes in task distribution are communicated clearly. We need to make sure no critical task is missed.","align":"right"}},{"background":null,"character":"Maria","position":null,"opacity":null,"startTime":68.88,"finishTime":73.22,"dialogue":{"text":"Exactly, James. I'll make a plan for resource allocation and share it with you tomorrow.","align":"left"}},{"background":null,"character":"Maria","position":null,"opacity":null,"startTime":73.5,"finishTime":77.06,"dialogue":{"text":"We can review it together and make changes before showing it to the whole team.","align":"left"}},{"background":null,"character":"James","position":null,"opacity":null,"startTime":77.64,"finishTime":82.74,"dialogue":{"text":"Perfect, Maria. Thank you for leading this. We'll meet again this Friday to finish everything.","align":"right"}},{"background":null,"character":"James","position":{"x":125,"y":0,"z":1},"opacity":null,"startTime":83.24,"finishTime":null,"dialogue":null},{"background":null,"character":"Maria","position":{"x":-25,"y":0,"z":1},"opacity":null,"startTime":83.74,"finishTime":null,"dialogue":null}]},"superBlock":"b1-english-for-developers","tests":[],"title":"Dijalog 3: Balansiranje projekata","transcript":null,"translationPending":false,"videoId":null,"videoLocaleIds":null}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/b1-english-for-developers/#learn-determiners-and-advanced-use-of-articles","dashedName":"dialogue-3-balancing-projects","certification":"b1-english-for-developers","disableLoopProtectTests":false,"disableLoopProtectPreview":false,"superBlock":"b1-english-for-developers","chapter":null,"module":null,"block":"learn-determiners-and-advanced-use-of-articles","isFirstStep":false,"template":null,"required":[],"isLastChallengeInBlock":false,"nextChallengePath":"/learn/b1-english-for-developers/learn-determiners-and-advanced-use-of-articles/task-113","prevChallengePath":"/learn/b1-english-for-developers/learn-determiners-and-advanced-use-of-articles/task-112","id":"681478e4b54ac6044a51e385","saveSubmissionToDB":null},"projectPreview":{"challengeData":{"challengeType":19,"challengeFiles":[]}},"id"