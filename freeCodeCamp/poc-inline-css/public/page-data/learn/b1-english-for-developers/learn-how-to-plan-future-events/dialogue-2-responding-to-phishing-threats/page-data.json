ition":null,"opacity":null,"startTime":11.38,"finishTime":13.86,"dialogue":{"text":"Not yet, but I think it came from an email link.","align":"left"}},{"background":null,"character":"Jake","position":null,"opacity":null,"startTime":14.1,"finishTime":18.02,"dialogue":{"text":"We need to investigate quickly. I'll send out a warning to everyone right away.","align":"left"}},{"background":null,"character":"Sarah","position":null,"opacity":null,"startTime":18.42,"finishTime":21.48,"dialogue":{"text":"That sounds like a good plan. Do you think it will affect our project deadlines?","align":"right"}},{"background":null,"character":"Jake","position":null,"opacity":null,"startTime":21.88,"finishTime":25.16,"dialogue":{"text":"It might. I hope it won't, but we should prepare for delays.","align":"left"}},{"background":null,"character":"Jake","position":null,"opacity":null,"startTime":25.54,"finishTime":27.98,"dialogue":{"text":"I'll update the project manager about the situation.","align":"left"}},{"background":null,"character":"Sarah","position":null,"opacity":null,"startTime":27.98,"finishTime":31.62,"dialogue":{"text":"I'll alert the development team and tell them to check their emails carefully.","align":"right"}},{"background":null,"character":"Sarah","position":null,"opacity":null,"startTime":31.98,"finishTime":33.16,"dialogue":{"text":"Is there anything else we should do?","align":"right"}},{"background":null,"character":"Jake","position":null,"opacity":null,"startTime":33.46,"finishTime":37.6,"dialogue":{"text":"We'll probably need to run a full system scan to ensure that there's no hidden malware.","align":"left"}},{"background":null,"character":"Jake","position":null,"opacity":null,"startTime":37.96,"finishTime":40.6,"dialogue":{"text":"Can you coordinate with the IT support team for that?","align":"left"}},{"background":null,"character":"Sarah","position":null,"opacity":null,"startTime":41,"finishTime":44.92,"dialogue":{"text":"Yes, I'll contact them now. How do you think our clients will react to this news?","align":"right"}},{"background":null,"character":"Jake","position":null,"opacity":null,"startTime":45.6,"finishTime":51.98,"dialogue":{"text":"They'll likely be concerned, but I'll reassure them that we're taking all necessary steps to secure our systems.","align":"left"}},{"background":null,"character":"Sarah","position":null,"opacity":null,"startTime":52.5,"finishTime":56.92,"dialogue":{"text":"Thanks, Jake. Let's meet later to discuss the investigation results and plan our next steps.","align":"right"}},{"background":null,"character":"Sarah","position":{"x":125,"y":0,"z":1},"opacity":null,"startTime":57.52,"finishTime":null,"dialogue":null},{"background":null,"character":"Jake","position":{"x":-25,"y":0,"z":1},"opacity":null,"startTime":57.92,"finishTime":null,"dialogue":null}]},"superBlock":"b1-english-for-developers","tests":[],"title":"Razgovor 2: Odgovaranje na pretnje phishinga","transcript":null,"translationPending":false,"videoId":null,"videoLocaleIds":null}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/b1-english-for-developers/#learn-how-to-plan-future-events","dashedName":"dialogue-2-responding-to-phishing-threats","certification":"b1-english-for-developers","disableLoopProtectTests":false,"disableLoopProtectPreview":false,"superBlock":"b1-english-for-developers","chapter":null,"module":null,"block":"learn-how-to-plan-future-events","isFirstStep":false,"template":null,"required":[],"isLastChallengeInBlock":false,"nextChallengePath":"/learn/b1-english-for-developers/learn-how-to-plan-future-events/task-51","prevChallengePath":"/learn/b1-english-for-developers/learn-how-to-plan-future-events/task-50","id":"67531709d628ef047202e6ae","saveSubmissionToDB":null},"projectPreview":{"challengeData":{"challengeType":19,"challengeFiles":[]}},"id":"/learn/b1-english-for-developers/learn-how-to-plan-future-events/dialogue-2-responding-to-phishing-threats"}},"staticQueryHashes":["3858520367"],"slicesMap":{}}