{"componentChunkName":"component---src-templates-challenges-classic-show-tsx","path":"/learn/javascript-v9/lab-prime-number-sum-calculator/build-a-prime-number-sum-calculator","result":{"data":{"challengeNode":{"challenge":{"block":"lab-prime-number-sum-calculator","demoType":null,"title":"Konstruktor kalkulatora za sabiranje osnovnih brojeva","description":"<section id=\"description\">\n<p>U ovoj laboratoriji, ćeš napraviti kalkulator koji prima brojeve i vraća sumu svih premijnih brojeva koji su manji ili jednaki tom broju.</p>\n<p><strong>Cilj</strong>: Popunite korisničke priče navedene ispod i prođite sve testove kako biste završili laboratoriju.</p>\n<p><strong>Priče korisnika:</strong></p>\n<ol>\n<li>Trebalo bi da ima funkciju <code>sumPrimes</code> koja prima brojeve kao argumente.</li>\n<li>Funkcija <code>sumPrimes</code> treba da vrati zbir svih osnovnih brojeva manjih ili jednakih datoj/unesenom broju.</li>\n<li>Ako je ulazni broj manji od <code>2</code>, funkcija treba da vrati <code>0</code>.</li>\n</ol>\n</section>","id":"a3bfc1673c0526e06d3ac698","hasEditableBoundaries":false,"instructions":"","notes":null,"challengeType":26,"helpCategory":"JavaScript","videoUrl":null,"superBlock":"javascript-v9","translationPending":false,"forumTopicId":null,"hooks":null,"fields":{"slug":"/learn/javascript-v9/lab-prime-number-sum-calculator/build-a-prime-number-sum-calculator"},"required":[],"usesMultifileEditor":true,"challengeFiles":[{"fileKey":"scriptjs","ext":"js","name":"script","contents":"","head":null,"tail":null,"editableRegionBoundaries":[],"history":["script.js"]}],"saveSubmissionToDB":null,"tests":[{"text":"<p>Trebalo bi da imaš funkciju <code>sumPrimes</code>.</p>","testString":"assert.isFunction(sumPrimes);"},{"text":"<p><code>sumPrimes(10)</code> trebalo bi da vrati <code>17</code>.</p>","testString":"assert.strictEqual(sumPrimes(10), 17);"},{"text":"<p><code>sumPrimes(5)</code> trebalo bi da vrati <code>10</code>.</p>","testString":"assert.strictEqual(sumPrimes(5), 10);"},{"text":"<p><code>sumPrimes(2)</code> treba da vrati <code>2</code>.</p>","testString":"assert.strictEqual(sumPrimes(2), 2);"},{"text":"<p><code>sumPrimes(0)</code> trebalo bi vratiti <code>0</code>.</p>","testString":"assert.strictEqual(sumPrimes(0), 0);"},{"text":"<p><code>sumPrimes(977)</code> treba da vrati <code>73156</code>.</p>","testString":"assert.strictEqual(sumPrimes(977), 73156);"}]}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/javascript-v9/#lab-prime-number-sum-calculator","dashedName":"build-a-prime-number-sum-calculator","certification":"javascript-v9","disableLoopProtectTests":false,"disableLoopProtectPreview":false,"superBlock":"javascript-v9","chapter":"javascript","module":"dynamic-programming","block":"lab-prime-number-sum-calculator","isFirstStep":true,"template":null,"required":[],"isLastChallengeInBlock":true,"nextChallengePath":"/learn/javascript-v9/review-dynamic-programming-js/review-dynamic-programming-js","prevChallengePath":"/learn/javascript-v9/lab-nth-fibonacci-number-js/build-an-nth-fibonacci-number-calculator","id":"a3bfc1673c0526e06d3ac698","saveSubmissionToDB":null},"projectPreview":{"challengeData":{"challengeType":26,"challengeFiles":[{"name":"script","ext":"js","contents":"function sumPrimes(num) {\r\n  function isPrime(n) {\r\n    if (n < 2) return false;\r\n    for (let i = 2; i <= Math.sqrt(n); i++) {\r\n      if (n % i === 0) {\r\n        return false;\r\n      }\r\n    }\r\n    return true;\r\n  }\r\n\r\n  let sum = 0;\r\n\r\n  for (let i = 2; i <= num; i++) {\r\n    if (isPrime(i)) {\r\n      sum += i;\r\n    }\r\n  }\r\n  return sum;\r\n}","history":["script.js"],"fileKey":"scriptjs"}]}},"id":"/learn/javascript-v9/lab-prime-number-sum-calculator/build-a-prime-number-sum-calculator"}},"staticQueryHashes":["3858520367"],"slicesMap":{}}