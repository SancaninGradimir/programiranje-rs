        "seed": "function fearNotLetter (str) {\r\n  for (var i = str.charCodeAt(0); i <= str.charCodeAt(str.length - 1); i++) {\r\n    var letter = String.fromCharCode(i);\r\n    if (str.indexOf(letter) === -1) {\r\n      return letter;\r\n    }\r\n  }\r\n\r\n  return undefined;\r\n}"
