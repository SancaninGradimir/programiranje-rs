{"componentChunkName":"component---src-templates-challenges-classic-show-tsx","path":"/learn/responsive-web-design-v9/workshop-build-a-video-display-using-iframe/step-7","result":{"data":{"challengeNode":{"challenge":{"block":"workshop-build-a-video-display-using-iframe","demoType":null,"title":"Korak 7","description":"<section id=\"description\">\n<p>Atribut sledećeg elementa koji ćete dodati je <code>referrerpolicy</code>. Ovo je pravilo koje određuje koje podatke delite kada povezujete svoju stranicu sa drugom stranicom.</p>\n<p>Dodaj svojstvo elementa <code>referrerpolicy</code> i postavi ga na <code>strict-origin-when-cross-origin</code>. Ovo deli punu adresu na istom veb-sajtu, samo naziv sajta na drugom web-sajtu, i nema ništa na nesigurnim sajtovima.</p>\n</section>","id":"68ba9c4f1688914d72876098","hasEditableBoundaries":true,"instructions":"","notes":null,"challengeType":0,"helpCategory":"HTML-CSS","videoUrl":null,"superBlock":"responsive-web-design-v9","translationPending":false,"forumTopicId":null,"hooks":null,"fields":{"slug":"/learn/responsive-web-design-v9/workshop-build-a-video-display-using-iframe/step-7"},"required":[],"usesMultifileEditor":true,"challengeFiles":[{"fileKey":"indexhtml","ext":"html","name":"index","contents":"<!DOCTYPE html>\n<html lang=\"en\">\n  <head>\n    <meta charset=\"UTF-8\" />\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" />\n    <title>Display Videos in an iframe</title>\n  </head>\n  <body>\n    <h1>iframe Video Display</h1>\n    <iframe\n      width=\"560\"\n      height=\"315\"\n      src=\"https://www.youtube.com/embed/I0_951_MPE0\"\n      allow=\"accelerometer autoplay clipboard-write encrypted-media gyroscope web-share\"\n      \n    >\n\n    </iframe>\n  </body>\n</html>","head":null,"tail":null,"editableRegionBoundaries":[14,16],"history":["index.html"]}],"saveSubmissionToDB":null,"tests":[{"text":"<p>Vaš element <code>iframe</code> mora imati svojstvo elemenata <code>referrerpolicy</code> postavljeno na <code>strict-origin-when-cross-origin</code>.</p>","testString":"const iframeEl = document.querySelector('iframe')\nassert.equal(iframeEl?.getAttribute('referrerpolicy'), 'strict-origin-when-cross-origin')"}]}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/responsive-web-design-v9/#workshop-build-a-video-display-using-iframe","dashedName":"step-7","certification":"responsive-web-design-v9","disableLoopProtectTests":false,"disableLoopProtectPreview":false,"superBlock":"responsive-web-design-v9","chapter":"html","module":"basic-html","block":"workshop-build-a-video-display-using-iframe","isFirstStep":false,"template":null,"required":[],"isLastChallengeInBlock":false,"nextChallengePath":"/learn/responsive-web-design-v9/workshop-build-a-video-display-using-iframe/step-8","prevChallengePath":"/learn/responsive-web-design-v9/workshop-build-a-video-display-using-iframe/step-6","id":"68ba9c4f1688914d72876098","saveSubmissionToDB":null},"projectPreview":{"challengeData":{"challengeType":0,"challengeFiles":[{"name":"index","ext":"html","contents":"<!DOCTYPE html>\n<html lang=\"en\">\n  <head>\n    <meta charset=\"UTF-8\" />\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" />\n    <title>Display Videos in an iframe</title>\n  </head>\n  <body>\n    <h1>iframe Video Display</h1>\n    <br />\n    <iframe\n      width=\"560\"\n      height=\"315\"\n      src=\"https://www.youtube.com/embed/I0_951_MPE0\"\n      allow=\"accelerometer autoplay clipboard-write encrypted-media gyroscope web-share\"\n      referrerpolicy=\"strict-origin-when-cross-origin\"\n      allowfullscreen\n    >\n    </iframe>\n  </body>\n</html>","history":["index.html"],"fileKey":"indexhtml"}]}},"id":"/learn/responsive-web-design-v9/workshop-build-a-video-display-using-iframe/step-7"}},"staticQueryHashes":["3858520367"],"slicesMap":{}}