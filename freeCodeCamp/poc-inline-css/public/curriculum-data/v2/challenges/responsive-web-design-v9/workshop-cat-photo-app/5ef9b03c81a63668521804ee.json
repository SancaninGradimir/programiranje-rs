      "text": "<p><code>&#x3C;!DOCTYPE html></code> Mora biti na samom vrhu dokumenta.</p>",
      "testString": "const noSpaces = code.replace(/\\s/g, '');\nassert.match(noSpaces, /^<\\!doctypehtml><html/i);"
    }
