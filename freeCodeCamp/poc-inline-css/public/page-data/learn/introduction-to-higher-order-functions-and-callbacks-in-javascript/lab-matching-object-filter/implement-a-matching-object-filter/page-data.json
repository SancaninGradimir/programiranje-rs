{"componentChunkName":"component---src-templates-challenges-classic-show-tsx","path":"/learn/introduction-to-higher-order-functions-and-callbacks-in-javascript/lab-matching-object-filter/implement-a-matching-object-filter","result":{"data":{"challengeNode":{"challenge":{"block":"lab-matching-object-filter","demoType":null,"title":"Primeni filter za odgovarajući predmet","description":"<section id=\"description\">\n<p>U ovoj laboratoriji, kreiraćete funkciju koja filtrira niz elemenata i vraća samo elemente koji odgovaraju svim parovima ključ-vrednost u datom izvornom objektu.</p>\n<p><strong>Cilj</strong>: Popuni priče korisnika ispod i prođi sve testove kako bi se završio laboratorijum.</p>\n<p><strong>Priče korisnika:</strong></p>\n<ol>\n<li>Trebalo bi da postoji funkcija <code>whatIsInAName</code> koja prima dva argumenta: niz stavki i izvorni objekat.</li>\n<li>Funkcija <code>whatIsInAName</code> treba da vrati novi niz koji sadrži samo stavke iz kolekcije koje imaju sve parove ključ-vrednost prisutne u izvornom objektu.</li>\n<li>Ako ne postoji stavka koja odgovara svim parovima ključ-vrednost iz izvora, funkcija treba da vrati prazan niz. Primer:</li>\n</ol>\n<pre><code class=\"language-js\">whatIsInAName(\r\n  [\r\n    { first: \"Romeo\", last: \"Montague\" },\r\n    { first: \"Mercutio\", last: null },\r\n    { first: \"Tybalt\", last: \"Capulet\" }\r\n  ],\r\n  { last: \"Capulet\" }\r\n);\r\n// should return [{ first: \"Tybalt\", last: \"Capulet\" }]\n</code></pre>\n</section>","id":"a8e512fbe388ac2f9198f0fa","hasEditableBoundaries":false,"instructions":"","notes":null,"challengeType":26,"helpCategory":"JavaScript","videoUrl":null,"superBlock":"introduction-to-higher-order-functions-and-callbacks-in-javascript","translationPending":false,"forumTopicId":null,"hooks":null,"fields":{"slug":"/learn/introduction-to-higher-order-functions-and-callbacks-in-javascript/lab-matching-object-filter/implement-a-matching-object-filter"},"required":[],"usesMultifileEditor":true,"challengeFiles":[{"fileKey":"scriptjs","ext":"js","name":"script","contents":"","head":null,"tail":null,"editableRegionBoundaries":[],"history":["script.js"]}],"saveSubmissionToDB":null,"tests":[{"text":"<p>Trebalo bi da imaš funkciju <code>whatIsInAName</code>.</p>","testString":"assert.isFunction(whatIsInAName);"},{"text":"<p><code>whatIsInAName([{ first: \"Romeo\", last: \"Montague\" }, { first: \"Mercutio\", last: null }, { first: \"Tybalt\", last: \"Capulet\" }], { last: \"Capulet\" })</code> trebalo bi da vrati <code>[{ first: \"Tybalt\", last: \"Capulet\" }]</code>.</p>","testString":"assert.deepEqual(\r\n  whatIsInAName(\r\n    [{ first: \"Romeo\", last: \"Montague\" }, { first: \"Mercutio\", last: null }, { first: \"Tybalt\", last: \"Capulet\" }],\r\n    { last: \"Capulet\" }\r\n  ),\r\n  [{ first: \"Tybalt\", last: \"Capulet\" }]\r\n);"},{"text":"<p><code>whatIsInAName([{ \"apple\": 1 }, { \"apple\": 1 }, { \"apple\": 1, \"bat\": 2 }], { \"apple\": 1 })</code> treba da vrati <code>[{\"apple\": 1}, {\"apple\": 1}, {\"apple\": 1, \"bat\": 2}]</code>.</p>","testString":"assert.deepEqual(\r\n  whatIsInAName(\r\n    [{ \"apple\": 1 }, { \"apple\": 1 }, { \"apple\": 1, \"bat\": 2 }],\r\n    { \"apple\": 1 }\r\n  ),\r\n  [{ \"apple\": 1 }, { \"apple\": 1 }, { \"apple\": 1, \"bat\": 2 }]\r\n);"},{"text":"<p><code>whatIsInAName([{ \"apple\": 1, \"bat\": 2 }, { \"bat\": 2 }, { \"apple\": 1, \"bat\": 2, \"cookie\": 2 }], { \"apple\": 1, \"bat\": 2 })</code> trebalo bi vratiti <code>[{\"apple\": 1, \"bat\": 2}, {\"apple\": 1, \"bat\": 2, \"cookie\": 2}]</code>.</p>","testString":"assert.deepEqual(\r\n  whatIsInAName(\r\n    [{ \"apple\": 1, \"bat\": 2 }, { \"bat\": 2 }, { \"apple\": 1, \"bat\": 2, \"cookie\": 2 }],\r\n    { \"apple\": 1, \"bat\": 2 }\r\n  ),\r\n  [{ \"apple\": 1, \"bat\": 2 }, { \"apple\": 1, \"bat\": 2, \"cookie\": 2 }]\r\n);"},{"text":"<p><code>whatIsInAName([{ \"apple\": 1, \"bat\": 2 }, { \"apple\": 1 }, { \"apple\": 1, \"bat\": 2, \"cookie\": 2 }], { \"apple\": 1, \"cookie\": 2 })</code> trebalo bi da vrati <code>[{\"apple\": 1, \"bat\": 2, \"cookie\": 2}]</code>.</p>","testString":"assert.deepEqual(\r\n  whatIsInAName(\r\n    [{ \"apple\": 1, \"bat\": 2 }, { \"apple\": 1 }, { \"apple\": 1, \"bat\": 2, \"cookie\": 2 }],\r\n    { \"apple\": 1, \"cookie\": 2 }\r\n  ),\r\n  [{ \"apple\": 1, \"bat\": 2, \"cookie\": 2 }]\r\n);"},{"text":"<p><code>whatIsInAName([{ \"apple\": 1, \"bat\": 2 }, { \"apple\": 1 }, { \"apple\": 1, \"bat\": 2, \"cookie\": 2 }, { \"bat\": 2 }], { \"apple\": 1, \"bat\": 2 })</code> treba da vrati <code>[{\"apple\": 1, \"bat\": 2}, {\"apple\": 1, \"bat\": 2, \"cookie\": 2}]</code></p>","testString":"assert.deepEqual(\r\n  whatIsInAName(\r\n    [{ \"apple\": 1, \"bat\": 2 }, { \"apple\": 1 }, { \"apple\": 1, \"bat\": 2, \"cookie\": 2 }, { \"bat\": 2 }],\r\n    { \"apple\": 1, \"bat\": 2 }\r\n  ),\r\n  [{ \"apple\": 1, \"bat\": 2 }, { \"apple\": 1, \"bat\": 2, \"cookie\": 2 }]\r\n);"},{"text":"<p><code>whatIsInAName([{\"a\": 1, \"b\": 2, \"c\": 3}], {\"a\": 1, \"b\": 9999, \"c\": 3})</code> trebalo bi da vrati <code>[]</code>.</p>","testString":"assert.deepEqual(\r\n  whatIsInAName([{ \"a\": 1, \"b\": 2, \"c\": 3 }], { \"a\": 1, \"b\": 9999, \"c\": 3 }),\r\n  []\r\n);"},{"text":"<p><code>whatIsInAName([{\"a\": 1, \"b\": 2, \"c\": 3, \"d\": 9999}], {\"a\": 1, \"b\": 9999, \"c\": 3})</code> trebalo bi vratiti <code>[]</code>.</p>","testString":"assert.deepEqual(\r\n  whatIsInAName([{ \"a\": 1, \"b\": 2, \"c\": 3, \"d\": 9999 }], { \"a\": 1, \"b\": 9999, \"c\": 3 }),\r\n  []\r\n);"}]}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/introduction-to-higher-order-functions-and-callbacks-in-javascript/#lab-matching-object-filter","dashedName":"implement-a-matching-object-filter","certification":"introduction-to-higher-order-functions-and-callbacks-in-javascript","disableLoopProtectTests":false,"disableLoopProtectPreview":false,"superBlock":"introduction-to-higher-order-functions-and-callbacks-in-javascript","chapter":null,"module":null,"block":"lab-matching-object-filter","isFirstStep":true,"template":null,"required":[],"isLastChallengeInBlock":true,"nextChallengePath":"/learn/introduction-to-higher-order-functions-and-callbacks-in-javascript/lab-prime-number-sum-calculator/build-a-prime-number-sum-calculator","prevChallengePath":"/learn/introduction-to-higher-order-functions-and-callbacks-in-javascript/lab-value-remover-function/implement-a-value-remover-function","id":"a8e512fbe388ac2f9198f0fa","saveSubmissionToDB":null},"projectPreview":{"challengeData":{"challengeType":26,"challengeFiles":[{"name":"script","ext":"js","contents":"function whatIsInAName(collection, source) {\r\n  const sourceKeys = Object.keys(source);\r\n\r\n  return collection.filter(obj =>\r\n    sourceKeys.every(key => obj.hasOwnProperty(key) && obj[key] === source[key])\r\n  );\r\n}","history":["script.js"],"fileKey":"scriptjs"}]}},"id":"/learn/introduction-to-higher-order-functions-and-callbacks-in-javascript/lab-matching-object-filter/implement-a-matching-object-filter"}},"staticQueryHashes":["3858520367"],"slicesMap":{}}