        "path": "script.js",
        "fileKey": "scriptjs",
        "contents": "function iteratedSquare(n) {\n    var total;\n    while (n != 89 && n != 1) {\n        total = 0;\n        while (n > 0) {\n            total += Math.pow(n % 10, 2);\n            n = Math.floor(n/10);\n        }\n        n = total;\n    }\n    return n;\n}",
