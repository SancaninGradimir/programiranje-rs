  "tests": [
    {
      "text": "<p><code>addTogether(2, 3)</code> trebalo bi da vrati 5.</p>",
      "testString": "assert.deepEqual(addTogether(2, 3), 5);"
    },
    {
      "text": "<p><code>addTogether(23.4, 30)</code> treba da vrati 53.4.</p>",
      "testString": "assert.deepEqual(addTogether(23.4, 30), 53.4);"
    },
    {
      "text": "<p><code>addTogether(\"2\", 3)</code> trebalo bi vratiti <code>undefined</code>.</p>",
      "testString": "assert.isUndefined(addTogether('2', 3));"
    },
    {
      "text": "<p><code>addTogether(5, undefined)</code> treba da vrati <code>undefined</code>.</p>",
      "testString": "assert.isUndefined(addTogether(5, undefined));"
    },
    {
      "text": "<p><code>addTogether(\"https://www.youtube.com/watch?v=dQw4w9WgXcQ\")</code> trebalo bi da vrati <code>undefined</code>.</p>",
      "testString": "assert.isUndefined(addTogether('https://www.youtube.com/watch?v=dQw4w9WgXcQ'));"
    },
    {
      "text": "<p><code>addTogether(5)</code> Trebalo bi da vrati funkciju.</p>",
      "testString": "assert.deepEqual(typeof(addTogether(5)), 'function');"
