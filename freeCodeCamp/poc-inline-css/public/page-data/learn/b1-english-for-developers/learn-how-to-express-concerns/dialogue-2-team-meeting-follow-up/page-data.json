{"componentChunkName":"component---src-templates-challenges-generic-show-tsx","path":"/learn/b1-english-for-developers/learn-how-to-express-concerns/dialogue-2-team-meeting-follow-up","result":{"data":{"challengeNode":{"challenge":{"assignments":["<p>Gledaj video.</p>"],"bilibiliIds":null,"block":"learn-how-to-express-concerns","challengeType":21,"description":"<section id=\"description\">\n<p>Pogledajte video ispod da biste razumeli kontekst sledećih lekcija.</p>\n</section>","nodules":null,"explanation":null,"helpCategory":"English","instructions":"","fields":{"slug":"/learn/b1-english-for-developers/learn-how-to-express-concerns/dialogue-2-team-meeting-follow-up"},"questions":[],"scene":{"setup":{"background":"company2-boardroom.png","characters":[{"character":"Maria","position":{"x":-25,"y":0,"z":1},"opacity":null},{"character":"James","position":{"x":125,"y":0,"z":1},"opacity":null}],"audio":{"filename":"B1_12-2.mp3","startTime":1,"startTimestamp":null,"finishTimestamp":null},"alwaysShowDialogue":true},"commands":[{"background":null,"character":"Maria","position":{"x":25,"y":0,"z":1},"opacity":null,"startTime":0,"finishTime":null,"dialogue":null},{"background":null,"character":"James","position":{"x":70,"y":0,"z":1},"opacity":null,"startTime":0.5,"finishTime":null,"dialogue":null},{"background":null,"character":"Maria","position":null,"opacity":null,"startTime":1,"finishTime":3.94,"dialogue":{"text":"Hey James, can we talk about my latest meeting with Bob?","align":"left"}},{"background":null,"character":"Maria","position":null,"opacity":null,"startTime":4.28,"finishTime":7.32,"dialogue":{"text":"I need to understand how the team feels about the new project deadline.","align":"left"}},{"background":null,"character":"James","position":null,"opacity":null,"startTime":7.78,"finishTime":10.2,"dialogue":{"text":"Sure, Maria. What did he say about it?","align":"right"}},{"background":null,"character":"Maria","position":null,"opacity":null,"startTime":10.34,"finishTime":13.66,"dialogue":{"text":"Bob mentioned that the client wants us to finish the project a week earlier.","align":"left"}},{"background":null,"character":"Maria","position":null,"opacity":null,"startTime":13.94,"finishTime":15.62,"dialogue":{"text":"How do you think they will feel about that?","align":"left"}},{"background":null,"character":"James","position":null,"opacity":null,"startTime":16,"finishTime":21.96,"dialogue":{"text":"Honestly, they're pretty stressed. We've already been putting in extra hours and this new deadline isn't helping.","align":"right"}},{"background":null,"character":"James","position":null,"opacity":null,"startTime":22.5,"finishTime":24.78,"dialogue":{"text":"It's like there's always more to do.","align":"right"}},{"background":null,"character":"Maria","position":null,"opacity":null,"startTime":25.24,"finishTime":27.96,"dialogue":{"text":"I hear you. This extra workload could lead to burnout.","align":"left"}},{"background":null,"character":"Maria","position":null,"opacity":null,"startTime":27.96,"finishTime":32.18,"dialogue":{"text":"Wouldn't it be better if we prioritized the tasks differently to reduce stress?","align":"left"}},{"background":null,"character":"James","position":null,"opacity":null,"startTime":33.02,"finishTime":35.84,"dialogue":{"text":"That might help, but we also need more hands on deck.","align":"right"}},{"background":null,"character":"James","position":null,"opacity":null,"startTime":36.38,"finishTime":40.66,"dialogue":{"text":"We're short on a few key roles and it's making things difficult for everyone.","align":"right"}},{"background":null,"character":"Maria","position":null,"opacity":null,"startTime":41.44,"finishTime":44.64,"dialogue":{"text":"I understand. I've talked to Bob about this, but I don't think it's an option.","align":"left"}},{"background":null,"character":"Maria","position":null,"opacity":null,"startTime":44.98,"finishTime":49.52,"dialogue":{"text":"I'll bring it up again and see if I can convince him. Besides that, are there other issues I should know about?","align":"left"}},{"background":null,"character":"James","position":null,"opacity":null,"startTime":49.96,"finishTime":55.42,"dialogue":{"text":"Yes. Communication has been a challenge. Sometimes we get updates too late and it affects our work.","align":"right"}},{"background":null,"character":"James","position":null,"opacity":null,"startTime":55.42,"finishTime":57.92,"dialogue":{"text":"It'd be great if we had more regular check-ins.","align":"right"}},{"background":null,"character":"Maria","position":null,"opacity":null,"startTime":58.34,"finishTime":63.14,"dialogue":{"text":"That's a good point. I'll suggest having more regular check-ins with the team to improve communication. Would that help?","align":"left"}},{"background":null,"character":"James","position":null,"opacity":null,"startTime":63.6,"finishTime":66.36,"dialogue":{"text":"Yes, that would be great. Thanks for listening, Maria.","align":"right"}},{"background":null,"character":"Maria","position":null,"opacity":null,"startTime":66.9,"finishTime":71.18,"dialogue":{"text":"No problem, James. I'll take this feedback to Bob. Let's work together to find a way to manage the stress.","align":"left"}},{"background":null,"character":"James","position":{"x":125,"y":0,"z":1},"opacity":null,"startTime":71.68,"finishTime":null,"dialogue":null},{"background":null,"character":"Maria","position":{"x":-25,"y":0,"z":1},"opacity":null,"startTime":72.18,"finishTime":null,"dialogue":null}]},"superBlock":"b1-english-for-developers","tests":[],"title":"Dijalog 2: Praćenje sastanka tima","transcript":null,"translationPending":false,"videoId":null,"videoLocaleIds":null}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/b1-english-for-developers/#learn-how-to-express-concerns","dashedName":"dialogue-2-team-meeting-follow-up","certification":"b1-english-for-developers","disableLoopProtectTests":false,"disableLoopProtectPreview":false,"superBlock":"b1-english-