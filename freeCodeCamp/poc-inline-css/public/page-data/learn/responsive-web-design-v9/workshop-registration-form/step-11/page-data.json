{"componentChunkName":"component---src-templates-challenges-classic-show-tsx","path":"/learn/responsive-web-design-v9/workshop-registration-form/step-11","result":{"data":{"challengeNode":{"challenge":{"block":"workshop-registration-form","demoType":null,"title":"Korak 11","description":"<section id=\"description\">\n<p>U prethodnim lekcijama, naučili ste kako da radite sa dimenzijama za <code>rem</code>. Zapamtite da dimenzija od <code>rem</code> predstavlja koren <code>em</code>, i da je povezana sa veličinom fonta elementa <code>html</code>.</p>\n<p>Pošto elementi <code>label</code> su po defaultu inline, svi se prikazuju jedan pored drugog na jednoj liniji, što čini njihov tekst teškim za čitanje.</p>\n<p>Da bi se prikazalo na različitim redovima, dodajte <code>display: block</code> u element <code>label</code>, i dodajte atribut <code>margin</code> sa vrednošću <code>0.5rem 0</code>, kako biste ih razdvojili od jedinstvenog.</p>\n</section>","id":"60f803d5241e6a0433a523a1","hasEditableBoundaries":true,"instructions":"","notes":null,"challengeType":0,"helpCategory":"HTML-CSS","videoUrl":null,"superBlock":"responsive-web-design-v9","translationPending":false,"forumTopicId":null,"hooks":null,"fields":{"slug":"/learn/responsive-web-design-v9/workshop-registration-form/step-11"},"required":[],"usesMultifileEditor":true,"challengeFiles":[{"fileKey":"indexhtml","ext":"html","name":"index","contents":"<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <title>Registration Form</title>\n  <link rel=\"stylesheet\" href=\"styles.css\" />\n</head>\n<body>\n  <h1>Registration Form</h1>\n  <p>Please fill out this form with the required information</p>\n  <form method=\"post\" action='https://register-demo.freecodecamp.org'>\n    <fieldset>\n      <label>Enter Your First Name:</label>\n      <label>Enter Your Last Name:</label>\n      <label>Enter Your Email:</label>\n      <label>Create a New Password:</label>\n    </fieldset>\n    <fieldset></fieldset>\n    <fieldset></fieldset>\n  </form>\n</body>\n</html>","head":null,"tail":null,"editableRegionBoundaries":[],"history":["index.html"]},{"fileKey":"stylescss","ext":"css","name":"styles","contents":"body {\n  width: 100%;\n  height: 100vh;\n  margin: 0;\n  background-color: #1b1b32;\n  color: #f5f6f7;\n}\n\n","head":null,"tail":null,"editableRegionBoundaries":[8,10],"history":["styles.css"]}],"saveSubmissionToDB":null,"tests":[{"text":"<p>Treba ti da koristiš alat <code>label</code>.</p>","testString":"assert.exists(new __helpers.CSSHelp(document).getStyle('label'));"},{"text":"<p>Treba da dodaš atribut <code>display</code> sa vrednošću <code>block</code>.</p>","testString":"assert.equal(new __helpers.CSSHelp(document).getStyle('label')?.display, 'block');"},{"text":"<p>Treba dodati svojstvo <code>margin</code> sa vrednošću <code>0.5rem 0</code>.</p>","testString":"assert.equal(new __helpers.CSSHelp(document).getStyle('label')?.margin, '0.5rem 0px');"}]}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/responsive-web-design-v9/#workshop-registration-form","dashedName":"step-11","certification":"responsive-web-design-v9","disableLoopProtectTests":false,"disableLoopProtectPreview":false,"superBlock":"responsive-web-design-v9","chapter":"css","module":"styling-forms","block":"workshop-registration-form","isFirstStep":false,"template":null,"required":[],"isLastChallengeInBlock":false,"nextChallengePath":"/learn/responsive-web-design-v9/workshop-registration-form/step-12","prevChallengePath":"/learn/responsive-web-design-v9/workshop-registration-form/step-10","id":"60f803d5241e6a0433a523a1","saveSubmissionToDB":null},"projectPreview":{"challengeData":{"challengeType":0,"challengeFiles":[{"name":"index","ext":"html","contents":"<!DOCTYPE html>\n<html lang=\"en\">\n  <head>\n    <meta charset=\"UTF-8\">\n    <title>Registration Form</title>\n    <link rel=\"stylesheet\" href=\"styles.css\" />\n  </head>\n  <body>\n    <h1>Registration Form</h1>\n    <p>Please fill out this form with the required information</p>\n    <form method=\"post\" action='https://register-demo.freecodecamp.org'>\n      <fieldset>\n        <label for=\"first-name\">Enter Your First Name: <input id=\"first-name\" type=\"text\" name=\"first-name\" required /></label>\n        <label for=\"last-name\">Enter Your Last Name: <input id=\"last-name\" type=\"text\" name=\"last-name\" required /></label>\n        <label for=\"email\">Enter Your Email: <input id=\"email\" type=\"email\" name=\"email\" required /></label>\n        <label for=\"new-password\">Create a New Password: <input id=\"new-password\" type=\"password\" name=\"password\" pattern=\"[a-z0-5]{8,}\" required /></label>\n      </fieldset>\n      <fieldset>\n        <legend>Account type (required)</legend>\n        <label for=\"personal-account\"><input id=\"personal-account\" type=\"radio\" name=\"account-type\" value=\"personal\" class=\"inline\" checked /> Personal</label>\n        <label for=\"business-account\"><input id=\"business-account\" type=\"radio\" name=\"account-type\" value=\"business\" class=\"inline\" /> Business</label>\n      </fieldset>\n      <fieldset>\n        <label for=\"profile-picture\">Upload a profile picture: <input id=\"profile-picture\" type=\"file\" name=\"file\" /></label>\n        <label for=\"age\">Input your age (years): <input id=\"age\" type=\"number\" name=\"age\" min=\"13\" max=\"120\" /></label>\n        <label for=\"referrer\">How did you hear about us?\n          <select id=\"referrer\" name=\"referrer\">\n            <option value=\"\">(select one)</option>\n            <option value=\"1\">freeCodeCamp News</option>\n            <option value=\"2\">freeCodeCamp YouTube Channel</option>\n            <option value=\"3\">freeCodeCamp Forum</option>\n            <option value=\"4\">Other</option>\n          </select>\n        </label>\n        <label for=\"bio\">Provide a bio:\n          <textarea id=\"bio\" name=\"bio\" rows=\"3\" cols=\"30\" placeholder=\"I like coding on the beach...\"></textarea>\n        </label>\n      </fieldset>\n      <a href=\"https://www.freecodecamp.org/news/terms-of-service\">Read our terms and conditions</a>\n      <label for=\"terms-and-conditions\">\n        <input class=\"inline\" name=\"terms\" id=\"terms-and-conditions\" type=\"checkbox\" required />\n        I accept the terms and conditions\n      </label>\n      <input type=\"submit\" value=\"Submit\" />\n    </form>\n  </body>\n</html>","history":["index.html"],"fileKey":"indexhtml"},{"name":"styles","ext":"css","contents":"body {\n  width: 100%;\n  height: 100vh;\n  margin: 0;\n  background-color: #1b1b32;\n  color: #f5f6f7;\n  font-family: Tahoma;\n  font-size: 16px;\n}\n\nh1, p {\n  margin: 1em auto;\n  text-align: center;\n}\n\nform {\n  width: 60vw;\n  max-width: 500px;\n  min-width: 300px;\n  margin: 0 auto;\n  padding-bottom: 2em;\n}\n\nfieldset {\n  border: none;\n  padding: 2rem 0;\n  border-bottom: 3px solid #3b3b4f;\n}\n\nfieldset:last-of-type {\n  border-bottom: none;\n}\n\nlabel {\n  display: block;\n  margin: 0.5rem 0;\n}\n\ninput,\ntextarea,\nselect {\n  margin: 10px 0 0 0;\n  width: 100%;\n  min-height: 2em;\n}\n\ninput, textarea {\n  background-color: #0a0a23;\n  border: 1px solid #0a0a23;\n  color: #ffffff;\n}\n\n.inline {\n  width: unset;\n  margin: 0 0.5em 0 0;\n  vertical-align: middle;\n}\n\ninput[type=\"submit\"] {\n  display: block;\n  width: 60%;\n  margin: 1em auto;\n  height: 2em;\n  font-size: 1.1rem;\n  background-color: #3b3b4f;\n  border-color: white;\n  min-width: 300px;\n}\n\ninput[type=\"file\"] {\n  padding: 1px 2px;\n}\n\na {\n  color: #dfdfe2;\n}\n","history":["styles.css"],"fileKey":"stylescss"}]}},"id":"/learn/responsive-web-design-v9/workshop-registration-form/step-11"}},"staticQueryHashes":["3858520367"],"slicesMap":{}}