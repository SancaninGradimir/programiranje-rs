      "text": "<p>Treba da uklonite funkciju <code>background-color</code> koja je objavljena kao komentar.</p>",
      "testString": "assert.notMatch(code, /\\/\\*\\s*background-color:\\s*burlywood;?\\s*\\*\\//i);"
