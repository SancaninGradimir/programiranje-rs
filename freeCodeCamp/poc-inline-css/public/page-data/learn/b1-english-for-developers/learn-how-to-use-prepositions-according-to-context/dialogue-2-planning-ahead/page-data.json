{"componentChunkName":"component---src-templates-challenges-generic-show-tsx","path":"/learn/b1-english-for-developers/learn-how-to-use-prepositions-according-to-context/dialogue-2-planning-ahead","result":{"data":{"challengeNode":{"challenge":{"assignments":["<p>Gledaj video.</p>"],"bilibiliIds":null,"block":"learn-how-to-use-prepositions-according-to-context","challengeType":21,"description":"<section id=\"description\">\n<p>Pogledajte video dole/ispod kako biste razumeli kontekst predstojećih lekcija.</p>\n</section>","nodules":null,"explanation":null,"helpCategory":"English","instructions":"","fields":{"slug":"/learn/b1-english-for-developers/learn-how-to-use-prepositions-according-to-context/dialogue-2-planning-ahead"},"questions":[],"scene":{"setup":{"background":"company2-boardroom.png","characters":[{"character":"Maria","position":{"x":-25,"y":0,"z":1},"opacity":null},{"character":"David","position":{"x":125,"y":0,"z":1},"opacity":null}],"audio":{"filename":"B1_22-2.mp3","startTime":1,"startTimestamp":null,"finishTimestamp":null},"alwaysShowDialogue":true},"commands":[{"background":null,"character":"Maria","position":{"x":25,"y":0,"z":1},"opacity":null,"startTime":0,"finishTime":null,"dialogue":null},{"background":null,"character":"David","position":{"x":70,"y":0,"z":1},"opacity":null,"startTime":0.5,"finishTime":null,"dialogue":null},{"background":null,"character":"Maria","position":null,"opacity":null,"startTime":1,"finishTime":3.42,"dialogue":{"text":"Good morning, David. Thank you for meeting with me today.","align":"left"}},{"background":null,"character":"Maria","position":null,"opacity":null,"startTime":3.72,"finishTime":9.06,"dialogue":{"text":"I'd like to go over the resource needs for the next phase of our app development to make sure everything lined up on time.","align":"left"}},{"background":null,"character":"David","position":null,"opacity":null,"startTime":9.78,"finishTime":13.68,"dialogue":{"text":"Excellent. That sounds good. How many developers do we currently have working on this?","align":"right"}},{"background":null,"character":"Maria","position":null,"opacity":null,"startTime":14,"finishTime":19.62,"dialogue":{"text":"We have 10 developers on the team at the moment. By next month, we'll need at least five more to handle the back-end integration.","align":"left"}},{"background":null,"character":"David","position":null,"opacity":null,"startTime":20.36,"finishTime":25.6,"dialogue":{"text":"All right. Do we have enough designers for the new user interface changes scheduled for the end of the quarter?","align":"right"}},{"background":null,"character":"Maria","position":null,"opacity":null,"startTime":26.06,"finishTime":31.94,"dialogue":{"text":"We currently have three designers. For the tasks planned, I think adding two more by the start of the quarter will be sufficient.","align":"left"}},{"background":null,"character":"David","position":null,"opacity":null,"startTime":32.32,"finishTime":36,"dialogue":{"text":"What about testing? The last update brought up some unexpected challenges.","align":"right"}},{"background":null,"character":"Maria","position":null,"opacity":null,"startTime":36.64,"finishTime":39.24,"dialogue":{"text":"Right. We're planning on bringing in additional testers.","align":"left"}},{"background":null,"character":"Maria","position":null,"opacity":null,"startTime":39.4,"finishTime":44.64,"dialogue":{"text":"I suggest we double our testing team from four to eight around mid-quarter to ensure thorough coverage.","align":"left"}},{"background":null,"character":"David","position":null,"opacity":null,"startTime":45.08,"finishTime":47.56,"dialogue":{"text":"That makes sense. How about project management?","align":"right"}},{"background":null,"character":"Maria","position":null,"opacity":null,"startTime":48.1,"finishTime":54,"dialogue":{"text":"Our project manager, Bob, is on vacation in July, so we'll need short-term support during that period.","align":"left"}},{"background":null,"character":"Maria","position":null,"opacity":null,"startTime":54.3,"finishTime":59.78,"dialogue":{"text":"I'm arranging for Sarah to step in during the second week of July until Bob returns at the end of the month.","align":"left"}},{"background":null,"character":"David","position":null,"opacity":null,"startTime":60.06,"finishTime":64.02,"dialogue":{"text":"Sounds like a plan. Can we review the budget for these additional resources?","align":"right"}},{"background":null,"character":"Maria","position":null,"opacity":null,"startTime":64.7,"finishTime":72.02,"dialogue":{"text":"Absolutely. I'll send you a detailed breakdown by tomorrow. It will include the costs for the extra personnel and any additional tools we might need.","align":"left"}},{"background":null,"character":"David","position":null,"opacity":null,"startTime":72.28,"finishTime":78.72,"dialogue":{"text":"Perfect, Maria. Let's make sure everything is in place so we can meet our project milestones without any delays.","align":"right"}},{"background":null,"character":"Maria","position":null,"opacity":null,"startTime":79.16,"finishTime":82.6,"dialogue":{"text":"Definitely. I'll keep everything on track and update you weekly on our progress.","align":"left"}},{"background":null,"character":"David","position":{"x":125,"y":0,"z":1},"opacity":null,"startTime":83.1,"finishTime":null,"dialogue":null},{"background":null,"character":"Maria","position":{"x":-25,"y":0,"z":1},"opacity":null,"startTime":83.6,"finishTime":null,"dialogue":null}]},"superBlock":"b1-english-for-developers","tests":[],"title":"Dialog 2: Planiranje unapred","transcript":null,"translationPending":false,"videoId":null,"videoLocaleIds":null}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/b1-english-for-developers/#learn-how-to-use-prepositions-according-to-context","dashedName":"dialogue-2-planning-ahead","certification":"b1-english-for-developers","disableLoopProtectTests":false,"disableLoopProtectPreview":false,"superBlock":"b1-english-for-deve