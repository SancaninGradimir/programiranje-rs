      "text": "<p>Elementi vašeg <code>span</code> treba da imaju klasu <code>mr-2</code>.</p>",
      "testString": "const spanEls = document.querySelectorAll(\"ul li span\")\nconst familyPlanSpans = [spanEls[5], spanEls[6], spanEls[7], spanEls[8]]\n\nfamilyPlanSpans.forEach(span => {\n  assert.isTrue(span.classList.contains(\"mr-2\"))\n})"
