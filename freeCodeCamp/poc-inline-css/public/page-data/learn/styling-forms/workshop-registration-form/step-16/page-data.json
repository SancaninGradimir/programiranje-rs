{"componentChunkName":"component---src-templates-challenges-classic-show-tsx","path":"/learn/styling-forms/workshop-registration-form/step-16","result":{"data":{"challengeNode":{"challenge":{"block":"workshop-registration-form","demoType":null,"title":"Korak 16","description":"<section id=\"description\">\n<p>Trenutno bi trebalo da budete u mogućnosti za slanje formulara. Međutim, možete primetiti da se ne dešava mnogo toga.</p>\n<p>Kako bi se forma učinila interaktivnijom, dodajte atribut elementa <code>required</code> za elemente <code>input</code> u prvom <code>fieldset</code>.</p>\n<p>Sada, ako pokušate da pošaljete formular bez popunjavanja neophodnih polja, videćete poruku o grešci.</p>\n</section>","id":"60f81616cff80508badf9ad5","hasEditableBoundaries":true,"instructions":"","notes":null,"challengeType":0,"helpCategory":"HTML-CSS","videoUrl":null,"superBlock":"styling-forms","translationPending":false,"forumTopicId":null,"hooks":null,"fields":{"slug":"/learn/styling-forms/workshop-registration-form/step-16"},"required":[],"usesMultifileEditor":true,"challengeFiles":[{"fileKey":"indexhtml","ext":"html","name":"index","contents":"<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <title>Registration Form</title>\n  <link rel=\"stylesheet\" href=\"styles.css\" />\n</head>\n<body>\n  <h1>Registration Form</h1>\n  <p>Please fill out this form with the required information</p>\n  <form method=\"post\" action='https://register-demo.freecodecamp.org'>\n    <fieldset>\n      <label for=\"first-name\">Enter Your First Name: <input id=\"first-name\" type=\"text\" /></label>\n      <label for=\"last-name\">Enter Your Last Name: <input id=\"last-name\" type=\"text\" /></label>\n      <label for=\"email\">Enter Your Email: <input id=\"email\" type=\"email\" /></label>\n      <label for=\"new-password\">Create a New Password: <input id=\"new-password\" type=\"password\" /></label>\n    </fieldset>\n    <fieldset></fieldset>\n    <fieldset></fieldset>\n    <input type=\"submit\" value=\"Submit\" />\n  </form>\n</body>\n</html>","head":null,"tail":null,"editableRegionBoundaries":[12,17],"history":["index.html"]},{"fileKey":"stylescss","ext":"css","name":"styles","contents":"body {\n  width: 100%;\n  height: 100vh;\n  margin: 0;\n  background-color: #1b1b32;\n  color: #f5f6f7;\n}\n\nlabel {\n  display: block;\n  margin: 0.5rem 0;\n}\n","head":null,"tail":null,"editableRegionBoundaries":[],"history":["styles.css"]}],"saveSubmissionToDB":null,"tests":[{"text":"<p>Treba da mu daš prvi element od <code>input</code> svojstvo elementa <code>required</code>.</p>","testString":"assert.isTrue(document.querySelector('input')?.required);"},{"text":"<p>Trebalo bi mu dati drugi atribut za <code>input</code>, atribut <code>required</code>.</p>","testString":"assert.isTrue(document.querySelectorAll('input')?.[1]?.required);"},{"text":"<p>Trebalo bi mu dati treći atribut <code>input</code> svojstvo atributa <code>required</code>.</p>","testString":"assert.isTrue(document.querySelectorAll('input')?.[2]?.required);"},{"text":"<p>Trebalo bi mu dodeliti četvrti element od <code>input</code> svojstvo elementa <code>required</code>.</p>","testString":"assert.isTrue(document.querySelectorAll('input')?.[3]?.required);"},{"text":"<p>Trebalo bi dati <code>input</code> koji je tipa <code>submit</code> svojstvo komponente <code>required</code>.</p>","testString":"assert.isFalse(document.querySelector('input[type=\"submit\"]')?.required);"}]}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/styling-forms/#workshop-registration-form","dashedName":"step-16","certification":"styling-forms","disableLoopProtectTests":false,"disableLoopProtectPreview":false,"superBlock":"styling-forms","chapter":null,"module":null,"block":"workshop-registration-form","isFirstStep":false,"template":null,"required":[],"isLastChallengeInBlock":false,"nextChallengePath":"/learn/styling-forms/workshop-registration-form/step-17","prevChallengePath":"/learn/styling-forms/workshop-registration-form/step-15","id":"60f81616cff80508badf9ad5","saveSubmissionToDB":null},"projectPreview":{"challengeData":{"challengeType":0,"challengeFiles":[{"name":"index","ext":"html","contents":"<!DOCTYPE html>\n<html lang=\"en\">\n  <head>\n    <meta charset=\"UTF-8\">\n    <title>Registration Form</title>\n    <link rel=\"stylesheet\" href=\"styles.css\" />\n  </head>\n  <body>\n    <h1>Registration Form</h1>\n    <p>Please fill out this form with the required information</p>\n    <form method=\"post\" action='https://register-demo.freecodecamp.org'>\n      <fieldset>\n        <label for=\"first-name\">Enter Your First Name: <input id=\"first-name\" type=\"text\" name=\"first-name\" required /></label>\n        <label for=\"last-name\">Enter Your Last Name: <input id=\"last-name\" type=\"text\" name=\"last-name\" required /></label>\n        <label for=\"email\">Enter Your Email: <input id=\"email\" type=\"email\" name=\"email\" required /></label>\n        <label for=\"new-password\">Create a New Password: <input id=\"new-password\" type=\"password\" name=\"password\" pattern=\"[a-z0-5]{8,}\" required /></label>\n      </fieldset>\n      <fieldset>\n        <legend>Account type (required)</legend>\n        <label for=\"personal-account\"><input id=\"personal-account\" type=\"radio\" name=\"account-type\" value=\"personal\" class=\"inline\" checked /> Personal</label>\n        <label for=\"business-account\"><input id=\"business-account\" type=\"radio\" name=\"account-type\" value=\"business\" class=\"inline\" /> Business</label>\n      </fieldset>\n      <fieldset>\n        <label for=\"profile-picture\">Upload a profile picture: <input id=\"profile-picture\" type=\"file\" name=\"file\" /></label>\n        <label for=\"age\">Input your age (years): <input id=\"age\" type=\"number\" name=\"age\" min=\"13\" max=\"120\" /></label>\n        <label for=\"referrer\">How did you hear about us?\n          <select id=\"referrer\" name=\"referrer\">\n            <option value=\"\">(select one)</option>\n            <option value=\"1\">freeCodeCamp News</option>\n            <option value=\"2\">freeCodeCamp YouTube Channel</option>\n            <option value=\"3\">freeCodeCamp Forum</option>\n            <option value=\"4\">Other</option>\n          </select>\n        </label>\n        <label for=\"bio\">Provide a bio:\n          <textarea id=\"bio\" name=\"bio\" rows=\"3\" cols=\"30\" placeholder=\"I like coding on the beach...\"></textarea>\n        </label>\n      </fieldset>\n      <a href=\"https://www.freecodecamp.org/news/terms-of-service\">Read our terms and conditions</a>\n      <label for=\"terms-and-conditions\">\n        <input class=\"inline\" name=\"terms\" id=\"terms-and-conditions\" type=\"checkbox\" required />\n        I accept the terms and conditions\n      </label>\n      <input type=\"submit\" value=\"Submit\" />\n    </form>\n  </body>\n</html>","history":["index.html"],"fileKey":"indexhtml"},{"name":"styles","ext":"css","contents":"body {\n  width: 100%;\n  height: 100vh;\n  margin: 0;\n  background-color: #1b1b32;\n  color: #f5f6f7;\n  font-family: Tahoma;\n  font-size: 16px;\n}\n\nh1, p {\n  margin: 1em auto;\n  text-align: center;\n}\n\nform {\n  width: 60vw;\n  max-width: 500px;\n  min-width: 300px;\n  margin: 0 auto;\n  padding-bottom: 2em;\n}\n\nfieldset {\n  border: none;\n  padding: 2rem 0;\n  border-bottom: 3px solid #3b3b4f;\n}\n\nfieldset:last-of-type {\n  border-bottom: none;\n}\n\nlabel {\n  display: block;\n  margin: 0.5rem 0;\n}\n\ninput,\ntextarea,\nselect {\n  margin: 10px 0 0 0;\n  width: 100%;\n  min-height: 2em;\n}\n\ninput, textarea {\n  background-color: #0a0a23;\n  border: 1px solid #0a0a23;\n  color: #ffffff;\n}\n\n.inline {\n  width: unset;\n  margin: 0 0.5em 0 0;\n  vertical-align: middle;\n}\n\ninput[type=\"submit\"] {\n  display: block;\n  width: 60%;\n  margin: 1em auto;\n  height: 2em;\n  font-size: 1.1rem;\n  background-color: #3b3b4f;\n  border-color: white;\n  min-width: 300px;\n}\n\ninput[type=\"file\"] {\n  padding: 1px 2px;\n}\n\na {\n  color: #dfdfe2;\n}\n","history":["styles.css"],"fileKey":"stylescss"}]}},"id":"/learn/styling-forms/workshop-registration-form/step-16"}},"staticQueryHashes":["3858520367"],"slicesMap":{}}