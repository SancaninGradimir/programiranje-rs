{"componentChunkName":"component---src-templates-challenges-generic-show-tsx","path":"/learn/b1-english-for-developers/learn-how-to-clarify-misunderstandings/dialogue-1-guessing-the-meaning","result":{"data":{"challengeNode":{"challenge":{"assignments":["<p>Gledaj video.</p>"],"bilibiliIds":null,"block":"learn-how-to-clarify-misunderstandings","challengeType":21,"description":"<section id=\"description\">\n<p>Pogledajte video ispod da biste razumeli kontekst sledećih lekcija.</p>\n</section>","nodules":null,"explanation":null,"helpCategory":"English","instructions":"","fields":{"slug":"/learn/b1-english-for-developers/learn-how-to-clarify-misunderstandings/dialogue-1-guessing-the-meaning"},"questions":[],"scene":{"setup":{"background":"company2-center.png","characters":[{"character":"Mark","position":{"x":-25,"y":0,"z":1},"opacity":null},{"character":"Sophie","position":{"x":125,"y":0,"z":1},"opacity":null}],"audio":{"filename":"B1_16-1.mp3","startTime":1,"startTimestamp":null,"finishTimestamp":null},"alwaysShowDialogue":true},"commands":[{"background":null,"character":"Mark","position":{"x":25,"y":0,"z":1},"opacity":null,"startTime":0,"finishTime":null,"dialogue":null},{"background":null,"character":"Sophie","position":{"x":70,"y":0,"z":1},"opacity":null,"startTime":0.5,"finishTime":null,"dialogue":null},{"background":null,"character":"Mark","position":null,"opacity":null,"startTime":1,"finishTime":4.24,"dialogue":{"text":"Hey Sophie. Thanks for letting me sit in on the code review.","align":"left"}},{"background":null,"character":"Mark","position":null,"opacity":null,"startTime":4.54,"finishTime":8.08,"dialogue":{"text":"I heard some terms that were new to me. Can I ask you about a few of them?","align":"left"}},{"background":null,"character":"Sophie","position":null,"opacity":null,"startTime":8.44,"finishTime":9.84,"dialogue":{"text":"Sure Mark. What's on your mind?","align":"right"}},{"background":null,"character":"Mark","position":null,"opacity":null,"startTime":10.34,"finishTime":12.62,"dialogue":{"text":"Well, you mentioned polymorphism.","align":"left"}},{"background":null,"character":"Mark","position":null,"opacity":null,"startTime":13.1,"finishTime":17.6,"dialogue":{"text":"I think it means a code structure that can have multiple shapes or forms. Is that right?","align":"left"}},{"background":null,"character":"Sophie","position":null,"opacity":null,"startTime":18.2,"finishTime":24.1,"dialogue":{"text":"Kind of. Polymorphism refers to a function or object that can behave differently depending on the context.","align":"right"}},{"background":null,"character":"Sophie","position":null,"opacity":null,"startTime":24.52,"finishTime":28.86,"dialogue":{"text":"It's not just about having different shapes, but about being flexible in how it operates.","align":"right"}},{"background":null,"character":"Mark","position":null,"opacity":null,"startTime":28.86,"finishTime":34.26,"dialogue":{"text":"Oh, okay. Thanks for explaining. I also heard encapsulation.","align":"left"}},{"background":null,"character":"Mark","position":null,"opacity":null,"startTime":34.56,"finishTime":38.42,"dialogue":{"text":"Does that mean breaking code into smaller parts like encapsulating it?","align":"left"}},{"background":null,"character":"Sophie","position":null,"opacity":null,"startTime":38.88,"finishTime":44.36,"dialogue":{"text":"Not quite. Encapsulation is about keeping some details hidden to make the code easier to work with.","align":"right"}},{"background":null,"character":"Sophie","position":null,"opacity":null,"startTime":44.7,"finishTime":47.86,"dialogue":{"text":"Think of it as wrapping code to limit what other parts can see.","align":"right"}},{"background":null,"character":"Mark","position":null,"opacity":null,"startTime":48.3,"finishTime":53.88,"dialogue":{"text":"Got it. And what about inheritance? Does this mean passing down code from one project to another?","align":"left"}},{"background":null,"character":"Sophie","position":null,"opacity":null,"startTime":53.88,"finishTime":59.96,"dialogue":{"text":"Not exactly. Inheritance is when one class inherits properties and methods from another class,","align":"right"}},{"background":null,"character":"Sophie","position":null,"opacity":null,"startTime":60.04,"finishTime":63.38,"dialogue":{"text":"allowing for code reuse and extending functionality within a project.","align":"right"}},{"background":null,"character":"Mark","position":null,"opacity":null,"startTime":64.1,"finishTime":70.58,"dialogue":{"text":"Thanks for clarifying. And abstraction. Does it mean simplifying complex systems by hiding unnecessary details?","align":"left"}},{"background":null,"character":"Sophie","position":null,"opacity":null,"startTime":71.2,"finishTime":74.26,"dialogue":{"text":"Yes, that's correct. Abstraction is about reducing complexity","align":"right"}},{"background":null,"character":"Sophie","position":null,"opacity":null,"startTime":74.26,"finishTime":77,"dialogue":{"text":"by showing only what's necessary, keeping the details hidden.","align":"right"}},{"background":null,"character":"Mark","position":null,"opacity":null,"startTime":77.44,"finishTime":81.14,"dialogue":{"text":"At least I got one right. I think I'm starting to understand these terms better.","align":"left"}},{"background":null,"character":"Mark","position":null,"opacity":null,"startTime":81.36,"finishTime":82.82,"dialogue":{"text":"Thanks for the explanation, Sophie.","align":"left"}},{"background":null,"character":"Sophie","position":{"x":125,"y":0,"z":1},"opacity":null,"startTime":83.32,"finishTime":null,"dialogue":null},{"background":null,"character":"Mark","position":{"x":-25,"y":0,"z":1},"opacity":null,"startTime":83.82,"finishTime":null,"dialogue":null}]},"superBlock":"b1-english-for-developers","tests":[],"title":"Dialog 1: Pogađanje značenja","transcript":null,"translationPending":false,"videoId":null,"videoLocaleIds":null}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/b1-english-for-developers/#learn-how-to-clarify-misunderstandings","dashedName":"dialogue-1-guessing-the-meaning","certification":"b1-english-for-developers","disableLoopProtectTests":false,"disableLoopProtectPreview":false,"superBlock":"b1-english-for-developers","chapter":null,"module":null,"block":"learn-how-to-clarify-misunderstandings","isFirstStep":true,"template":null,"required":[],"isLastChallengeInBlock":false,"nextChallengePath":"/learn/b1-english-for-developers/learn-how-to-clarify-misunderstandings/task-1","prevChallengePath":"/learn/b1-english-for-developers/en-b1-quiz-manage-conversations/en-b1-quiz-manage-conversations","id":"67e0f2aee45dc6994a0c2f06","saveSubmissionToDB":null},"projectPreview":{"challengeData":{"challengeType":19,"challengeFiles":[]}},"id":"/learn/b1-english-for-developers/learn-how-to-clarify-misunderstandings/dialogue-1-guessing-the-meaning"}},"staticQueryHashes":["3858520367"],"slicesMap":{}}