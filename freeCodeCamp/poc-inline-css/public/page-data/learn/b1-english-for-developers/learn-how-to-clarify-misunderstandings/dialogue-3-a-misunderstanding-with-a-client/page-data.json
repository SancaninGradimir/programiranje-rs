{"componentChunkName":"component---src-templates-challenges-generic-show-tsx","path":"/learn/b1-english-for-developers/learn-how-to-clarify-misunderstandings/dialogue-3-a-misunderstanding-with-a-client","result":{"data":{"challengeNode":{"challenge":{"assignments":["<p>Gledaj video.</p>"],"bilibiliIds":null,"block":"learn-how-to-clarify-misunderstandings","challengeType":21,"description":"<section id=\"description\">\n<p>Pogledajte video ispod da biste razumeli kontekst sledećih lekcija.</p>\n</section>","nodules":null,"explanation":null,"helpCategory":"English","instructions":"","fields":{"slug":"/learn/b1-english-for-developers/learn-how-to-clarify-misunderstandings/dialogue-3-a-misunderstanding-with-a-client"},"questions":[],"scene":{"setup":{"background":"company1-boardroom.png","characters":[{"character":"Jessica","position":{"x":-25,"y":0,"z":1},"opacity":null},{"character":"David","position":{"x":125,"y":0,"z":1},"opacity":null}],"audio":{"filename":"B1_16-3.mp3","startTime":1,"startTimestamp":null,"finishTimestamp":null},"alwaysShowDialogue":true},"commands":[{"background":null,"character":"Jessica","position":{"x":25,"y":0,"z":1},"opacity":null,"startTime":0,"finishTime":null,"dialogue":null},{"background":null,"character":"David","position":{"x":70,"y":0,"z":1},"opacity":null,"startTime":0.5,"finishTime":null,"dialogue":null},{"background":null,"character":"Jessica","position":null,"opacity":null,"startTime":1,"finishTime":5.56,"dialogue":{"text":"Hi David, I wanted to check in about the latest mobile app update for the finance project.","align":"left"}},{"background":null,"character":"Jessica","position":null,"opacity":null,"startTime":5.98,"finishTime":9.58,"dialogue":{"text":"There seems to be some misunderstanding about the testing phase. Can we go over it?","align":"right"}},{"background":null,"character":"David","position":null,"opacity":null,"startTime":10.24,"finishTime":13.62,"dialogue":{"text":"Sure, Jessica. I thought the testing was complete, but when I looked at the report,","align":"left"}},{"background":null,"character":"David","position":null,"opacity":null,"startTime":14,"finishTime":16.56,"dialogue":{"text":"it said there were still some issues. What's the story?","align":"left"}},{"background":null,"character":"Jessica","position":null,"opacity":null,"startTime":17.2,"finishTime":22.54,"dialogue":{"text":"I'm sorry for the confusion. We've completed the main testing, but we found some minor bugs in the user interface.","align":"right"}},{"background":null,"character":"Jessica","position":null,"opacity":null,"startTime":23.06,"finishTime":25.96,"dialogue":{"text":"We're fixing them, but I get why the report might have been unclear.","align":"right"}},{"background":null,"character":"David","position":null,"opacity":null,"startTime":26.92,"finishTime":32.1,"dialogue":{"text":"Does that mean the app's launch will be delayed? I thought we were on track to release by the end of the week.","align":"left"}},{"background":null,"character":"Jessica","position":null,"opacity":null,"startTime":33.18,"finishTime":36.72,"dialogue":{"text":"Not necessarily. We're handling the bugs, but it shouldn't affect the launch schedule.","align":"right"}},{"background":null,"character":"Jessica","position":null,"opacity":null,"startTime":37.14,"finishTime":42.6,"dialogue":{"text":"Just to clarify, the core features are working fine, but there are a few glitches we're ironing out. Does that help?","align":"right"}},{"background":null,"character":"David","position":null,"opacity":null,"startTime":42.94,"finishTime":46.12,"dialogue":{"text":"That makes sense. I was worried we'd have to push back the launch date.","align":"left"}},{"background":null,"character":"Jessica","position":null,"opacity":null,"startTime":46.56,"finishTime":49.16,"dialogue":{"text":"No, we're still on schedule. Sorry for the miscommunication.","align":"right"}},{"background":null,"character":"Jessica","position":null,"opacity":null,"startTime":49.6,"finishTime":54.24,"dialogue":{"text":"If anything changes, I'll let you know right away. Is there anything else about the app you want to discuss?","align":"right"}},{"background":null,"character":"David","position":null,"opacity":null,"startTime":54.86,"finishTime":58.26,"dialogue":{"text":"Yeah, I noticed the budget tracking feature wasn't in the latest build.","align":"left"}},{"background":null,"character":"David","position":null,"opacity":null,"startTime":58.26,"finishTime":61.4,"dialogue":{"text":"Was that supposed to be in this update, or is it coming later?","align":"left"}},{"background":null,"character":"Jessica","position":null,"opacity":null,"startTime":61.98,"finishTime":66.76,"dialogue":{"text":"Oh, that might be a mix-up. The budget tracking feature is planned for the next update, not this one.","align":"right"}},{"background":null,"character":"Jessica","position":null,"opacity":null,"startTime":67.12,"finishTime":68.56,"dialogue":{"text":"Let me double-check and get back to you.","align":"right"}},{"background":null,"character":"David","position":null,"opacity":null,"startTime":69.08,"finishTime":72.84,"dialogue":{"text":"Thanks, Jessica. I'd appreciate it. I just want to make sure we're on the same page.","align":"left"}},{"background":null,"character":"Jessica","position":null,"opacity":null,"startTime":73.38,"finishTime":77.92,"dialogue":{"text":"Of course. I'll send you an updated project timeline later today so we're clear on what's coming up.","align":"right"}},{"background":null,"character":"Jessica","position":null,"opacity":null,"startTime":78,"finishTime":79.18,"dialogue":{"text":"Thanks for pointing that out.","align":"right"}},{"background":null,"character":"David","position":null,"opacity":null,"startTime":79.28,"finishTime":80.6,"dialogue":{"text":"No problem. Talk to you soon.","align":"left"}},{"background":null,"character":"David","position":{"x":125,"y":0,"z":1},"opacity":null,"startTime":81.1,"finishTime":null,"dialogue":null},{"background":null,"character":"Jessica","position":{"x":-25,"y":0,"z":1},"opacity":null,"startTime":81.6,"finishTime":null,"dialogue":null}]},"superBlock":"b1-english-for-developers","tests":[],"title":"Dijalog 3: Nesporazum sa klijentom","transcript":null,"translationPending":false,"videoId":null,"videoLocaleIds":null}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/b1-english-for-developers/#learn-how-to-clarify-misunderstandings","dashedName":"dialogue-3-a-misunderstanding-with-a-client","certification":"b1-english-for-developers","disableLoopProtectTests":false,"disableLoopProtectPreview":false,"superBlock":"b1-english-for-developers","chapter":null,"module":null,"block":"learn-how-to-clarify-misunderstandings","isFirstStep":false,"template":null,"required":[],"isLastChallengeInBlock":false,"nextChallengePath":"/learn/b1-english-for-developers/learn-how-to-clarify-misunderstandings/task-97","prevChallengePath":"/learn/b1-english-for-developers/learn-how-to-clarify-misunderstandings/task-96","id":"67f1d02eb2aec2500dab5ae2","saveSubmissionToDB":null},"projectPreview":{"challengeData":{"challengeType":19,"challengeFiles":[]}},"id":"/learn/b1-english-for-developers/learn-how-to-clarify-misunderstandings/dialogue-3-a-misunderstanding-with-a-client"}},"staticQueryHashes":["3858520367"],"slicesMap":{}}