  "tests": [
    {
      "text": "<p><code>repeatStringNumTimes(\"*\", 3)</code> treba da vrati string <code>***</code>.</p>",
      "testString": "assert.strictEqual(repeatStringNumTimes('*', 3), '***');"
    },
    {
      "text": "<p><code>repeatStringNumTimes(\"abc\", 3)</code> treba da vrati string <code>abcabcabc</code>.</p>",
      "testString": "assert.strictEqual(repeatStringNumTimes('abc', 3), 'abcabcabc');"
    },
    {
      "text": "<p><code>repeatStringNumTimes(\"abc\", 4)</code> treba da vrati string <code>abcabcabcabc</code>.</p>",
      "testString": "assert.strictEqual(repeatStringNumTimes('abc', 4), 'abcabcabcabc');"
    },
    {
      "text": "<p><code>repeatStringNumTimes(\"abc\", 1)</code> treba da vrati string <code>abc</code>.</p>",
      "testString": "assert.strictEqual(repeatStringNumTimes('abc', 1), 'abc');"
    },
    {
      "text": "<p><code>repeatStringNumTimes(\"*\", 8)</code> treba da vrati string <code>********</code>.</p>",
      "testString": "assert.strictEqual(repeatStringNumTimes('*', 8), '********');"
    },
    {
      "text": "<p><code>repeatStringNumTimes(\"abc\", -2)</code> treba da vrati prazan string (<code>\"\"</code>).</p>",
      "testString": "assert.isEmpty(repeatStringNumTimes('abc', -2));"
    },
