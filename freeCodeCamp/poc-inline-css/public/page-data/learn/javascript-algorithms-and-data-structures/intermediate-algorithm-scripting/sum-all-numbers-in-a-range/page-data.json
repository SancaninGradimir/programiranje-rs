{"componentChunkName":"component---src-templates-challenges-classic-show-tsx","path":"/learn/javascript-algorithms-and-data-structures/intermediate-algorithm-scripting/sum-all-numbers-in-a-range","result":{"data":{"challengeNode":{"challenge":{"block":"intermediate-algorithm-scripting","demoType":null,"title":"Izračunaj zbir svih brojeva u koloni","description":"<section id=\"description\">\n<p>Dati ćemo vam red podataka sa dve brojeve. Vratite zbir tih dve broja zajedno sa zbirom svih brojeva koji su između njih. Manji broj neće uvek biti prvi.</p>\n<p>Na primer, <code>sumAll([4,1])</code> treba da vrati <code>10</code> jer je suma svih brojeva između 1 i 4 (uključujući sve) <code>10</code>.</p>\n</section>","id":"a3566b1109230028080c9345","hasEditableBoundaries":false,"instructions":"","notes":null,"challengeType":1,"helpCategory":"JavaScript","videoUrl":null,"superBlock":"javascript-algorithms-and-data-structures","translationPending":false,"forumTopicId":16083,"hooks":null,"fields":{"slug":"/learn/javascript-algorithms-and-data-structures/intermediate-algorithm-scripting/sum-all-numbers-in-a-range"},"required":[],"usesMultifileEditor":false,"challengeFiles":[{"fileKey":"scriptjs","ext":"js","name":"script","contents":"function sumAll(arr) {\r\n  return 1;\r\n}\r\n\r\nsumAll([1, 4]);","head":null,"tail":null,"editableRegionBoundaries":[],"history":["script.js"]}],"saveSubmissionToDB":null,"tests":[{"text":"<p><code>sumAll([1, 4])</code> Trebalo bi da vrati broj.</p>","testString":"assert(typeof sumAll([1, 4]) === 'number');"},{"text":"<p><code>sumAll([1, 4])</code> Trebalo bi da vrati 10.</p>","testString":"assert.deepEqual(sumAll([1, 4]), 10);"},{"text":"<p><code>sumAll([4, 1])</code> trebalo bi da vrati 10.</p>","testString":"assert.deepEqual(sumAll([4, 1]), 10);"},{"text":"<p><code>sumAll([5, 10])</code> trebalo bi da vrati 45.</p>","testString":"assert.deepEqual(sumAll([5, 10]), 45);"},{"text":"<p><code>sumAll([10, 5])</code> treba da vrati 45.</p>","testString":"assert.deepEqual(sumAll([10, 5]), 45);"}]}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/javascript-algorithms-and-data-structures/#intermediate-algorithm-scripting","dashedName":"sum-all-numbers-in-a-range","certification":"javascript-algorithms-and-data-structures","disableLoopProtectTests":false,"disableLoopProtectPreview":false,"superBlock":"javascript-algorithms-and-data-structures","chapter":null,"module":null,"block":"intermediate-algorithm-scripting","isFirstStep":true,"template":null,"required":[],"isLastChallengeInBlock":false,"nextChallengePath":"/learn/javascript-algorithms-and-data-structures/intermediate-algorithm-scripting/diff-two-arrays","prevChallengePath":"/learn/javascript-algorithms-and-data-structures/functional-programming/introduction-to-currying-and-partial-application","id":"a3566b1109230028080c9345","saveSubmissionToDB":null},"projectPreview":{"challengeData":{"challengeType":1,"challengeFiles":[{"name":"script","ext":"js","contents":"function orbitalPeriod(arr) {\n  const GM = 398600.4418;\n  const earthRadius = 6367.4447;\n  const TAU = 2 * Math.PI;\n  return arr.map(function(obj) {\n    return {\n      name: obj.name,\n      orbitalPeriod: Math.round(TAU * Math.sqrt(Math.pow(obj.avgAlt+earthRadius, 3)/GM))\n    };\n  });\n}","history":["script.js"],"fileKey":"scriptjs"}]}},"id":"/learn/javascript-algorithms-and-data-structures/intermediate-algorithm-scripting/sum-all-numbers-in-a-range"}},"staticQueryHashes":["3858520367"],"slicesMap":{}}