      "testString": "const audio = document.querySelector('audio:nth-of-type(2)');\nassert.strictEqual(audio?.getAttribute('src'),\n\"https://cdn.freecodecamp.org/curriculum/js-music-player/cruising-for-a-musing.mp3\");"
