{"componentChunkName":"component---src-templates-challenges-generic-show-tsx","path":"/learn/b1-english-for-developers/learn-how-to-use-reported-speech/dialogue-3-a-system-failure","result":{"data":{"challengeNode":{"challenge":{"assignments":["<p>Gledaj video.</p>"],"bilibiliIds":null,"block":"learn-how-to-use-reported-speech","challengeType":21,"description":"<section id=\"description\">\n<p>Pogledajte video dole/ispod kako biste razumeli kontekst predstojećih lekcija.</p>\n</section>","nodules":null,"explanation":null,"helpCategory":"English","instructions":"","fields":{"slug":"/learn/b1-english-for-developers/learn-how-to-use-reported-speech/dialogue-3-a-system-failure"},"questions":[],"scene":{"setup":{"background":"company2-center.png","characters":[{"character":"Lisa","position":{"x":-25,"y":0,"z":1},"opacity":null},{"character":"Mark","position":{"x":125,"y":0,"z":1},"opacity":null}],"audio":{"filename":"B1_21-3.mp3","startTime":1,"startTimestamp":null,"finishTimestamp":null},"alwaysShowDialogue":true},"commands":[{"background":null,"character":"Lisa","position":{"x":25,"y":0,"z":1},"opacity":null,"startTime":0,"finishTime":null,"dialogue":null},{"background":null,"character":"Mark","position":{"x":70,"y":0,"z":1},"opacity":null,"startTime":0.5,"finishTime":null,"dialogue":null},{"background":null,"character":"Lisa","position":null,"opacity":null,"startTime":1,"finishTime":4.42,"dialogue":{"text":"Hey Mark, I've been reviewing the logs from last week's database crash.","align":"left"}},{"background":null,"character":"Lisa","position":null,"opacity":null,"startTime":4.78,"finishTime":9.32,"dialogue":{"text":"It seems like if we had monitored the system load more closely, we could have prevented the overload.","align":"left"}},{"background":null,"character":"Mark","position":null,"opacity":null,"startTime":9.8,"finishTime":15.7,"dialogue":{"text":"That's true. The logs showed that the database was receiving an unusually high number of queries before it crashed.","align":"right"}},{"background":null,"character":"Mark","position":null,"opacity":null,"startTime":16.12,"finishTime":20.64,"dialogue":{"text":"Had we spread those queries more evenly, perhaps the system wouldn't have failed.","align":"right"}},{"background":null,"character":"Lisa","position":null,"opacity":null,"startTime":21.48,"finishTime":26.1,"dialogue":{"text":"Exactly. Also, I noticed we hadn't updated our database management software in a while.","align":"left"}},{"background":null,"character":"Lisa","position":null,"opacity":null,"startTime":26.22,"finishTime":31.16,"dialogue":{"text":"If the latest patches had been applied, they might have addressed some of the vulnerabilities that were exploited.","align":"left"}},{"background":null,"character":"Mark","position":null,"opacity":null,"startTime":31.5,"finishTime":37.04,"dialogue":{"text":"I was thinking the same thing. If only we had prioritized the update, we might not have faced this issue.","align":"right"}},{"background":null,"character":"Mark","position":null,"opacity":null,"startTime":37.26,"finishTime":40.18,"dialogue":{"text":"It's frustrating that we realized its importance too late.","align":"right"}},{"background":null,"character":"Lisa","position":null,"opacity":null,"startTime":40.5,"finishTime":45.78,"dialogue":{"text":"It's a tough lesson, but a valuable one. Going forward, how can we ensure this doesn't happen again?","align":"left"}},{"background":null,"character":"Lisa","position":null,"opacity":null,"startTime":45.9,"finishTime":47.86,"dialogue":{"text":"We need a more proactive maintenance strategy.","align":"left"}},{"background":null,"character":"Mark","position":{"x":125,"y":0,"z":1},"opacity":null,"startTime":48.36,"finishTime":null,"dialogue":null},{"background":null,"character":"Lisa","position":{"x":-25,"y":0,"z":1},"opacity":null,"startTime":48.86,"finishTime":null,"dialogue":null}]},"superBlock":"b1-english-for-developers","tests":[],"title":"Dialogue 3: Sistemski kvar","tran