{"componentChunkName":"component---src-templates-challenges-classic-show-tsx","path":"/learn/responsive-web-design-v9/workshop-parent-teacher-conference-form/step-14","result":{"data":{"challengeNode":{"challenge":{"block":"workshop-parent-teacher-conference-form","demoType":null,"title":"Korak 14","description":"<section id=\"description\">\n<p>Sada dodajte <code>label</code> element sa tekstom <code>Any specific concerns or topics you'd like to discuss?</code> i atributom <code>for</code> postavljenim na <code>notes</code>.</p>\n<p>Ispod ovog <code>label</code>, dodajte <code>textarea</code> element. Postavite njegov <code>id</code> na <code>notes</code>, <code>name</code> na <code>notes</code>, <code>rows</code> na <code>4</code>, i <code>cols</code> na <code>50</code>.</p>\n</section>","id":"68eaa668d4d9fbe529a0e16b","hasEditableBoundaries":true,"instructions":"","notes":null,"challengeType":0,"helpCategory":"HTML-CSS","videoUrl":null,"superBlock":"responsive-web-design-v9","translationPending":false,"forumTopicId":null,"hooks":null,"fields":{"slug":"/learn/responsive-web-design-v9/workshop-parent-teacher-conference-form/step-14"},"required":[],"usesMultifileEditor":true,"challengeFiles":[{"fileKey":"indexhtml","ext":"html","name":"index","contents":"<!DOCTYPE html>\n<html lang=\"en\">\n\n<head>\n  <meta charset=\"utf-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Parent Teacher Conference Form</title>\n  <link rel=\"stylesheet\" href=\"./styles.css\" />\n</head>\n\n<body>\n  <main class=\"container\">\n    <h1 class=\"title center\">Parent Teacher Conference Form</h1>\n    <p class=\"description center\">Please fill out the form below to help schedule your parent-teacher conference.</p>\n\n    <form>\n      <fieldset>\n        <legend>Student Information</legend>\n        <label for=\"student-name\">Full Name: </label>\n        <input\n            type=\"text\"\n            name=\"student-name\"\n            id=\"student-name\"\n            required\n            placeholder=\"E.g., Jane Doe\"\n          />\n\n        <label for=\"grade\">Student Grade: </label>\n        <input\n            type=\"number\"\n            name=\"grade\"\n            id=\"grade\"\n            required\n            placeholder=\"E.g., 4\"\n          />\n      </fieldset>\n\n      <fieldset>\n        <legend>Parent/Guardian Information</legend>\n        <label for=\"parent-name\">Parent/Guardian Name: </label>\n        <input\n            type=\"text\"\n            name=\"parent-name\"\n            id=\"parent-name\"\n            required\n            placeholder=\"E.g., Nancy Doe\"\n          />\n      </fieldset>\n\n      <fieldset>\n        <legend>Preferred Contact Method</legend>\n        <label class=\"contact-method\" for=\"email\">Email: </label>\n        <input\n            id=\"email\"\n            class=\"contact-method-radio-btn\"\n            type=\"radio\"\n            name=\"contact-method\"\n            value=\"email\"\n            checked\n          />\n\n        <label class=\"contact-method\" for=\"phone\">Phone: </label>\n        <input\n            id=\"phone\"\n            class=\"contact-method-radio-btn\"\n            type=\"radio\"\n            name=\"contact-method\"\n            value=\"phone\"\n          />\n      </fieldset>\n\n      <fieldset>\n        <legend>Additional Notes</legend>\n        \n      </fieldset>\n    </form>\n  </main>\n</body>\n\n</html>","head":null,"tail":null,"editableRegionBoundaries":[73,75],"history":["index.html"]}],"saveSubmissionToDB":null,"tests":[{"text":"<p>Your last <code>fieldset</code> should contain a <code>label</code> element.</p>","testString":"assert.exists(document.querySelector(\"fieldset:last-of-type label\"));"},{"text":"<p>The <code>label</code> element should have the text <code>Any specific concerns or topics you'd like to discuss?</code>.</p>","testString":"const label = document.querySelector(\"fieldset:last-of-type label\");\nassert.strictEqual(label?.innerText, \"Any specific concerns or topics you'd like to discuss?\");"},{"text":"<p>The <code>label</code> element's <code>for</code> attribute should be set to <code>\"notes\"</code>.</p>","testString":"const label = document.querySelector(\"fieldset:last-of-type label\");\nassert.strictEqual(label?.getAttribute(\"for\"), \"notes\");"},{"text":"<p>Your last <code>fieldset</code> should contain a <code>textarea</code> element.</p>","testString":"assert.exists(document.querySelector(\"fieldset:last-of-type textarea\"));"},{"text":"<p>Your <code>textarea</code> element should be below the <code>label</code> element.</p>","testString":"const label = document.querySelector(\"fieldset:last-of-type label\");\nconst textarea = document.querySelector(\"fieldset:last-of-type textarea\");\nassert.strictEqual(label?.nextElementSibling, textarea);"},{"text":"<p>The <code>textarea</code> element should have an <code>id</code> attribute set to <code>\"notes\"</code>.</p>","testString":"const textarea = document.querySelector(\"fieldset:last-of-type textarea\");\nassert.strictEqual(textarea?.getAttribute(\"id\"), \"notes\");"},{"text":"<p>The <code>textarea</code> element should have a <code>name</code> attribute set to <code>\"notes\"</code>.</p>","testString":"const textarea = document.querySelector(\"fieldset:last-of-type textarea\");\nassert.strictEqual(textarea?.getAttribute(\"name\"), \"notes\");"},{"text":"<p>The <code>textarea</code> element should have a <code>rows</code> attribute set to <code>4</code>.</p>","testString":"const textarea = document.querySelector(\"fieldset:last-of-type textarea\");\nassert.strictEqual(textarea?.getAttribute(\"rows\"), \"4\");"},{"text":"<p>The <code>textarea</code> element should have a <code>cols</code> attribute set to <code>50</code>.</p>","testString":"const textarea = document.querySelector(\"fieldset:last-of-type textarea\");\nassert.strictEqual(textarea?.getAttribute(\"cols\"), \"50\");"}]}}},"pageC