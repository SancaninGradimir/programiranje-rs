{"componentChunkName":"component---src-templates-challenges-generic-show-tsx","path":"/learn/b1-english-for-developers/learn-how-to-share-feedback/dialogue-1-performance-review-feedback","result":{"data":{"challengeNode":{"challenge":{"assignments":["<p>Gledaj video</p>"],"bilibiliIds":null,"block":"learn-how-to-share-feedback","challengeType":21,"description":"<section id=\"description\">\n<p>Pogledajte video dole/ispod kako biste razumeli kontekst predstojećih lekcija.</p>\n</section>","nodules":null,"explanation":null,"helpCategory":"English","instructions":"","fields":{"slug":"/learn/b1-english-for-developers/learn-how-to-share-feedback/dialogue-1-performance-review-feedback"},"questions":[],"scene":{"setup":{"background":"company2-boardroom.png","characters":[{"character":"Bob","position":{"x":-25,"y":0,"z":1},"opacity":null},{"character":"Jessica","position":{"x":125,"y":0,"z":1},"opacity":null}],"audio":{"filename":"B1_8-1.mp3","startTime":1,"startTimestamp":null,"finishTimestamp":null},"alwaysShowDialogue":true},"commands":[{"background":null,"character":"Bob","position":{"x":25,"y":0,"z":1},"opacity":null,"startTime":0,"finishTime":null,"dialogue":null},{"background":null,"character":"Jessica","position":{"x":70,"y":0,"z":1},"opacity":null,"startTime":0.5,"finishTime":null,"dialogue":null},{"background":null,"character":"Bob","position":null,"opacity":null,"startTime":1,"finishTime":4.08,"dialogue":{"text":"Hi, Jessica. Thanks for joining me for your performance review.","align":"left"}},{"background":null,"character":"Bob","position":null,"opacity":null,"startTime":4.3,"finishTime":7.5,"dialogue":{"text":"I want to start by saying that you've done a great job with your QA work.","align":"left"}},{"background":null,"character":"Bob","position":null,"opacity":null,"startTime":7.82,"finishTime":10.52,"dialogue":{"text":"You've caught several issues, which has really helped the team.","align":"left"}},{"background":null,"character":"Jessica","position":null,"opacity":null,"startTime":10.88,"finishTime":12.34,"dialogue":{"text":"Thank you, Bob. I'm glad to hear that.","align":"right"}},{"background":null,"character":"Bob","position":null,"opacity":null,"startTime":12.7,"finishTime":15.72,"dialogue":{"text":"However, I've noticed that your documentation isn't always complete.","align":"left"}},{"background":null,"character":"Bob","position":null,"opacity":null,"startTime":15.94,"finishTime":20.54,"dialogue":{"text":"If the documentation isn't detailed enough, it can cause problems later. What do you think?","align":"left"}},{"background":null,"character":"Jessica","position":null,"opacity":null,"startTime":21.02,"finishTime":25.94,"dialogue":{"text":"I understand. I've been focusing more on the testing, but I see how better documentation could help the team.","align":"right"}},{"background":null,"character":"Jessica","position":null,"opacity":null,"startTime":26.08,"finishTime":26.72,"dialogue":{"text":"I'll work on it.","align":"right"}},{"background":null,"character":"Bob","position":null,"opacity":null,"startTime":26.94,"finishTime":32.06,"dialogue":{"text":"Sounds good. If we improve the documentation, it will be easier for others to follow your work.","align":"left"}},{"background":null,"character":"Bob","position":null,"opacity":null,"startTime":32.26,"finishTime":34.94,"dialogue":{"text":"If you need any support with this, let me know.","align":"left"}},{"background":null,"character":"Jessica","position":null,"opacity":null,"startTime":35.3,"finishTime":37.5,"dialogue":{"text":"Thanks, Bob. I'll start making changes right away.","align":"right"}},{"background":null,"character":"Bob","position":null,"opacity":null,"startTime":38.1,"finishTime":41.08,"dialogue":{"text":"Great. Overall, I think you're doing a fantastic job.","align":"left"}},{"background":null,"character":"Bob","position":null,"opacity":null,"startTime":41.48,"finishTime":46.36,"dialogue":{"text":"Let's set some goals for the next quarter to ensure you're on track. If you need help, just ask.","align":"left"}},{"background":null,"character":"Jessica","position":null,"opacity":null,"startTime":46.86,"finishTime":49.1,"dialogue":{"text":"That sounds like a plan. I appreciate your feedback.","align":"right"}},{"background":null,"character":"Jessica","position":null,"opacity":null,"startTime":49.38,"finishTime":52.48,"dialogue":{"text":"I'll work on improving the documentation and continue to focus on quality.","align":"right"}},{"background":null,"character":"Bob","position":null,"opacity":null,"startTime":53.2,"finishTime":56.86,"dialogue":{"text":"Excellent. Let's have a great quarter ahead. Talk to you soon, Jessica.","align":"left"}},{"background":null,"character":"Jessica","position":null,"opacity":null,"startTime":57.2,"finishTime":58.52,"dialogue":{"text":"Thanks, Bob. Talk to you soon.","align":"right"}},{"background":null,"character":"Jessica","position":{"x":125,"y":0,"z":1},"opacity":null,"startTime":59.02,"finishTime":null,"dialogue":null},{"background":null,"character":"Bob","position":{"x":-25,"y":0,"z":1},"opacity":null,"startTime":59.52,"finishTime":null,"dialogue":null}]},"superBlock":"b1-english-for-developers","tests":[],"title":"Dijalog 1: Povratne informacije o evaluaciji performansi","transcript":null,"translationPending":false,"videoId":null,"videoLocaleIds":null}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/b1-english-for-developers/#learn-how-to-share-feedback","dashedName":"dialogue-1-performance-review-feedback","certification":"b1-english-for-developers","disableLoopProtectTests":false,"disableLoopProtectPreview":false,"superBlock":"b1-english-for-developers","chapter":null,"module":null,"block":"learn-how-to-share-feedback","isFirstStep":true,"template":null,"required":[],"isLastChallengeInBlock":false,"nextChallengePath":"/learn/b1-english-for-developers/learn-how-to-share-feedback/task-1","prevChallengePath":"/learn/b1-english-for-developers/en-b1-quiz-conditionals/en-b1-q