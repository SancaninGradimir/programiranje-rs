      "text": "<p>Vaš <code>h2</code> element više ne bi trebalo da ima klasu <code>red-text</code>.</p>",
      "testString": "assert.isFalse(document.querySelector('h2')?.classList?.contains('red-text'));"
    },
    {
      "text": "<p>Vaš <code>h2</code> element sada bi trebalo da ima klasu <code>text-primary</code>.</p>",
      "testString": "assert.isTrue(document.querySelector('h2')?.classList?.contains('text-primary'));"
    },
    {
      "text": "<p>Vaši paragrafi više ne bi trebalo da koriste font <code>Monospace</code>.</p>",
      "testString": "const paragraphElement = document.querySelector('p');\r\nconst paragraphFontFamily = window.getComputedStyle(paragraphElement)[\"font-family\"]; \r\nassert.notMatch(paragraphFontFamily,/monospace/i);"
    },
    {
      "text": "<p>Klasa <code>smaller-image</code> bi trebalo da bude uklonjena sa vaše gornje slike.</p>",
      "testString": "assert.isFalse(document.querySelector('img')?.classList?.contains('smaller-image'));"
    },
    {
      "text": "<p>Trebalo bi da dodate klasu <code>img-responsive</code> na vašu gornju sliku.</p>",
      "testString": "assert.lengthOf(document.querySelectorAll('.img-responsive'),2);"
    }
