  "tests": [
    {
      "text": "<p>Vaš kod treba da ima prefiks <code>DOCTYPE</code>.</p>",
      "testString": "assert.match(code, /<!DOCTYPE/gi);"
    },
    {
      "text": "<p>Treba da staviš razmak nakon deklaracije <code>DOCTYPE</code>.</p>",
      "testString": "assert.match(code, /<!DOCTYPE\\s+/gi);"
    },
    {
      "text": "<p>Trebalo bi da definišete tip dokumenta kao <code>html</code>.</p>",
      "testString": "assert.match(code, /<!DOCTYPE\\s+html/gi);"
    },
    {
      "text": "<p>Trebalo bi da zatvorite deklaraciju <code>DOCTYPE</code> sa etiketom za zatvaranje <code>></code> nakon tipa.</p>",
      "testString": "assert.match(code, /<!DOCTYPE\\s+html\\s*>/gi);"
    },
    {
      "text": "<p>Vaš element za <code>html</code> mora imati oznaku za otvaranje sa atributom elementa <code>lang</code> sa vrednošću <code>en</code>.</p>",
      "testString": "assert.match(code, /<html\\s+lang\\s*=\\s*('|\")en\\1\\s*>/gi);"
    },
    {
      "text": "<p>Element vašeg <code>html</code> treba da ima zatvarajući tag.</p>",
      "testString": "assert.match(code, /<\\/html\\s*>/);"
    },
    {
      "text": "<p>Tvoje saopštenje za <code>DOCTYPE</code> trebalo bi biti na početku tvog HTML.</p>",
      "testString": "assert.match(__helpers.removeHtmlComments(code), /^\\s*<!DOCTYPE\\s+html\\s*>/i);"
    },
    {
      "text": "<p>Trebalo bi da imaš etiketu za otvaranje <code>head</code>.</p>",
      "testString": "assert.match(code, /<head\\s*>/i);"
    },
    {
      "text": "<p>Trebalo bi da ima oznaku za zatvaranje <code>head</code>.</p>",
      "testString": "assert.match(code, /<\\/head\\s*>/i);"
    },
    {
      "text": "<p>Trebalo bi da imaš etiketu za otvaranje <code>body</code>.</p>",
      "testString": "assert.match(code, /<body\\s*>/i);"
    },
    {
      "text": "<p>Trebalo bi da ima oznaku za zatvaranje <code>body</code>.</p>",
      "testString": "assert.match(code, /<\\/body\\s*>/i);"
    },
    {
      "text": "<p>Tvoj element <code>body</code> treba da bude prvi element nakon elementa <code>head</code>.</p>",
      "testString": "assert.match(code, /<\\/head\\s*>\\s*<body\\s*>/i);"
    },
    {
      "text": "<p>Vaši elementi za <code>head</code> i <code>body</code> treba da budu braća/sestre.</p>",
      "testString": "assert.strictEqual(document.querySelector('head')?.nextElementSibling?.localName, 'body');"
    },
    {
      "text": "<p>Tvoj element za <code>head</code> treba da bude prvi element unutar tvog elementa za <code>html</code>.</p>",
      "testString": "assert.match(code, /<html\\s+lang\\s*=\\s*('|\")en\\1\\s*>\\s*<head\\s*>/);"
