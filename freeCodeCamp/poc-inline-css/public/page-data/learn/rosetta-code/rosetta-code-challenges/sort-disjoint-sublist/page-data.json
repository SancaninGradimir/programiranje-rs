{"componentChunkName":"component---src-templates-challenges-classic-show-tsx","path":"/learn/rosetta-code/rosetta-code-challenges/sort-disjoint-sublist","result":{"data":{"challengeNode":{"challenge":{"block":"rosetta-code-challenges","demoType":null,"title":"Sortiranje razdvojenih podnizova","description":"<section id=\"description\">\n<p>Ako je dat spisak vrednosti i skup celobrojnih indeksa u tom spisku, zadatak je da se sortiraju samo vrednosti na navedenim indeksima, dok vrednosti na ostalim indeksima ostaju nepromenjene.</p>\n<p>Neka tvoja funkcija radi sa sledećim spiskom vrednosti i skupom indeksa:</p>\n<p><code>values: [7, <b>6</b>, 5, 4, 3, 2, <b>1</b>, <b>0</b>]</code></p>\n<pre><code class=\"language-js\">indices(0-based): {6, 1, 7}\n</code></pre>\n<p>Ispravan rezultat treba da bude:</p>\n<p><code>[7, <b>0</b>, 5, 4, 3, 2, <b>1</b>, <b>6</b>]</code>.</p>\n</section>","id":"5a23c84252665b21eecc8000","hasEditableBoundaries":false,"instructions":"","notes":null,"challengeType":1,"helpCategory":"Rosetta","videoUrl":null,"superBlock":"rosetta-code","translationPending":false,"forumTopicId":302307,"hooks":null,"fields":{"slug":"/learn/rosetta-code/rosetta-code-challenges/sort-disjoint-sublist"},"required":[],"usesMultifileEditor":false,"challengeFiles":[{"fileKey":"scriptjs","ext":"js","name":"script","contents":"function sortDisjoint(values, indices) {\n\n}","head":null,"tail":null,"editableRegionBoundaries":[],"history":["script.js"]}],"saveSubmissionToDB":null,"tests":[{"text":"<p><code>sortDisjoint</code> treba da bude funkcija.</p>","testString":"assert(typeof sortDisjoint == 'function');"},{"text":"<p><code>sortDisjoint([7, 6, 5, 4, 3, 2, 1, 0], [6, 1, 7])</code> treba da vrati niz.</p>","testString":"assert(Array.isArray(sortDisjoint([7, 6, 5, 4, 3, 2, 1, 0], [6, 1, 7])));"},{"text":"<p><code>sortDisjoint([7, 6, 5, 4, 3, 2, 1, 0], [6, 1, 7])</code> inapaswa kurudisha <code>[7, 0, 5, 4, 3, 2, 1, 6]</code>.</p>","testString":"assert.deepEqual(sortDisjoint([7, 6, 5, 4, 3, 2, 1, 0], [6, 1, 7]), [\n  7,\n  0,\n  5,\n  4,\n  3,\n  2,\n  1,\n  6\n]);"},{"text":"<p><code>sortDisjoint([7, 6, 5, 4, 3, 2, 1, 0], [1, 2, 5, 6])</code> inapaswa kurudisha <code>[7, 1, 2, 4, 3, 5, 6, 0]</code>.</p>","testString":"assert.deepEqual(sortDisjoint([7, 6, 5, 4, 3, 2, 1, 0], [1, 2, 5, 6]), [\n  7,\n  1,\n  2,\n  4,\n  3,\n  5,\n  6,\n  0\n]);"},{"text":"<p><code>sortDisjoint([8, 7, 6, 5, 4, 3, 2, 1], [6, 1, 7])</code> inapaswa kurudisha <code>[8, 1, 6, 5, 4, 3, 2, 7]</code>.</p>","testString":"assert.deepEqual(sortDisjoint([8, 7, 6, 5, 4, 3, 2, 1], [6, 1, 7]), [\n  8,\n  1,\n  6,\n  5,\n  4,\n  3,\n  2,\n  7\n]);"},{"text":"<p><code>sortDisjoint([8, 7, 6, 5, 4, 3, 2, 1], [1, 3, 5, 6])</code> inapaswa kurudisha <code>[8, 2, 6, 3, 4, 5, 7, 1]</code>.</p>","testString":"assert.deepEqual(sortDisjoint([8, 7, 6, 5, 4, 3, 2, 1], [1, 3, 5, 6]), [\n  8,\n  2,\n  6,\n  3,\n  4,\n  5,\n  7,\n  1\n]);"},{"text":"<p><code>sortDisjoint([6, 1, 7, 1, 3, 5, 6], [6, 1, 5, 4])</code> inapaswa kurudisha <code>[6, 1, 7, 1, 3, 5, 6]</code>.</p>","testString":"assert.deepEqual(sortDisjoint([6, 1, 7, 1, 3, 5, 6], [6, 1, 5, 4]), [\n  6,\n  1,\n  7,\n  1,\n  3,\n  5,\n  6\n]);"}]}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/rosetta-code/#rosetta-code-challenges","dashedName":"sort-disjoint-sublist","certification":"rosetta-code","disableLoopProtectTests":true,"disableLoopProtectPreview":false,"superBlock":"rosetta-code","chapter":null,"module":null,"block":"rosetta-code-challenges","isFirstStep":false,"template":null,"required":[],"isLastChallengeInBlock":false,"nextChallengePath":"/learn/rosetta-code/rosetta-code-challenges/sort-stability","prevChallengePath":"/learn/rosetta-code/rosetta-code-challenges/sort-an-array-of-composite-structures","id":"5a23c84252665b21eecc8000","saveSubmissionToDB":null},"projectPreview":{"challengeData":{"challengeType":1,"challengeFiles":[{"name":"script","ext":"js","contents":"function ZigZagMatrix(n) {\n  const mtx = [];\n  for (let i = 0; i < n; i++) {\n    mtx[i] = [];\n  }\n\n  let i = 1;\n  let j = 1;\n  for (let e = 0; e < n * n; e++) {\n    mtx[i - 1][j - 1] = e;\n    if ((i + j) % 2 === 0) {\n      // Even stripes\n      if (j < n) j++;\n      else i += 2;\n      if (i > 1) i--;\n    } else {\n      // Odd stripes\n      if (i < n) i++;\n      else j += 2;\n      if (j > 1) j--;\n    }\n  }\n  return mtx;\n}","history":["script.js"],"fileKey":"scriptjs"}]}},"id":"/learn/rosetta-code/rosetta-code-challenges/sort-disjoint-sublist"}},"staticQueryHashes":["3858520367"],"slicesMap":{}}