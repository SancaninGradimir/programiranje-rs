2,"dialogue":{"text":"That's awesome. What kind of figures are you most interested in?","align":"left"}},{"background":null,"character":"Sarah","position":null,"opacity":null,"startTime":12.7,"finishTime":14.8,"dialogue":{"text":"I like sci-fi and fantasy, mostly.","align":"right"}},{"background":null,"character":"Sarah","position":null,"opacity":null,"startTime":14.8,"finishTime":17.9,"dialogue":{"text":"You can find everything here, from Star Wars to Lord of the Rings.","align":"right"}},{"background":null,"character":"James","position":null,"opacity":null,"startTime":18.6,"finishTime":21.1,"dialogue":{"text":"That's cool. How long have you been into collecting?","align":"left"}},{"background":null,"character":"Sarah","position":null,"opacity":null,"startTime":21.7,"finishTime":24.2,"dialogue":{"text":"I've been a collector since I was 8 or 9 years old.","align":"right"}},{"background":null,"character":"Sarah","position":null,"opacity":null,"startTime":24.5,"finishTime":28.2,"dialogue":{"text":"It all started when I got my first action figure at a comic convention.","align":"right"}},{"background":null,"character":"James","position":null,"opacity":null,"startTime":28.7,"finishTime":30.3,"dialogue":{"text":"I didn't know you were interested in this.","align":"left"}},{"background":null,"character":"Sarah","position":null,"opacity":null,"startTime":30.3,"finishTime":33.4,"dialogue":{"text":"Are you kidding? I go to at least one convention every year.","align":"right"}},{"background":null,"character":"Sarah","position":null,"opacity":null,"startTime":33.7,"finishTime":35.2,"dialogue":{"text":"It's the best moment of the year for me.","align":"right"}},{"background":null,"character":"Sarah","position":{"x":125,"y":0,"z":1},"opacity":null,"startTime":35.7,"finishTime":null,"dialogue":null},{"background":null,"character":"James","position":{"x":-25,"y":0,"z":1},"opacity":null,"startTime":36.2,"finishTime":null,"dialogue":null}]},"superBlock":"a2-english-for-developers",