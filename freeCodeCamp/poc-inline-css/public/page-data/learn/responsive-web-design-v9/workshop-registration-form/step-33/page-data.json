word: <input id=\"new-password\" type=\"password\" pattern=\"[a-z0-5]{8,}\" required /></label>\n    </fieldset>\n    <fieldset>\n      <legend>Account type (required)</legend>\n      <label for=\"personal-account\"><input id=\"personal-account\" type=\"radio\" name=\"account-type\" value=\"personal\" checked/> Personal</label>\n      <label for=\"business-account\"><input id=\"business-account\" type=\"radio\" name=\"account-type\" value=\"business\" /> Business</label>\n    </fieldset>\n    <fieldset>\n      <label>Upload a profile picture: <input type=\"file\" /></label>\n      <label>Input your age (years): <input type=\"number\" min=\"13\" max=\"120\" /></label>\n      <label>How did you hear about us?\n        <select>\n          <option>(select one)</option>\n          <option>freeCodeCamp News</option>\n          <option>freeCodeCamp YouTube Channel</option>\n          <option>freeCodeCamp Forum</option>\n          <option>Other</option>\n        </select>\n      </label>\n    </fieldset>\n    <a href=\"https://www.freecodecamp.org/news/terms-of-service\">Read our terms and conditions</a>\n    <label for=\"terms-and-conditions\">\n      <input id=\"terms-and-conditions\" type=\"checkbox\" required />\n      I accept the terms and conditions\n    </label>\n    <input type=\"submit\" value=\"Submit\" />\n  </form>\n</body>\n</html>","head":null,"tail":null,"editableRegionBoundaries":[27,33],"history":["index.html"]},{"fileKey":"stylescss","ext":"css","name":"styles","contents":"body {\n  width: 100%;\n  height: 100vh;\n  margin: 0;\n  background-color: #1b1b32;\n  color: #f5f6f7;\n}\n\nlabel {\n  display: block;\n  margin: 0.5rem 0;\n}\n","head":null,"tail":null,"editableRegionBoundaries":[],"history":["styles.css"]}],"saveSubmissionToDB":null,"tests":[{"text":"<p>Trebalo bi da napišete <code>option</code> za <code>value</code> za prvi <code>\"\"</code>.</p>","testString":"assert.equal(document.querySelectorAll('fieldset:nth-child(3) > label:nth-child(3) optio