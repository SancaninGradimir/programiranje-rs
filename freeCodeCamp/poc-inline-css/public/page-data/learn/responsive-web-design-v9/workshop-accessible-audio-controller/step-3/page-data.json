{"componentChunkName":"component---src-templates-challenges-classic-show-tsx","path":"/learn/responsive-web-design-v9/workshop-accessible-audio-controller/step-3","result":{"data":{"challengeNode":{"challenge":{"block":"workshop-accessible-audio-controller","demoType":null,"title":"Korak 3","description":"<section id=\"description\">\n<p>Sledeće, dodajte element za <code>div</code> ili uključite sve elemente kontrole zvuka.</p>\n<p>Unutar elementa <code>div</code>, postavite unutar element/polja <code>span</code> sa atributom <code>id</code> koji je postavljen na <code>volume-label</code>.\nTakođe, tekst elementa <code>span</code> treba da bude <code>Volume</code>.</p>\n<p><code>id</code> Kasnije će se vratiti sa ARIA atributima ili pomoćne tehnologije moći da prepoznaju ovaj tekst kao oznaku za kontrolu zvuka.</p>\n</section>","id":"68eb7f2397da251a40e04aa2","hasEditableBoundaries":true,"instructions":"","notes":null,"challengeType":0,"helpCategory":"HTML-CSS","videoUrl":null,"superBlock":"responsive-web-design-v9","translationPending":false,"forumTopicId":null,"hooks":null,"fields":{"slug":"/learn/responsive-web-design-v9/workshop-accessible-audio-controller/step-3"},"required":[],"usesMultifileEditor":true,"challengeFiles":[{"fileKey":"indexhtml","ext":"html","name":"index","contents":"<!DOCTYPE html>\n<html lang=\"en\">\n  <head>\n    <meta charset=\"UTF-8\">\n    <title>Accessible Controls</title>\n  </head>\n  <body>\n\n    <h1>Audio Controls</h1>\n\n    <button type=\"button\">Play</button>\n\n\n\n  </body>\n</html>","head":null,"tail":null,"editableRegionBoundaries":[12,14],"history":["index.html"]}],"saveSubmissionToDB":null,"tests":[{"text":"<p>Trebalo bi da imaš element <code>div</code> ispod tvog elementa <code>button</code>.</p>","testString":"assert.exists(document.querySelector('button + div'));"},{"text":"<p>Trebalo bi da imaš element <code>span</code> unutar svog elementa <code>div</code>.</p>","testString":"assert.exists(document.querySelector('button + div > span'));"},{"text":"<p>Tvoj element od <code>span</code> mora imati svojstvo <code>id</code>.</p>","testString":"const spanEl = document.querySelector('button + div > span');\nassert.isTrue(spanEl?.hasAttribute('id'));"},{"text":"<p>Vaš element <code>span</code> mora imati svojstvo <code>id</code> sa vrednošću postavljenu na <code>volume-label</code>.</p>","testString":"const spanEl = document.querySelector('button + div > span');\nassert.equal(spanEl?.getAttribute('id'), 'volume-label');"},{"text":"<p>Vaše polje <code>span</code> mora imati tekst od <code>Volume</code>.</p>","testString":"const spanEl = document.querySelector('button + div > span');\nassert.equal(spanEl?.innerText.trim(), 'Volume');"}]}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/responsive-web-design-v9/#workshop-accessible-audio-controller","dashedName":"step-3","certification":"responsive-web-design-v9","disableLoopProtectTests":false,"disableLoopProtectPreview":false,"superBlock":"responsive-web-design-v9","chapter":"html","module":"html-and-accessibility","block":"workshop-accessible-audio-controller","isFirstStep":false,"template":null,"required":[],"isLastChallengeInBlock":false,"nextChallengePath":"/learn/responsive-web-design-v9/workshop-accessible-audio-controller/step-4","prevChallengePath":"/learn/responsive-web-design-v9/workshop-accessible-audio-controller/step-2","id":"68eb7f2397da251a40e04aa2","saveSubmissionToDB":null},"projectPreview":{"challengeData":{"challengeType":0,"challengeFiles":[{"name":"index","ext":"html","contents":"<!DOCTYPE html>\n<html lang=\"en\">\n  <head>\n    <meta charset=\"UTF-8\">\n    <title>Accessible Controls</title>\n  </head>\n  <body>\n\n    <h1>Audio Controls</h1>\n\n    <button type=\"button\">Play</button>\n\n    <div>\n      <span id=\"volume-label\">Volume</span>\n      <span id=\"volume-description\">Adjust the sound level</span>\n      <input type=\"range\" min=\"0\" max=\"100\" value=\"50\"\n             aria-labelledby