{"componentChunkName":"component---src-templates-challenges-generic-show-tsx","path":"/learn/b1-english-for-developers/learn-how-to-manage-a-conversation/dialogue-3-project-check-in","result":{"data":{"challengeNode":{"challenge":{"assignments":["<p>Gledaj video.</p>"],"bilibiliIds":null,"block":"learn-how-to-manage-a-conversation","challengeType":21,"description":"<section id=\"description\">\n<p>Pogledajte video ispod da biste razumeli kontekst sledećih lekcija.</p>\n</section>","nodules":null,"explanation":null,"helpCategory":"English","instructions":"","fields":{"slug":"/learn/b1-english-for-developers/learn-how-to-manage-a-conversation/dialogue-3-project-check-in"},"questions":[],"scene":{"setup":{"background":"company2-center.png","characters":[{"character":"Brian","position":{"x":-25,"y":0,"z":1},"opacity":null},{"character":"Sarah","position":{"x":125,"y":0,"z":1},"opacity":null}],"audio":{"filename":"B1_15-3.mp3","startTime":1,"startTimestamp":null,"finishTimestamp":null},"alwaysShowDialogue":true},"commands":[{"background":null,"character":"Brian","position":{"x":25,"y":0,"z":1},"opacity":null,"startTime":0,"finishTime":null,"dialogue":null},{"background":null,"character":"Sarah","position":{"x":70,"y":0,"z":1},"opacity":null,"startTime":0.5,"finishTime":null,"dialogue":null},{"background":null,"character":"Brian","position":null,"opacity":null,"startTime":1,"finishTime":4.62,"dialogue":{"text":"Hey, Sarah. I wanted to discuss an ongoing project with you.","align":"left"}},{"background":null,"character":"Brian","position":null,"opacity":null,"startTime":4.72,"finishTime":8.28,"dialogue":{"text":"It's been a while since we last checked in. How's everything going on your end?","align":"left"}},{"background":null,"character":"Sarah","position":null,"opacity":null,"startTime":9.08,"finishTime":12.08,"dialogue":{"text":"Hi, Brian. Everything is progressing, but we have a few challenges.","align":"right"}},{"background":null,"character":"Sarah","position":null,"opacity":null,"startTime":12.56,"finishTime":14.96,"dialogue":{"text":"Some parts of the project are taking longer than expected.","align":"right"}},{"background":null,"character":"Sarah","position":null,"opacity":null,"startTime":15.5,"finishTime":19.02,"dialogue":{"text":"By the way, have you heard anything about the additional resources we requested?","align":"right"}},{"background":null,"character":"Brian","position":null,"opacity":null,"startTime":19.56,"finishTime":23.58,"dialogue":{"text":"Yes, I spoke with management. We might get some support, but they're still deciding.","align":"left"}},{"background":null,"character":"Brian","position":null,"opacity":null,"startTime":24.16,"finishTime":26.38,"dialogue":{"text":"Is there anything else slowing you down?","align":"left"}},{"background":null,"character":"Sarah","position":null,"opacity":null,"startTime":26.38,"finishTime":29.6,"dialogue":{"text":"Well, we've had some issues with the new software integration.","align":"right"}},{"background":null,"character":"Sarah","position":null,"opacity":null,"startTime":30.18,"finishTime":33.3,"dialogue":{"text":"It's not as seamless as we hoped. We're working on it, though.","align":"right"}},{"background":null,"character":"Sarah","position":null,"opacity":null,"startTime":33.54,"finishTime":36.42,"dialogue":{"text":"Speaking of which, do you know if there's a timeline for the next phase?","align":"right"}},{"background":null,"character":"Brian","position":null,"opacity":null,"startTime":36.9,"finishTime":38.58,"dialogue":{"text":"Not yet, but I can find out.","align":"left"}},{"background":null,"character":"Brian","position":null,"opacity":null,"startTime":38.82,"finishTime":44.04,"dialogue":{"text":"We should probably plan a meeting with the team to discuss the integration issues. Would that help?","align":"left"}},{"background":null,"character":"Sarah","position":null,"opacity":null,"startTime":44.64,"finishTime":48.06,"dialogue":{"text":"Absolutely. Also, I've been meaning to ask about the new training sessions.","align":"right"}},{"background":null,"character":"Sarah","position":null,"opacity":null,"startTime":48.36,"finishTime":52.38,"dialogue":{"text":"When do they start? I think the team could really use some refreshers on the new tools.","align":"right"}},{"background":null,"character":"Brian","position":null,"opacity":null,"startTime":52.38,"finishTime":55.66,"dialogue":{"text":"Good point. The training sessions are scheduled for next week.","align":"left"}},{"background":null,"character":"Brian","position":null,"opacity":null,"startTime":55.88,"finishTime":58.62,"dialogue":{"text":"I'll send you the details. Anything else you'd like to discuss?","align":"left"}},{"background":null,"character":"Sarah","position":null,"opacity":null,"startTime":59.22,"finishTime":61.52,"dialogue":{"text":"Not for now. Thanks, Brian. I appreciate the update.","align":"right"}},{"background":null,"character":"Sarah","position":null,"opacity":null,"startTime":61.74,"finishTime":63.2,"dialogue":{"text":"If anything comes up, I'll let you know.","align":"right"}},{"background":null,"character":"Brian","position":null,"opacity":null,"startTime":63.44,"finishTime":66.62,"dialogue":{"text":"Sounds good. Feel free to reach out to me if you need anything else.","align":"left"}},{"background":null,"character":"Sarah","position":{"x":125,"y":0,"z":1},"opacity":null,"startTime":67.12,"finishTime":null,"dialogue":null},{"background":null,"character":"Brian","position":{"x":-25,"y":0,"z":1},"opacity":null,"startTime":67.62,"finishTime":null,"dialogue":null}]},"superBlock":"b1-english-for-developers","tests":[],"title":"Dijalog 3: Pregled projekta","transcript":null,"translationPending":false,"videoId":null,"videoLocaleIds":null}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/b1-english-for-developers/#learn-how-to-manage-a-conversation","dashedName":"dialogue-3-project-check-in","certification":"b1-english-for-developers","disableLoopProtectTe