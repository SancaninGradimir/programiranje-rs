    {
      "text": "<p>Vas <code>h2</code> element treba da koristi <code>Lobster</code> font.</p>",
      "testString": "const h2 = document.querySelector('h2'); \nconst fontFamily = window.getComputedStyle(h2)['font-family']; \nassert.match(fontFamily, /lobster/i);"
