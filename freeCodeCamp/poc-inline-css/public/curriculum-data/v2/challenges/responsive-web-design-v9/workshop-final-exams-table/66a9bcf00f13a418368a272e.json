    {
      "text": "<p>Trebalo bi da imate otvarajući tag <code>tr</code>.</p>",
      "testString": "assert.match(code, /<tr>/i);"
    },
    {
      "text": "<p>Trebalo bi da imate zatvarajući tag <code>tr</code>.</p>",
      "testString": "assert.match(code, /<\\/tr>/i);"
    },
    {
      "text": "<p>Vaš <code>tr</code> element treba da bude unutar vašeg <code>thead</code> elementa.</p>",
      "testString": "const trEl = document.querySelector('tr');\nassert.strictEqual(trEl?.parentElement?.tagName, 'THEAD');"
