{"componentChunkName":"component---src-templates-challenges-classic-show-tsx","path":"/learn/2022/responsive-web-design/learn-css-flexbox-by-building-a-photo-gallery/step-1","result":{"data":{"challengeNode":{"challenge":{"block":"learn-css-flexbox-by-building-a-photo-gallery","demoType":"onLoad","title":"Korak 1","description":"<section id=\"description\">\n<p>Počni sa svojom osnovnom strukturom od HTML. Dodaj deklaraciju <code>DOCTYPE</code>, element od <code>html</code>, element od <code>head</code>, i element od <code>body</code>.</p>\n<p>Dodaj atribut <code>lang</code> otvarajućoj oznaci <code>&#x3C;html></code> i postavi njegovu vrednost na <code>en</code>.</p>\n</section>","id":"61537485c4f2a624f18d7794","hasEditableBoundaries":true,"instructions":"","notes":null,"challengeType":0,"helpCategory":"HTML-CSS","videoUrl":null,"superBlock":"2022/responsive-web-design","translationPending":false,"forumTopicId":null,"hooks":null,"fields":{"slug":"/learn/2022/responsive-web-design/learn-css-flexbox-by-building-a-photo-gallery/step-1"},"required":[],"usesMultifileEditor":true,"challengeFiles":[{"fileKey":"indexhtml","ext":"html","name":"index","contents":"","head":null,"tail":null,"editableRegionBoundaries":[0,2],"history":["index.html"]},{"fileKey":"stylescss","ext":"css","name":"styles","contents":"","head":null,"tail":null,"editableRegionBoundaries":[],"history":["styles.css"]}],"saveSubmissionToDB":null,"tests":[{"text":"<p>Vaš kod treba da ima referencu na <code>DOCTYPE</code>.</p>","testString":"assert(code.match(/<!DOCTYPE/gi));"},{"text":"<p>Treba da staviš razmak nakon reference <code>DOCTYPE</code>.</p>","testString":"assert(code.match(/<!DOCTYPE\\s+/gi));"},{"text":"<p>Trebalo bi da definišete <code>html</code> kao vrstu dokumenta.</p>","testString":"assert(code.match(/<!DOCTYPE\\s+html/gi));"},{"text":"<p>Trebalo bi da zatvorite deklaraciju <code>DOCTYPE</code> sa etikete za zatvaranje <code>></code> nakon tipa.</p>","testString":"assert(code.match(/<!DOCTYPE\\s+html\\s*>/gi));"},{"text":"<p>Vaš element <code>html</code> bi trebalo da ima otvarajući labelu.</p>","testString":"assert(code.match(/<html\\s*>|<html\\s+lang\\s*=\\s*('|\")en\\1\\s*>/gi));"},{"text":"<p>Element vašeg <code>html</code> treba da ima zatvarajući tag.</p>","testString":"assert(code.match(/<\\/html\\s*>/));"},{"text":"<p>Otvarajući deo za <code>&#x3C;html></code> mora imati svojstvo atributa <code>lang</code> sa vrednošću <code>en</code>.</p>","testString":"assert(code.match(/<html\\s+lang\\s*=\\s*('|\")en\\1\\s*>/));"},{"text":"<p>Tvoje saopštenje za <code>DOCTYPE</code> trebalo bi biti na početku tvog HTML.</p>","testString":"assert(__helpers.removeHtmlComments(code).match(/^\\s*<!DOCTYPE\\s+html\\s*>/i));"},{"text":"<p>Trebalo bi da imate etiketu za otvaranje <code>head</code>.</p>","testString":"assert(code.match(/<head\\s*>/i));"},{"text":"<p>Trebalo bi da imaš oznaku za zatvaranje <code>head</code>.</p>","testString":"assert(code.match(/<\\/head\\s*>/i));"},{"text":"<p>Trebalo bi da imaš oznaku za otvaranje <code>body</code>.</p>","testString":"assert(code.match(/<body\\s*>/i));"},{"text":"<p>Trebalo bi da imaš oznaku za zatvaranje <code>body</code>.</p>","testString":"assert(code.match(/<\\/body\\s*>/i));"},{"text":"<p>Elementi za <code>head</code> i <code>body</code> bi trebalo da budu sestrinski elementi.</p>","testString":"assert(document.querySelector('head')?.nextElementSibling?.localName === 'body');"},{"text":"<p>Element <code>head</code> treba da bude unutar elementa <code>html</code>.</p>","testString":"assert([...document.querySelector('html')?.children].some(x => x?.localName === 'head'));"},{"text":"<p>Element za <code>body</code> treba da bude unutar elementa <code>html</code>.</p>","testString":"assert([...document.querySelector('html')?.children].some(x => x?.localName === 'body'));"}]}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/2022/responsive-web-design/#learn-css-flexbox-by-building-a-photo-gallery","dashedName":"step-1","certification":"responsive-web-design","disableLoopProtectTests":false,"disableLoopProtectPreview":false,"superBlock":"2022/responsive-web-design","chapter":null,"module":null,"block":"learn-css-flexbox-by-building-a-photo-gallery","isFirstStep":true,"template":null,"required":[],"isLastChallengeInBlock":false,"nextChallengePath":"/learn/2022/responsive-web-design/learn-css-flexbox-by-building-a-photo-gallery/step-2","prevChallengePath":"/learn/2022/responsive-web-design/learn-the-css-box-model-by-building-a-rothko-painting/step-45","id":"61537485c4f2a624f18d7794","saveSubmissionToDB":null},"projectPreview":{"challengeData":{"challengeType":0,"challengeFiles":[{"name":"index","ext":"html","contents":"<!DOCTYPE html>\r\n<html lang=\"en\">\r\n  <head>\r\n    <meta charset=\"utf-8\">\r\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\r\n    <title>Photo Gallery</title>\r\n    <link rel=\"stylesheet\" href=\"./styles.css\">\r\n  </head>\r\n  <body>\r\n    <header class=\"header\">\r\n      <h1>css flexbox photo gallery</h1>\r\n    </header>\r\n    <div class=\"gallery\">\r\n      <img src=\"https://cdn.freecodecamp.org/curriculum/css-photo-gallery/1.jpg\" alt=\"Gallery\">\r\n      <img src=\"https://cdn.freecodecamp.org/curriculum/css-photo-gallery/2.jpg\" alt=\"Gallery\">\r\n      <img src=\"https://cdn.freecodecamp.org/curriculum/css-photo-gallery/3.jpg\" alt=\"Gallery\">\r\n      <img src=\"https://cdn.freecodecamp.org/curriculum/css-photo-gallery/4.jpg\" alt=\"Gallery\">\r\n      <img src=\"https://cdn.freecodecamp.org/curriculum/css-photo-gallery/5.jpg\" alt=\"Gallery\">\r\n      <img src=\"https://cdn.freecodecamp.org/curriculum/css-photo-gallery/6.jpg\" alt=\"Gallery\">\r\n      <img src=\"https://cdn.freecodecamp.org/curriculum/css-photo-gallery/7.jpg\" alt=\"Gallery\">\r\n      <img src=\"https://cdn.freecodecamp.org/curriculum/css-photo-gallery/8.jpg\" alt=\"Gallery\">\r\n      <img src=\"https://cdn.freecodecamp.org/curriculum/css-photo-gallery/9.jpg\" alt=\"Gallery\">\r\n    </div>\r\n  </body>\r\n</html>","history":["index.html"],"fileKey":"indexhtml"},{"name":"styles","ext":"css","contents":"* {\r\n  box-sizing: border-box;\r\n}\r\n\r\nbody {\r\n  margin: 0;\r\n  font-family: sans-serif;\r\n  background: #f5f6f7;\r\n}\r\n\r\n.header {\r\n  text-align: center;\r\n  text-transform: uppercase;\r\n  padding: 32px;\r\n  background-color: #0a0a23;\r\n  color: #fff;\r\n  border-bottom: 4px solid #fdb347;\r\n}\r\n\r\n.gallery {\r\n  display: flex;\r\n  flex-direction: row;\r\n  flex-wrap: wrap;\r\n  justify-content: center;\r\n  align-items: center;\r\n  gap: 16px;\r\n  max-width: 1400px;\r\n  margin: 0 auto;\r\n  padding: 20px 10px;\r\n}\r\n\r\n.gallery img {\r\n  width: 100%;\r\n  max-width: 350px;\r\n  height: 300px;\r\n  object-fit: cover;\r\n  border-radius: 10px;\r\n}\r\n\r\n.gallery::after {\r\n  content: \"\";\r\n  width: 350px;\r\n}","history":["styles.css"],"fileKey":"stylescss"}]}},"id":"/learn/2022/responsive-web-design/learn-css-flexbox-by-building-a-photo-gallery/step-1"}},"staticQueryHashes":["3858520367"],"slicesMap":{}}