{"componentChunkName":"component---src-templates-challenges-generic-show-tsx","path":"/learn/b1-english-for-developers/learn-how-to-use-modal-verbs/dialogue-3-security-breach-investigation","result":{"data":{"challengeNode":{"challenge":{"assignments":["<p>Gledaj video.</p>"],"bilibiliIds":null,"block":"learn-how-to-use-modal-verbs","challengeType":21,"description":"<section id=\"description\">\n<p>Pogledajte video dole/ispod kako biste razumeli kontekst predstojećih lekcija.</p>\n</section>","nodules":null,"explanation":null,"helpCategory":"English","instructions":"","fields":{"slug":"/learn/b1-english-for-developers/learn-how-to-use-modal-verbs/dialogue-3-security-breach-investigation"},"questions":[],"scene":{"setup":{"background":"company2-center.png","characters":[{"character":"Jake","position":{"x":-25,"y":0,"z":1},"opacity":null},{"character":"Lisa","position":{"x":125,"y":0,"z":1},"opacity":null}],"audio":{"filename":"B1_14-3.mp3","startTime":1,"startTimestamp":null,"finishTimestamp":null},"alwaysShowDialogue":true},"commands":[{"background":null,"character":"Jake","position":{"x":25,"y":0,"z":1},"opacity":null,"startTime":0,"finishTime":null,"dialogue":null},{"background":null,"character":"Lisa","position":{"x":70,"y":0,"z":1},"opacity":null,"startTime":0.5,"finishTime":null,"dialogue":null},{"background":null,"character":"Jake","position":null,"opacity":null,"startTime":1,"finishTime":3.86,"dialogue":{"text":"Lisa, we've had a security breach in our internal network.","align":"left"}},{"background":null,"character":"Jake","position":null,"opacity":null,"startTime":4.08,"finishTime":7.74,"dialogue":{"text":"We need to find out how this happened. Can you help me investigate it?","align":"left"}},{"background":null,"character":"Lisa","position":null,"opacity":null,"startTime":8.12,"finishTime":10.36,"dialogue":{"text":"Sure, Jake. Do we know when the breach occurred?","align":"right"}},{"background":null,"character":"Jake","position":null,"opacity":null,"startTime":11.48,"finishTime":16.02,"dialogue":{"text":"It must have happened last night because that's when we started noticing unusual activity on the servers.","align":"left"}},{"background":null,"character":"Jake","position":null,"opacity":null,"startTime":16.44,"finishTime":19.4,"dialogue":{"text":"What I can't figure out is how they got past our firewall.","align":"left"}},{"background":null,"character":"Lisa","position":null,"opacity":null,"startTime":20,"finishTime":25.06,"dialogue":{"text":"That's strange. Our firewall settings are usually solid. It must have been something else.","align":"right"}},{"background":null,"character":"Lisa","position":null,"opacity":null,"startTime":25.3,"finishTime":26.74,"dialogue":{"text":"Could someone have left a port open?","align":"right"}},{"background":null,"character":"Jake","position":null,"opacity":null,"startTime":27.08,"finishTime":32.36,"dialogue":{"text":"It's possible. I was checking the logs and there was a lot of traffic from one particular IP address.","align":"left"}},{"background":null,"character":"Jake","position":null,"opacity":null,"startTime":32.68,"finishTime":34.7,"dialogue":{"text":"It might have been a targeted attack.","align":"left"}},{"background":null,"character":"Lisa","position":null,"opacity":null,"startTime":35.44,"finishTime":38.72,"dialogue":{"text":"If it was a targeted attack, we need to find out what they accessed.","align":"right"}},{"background":null,"character":"Lisa","position":null,"opacity":null,"startTime":39.02,"finishTime":40.88,"dialogue":{"text":"Have you checked which files were compromised?","align":"right"}},{"background":null,"character":"Jake","position":null,"opacity":null,"startTime":41.48,"finishTime":44.58,"dialogue":{"text":"Not yet, but we should focus on the critical systems first.","align":"left"}},{"background":null,"character":"Jake","position":null,"opacity":null,"startTime":44.98,"finishTime":50.4,"dialogue":{"text":"It can't be just a random breach. There must be a specific reason they targeted us.","align":"left"}},{"background":null,"character":"Lisa","position":null,"opacity":null,"startTime":50.92,"finishTime":54.8,"dialogue":{"text":"Agreed. We should probably isolate the affected systems and run a full scan.","align":"right"}},{"background":null,"character":"Lisa","position":null,"opacity":null,"startTime":54.8,"finishTime":58.7,"dialogue":{"text":"This will help us understand the extent of the breach and what they might have taken.","align":"right"}},{"background":null,"character":"Jake","position":null,"opacity":null,"startTime":59.08,"finishTime":65.18,"dialogue":{"text":"Good idea. I'll start working on it. We should also notify the security team and follow our incident response plan.","align":"left"}},{"background":null,"character":"Lisa","position":null,"opacity":null,"startTime":65.78,"finishTime":68.92,"dialogue":{"text":"Absolutely. I'll work on isolating the systems and keep you updated.","align":"right"}},{"background":null,"character":"Lisa","position":null,"opacity":null,"startTime":69.22,"finishTime":71.44,"dialogue":{"text":"Let me know if you find anything unusual in the logs.","align":"right"}},{"background":null,"character":"Jake","position":null,"opacity":null,"startTime":71.7,"finishTime":73.44,"dialogue":{"text":"Will do. Thanks for your help, Lisa.","align":"left"}},{"background":null,"character":"Lisa","position":null,"opacity":null,"startTime":73.86,"finishTime":75.96,"dialogue":{"text":"No problem, Jake. We have to get to the bottom of this.","align":"right"}},{"background":null,"character":"Lisa","position":{"x":125,"y":0,"z":1},"opacity":null,"startTime":76.46,"finishTime":null,"dialogue":null},{"background":null,"character":"Jake","position":{"x":-25,"y":0,"z":1},"opacity":null,"startTime":76.96,"finishTime":null,"dialogue":null}]},"superBlock":"b1-english-for-developers","tests":[],"title":"Dijalog 3: Istraživanje bezbednosnog proboja","transcript":null,"translationPending":false,"videoId":null,"videoLocaleIds":null}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/b1-english-for-developers/#learn-how-to-use-modal-verbs","dashedName":"dialogue-3-security-breach-investigation","certification":"b1-english-for-developers","disableLoopProtectTests":false,"disableLoopProtectPreview":false,"superBlock":"b1-english-for-developers","chapter":null,"module":null,"block":"learn-how-to-use-modal-verbs","isFirstStep":false,"template":null,"required":[],"isLastChallengeInBlock":false,"nextChallengePath":"/learn/b1-english-for-developers/learn-how-to-use-modal-verbs/task-104","prevChallengePath":"/learn/b1-english-for-developers/learn-how-to-use-modal-verbs/task-103","id":"67d6c01d726ccd6b384784e8","saveSubmissionToDB":null},"projectPreview":{"challengeData":{"challengeType":19,"challengeFiles":[]}},"id":"/learn/b1-english-for-developers/learn-how-to-use-modal-verbs/dialogue-3-security-breach-investigation"}},"staticQueryHashes":["3858520367"],"slicesMap":{}}