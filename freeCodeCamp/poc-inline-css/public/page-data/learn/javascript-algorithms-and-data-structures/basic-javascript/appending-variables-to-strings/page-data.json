{"componentChunkName":"component---src-templates-challenges-classic-show-tsx","path":"/learn/javascript-algorithms-and-data-structures/basic-javascript/appending-variables-to-strings","result":{"data":{"challengeNode":{"challenge":{"block":"basic-javascript","demoType":null,"title":"Dodavanje Promenljivih u String","description":"<section id=\"description\">\n<p>Kao sto mozemo da gradimo string kroz vise linija koristeci <dfn>string literale</dfn>, mozemo i da dodajemo promenljive u string pomocu plus-equals operatora (<code>+=</code>).</p>\n<p>Mfano:</p>\n<pre><code class=\"language-js\">const anAdjective = \"awesome!\";\nlet ourStr = \"freeCodeCamp is \";\nourStr += anAdjective;\n</code></pre>\n<p><code>ourStr</code> bi imao vrednost <code>freeCodeCamp is awesome!</code>.</p>\n</section>","id":"56533eb9ac21ba0edf2244ed","hasEditableBoundaries":false,"instructions":"<section id=\"instructions\">\n<p>Postavite <code>someAdjective</code> na string od najmanje 3 karaktera i dodajte ga u <code>myStr</code> koristeci operator <code>+=</code>.</p>\n</section>","notes":null,"challengeType":1,"helpCategory":"JavaScript","videoUrl":null,"superBlock":"javascript-algorithms-and-data-structures","translationPending":false,"forumTopicId":16656,"hooks":null,"fields":{"slug":"/learn/javascript-algorithms-and-data-structures/basic-javascript/appending-variables-to-strings"},"required":[],"usesMultifileEditor":false,"challengeFiles":[{"fileKey":"scriptjs","ext":"js","name":"script","contents":"// Change code below this line\nconst someAdjective = \"\";\nlet myStr = \"Learning to code is \";","head":null,"tail":null,"editableRegionBoundaries":[],"history":["script.js"]}],"saveSubmissionToDB":null,"tests":[{"text":"<p><code>someAdjective</code> treba da bude postavljen na string od najmanje 3 karaktera.</p>","testString":"assert(typeof someAdjective !== 'undefined' && someAdjective.length > 2);"},{"text":"<p>Treba da dodate <code>someAdjective</code> u <code>myStr</code> koristeci operator <code>+=</code>.</p>","testString":"assert(__helpers.removeJSComments(code).match(/myStr\\s*\\+=\\s*someAdjective\\s*/).length > 0);"}]}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/javascript-algorithms-and-data-structures/#basic-javascript","dashedName":"appending-variables-to-strings","certification":"javascript-algorithms-and-data-structures","disableLoopProtectTests":false,"disableLoopProtectPreview":false,"superBlock":"javascript-algorithms-and-data-structures","chapter":null,"module":null,"block":"basic-javascript","isFirstStep":false,"template":null,"required":[],"isLastChallengeInBlock":false,"nextChallengePath":"/learn/javascript-algorithms-and-data-structures/basic-javascript/find-the-length-of-a-string","prevChallengePath":"/learn/javascript-algorithms-and-data-structures/basic-javascript/constructing-strings-with-variables","id":"56533eb9ac21ba0edf2244ed","saveSubmissionToDB":null},"projectPreview":{"challengeData":{"challengeType":1,"challengeFiles":[{"name":"script","ext":"js","contents":"function rangeOfNumbers(startNum, endNum) {\n  if (endNum - startNum === 0) {\n    return [startNum];\n  } else {\n    const numbers = rangeOfNumbers(startNum, endNum - 1);\n    numbers.push(endNum);\n    return numbers;\n  }\n}","history":["script.js"],"fileKey":"scriptjs"}]}},"id":"/learn/javascript-algorithms-and-data-structures/basic-javascript/appending-variables-to-strings"}},"staticQueryHashes":["3858520367"],"slicesMap":{}}