        "contents": "function steamrollArray(arr) {\r\n  if (!Array.isArray(arr)) {\r\n    return [arr];\r\n  }\r\n  var out = [];\r\n  arr.forEach(function(e) {\r\n    steamrollArray(e).forEach(function(v) {\r\n      out.push(v);\r\n    });\r\n  });\r\n  return out;\r\n}",
