 sa kolegama na poslu.</p>"},{"answer":"discusses","feedback":"<p>Ovaj glagol znači govoriti ili pružati informacije o nečemu. Ne zaboravite <span class=\"highlighted-text\">-es</span>.</p>"}]},"inputType":null,"tests":[],"transcript":null,"scene":{"setup":{"background":"interview-room3.png","characters":[{"character":"Tom","position":{"x":50,"y":15,"z":1.2},"opacity":0},{"character":"Anna","position":{"x":50,"y":15,"z":1.2},"opacity":0}],"audio":{"filename":"2.1-2.mp3","startTime":1,"startTimestamp":9.75,"finishTimestamp":18.9},"alwaysShowDialogue":null},"commands":[{"background":null,"character":"Tom","position":null,"opacity":1,"startTime":0,"finishTime":null,"dialogue":null},{"background":null,"character":"Tom","position":null,"opacity":null,"startTime":1,"finishTime":3.44,"dialogue":{"text":"Sounds good. What do I do after checking emails?","align":"center"}},{"background":null,"character":"Tom","position":null,"opacity":0,"startTime":3.44,"finishTime":null,"dialogue":null},{"background":null,"character":"Anna","position":null,"opacity":1,"startTime":3.44,"finishTime":null,"dialogue":null},{"background":null,"character":"Anna","position":null,"opacity":null,"startTime":4.28,"finishTime":7.24,"dialogue":{"text":"After that, you'll probably attend the daily team meeting at 9:30.","align":"center"}},{"background":null,"character":"Anna","position":null,"opacity":null,"startTime":7.72,"finishTime":10.1,"dialogue":{"text":"During the meeting, the team discusses project updates.","align":"center"}},{"background":null,"character":"Anna","position":null,"opacity":0,"startTime":10.6,"finishTime":null,"dialogue":null}]},"translationPending":false}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/a2-english-for-developers/#learn-how-to-talk-about-a-typical-workday-and-tasks","dashedName":"task-33","certification":"a2-english-for-developers","disableLoopProtectTests":false,"disableLoopProtectPreview":false,"superBlock":"a2-english-for-developers","chapter":null,"m