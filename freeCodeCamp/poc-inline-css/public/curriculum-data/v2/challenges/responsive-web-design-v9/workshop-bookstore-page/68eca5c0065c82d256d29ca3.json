      "text": "<p>Trebalo bi da imaš element <code>button</code> postavljen unutar drugog elementa sa klasom <code>card</code>.</p>",
      "testString": "const cards = document.querySelectorAll('.card');\nassert.exists(cards[1]?.querySelector('button'));"
    },
    {
      "text": "<p>Funkcija za vašu drugu karticu, <code>button</code>, treba da ima atribut <code>class</code>.</p>",
      "testString": "const cards = document.querySelectorAll('.card');\nassert.isTrue(cards[1]?.querySelector('button')?.hasAttribute('class'));"
    },
    {
      "text": "<p>Atribut <code>button</code> vaše druge kartice treba da ima <code>class</code> sa vrednošću <code>btn</code>.</p>",
      "testString": "const cards = document.querySelectorAll('.card');\nassert.equal(cards[1]?.querySelector('button')?.className, 'btn');"
