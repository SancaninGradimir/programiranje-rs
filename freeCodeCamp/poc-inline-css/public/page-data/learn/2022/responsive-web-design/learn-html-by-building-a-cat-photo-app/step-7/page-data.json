{"componentChunkName":"component---src-templates-challenges-classic-show-tsx","path":"/learn/2022/responsive-web-design/learn-html-by-building-a-cat-photo-app/step-7","result":{"data":{"challengeNode":{"challenge":{"block":"learn-html-by-building-a-cat-photo-app","demoType":null,"title":"Korak 7","description":"<section id=\"description\">\n<p>Možete dodati slike na vaš sajt koristeći element <code>img</code>. Elementi <code>img</code> imaju otvarajući tag bez zatvarajućeg taga. Element bez zatvarajućeg taga poznat je kao <dfn>prazan element</dfn>.</p>\n<p>Dodajte element za <code>img</code> ispod elementa <code>p</code>. Do sada, slika neće biti prikazana u pretraživaču.</p>\n</section>","id":"5dc23f9bf86c76b9248c6eba","hasEditableBoundaries":true,"instructions":"","notes":null,"challengeType":0,"helpCategory":"HTML-CSS","videoUrl":null,"superBlock":"2022/responsive-web-design","translationPending":false,"forumTopicId":null,"hooks":null,"fields":{"slug":"/learn/2022/responsive-web-design/learn-html-by-building-a-cat-photo-app/step-7"},"required":[],"usesMultifileEditor":true,"challengeFiles":[{"fileKey":"indexhtml","ext":"html","name":"index","contents":"<html>\n  <body>\n    <main>\n      <h1>CatPhotoApp</h1>\n      <h2>Cat Photos</h2>\n      <!-- TODO: Add link to cat photos -->\n      <p>Everyone loves cute cats online!</p>\n      \n    </main>\n  </body>\n</html>","head":null,"tail":null,"editableRegionBoundaries":[6,9],"history":["index.html"]}],"saveSubmissionToDB":null,"tests":[{"text":"<p>Vaša komponenta za <code>img</code> mora imati oznaku za otvaranje. Oznake za otvaranje imaju ovu sintaksu: <code>&#x3C;elementName></code>.</p>","testString":"assert(document.querySelector('img'));"},{"text":"<p>Tvoj element za <code>img</code> ne bi trebalo da ima zatvarajući atribut/tag <code>&#x3C;/img></code>.</p>","testString":"assert(!code.match(/<\\/img\\>/));"},{"text":"<p>Trebalo bi da ima samo jedan element od <code>img</code>. Uklonite sve viškove.</p>","testString":"assert(document.querySelectorAll('img').length === 1);"},{"text":"<p>Tvoj element za <code>img</code> treba da bude ispod elementa za <code>p</code>. Postavio si ga u pogrešnom redosledu.</p>","testString":"const collection = [...document.querySelectorAll('p,img')].map(\n  (node) => node.nodeName\n);\nassert(collection.indexOf('P') < collection.indexOf('IMG'));"}]}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/2022/responsive-web-design/#learn-html-by-building-a-cat-photo-app","dashedName":"step-7","certification":"responsive-web-design","disableLoopProtectTests":false,"disableLoopProtectPreview":false,"superBlock":"2022/responsive-web-design","chapter":null,"module":null,"block":"learn-html-by-building-a-cat-photo-app","isFirstStep":false,"template":null,"required":[],"isLastChallengeInBlock":false,"nextChallengePath":"/learn/2022/responsive-web-design/learn-html-by-building-a-cat-photo-app/step-8","prevChallengePath":"/learn/2022/responsive-web-design/learn-html-by-building-a-cat-photo-app/step-6","id":"5dc23f9bf86c76b9248c6eba","saveSubmissionToDB":null},"projectPreview":{"challengeData":{"challengeType":0,"challengeFiles":[{"name":"index","ext":"html","contents":"<!DOCTYPE html>\n<html lang=\"en\">\n  <head>\n    <meta charset=\"UTF-8\">\n    <title>CatPhotoApp</title>\n  </head>\n  <body>\n    <main>\n      <h1>CatPhotoApp</h1>\n      <section>\n        <h2>Cat Photos</h2>\n        <p>Everyone loves <a href=\"https://cdn.freecodecamp.org/curriculum/cat-photo-app/running-cats.jpg\">cute cats</a> online!</p>\n        <p>See more <a target=\"_blank\" href=\"https://freecatphotoapp.com\">cat photos</a> in our gallery.</p>\n        <a href=\"https://freecatphotoapp.com\"><img src=\"https://cdn.freecodecamp.org/curriculum/cat-photo-app/relaxing-cat.jpg\" alt=\"A cute orange cat lying on its back.\"></a>\n      </section>\n      <section>\n        <h2>Cat Lists</h2>\n        <h3>Things cats love:</h3>\n        <ul>\n          <li>catnip</li>\n          <li>laser pointers</li>\n          <li>lasagna</li>\n        </ul>\n        <figure>\n          <img src=\"https://cdn.freecodecamp.org/curriculum/cat-photo-app/lasagna.jpg\" alt=\"A slice of lasagna on a plate.\">\n          <figcaption>Cats <em>love</em> lasagna.</figcaption>  \n        </figure>\n        <h3>Top 3 things cats hate:</h3>\n        <ol>\n          <li>flea treatment</li>\n          <li>thunder</li>\n          <li>other cats</li>\n        </ol>\n        <figure>\n          <img src=\"https://cdn.freecodecamp.org/curriculum/cat-photo-app/cats.jpg\" alt=\"Two tabby kittens sleeping together on a couch.\">\n          <figcaption>Cats <strong>hate</strong> other cats.</figcaption>  \n        </figure>\n      </section>\n      <section>\n        <h2>Cat Form</h2>\n        <form action=\"https://freecatphotoapp.com/submit-cat-photo\">\n          <fieldset>\n            <legend>Is your cat an indoor or outdoor cat?</legend>\n            <label><input id=\"indoor\" type=\"radio\" name=\"indoor-outdoor\" value=\"indoor\" checked> Indoor</label>\n            <label><input id=\"outdoor\" type=\"radio\" name=\"indoor-outdoor\" value=\"outdoor\"> Outdoor</label>\n          </fieldset>\n          <fieldset>\n            <legend>What's your cat's personality?</legend>\n            <label for=\"loving\"><input id=\"loving\" type=\"checkbox\" name=\"personality\" value=\"loving\" checked> Loving</label>\n            <label for=\"lazy\"><input id=\"lazy\" type=\"checkbox\" name=\"personality\" value=\"lazy\"> Lazy</label>\n            <label for=\"energetic\"><input id=\"energetic\" type=\"checkbox\" name=\"personality\" value=\"energetic\"> Energetic</label>\n          </fieldset>\n          <input type=\"text\" name=\"catphotourl\" placeholder=\"cat photo URL\" required>\n          <button type=\"submit\">Submit</button>\n        </form>\n      </section>\n    </main>\n    <footer>\n      <p>\n        No Copyright - <a href=\"https://www.freecodecamp.org\">freeCodeCamp.org</a>\n      </p>\n    </footer>\n  </body>\n</html>","history":["index.html"],"fileKey":"indexhtml"}]}},"id":"/learn/2022/responsive-web-design/learn-html-by-building-a-cat-photo-app/step-7"}},"staticQueryHashes":["3858520367"],"slicesMap":{}}