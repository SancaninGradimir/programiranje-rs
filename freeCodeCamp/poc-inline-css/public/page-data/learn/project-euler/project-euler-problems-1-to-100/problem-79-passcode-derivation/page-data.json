{"componentChunkName":"component---src-templates-challenges-classic-show-tsx","path":"/learn/project-euler/project-euler-problems-1-to-100/problem-79-passcode-derivation","result":{"data":{"challengeNode":{"challenge":{"block":"project-euler-problems-1-to-100","demoType":null,"title":"Izazov 79: Dodeljivanje tajnog koda","description":"<section id=\"description\">\n<p>Sigurnosni metod koji se često koristi za online banke je traženje od korisnika tri nasumična slova iz tajnog koda. Na primer, ako je tajni kod bio <code>531278</code>, mogu tražiti slova 2, 3 i 5; očekivani odgovor će biti: <code>317</code>.</p>\n<p>Safu za data, <code>keylog1</code>, <code>keylog2</code>, na <code>keylog3</code>, zina jaribio hamsini la kuingia kwa mafanikio.</p>\n<p>Pošto se ova tri znaka uvek traže istim redosledom, analiziraj niz kako bi odredio najkraći mogući tajni kod nepoznate dužine.</p>\n</section>","id":"5900f3bb1000cf542c50fece","hasEditableBoundaries":false,"instructions":"","notes":null,"challengeType":1,"helpCategory":"Euler","videoUrl":null,"superBlock":"project-euler","translationPending":false,"forumTopicId":302192,"hooks":null,"fields":{"slug":"/learn/project-euler/project-euler-problems-1-to-100/problem-79-passcode-derivation"},"required":[],"usesMultifileEditor":false,"challengeFiles":[{"fileKey":"scriptjs","ext":"js","name":"script","contents":"function passcodeDerivation(arr) {\n\n  return true;\n}\n\n// Only change code above this line\n\nconst keylog1 = [\n  319,680,180,690,129,620,762,689,762,318,368,710,720,710,629,168,160,689,716,731,736,729,316,729,729,710,769,290,719,680,318,389,162,289,162,718,729,319,790,680,890,362,319,760,316,729,380,319,728,716,\n];\n\npasscodeDerivation(keylog1);","head":null,"tail":null,"editableRegionBoundaries":[],"history":["script.js"]}],"saveSubmissionToDB":null,"tests":[{"text":"<p><code>passcodeDerivation(keylog1)</code> treba da vrati broj.</p>","testString":"const _keylog1 = [\n  127,327,178,528,537,538,532,328,127,178,537,127,317,328,512,278,328,327,178,327,578,317,527,178,128,328,517,312,531,128,128,317,527,312,328,532,512,518,317,127,537,528,537,527,327,278,532,128,318,517\n];\nassert.isNumber(passcodeDerivation(_keylog1));"},{"text":"<p><code>passcodeDerivation(keylog1)</code> treba da vrati <code>531278</code>.</p>","testString":"const _keylog1 = [\n  127,327,178,528,537,538,532,328,127,178,537,127,317,328,512,278,328,327,178,327,578,317,527,178,128,328,517,312,531,128,128,317,527,312,328,532,512,518,317,127,537,528,537,527,327,278,532,128,318,517\n];\nassert.strictEqual(passcodeDerivation(_keylog1), 531278);"},{"text":"<p><code>passcodeDerivation(keylog2)</code> inapaswa kurudisha <code>1230567</code>.</p>","testString":"const _keylog2 = [\n  305,367,256,123,357,120,125,307,236,256,356,267,357,256,356,136,257,107,126,567,567,105,120,237,367,120,367,135,207,167,367,367,307,125,120,130,367,230,106,356,126,106,130,123,307,127,306,167,136,126\n];\nassert.strictEqual(passcodeDerivation(_keylog2), 1230567);"},{"text":"<p><code>passcodeDerivation(keylog3)</code> treba vratiti <code>73162890</code>.</p>","testString":"const _keylog3 = [\n  319,680,180,690,129,620,762,689,762,318,368,710,720,710,629,168,160,689,716,731,736,729,316,729,729,710,769,290,719,680,318,389,162,289,162,718,729,319,790,680,890,362,319,760,316,729,380,319,728,716,\n];\nassert.strictEqual(passcodeDerivation(_keylog3), 73162890);"}]}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/project-euler/#project-euler-problems-1-to-100","dashedName":"problem-79-passcode-derivation","certification":"project-euler","disableLoopProtectTests":true,"disableLoopProtectPreview":false,"superBlock":"project-euler","chapter":null,"module":null,"block":"project-euler-problems-1-to-100","isFirstStep":false,"template":null,"required":[],"isLastChallengeInBlock":false,"nextChallengePath":"/learn/project-euler/project-euler-problems-1-to-100/problem-80-square-root-digital-expansion","prevChallengePath":"/learn/project-euler/project-euler-problems-1-to-100/problem-78-coin-partitions","id":"5900f3bb1000cf542c50fece","saveSubmissionToDB":null},"projectPreview":{"challengeData":{"challengeType":1,"challengeFiles":[{"name":"script","ext":"js","contents":"function arrangedProbability(limit) {\n  // Based on https://www.mathblog.dk/project-euler-100-blue-discs-two-blue/\n  let blue = 15;\n  let discs = 21;\n\n  while (discs < limit) {\n    const nextBlue = 3 * blue + 2 * discs - 2;\n    const nextDiscs = 4 * blue + 3 * discs - 3;\n\n    blue = nextBlue;\n    discs = nextDiscs;\n  }\n  return blue;\n}","history":["script.js"],"fileKey":"scriptjs"}]}},"id":"/learn/project-euler/project-euler-problems-1-to-100/problem-79-passcode-derivation"}},"staticQueryHashes":["3858520367"],"slicesMap":{}}