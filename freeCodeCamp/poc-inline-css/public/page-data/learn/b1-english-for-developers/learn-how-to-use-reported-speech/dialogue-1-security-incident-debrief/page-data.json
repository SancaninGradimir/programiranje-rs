{"componentChunkName":"component---src-templates-challenges-generic-show-tsx","path":"/learn/b1-english-for-developers/learn-how-to-use-reported-speech/dialogue-1-security-incident-debrief","result":{"data":{"challengeNode":{"challenge":{"assignments":["<p>Gledaj video.</p>"],"bilibiliIds":null,"block":"learn-how-to-use-reported-speech","challengeType":21,"description":"<section id=\"description\">\n<p>Pogledajte video dole/ispod kako biste razumeli kontekst predstojećih lekcija.</p>\n</section>","nodules":null,"explanation":null,"helpCategory":"English","instructions":"","fields":{"slug":"/learn/b1-english-for-developers/learn-how-to-use-reported-speech/dialogue-1-security-incident-debrief"},"questions":[],"scene":{"setup":{"background":"company2-center.png","characters":[{"character":"Sophie","position":{"x":-25,"y":0,"z":1},"opacity":null},{"character":"Brian","position":{"x":125,"y":0,"z":1},"opacity":null}],"audio":{"filename":"B1_21-1.mp3","startTime":1,"startTimestamp":null,"finishTimestamp":null},"alwaysShowDialogue":true},"commands":[{"background":null,"character":"Sophie","position":{"x":25,"y":0,"z":1},"opacity":null,"startTime":0,"finishTime":null,"dialogue":null},{"background":null,"character":"Brian","position":{"x":70,"y":0,"z":1},"opacity":null,"startTime":0.5,"finishTime":null,"dialogue":null},{"background":null,"character":"Sophie","position":null,"opacity":null,"startTime":1,"finishTime":4.74,"dialogue":{"text":"Hi, Brian. I just spoke with Jake about the security breach we had last week.","align":"left"}},{"background":null,"character":"Sophie","position":null,"opacity":null,"startTime":4.92,"finishTime":8.58,"dialogue":{"text":"He told me we experienced a phishing attack that targeted several team members.","align":"left"}},{"background":null,"character":"Brian","position":null,"opacity":null,"startTime":9.14,"finishTime":11.56,"dialogue":{"text":"That sounds serious. What did Jake say?","align":"right"}},{"background":null,"character":"Sophie","position":null,"opacity":null,"startTime":12.16,"finishTime":15.2,"dialogue":{"text":"He said that the team responded quickly once the breach was detected.","align":"left"}},{"background":null,"character":"Sophie","position":null,"opacity":null,"startTime":15.64,"finishTime":20.26,"dialogue":{"text":"Jake mentioned that they managed to isolate the affected systems within minutes, which limited the damage.","align":"left"}},{"background":null,"character":"Brian","position":null,"opacity":null,"startTime":20.64,"finishTime":26.86,"dialogue":{"text":"Good to hear they contained it quickly. Did Jake give any feedback on how we can prevent similar incidents in the future?","align":"right"}},{"background":null,"character":"Sophie","position":null,"opacity":null,"startTime":27.46,"finishTime":34.22,"dialogue":{"text":"Yes, he suggested several steps. First, Jake thinks we should update our security training to cover more about phishing detection.","align":"left"}},{"background":null,"character":"Sophie","position":null,"opacity":null,"startTime":34.64,"finishTime":38.14,"dialogue":{"text":"He also said that we need to conduct regular security audits more frequently.","align":"left"}},{"background":null,"character":"Brian","position":null,"opacity":null,"startTime":38.5,"finishTime":42.06,"dialogue":{"text":"That makes sense. Did he mention anything about the team's overall reaction?","align":"right"}},{"background":null,"character":"Sophie","position":null,"opacity":null,"startTime":42.54,"finishTime":49.9,"dialogue":{"text":"He did. Jake said that while the team did well to respond quickly, there was some confusion about who was responsible for what during the incident.","align":"left"}},{"background":null,"character":"Sophie","position":null,"opacity":null,"startTime":50.14,"finishTime":53.82,"dialogue":{"text":"He believes better role clarity in our incident response plan could help.","align":"left"}},{"background":null,"character":"Brian","position":null,"opacity":null,"startTime":54.44,"finishTime":59.02,"dialogue":{"text":"That's an important point. We should definitely incorporate that feedback into our next training session.","align":"right"}},{"background":null,"character":"Brian","position":null,"opacity":null,"startTime":59.32,"finishTime":64.06,"dialogue":{"text":"Can you write up a summary of this discussion? I'd like to use it to update our training materials.","align":"right"}},{"background":null,"character":"Sophie","position":null,"opacity":null,"startTime":64.58,"finishTime":71,"dialogue":{"text":"Of course. I'll get that done. Jake also emphasized the importance of maintaining our software updates to prevent vulnerabilities.","align":"left"}},{"background":null,"character":"Sophie","position":null,"opacity":null,"startTime":71.5,"finishTime":74.76,"dialogue":{"text":"He explained that the breach exploited an outdated system component.","align":"left"}},{"background":null,"character":"Brian","position":null,"opacity":null,"startTime":75.22,"finishTime":80.3,"dialogue":{"text":"Right. Thanks for the update, Sophie. I'll make sure we address these points in our upcoming workshops.","align":"right"}},{"background":null,"character":"Brian","position":{"x":125,"y":0,"z":1},"opacity":null,"startTime":80.8,"finishTime":null,"dialogue":null},{"background":null,"character":"Sophie","position":{"x":-25,"y":0,"z":1},"opacity":null,"startTime":81.3,"finishTime":null,"dialogue":null}]},"superBlock":"b1-english-for-developers","tests":[],"title":"Dijalog 1: Izveštaj o bezbednosnom incidentu","transcript":null,"translationPending":false,"videoId":null,"videoLocaleIds":null}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/b1-english-for-developers/#learn-how-to-use-reported-speech","dashedName":"dialogue-1-security-incident-debrief","certification":"b1-english-for-developers","disableLoopProtectTests":false,"disableLoopProtectPreview":false,"superBlock":"b1-english-for-developers","chapter":null,"module":null,"block":"le