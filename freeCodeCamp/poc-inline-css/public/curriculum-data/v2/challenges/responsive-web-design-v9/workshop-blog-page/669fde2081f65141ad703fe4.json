    {
      "text": "<p>Vaš element za <code>section</code> mora imati svojstvo elementa <code>id</code> postavljeno na <code>\"about\"</code>.</p>",
      "testString": "const sectionElement = document.querySelector('section');\nassert.strictEqual(sectionElement?.getAttribute(\"id\"), \"about\");"
