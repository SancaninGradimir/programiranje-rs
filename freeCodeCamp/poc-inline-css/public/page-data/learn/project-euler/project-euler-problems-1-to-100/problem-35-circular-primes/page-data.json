{"componentChunkName":"component---src-templates-challenges-classic-show-tsx","path":"/learn/project-euler/project-euler-problems-1-to-100/problem-35-circular-primes","result":{"data":{"challengeNode":{"challenge":{"block":"project-euler-problems-1-to-100","demoType":null,"title":"Vežba 35: Osnovna konstanta kruga","description":"<section id=\"description\">\n<p>Broj 197 naziva se kružnim prostim brojem zato što su sve rotacije njegovih cifara — 197, 971 i 719 — takođe prosti brojevi.</p>\n<p>Postoji trinaest prostih brojeva ovakve vrste ispod 100: 2, 3, 5, 7, 11, 13, 17, 31, 37, 71, 73, 79 i 97.</p>\n<p>Koliko osnovnih brojeva za krug ispod <code>n</code>, dok je 100 ≤ <code>n</code> ≤ 1000000?</p>\n<p><strong>Napomena:</strong></p>\n<p>Kružni prosti brojevi mogu biti veći od <code>n</code>.</p>\n</section>","id":"5900f38f1000cf542c50fea2","hasEditableBoundaries":false,"instructions":"","notes":null,"challengeType":1,"helpCategory":"Euler","videoUrl":null,"superBlock":"project-euler","translationPending":false,"forumTopicId":302009,"hooks":null,"fields":{"slug":"/learn/project-euler/project-euler-problems-1-to-100/problem-35-circular-primes"},"required":[],"usesMultifileEditor":false,"challengeFiles":[{"fileKey":"scriptjs","ext":"js","name":"script","contents":"function circularPrimes(n) {\n\n  return n;\n}\n\ncircularPrimes(1000000);","head":null,"tail":null,"editableRegionBoundaries":[],"history":["script.js"]}],"saveSubmissionToDB":null,"tests":[{"text":"<p><code>circularPrimes(100)</code> Trebalo bi da vrati broj.</p>","testString":"assert(typeof circularPrimes(100) === 'number');"},{"text":"<p><code>circularPrimes(100)</code> trebalo bi da vrati 13.</p>","testString":"assert(circularPrimes(100) == 13);"},{"text":"<p><code>circularPrimes(100000)</code> treba da vrati 43.</p>","testString":"assert(circularPrimes(100000) == 43);"},{"text":"<p><code>circularPrimes(250000)</code> trebalo bi vratiti 45.</p>","testString":"assert(circularPrimes(250000) == 45);"},{"text":"<p><code>circularPrimes(500000)</code> Trebalo bi da vrati 49.</p>","testString":"assert(circularPrimes(500000) == 49);"},{"text":"<p><code>circularPrimes(750000)</code> inapaswa kurudisha 49.</p>","testString":"assert(circularPrimes(750000) == 49);"},{"text":"<p><code>circularPrimes(1000000)</code> treba da vrati 55.</p>","testString":"assert(circularPrimes(1000000) == 55);"}]}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/project-euler/#project-euler-problems-1-to-100","dashedName":"problem-35-circular-primes","certification":"project-euler","disableLoopProtectTests":true,"disableLoopProtectPreview":false,"superBlock":"project-euler","chapter":null,"module":null,"block":"project-euler-problems-1-to-100","isFirstStep":false,"template":null,"required":[],"isLastChallengeInBlock":false,"nextChallengePath":"/learn/project-euler/project-euler-problems-1-to-100/problem-36-double-base-palindromes","prevChallengePath":"/learn/project-euler/project-euler-problems-1-to-100/problem-34-digit-factorials","id":"5900f38f1000cf542c50fea2","saveSubmissionToDB":null},"projectPreview":{"challengeData":{"challengeType":1,"challengeFiles":[{"name":"script","ext":"js","contents":"function arrangedProbability(limit) {\n  // Based on https://www.mathblog.dk/project-euler-100-blue-discs-two-blue/\n  let blue = 15;\n  let discs = 21;\n\n  while (discs < limit) {\n    const nextBlue = 3 * blue + 2 * discs - 2;\n    const nextDiscs = 4 * blue + 3 * discs - 3;\n\n    blue = nextBlue;\n    discs = nextDiscs;\n  }\n  return blue;\n}","history":["script.js"],"fileKey":"scriptjs"}]}},"id":"/learn/project-euler/project-euler-problems-1-to-100/problem-35-circular-primes"}},"staticQueryHashes":["3858520367"],"slicesMap":{}}