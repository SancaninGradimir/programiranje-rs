{"componentChunkName":"component---src-templates-challenges-classic-show-tsx","path":"/learn/javascript-algorithms-and-data-structures-v8/learn-introductory-javascript-by-building-a-pyramid-generator/step-17","result":{"data":{"challengeNode":{"challenge":{"block":"learn-introductory-javascript-by-building-a-pyramid-generator","demoType":null,"title":"Korak 17","description":"<section id=\"description\">\n<p>Možete takođe izvršiti oduzimanje (<code>-</code>), množenje (<code>*</code>) i deljenje (<code>/</code>). Molimo vas da pokušate da koristite operacije i brojeve u vašem <code>console.log</code>. Kada budete spremni da nastavite, uklonite <code>console.log</code>.</p>\n</section>","id":"660ef857f2806aa626d29d17","hasEditableBoundaries":true,"instructions":"","notes":null,"challengeType":1,"helpCategory":"JavaScript","videoUrl":null,"superBlock":"javascript-algorithms-and-data-structures-v8","translationPending":false,"forumTopicId":null,"hooks":null,"fields":{"slug":"/learn/javascript-algorithms-and-data-structures-v8/learn-introductory-javascript-by-building-a-pyramid-generator/step-17"},"required":[],"usesMultifileEditor":true,"challengeFiles":[{"fileKey":"scriptjs","ext":"js","name":"script","contents":"let character = 'Hello';\nlet count = 8;\nconsole.log(count + 1);","head":null,"tail":null,"editableRegionBoundaries":[1,4],"history":["script.js"]}],"saveSubmissionToDB":null,"tests":[{"text":"<p>Ne bi trebalo da imaš <code>console.log()</code> u svoj kod.</p>","testString":"assert.notMatch(__helpers.removeJSComments(code), /console/);"},{"text":"<p>Vaš parametar za <code>character</code> treba da ima vrednost od <code>\"Hello\"</code>.</p>","testString":"assert.equal(character, \"Hello\");"},{"text":"<p>Vaš parametar za <code>count</code> bi trebalo da ima vrednost od <code>8</code>.</p>","testString":"assert.equal(count, 8);"}]}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/javascript-algorithms-and-data-structures-v8/#learn-introductory-javascript-by-building-a-pyramid-generator","dashedName":"step-17","certification":"javascript-algorithms-and-data-structures-v8","disableLoopProtectTests":false,"disableLoopProtectPreview":false,"superBlock":"javascript-algorithms-and-data-structures-v8","chapter":null,"module":null,"block":"learn-introductory-javascript-by-building-a-pyramid-generator","isFirstStep":false,"template":null,"required":[],"isLastChallengeInBlock":false,"nextChallengePath":"/learn/javascript-algorithms-and-data-structures-v8/learn-introductory-javascript-by-building-a-pyramid-generator/step-18","prevChallengePath":"/learn/javascript-algorithms-and-data-structures-v8/learn-introductory-javascript-by-building-a-pyramid-generator/step-16","id":"660ef857f2806aa626d29d17","saveSubmissionToDB":null},"projectPreview":{"challengeData":{"challengeType":1,"challengeFiles":[{"name":"script","ext":"js","contents":"const character = \"!\";\nconst count = 10;\nconst rows = [];\nlet inverted = false;\n\nfunction padRow(rowNumber, rowCount) {\n  return \" \".repeat(rowCount - rowNumber) + character.repeat(2 * rowNumber - 1) + \" \".repeat(rowCount - rowNumber);\n}\n\nfor (let i = 1; i <= count; i++) {\n  if (inverted) {\n    rows.unshift(padRow(i, count));\n  } else {\n    rows.push(padRow(i, count));\n  }\n}\n\nlet result = \"\"\n\nfor (const row of rows) {\n  result = result + row + \"\\n\";\n}\n\nconsole.log(result);","history":["script.js"],"fileKey":"scriptjs"}]}},"id":"/learn/javascript-algorithms-and-data-structures-v8/learn-introductory-javascript-by-building-a-pyramid-generator/step-17"}},"staticQueryHashes":["3858520367"],"slicesMap":{}}