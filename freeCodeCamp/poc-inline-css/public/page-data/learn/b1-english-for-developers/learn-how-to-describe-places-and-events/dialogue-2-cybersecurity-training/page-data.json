{"componentChunkName":"component---src-templates-challenges-generic-show-tsx","path":"/learn/b1-english-for-developers/learn-how-to-describe-places-and-events/dialogue-2-cybersecurity-training","result":{"data":{"challengeNode":{"challenge":{"assignments":["<p>Gledaj video.</p>"],"bilibiliIds":null,"block":"learn-how-to-describe-places-and-events","challengeType":21,"description":"<section id=\"description\">\n<p>Pogledajte video ispod da biste razumeli kontekst sledećih lekcija.</p>\n</section>","nodules":null,"explanation":null,"helpCategory":"English","instructions":"","fields":{"slug":"/learn/b1-english-for-developers/learn-how-to-describe-places-and-events/dialogue-2-cybersecurity-training"},"questions":[],"scene":{"setup":{"background":"company2-breakroom.png","characters":[{"character":"Anna","position":{"x":-25,"y":0,"z":1},"opacity":null},{"character":"Brian","position":{"x":125,"y":0,"z":1},"opacity":null}],"audio":{"filename":"B1_1-2.mp3","startTime":1,"startTimestamp":null,"finishTimestamp":null},"alwaysShowDialogue":true},"commands":[{"background":null,"character":"Anna","position":{"x":25,"y":0,"z":1},"opacity":null,"startTime":0,"finishTime":null,"dialogue":null},{"background":null,"character":"Brian","position":{"x":70,"y":0,"z":1},"opacity":null,"startTime":0.5,"finishTime":null,"dialogue":null},{"background":null,"character":"Anna","position":null,"opacity":null,"startTime":1,"finishTime":5.16,"dialogue":{"text":"Hi, Brian. Do you have a moment? I want to talk to you about our cybersecurity training.","align":"left"}},{"background":null,"character":"Brian","position":null,"opacity":null,"startTime":5.8,"finishTime":7.38,"dialogue":{"text":"Sure, Anna. What's on your mind?","align":"right"}},{"background":null,"character":"Anna","position":null,"opacity":null,"startTime":7.88,"finishTime":12.92,"dialogue":{"text":"It concerns me that some employees might not be using strong passwords. Do we cover this in our training?","align":"left"}},{"background":null,"character":"Brian","position":null,"opacity":null,"startTime":13.5,"finishTime":21.04,"dialogue":{"text":"We touch on it, but perhaps not in enough detail. I'm currently adding a new section focused on password security now.","align":"right"}},{"background":null,"character":"Anna","position":null,"opacity":null,"startTime":21.46,"finishTime":24.16,"dialogue":{"text":"Sounds good. How often do we hold these training sessions?","align":"left"}},{"background":null,"character":"Brian","position":null,"opacity":null,"startTime":24.38,"finishTime":30.3,"dialogue":{"text":"We have them quarterly, but I'm planning an extra session next month because of recent security threats.","align":"right"}},{"background":null,"character":"Brian","position":null,"opacity":null,"startTime":30.86,"finishTime":32.78,"dialogue":{"text":"Attendance is mandatory, right?","align":"right"}},{"background":null,"character":"Anna","position":null,"opacity":null,"startTime":33.2,"finishTime":34.24,"dialogue":{"text":"Yes, it's mandatory.","align":"left"}},{"background":null,"character":"Anna","position":null,"opacity":null,"startTime":34.5,"finishTime":35.74,"dialogue":{"text":"And how long are these sessions?","align":"left"}},{"background":null,"character":"Brian","position":null,"opacity":null,"startTime":36.14,"finishTime":44.36,"dialogue":{"text":"Usually two hours. I'm thinking of using real life scenarios this time, especially for identifying phishing attempts. What do you think?","align":"right"}},{"background":null,"character":"Anna","position":null,"opacity":null,"startTime":44.86,"finishTime":49.96,"dialogue":{"text":"Using real life scenarios makes the training more relevant. When do you think this new module will be ready?","align":"left"}},{"background":null,"character":"Brian","position":null,"opacity":null,"startTime":50.3,"finishTime":56.22,"dialogue":{"text":"I'm aiming to have it ready to roll out by the end of the week. The team is working on it as we speak.","align":"right"}},{"background":null,"character":"Anna","position":null,"opacity":null,"startTime":56.74,"finishTime":62.6,"dialogue":{"text":"That's great to hear. I appreciate your proactive approach to this, Brian. Let's touch base again once the module is ready.","align":"left"}},{"background":null,"character":"Brian","position":{"x":125,"y":0,"z":1},"opacity":null,"startTime":63.1,"finishTime":null,"dialogue":null},{"background":null,"character":"Anna","position":{"x":-25,"y":0,"z":1},"opacity":null,"startTime":63.6,"finishTime":null,"dialogue":null}]},"superBlock":"b1-english-for-developers","tests":[],"title":"Dialog 2: Sajberbezbednosna obuka","transcript":null,"translationPending":false,"videoId":null,"videoLocaleIds":null}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/b1-english-for-developers/#learn-how-to-describe-places-and-events","dashedName":"dialogue-2-cybersecurity-training","certification":"b1-english-for-developers","disableLoopProtectTests":false,"disableLoopProtectPreview":false,"superBlock":"b1-english-for-developers","chapter":null,"module":null,"block":"learn-how-to-describe-places-and-events","isFirstStep":false,"template":null,"required":[],"isLastChallengeInBlock":false,"nextChallengePath":"/learn/b1-english-for-developers/learn-how-to-describe-places-and-events/task-46","prevChallengePath":"/learn/b1-english-for-developers/learn-how-to-describe-places-and-events/task-45","id":"66b4f10361231d18f9fcf464","saveSubmissionToDB":null},"projectPreview":{"challengeData":{"challengeType":19,"challengeFiles":[]}},"id":"/learn/b1-english-for-developers/learn-how-to-describe-places-and-events/dialogue-2-cybersecurity-training"}},"staticQueryHashes":["3858520367"],"slicesMap":{}}