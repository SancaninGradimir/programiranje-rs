{"componentChunkName":"component---src-templates-challenges-classic-show-tsx","path":"/learn/front-end-development-libraries/jquery/disable-an-element-using-jquery","result":{"data":{"challengeNode":{"challenge":{"block":"jquery","demoType":null,"title":"Onemogući element koristeći jQuery","description":"<section id=\"description\">\n<p>Takođe možete promeniti svojstva koja nisu od CSS za elemente HTML koristeći jQuery. Na primer, možete onemogućiti dugmad.</p>\n<p>Kada onemogućite dugme, ono će biti sive boje i više se ne može kliknuti.</p>\n<p>jQuery ima funkciju nazvanu <code>.prop()</code> koja omogućava menjanje svojstava elemenata.</p>\n<p>Evo kako možete da onemogućite sva dugmad:</p>\n<pre><code class=\"language-js\">$(\"button\").prop(\"disabled\", true);\n</code></pre>\n<p>Zimski taster za <code>target1</code> samo.</p>\n</section>","id":"bad87fee1348bd9aed808826","hasEditableBoundaries":false,"instructions":"","notes":null,"challengeType":6,"helpCategory":"JavaScript","videoUrl":null,"superBlock":"front-end-development-libraries","translationPending":false,"forumTopicId":17563,"hooks":null,"fields":{"slug":"/learn/front-end-development-libraries/jquery/disable-an-element-using-jquery"},"required":[{"link":"https://cdnjs.cloudflare.com/ajax/libs/twitter-bootstrap/3.3.7/css/bootstrap.css","src":null},{"link":null,"src":"https://code.jquery.com/jquery-3.6.0.min.js"}],"usesMultifileEditor":false,"challengeFiles":[{"fileKey":"indexhtml","ext":"html","name":"index","contents":"<script>\r\n  $(document).ready(function() {\r\n    $(\"#target1\").css(\"color\", \"red\");\r\n\r\n  });\r\n</script>\r\n\r\n<!-- Only change code above this line -->\r\n\r\n<div class=\"container-fluid\">\r\n  <h3 class=\"text-primary text-center\">jQuery Playground</h3>\r\n  <div class=\"row\">\r\n    <div class=\"col-xs-6\">\r\n      <h4>#left-well</h4>\r\n      <div class=\"well\" id=\"left-well\">\r\n        <button class=\"btn btn-default target\" id=\"target1\">#target1</button>\r\n        <button class=\"btn btn-default target\" id=\"target2\">#target2</button>\r\n        <button class=\"btn btn-default target\" id=\"target3\">#target3</button>\r\n      </div>\r\n    </div>\r\n    <div class=\"col-xs-6\">\r\n      <h4>#right-well</h4>\r\n      <div class=\"well\" id=\"right-well\">\r\n        <button class=\"btn btn-default target\" id=\"target4\">#target4</button>\r\n        <button class=\"btn btn-default target\" id=\"target5\">#target5</button>\r\n        <button class=\"btn btn-default target\" id=\"target6\">#target6</button>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</div>","head":null,"tail":null,"editableRegionBoundaries":[],"history":["index.html"]}],"saveSubmissionToDB":null,"tests":[{"text":"<p>Vaše dugme za <code>target1</code> mora biti onemogućen.</p>","testString":"assert(\r\n  $('#target1') &&\r\n    $('#target1').prop('disabled') &&\r\n    code.match(/[\"']disabled[\"'],( true|true)/g)\r\n);"},{"text":"<p>Nema drugih dugmadi koja treba isključiti.</p>","testString":"assert($('#target2') && !$('#target2').prop('disabled'));"},{"text":"<p>Treba da koristiš jQuery samo da dodaš ove klase na element.</p>","testString":"assert(!code.match(/disabled[^<]*>/g));"}]}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/front-end-development-libraries/#jquery","dashedName":"disable-an-element-using-jquery","certification":"front-end-development-libraries","disableLoopProtectTests":false,"disableLoopProtectPreview":false,"superBlock":"front-end-development-libraries","chapter":null,"module":null,"block":"jquery","isFirstStep":false,"template":null,"required":[{"link":"https://cdnjs.cloudflare.com/ajax/libs/twitter-bootstrap/3.3.7/css/bootstrap.css","src":null},{"link":null,"src":"https://code.jquery.com/jquery-3.6.0.min.js"}],"isLastChallengeInBlock":false,"nextChallengePath":"/learn/front-end-development-libraries/jquery/change-text-inside-an-element-using-jquery","prevChallengePath":"/learn/front-end-development-libraries/j