    {
      "text": "<p>Trebalo bi da ima četvrti element <code>tr</code> unutar elemenata <code>tbody</code>.</p>",
      "testString": "assert.lengthOf(document.querySelectorAll(\"tbody tr\"), 4);"
    },
    {
      "text": "<p>Trebalo bi da imaš element <code>th</code> unutar četvrtog elementa <code>tr</code>.</p>",
      "testString": "assert.isNotNull(document.querySelectorAll(\"tbody tr\")[3].querySelector(\"th\"));"
    },
    {
      "text": "<p>Vaše polje <code>th</code> treba da ima tekstualni sadržaj od <code>11:30 AM</code>.</p>",
      "testString": "assert.strictEqual(document.querySelectorAll(\"tbody tr\")[3].querySelector(\"th\")?.textContent.trim(), \"11:30 AM\");"
    },
    {
      "text": "<p>Vaše polje od <code>th</code> mora imati atribut polja <code>scope</code>, postavljeno na <code>\"row\"</code>.</p>",
      "testString": "assert.strictEqual(document.querySelectorAll(\"tbody tr\")[3].querySelector(\"th\")?.getAttribute(\"scope\"), \"row\");"
    },
    {
      "text": "<p>Vaš četvrti element za <code>tr</code> treba da ima tri elementa od <code>td</code>.</p>",
      "testString": "assert.lengthOf(document.querySelectorAll(\"tbody tr\")[3].querySelectorAll(\"td\"), 3);"
