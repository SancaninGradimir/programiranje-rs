{"componentChunkName":"component---src-templates-challenges-classic-show-tsx","path":"/learn/responsive-web-design-v9/workshop-accessible-audio-controller/step-6","result":{"data":{"challengeNode":{"challenge":{"block":"workshop-accessible-audio-controller","demoType":null,"title":"Korak 6","description":"<section id=\"description\">\n<p>Kao što ste zapamtili iz prethodnih lekcija, atribut elementa <code>aria-labelledby</code> koristi se kada postoji postojeći tekst na stranici koji može da služi kao oznaka. U ovom slučaju, dodali ste atribut elementa <code>id</code> vašim elementima <code>span</code> koji će sada biti korišćeni ovde.</p>\n<p>Dodaj svojstvo elementa <code>aria-labelledby</code> za element <code>input</code>, kada je postavljeno na <code>volume-label volume-description</code>.</p>\n</section>","id":"68ed4204ab7edc66b6cb2383","hasEditableBoundaries":true,"instructions":"","notes":null,"challengeType":0,"helpCategory":"HTML-CSS","videoUrl":null,"superBlock":"responsive-web-design-v9","translationPending":false,"forumTopicId":null,"hooks":null,"fields":{"slug":"/learn/responsive-web-design-v9/workshop-accessible-audio-controller/step-6"},"required":[],"usesMultifileEditor":true,"challengeFiles":[{"fileKey":"indexhtml","ext":"html","name":"index","contents":"<!DOCTYPE html>\n<html lang=\"en\">\n  <head>\n    <meta charset=\"UTF-8\">\n    <title>Accessible Controls</title>\n  </head>\n  <body>\n\n    <h1>Audio Controls</h1>\n\n    <button type=\"button\">Play</button>\n\n    <div>\n      <span id=\"volume-label\">Volume</span>\n      <span id=\"volume-description\">Adjust the sound level</span>\n    <input type=\"range\" min=\"0\" max=\"100\" value=\"50\">\n    </div>\n\n  </body>\n</html>","head":null,"tail":null,"editableRegionBoundaries":[15,17],"history":["index.html"]}],"saveSubmissionToDB":null,"tests":[{"text":"<p>Vaš element za <code>input</code> mora imati atribut elementa <code>aria-labelledby</code>.</p>","testString":"const inputEl = document.querySelector('div > span:nth-of-type(2) + input');\nassert.isTrue(inputEl?.hasAttribute('aria-labelledby'));"},{"text":"<p>Element vašeg <code>input</code> mora imati svojstvo elementa <code>aria-labelledby</code> sa vrednošću <code>volume-label volume-description</code>.</p>","testString":"const inputEl = document.querySelector('div > span:nth-of-type(2) + input');\nconst ariaLabelledbyAttr = inputEl?.getAttribute('aria-labelledby');\nassert.oneOf(ariaLabelledbyAttr, ['volume-label volume-description', 'volume-description volume-label']);"}]}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/responsive-web-design-v9/#workshop-accessible-audio-controller","dashedName":"step-6","certification":"responsive-web-design-v9","disableLoopProtectTests":false,"disableLoopProtectPreview":false,"superBlock":"responsive-web-design-v9","chapter":"html","module":"html-and-accessibility","block":"workshop-accessible-audio-controller","isFirstStep":false,"template":null,"required":[],"isLastChallengeInBlock":false,"nextChallengePath":"/learn/responsive-web-design-v9/workshop-accessible-audio-controller/step-7","prevChallengePath":"/learn/responsive-web-design-v9/workshop-accessible-audio-controller/step-5","id":"68ed4204ab7edc66b6cb2383","saveSubmissionToDB":null},"projectPreview":{"challengeData":{"challengeType":0,"challengeFiles":[{"name":"index","ext":"html","contents":"<!DOCTYPE html>\n<html lang=\"en\">\n  <head>\n    <meta charset=\"UTF-8\">\n    <title>Accessible Controls</title>\n  </head>\n  <body>\n\n    <h1>Audio Controls</h1>\n\n    <button type=\"button\">Play</button>\n\n    <div>\n      <span id=\"volume-label\">Volume</span>\n      <span id=\"volume-description\">Adjust the sound level</span>\n      <input type=\"range\" min=\"0\" max=\"100\" value=\"50\"\n             aria-labelledby=\"volume-label volume-description\">\n    </div>\n\n    <button type=\"button\">Mute</button>\n\n  </body>\n</html>","history":["index.html"],"fileKey":"indexhtml"}]}},"id":"