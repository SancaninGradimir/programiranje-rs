{"componentChunkName":"component---src-templates-challenges-classic-show-tsx","path":"/learn/responsive-web-design-v9/workshop-cat-photo-app/step-2","result":{"data":{"challengeNode":{"challenge":{"block":"workshop-cat-photo-app","demoType":null,"title":"Korak 2","description":"<section id=\"description\">\n<p>Ispod elementa <code>h1</code>, dodaj element <code>h2</code> sa ovim tekstovima:</p>\n<p><code>Cat Photos</code></p>\n</section>","id":"5dc1798ff86c76b9248c6eb3","hasEditableBoundaries":true,"instructions":"","notes":null,"challengeType":0,"helpCategory":"HTML-CSS","videoUrl":null,"superBlock":"responsive-web-design-v9","translationPending":false,"forumTopicId":null,"hooks":null,"fields":{"slug":"/learn/responsive-web-design-v9/workshop-cat-photo-app/step-2"},"required":[],"usesMultifileEditor":true,"challengeFiles":[{"fileKey":"indexhtml","ext":"html","name":"index","contents":"<html>\n  <body>\n    <h1>CatPhotoApp</h1>\n    \n  </body>\n</html>","head":null,"tail":null,"editableRegionBoundaries":[3,5],"history":["index.html"]}],"saveSubmissionToDB":null,"tests":[{"text":"<p>Tvoj element od <code>h1</code> mora imati otvorenu oznaku. Otvarajuće oznake imaju ovu sintaksu: <code>&#x3C;elementName></code>.</p>","testString":"assert.exists(document.querySelector('h1'));"},{"text":"<p>Tvoj element <code>h1</code> treba da ima zatvarajući tag. Zatvarajući tagovi imaju ovu sintaksu: <code>&#x3C;/elementName></code>.</p>","testString":"assert.match(code, /<\\/h1\\>/);"},{"text":"<p>Trebalo bi da ima samo jedan element od <code>h1</code>. Uklonite višak.</p>","testString":"assert.lengthOf(document.querySelectorAll('h1'), 1);"},{"text":"<p>Tekst vašeg elementa/polja <code>h1</code> treba da bude 'CatPhotoApp'. Ostavili ste tekst ili postoje greške u pravopisu.</p>","testString":"assert.equal(document.querySelector('h1')?.innerText?.trim().toLowerCase(), 'catphotoapp');"},{"text":"<p>Etikete za <code>h2</code> bi trebalo da budu u malim slovima. Prema ugovoru, sve etikete za HTML se pišu malim slovima.</p>","testString":"assert.notMatch(code, /<\\/?H2>/);"},{"text":"<p>Tvoj element od <code>h2</code> treba da ima otvarajuću oznaku. Otvarajuće oznake imaju ovu sintaksu: <code>&#x3C;elementName></code>.</p>","testString":"assert.exists(document.querySelector('h2'));"},{"text":"<p>Vaš element za <code>h2</code> treba da ima zatvarajući tag. Zatvarajući tagovi sadrže <code>/</code> nakon karaktera <code>&#x3C;</code>.</p>","testString":"assert.match(code, /<\\/h2\\>/);"},{"text":"<p>Sadržaj vašeg elementa za <code>h2</code> treba da bude <code>Cat Photos</code>. Umestite tekst <code>Cat Photos</code> samo između otvarajućih i zatvarajućih oznaka za <code>h2</code>.</p>","testString":"assert.equal(document.querySelector('h2')?.innerText?.trim().replace(/\\s+/g, ' ').toLowerCase(), 'cat photos');"},{"text":"<p>Vaš element za <code>h2</code> treba biti ispod elementa <code>h1</code>. Element za <code>h1</code> je važniji i treba biti iznad elementa <code>h2</code>.</p>","testString":"const collection = [...document.querySelectorAll('h1,h2')].map(\n  (node) => node.nodeName\n);\nassert.isBelow(collection.indexOf('H1'), collection.indexOf('H2'));"}]}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/responsive-web-design-v9/#workshop-cat-photo-app","dashedName":"step-2","certification":"responsive-web-design-v9","disableLoopProtectTests":false,"disableLoopProtectPreview":false,"superBlock":"responsive-web-design-v9","chapter":"html","module":"basic-html","block":"workshop-cat-photo-app","isFirstStep":false,"template":null,"required":[],"isLastChallengeInBlock":false,"nextChallengePath":"/learn/responsive-web-design-v9/workshop-cat-photo-app/step-3","prevChallengePath":"/learn/responsive-web-design-v9/workshop-cat-photo-app/step-1","id":"5dc1798ff86c76b9248c6eb3","saveSubmissionToDB":null},"projectPreview":{"challengeData":{"challengeType":0,"challengeFiles":[{"name":"index","ext":"html","contents":"<!DOCTYPE html>\n<html lang=\"en\">\n  <head>\n    <meta charset=\"UTF-8\">\n    <title>CatPhotoApp</title>\n  </head>\n  <body>\n    <main>\n      <h1>CatPhotoApp</h1>\n      <section>\n        <h2>Cat Photos</h2>\n        <p>Everyone loves <a href=\"https://cdn.freecodecamp.org/curriculum/cat-photo-app/running-cats.jpg\">cute cats</a> online!</p>\n        <p>See more <a target=\"_blank\" href=\"https://freecatphotoapp.com\">cat photos</a> in our gallery.</p>\n        <a href=\"https://freecatphotoapp.com\"><img src=\"https://cdn.freecodecamp.org/curriculum/cat-photo-app/relaxing-cat.jpg\" alt=\"A cute orange cat lying on its back.\"></a>\n      </section>\n      <section>\n        <h2>Cat Lists</h2>\n        <h3>Things cats love:</h3>\n        <ul>\n          <li>catnip</li>\n          <li>laser pointers</li>\n          <li>lasagna</li>\n        </ul>\n        <figure>\n          <img src=\"https://cdn.freecodecamp.org/curriculum/cat-photo-app/lasagna.jpg\" alt=\"A slice of lasagna on a plate.\">\n          <figcaption>Cats <em>love</em> lasagna.</figcaption>  \n        </figure>\n        <h3>Top 3 things cats hate:</h3>\n        <ol>\n          <li>flea treatment</li>\n          <li>thunder</li>\n          <li>other cats</li>\n        </ol>\n        <figure>\n          <img src=\"https://cdn.freecodecamp.org/curriculum/cat-photo-app/cats.jpg\" alt=\"Two tabby kittens sleeping together on a couch.\">\n          <figcaption>Cats <strong>hate</strong> other cats.</figcaption>  \n        </figure>\n      </section>\n    </main>\n    <footer>\n      <p>\n        No Copyright - <a href=\"https://www.freecodecamp.org\">freeCodeCamp.org</a>\n      </p>\n    </footer>\n  </body>\n</html>","history":["index.html"],"fileKey":"indexhtml"}]}},"id":"/learn/responsive-web-design-v9/workshop-cat-photo-app/step-2"}},"staticQueryHashes":["3858520367"],"slicesMap":{}}