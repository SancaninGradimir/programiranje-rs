{"componentChunkName":"component---src-templates-challenges-generic-show-tsx","path":"/learn/b1-english-for-developers/learn-how-to-use-conditionals/dialogue-1-if-it-doesnt-boot","result":{"data":{"challengeNode":{"challenge":{"assignments":["<p>Gledaj video.</p>"],"bilibiliIds":null,"block":"learn-how-to-use-conditionals","challengeType":21,"description":"<section id=\"description\">\n<p>Pogledajte video dole/ispod kako biste razumeli kontekst predstojećih lekcija.</p>\n</section>","nodules":null,"explanation":null,"helpCategory":"English","instructions":"","fields":{"slug":"/learn/b1-english-for-developers/learn-how-to-use-conditionals/dialogue-1-if-it-doesnt-boot"},"questions":[],"scene":{"setup":{"background":"company2-center.png","characters":[{"character":"Sarah","position":{"x":-25,"y":0,"z":1},"opacity":null},{"character":"Mark","position":{"x":125,"y":0,"z":1},"opacity":null}],"audio":{"filename":"B1_7-1.mp3","startTime":1,"startTimestamp":null,"finishTimestamp":null},"alwaysShowDialogue":true},"commands":[{"background":null,"character":"Sarah","position":{"x":25,"y":0,"z":1},"opacity":null,"startTime":0,"finishTime":null,"dialogue":null},{"background":null,"character":"Mark","position":{"x":70,"y":0,"z":1},"opacity":null,"startTime":0.5,"finishTime":null,"dialogue":null},{"background":null,"character":"Sarah","position":null,"opacity":null,"startTime":1,"finishTime":4.26,"dialogue":{"text":"Hey Mark, have you noticed that some computers aren't booting properly?","align":"left"}},{"background":null,"character":"Mark","position":null,"opacity":null,"startTime":4.7,"finishTime":10,"dialogue":{"text":"Yes, I have. If the power cable isn't connected securely, the computer won't turn on. Did you check that?","align":"right"}},{"background":null,"character":"Sarah","position":null,"opacity":null,"startTime":10.32,"finishTime":14.78,"dialogue":{"text":"I did, but the problem seems to be more than just the power connection. Have you seen anything similar?","align":"left"}},{"background":null,"character":"Mark","position":null,"opacity":null,"startTime":15.32,"finishTime":19.46,"dialogue":{"text":"Sometimes if the BIOS is corrupted, it prevents the computer from starting.","align":"right"}},{"background":null,"character":"Mark","position":null,"opacity":null,"startTime":19.76,"finishTime":22.06,"dialogue":{"text":"If that's the case, it can be tricky to fix.","align":"right"}},{"background":null,"character":"Sarah","position":null,"opacity":null,"startTime":22.84,"finishTime":27.08,"dialogue":{"text":"Yeah, it can. Speaking of which, another thing we can check is if the hard drive is failing.","align":"left"}},{"background":null,"character":"Sarah","position":null,"opacity":null,"startTime":27.4,"finishTime":30.36,"dialogue":{"text":"If it's not functioning, the operating system won't load, will it?","align":"left"}},{"background":null,"character":"Mark","position":null,"opacity":null,"startTime":30.36,"finishTime":37.4,"dialogue":{"text":"Right, it won't. And if there's a software crash, it can be because of incompatible drivers or outdated software.","align":"right"}},{"background":null,"character":"Mark","position":null,"opacity":null,"startTime":37.9,"finishTime":39.64,"dialogue":{"text":"Have you updated the drivers recently?","align":"right"}},{"background":null,"character":"Sarah","position":null,"opacity":null,"startTime":40.16,"finishTime":42.54,"dialogue":{"text":"Not yet. I was thinking about updating them this week.","align":"left"}},{"background":null,"character":"Sarah","position":null,"opacity":null,"startTime":42.84,"finishTime":44.6,"dialogue":{"text":"What else could cause software to crash?","align":"left"}},{"background":null,"character":"Mark","position":null,"opacity":null,"startTime":45.1,"finishTime":47.92,"dialogue":{"text":"If the application has memory leaks, it can lead to crashes.","align":"right"}},{"background":null,"character":"Mark","position":null,"opacity":null,"startTime":48.5,"finishTime":51.94,"dialogue":{"text":"If you notice the system slowing down or freezing, that's a sign.","align":"right"}},{"background":null,"character":"Sarah","position":null,"opacity":null,"startTime":52.48,"finishTime":54.24,"dialogue":{"text":"Absolutely. Thanks for the insights, Mark.","align":"left"}},{"background":null,"character":"Mark","position":{"x":125,"y":0,"z":1},"opacity":null,"startTime":54.74,"finishTime":null,"dialogue":null},{"background":null,"character":"Sarah","position":{"x":-25,"y":0,"z":1},"opacity":null,"startTime":55.24,"finishTime":null,"dialogue":null}]},"superBlock":"b1-english-for-developers","tests":[],"title":"Dijalog 1: U slučaju da se ne pokrene","transcript":null,"translationPending":false,"videoId":null,"videoLocaleIds":null}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/b1-english-for-developers/#learn-how-to-use-conditionals","dashedName":"dialogue-1-if-it-doesnt-boot","certification":"b1-english-for-developers","disableLoopProtectTests":false,"disableLoopProtectPreview":false,"superBlock":"b1-english-for-developers","chapter":null,"module":null,"block":"learn-how-to-use-conditionals","isFirstStep":true,"template":null,"required":[],"isLastChallengeInBlock":false,"nextChallengePath":"/learn/b1-english-for-developers/learn-how-to-use-conditionals/task-1","prevChallengePath":"/learn/b1-english-for-developers/en-b1-quiz-future-continuous-actions/en-b1-quiz-future-continuous-actions","id":"66609feb0374fd5b449eabcf","saveSubmissionToDB":null},"projectPreview":{"challengeData":{"challengeType":19,"challengeFiles":[]}},"id":"/learn/b1-english-for-developers/learn-how-to-use-conditionals/dialogue-1-if-it-doesnt-boot"}},"staticQueryHashes":["3858520367"],"slicesMap":{}}