{"componentChunkName":"component---src-templates-challenges-classic-show-tsx","path":"/learn/basic-html/workshop-cat-photo-app/step-34","result":{"data":{"challengeNode":{"challenge":{"block":"workshop-cat-photo-app","demoType":null,"title":"Korak 34","description":"<section id=\"description\">\n<p>Funkcija <code>strong</code> se koristi za prikazivanje da određeni tekst ima veliku važnost ili je hitan.</p>\n<p>U <code>figcaption</code> koji si dodao, prikaži da <code>hate</code> ima veliku važnost za obavijanje u elementu <code>strong</code>.</p>\n</section>","id":"5ef9b03c81a63668521804d4","hasEditableBoundaries":true,"instructions":"","notes":null,"challengeType":0,"helpCategory":"HTML-CSS","videoUrl":null,"superBlock":"basic-html","translationPending":false,"forumTopicId":null,"hooks":null,"fields":{"slug":"/learn/basic-html/workshop-cat-photo-app/step-34"},"required":[],"usesMultifileEditor":true,"challengeFiles":[{"fileKey":"indexhtml","ext":"html","name":"index","contents":"<html>\n  <body>\n    <main>\n      <h1>CatPhotoApp</h1>\n      <section>\n        <h2>Cat Photos</h2>\n        <p>Everyone loves <a href=\"https://cdn.freecodecamp.org/curriculum/cat-photo-app/running-cats.jpg\">cute cats</a> online!</p>\n        <p>See more <a target=\"_blank\" href=\"https://freecatphotoapp.com\">cat photos</a> in our gallery.</p>\n        <a href=\"https://freecatphotoapp.com\"><img src=\"https://cdn.freecodecamp.org/curriculum/cat-photo-app/relaxing-cat.jpg\" alt=\"A cute orange cat lying on its back.\"></a>\n      </section>\n      <section>\n        <h2>Cat Lists</h2>\n        <h3>Things cats love:</h3>\n        <ul>\n          <li>catnip</li>\n          <li>laser pointers</li>\n          <li>lasagna</li>\n        </ul>\n        <figure>\n          <img src=\"https://cdn.freecodecamp.org/curriculum/cat-photo-app/lasagna.jpg\" alt=\"A slice of lasagna on a plate.\">\n          <figcaption>Cats <em>love</em> lasagna.</figcaption>  \n        </figure>\n        <h3>Top 