  "tests": [
    {
      "text": "<p><code>IBeforeExceptC</code> treba da bude funkcija.</p>",
      "testString": "assert(typeof IBeforeExceptC == 'function');"
    },
    {
      "text": "<p><code>IBeforeExceptC(\"receive\")</code> treba da vrati <code>true</code> ili <code>false</code>.</p>",
      "testString": "assert(typeof IBeforeExceptC('receive') == 'boolean');"
