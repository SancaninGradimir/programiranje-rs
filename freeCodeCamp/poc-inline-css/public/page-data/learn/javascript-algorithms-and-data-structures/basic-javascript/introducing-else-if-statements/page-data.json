{"componentChunkName":"component---src-templates-challenges-classic-show-tsx","path":"/learn/javascript-algorithms-and-data-structures/basic-javascript/introducing-else-if-statements","result":{"data":{"challengeNode":{"challenge":{"block":"basic-javascript","demoType":null,"title":"Uvod u else if Iskaze","description":"<section id=\"description\">\n<p>Ako imate vise uslova koje treba obraditi, mozete povezati <code>if</code> iskaze sa <code>else if</code> iskazima.</p>\n<pre><code class=\"language-js\">if (num > 15) {\n  return \"Bigger than 15\";\n} else if (num &#x3C; 5) {\n  return \"Smaller than 5\";\n} else {\n  return \"Between 5 and 15\";\n}\n</code></pre>\n</section>","id":"56533eb9ac21ba0edf2244db","hasEditableBoundaries":false,"instructions":"<section id=\"instructions\">\n<p>Izmenite logiku tako da koristi <code>else if</code> iskaze.</p>\n</section>","notes":null,"challengeType":1,"helpCategory":"JavaScript","videoUrl":null,"superBlock":"javascript-algorithms-and-data-structures","translationPending":false,"forumTopicId":18206,"hooks":null,"fields":{"slug":"/learn/javascript-algorithms-and-data-structures/basic-javascript/introducing-else-if-statements"},"required":[],"usesMultifileEditor":false,"challengeFiles":[{"fileKey":"scriptjs","ext":"js","name":"script","contents":"function testElseIf(val) {\n  if (val > 10) {\n    return \"Greater than 10\";\n  }\n\n  if (val < 5) {\n    return \"Smaller than 5\";\n  }\n\n  return \"Between 5 and 10\";\n}\n\ntestElseIf(7);","head":null,"tail":null,"editableRegionBoundaries":[],"history":["script.js"]}],"saveSubmissionToDB":null,"tests":[{"text":"<p>Treba da imate bar dva <code>else</code> iskaza</p>","testString":"assert(__helpers.removeJSComments(code).match(/else/g).length > 1);"},{"text":"<p>Treba da imate bar dva <code>if</code> iskaza</p>","testString":"assert(__helpers.removeJSComments(code).match(/if/g).length > 1);"},{"text":"<p>Treba da imate odgovarajuce vitičaste zagrade za svaki <code>if else</code> blok.</p>","testString":"assert(\n  __helpers.removeJSComments(code).match(\n    /if\\s*\\((.+)\\)\\s*\\{[\\s\\S]+\\}\\s*else\\s+if\\s*\\((.+)\\)\\s*\\{[\\s\\S]+\\}\\s*else\\s*\\{[\\s\\S]+\\s*\\}/\n  )\n);"},{"text":"<p><code>testElseIf(0)</code> treba da vrati string <code>Smaller than 5</code></p>","testString":"assert(testElseIf(0) === 'Smaller than 5');"},{"text":"<p><code>testElseIf(5)</code> treba da vrati string <code>Between 5 and 10</code></p>","testString":"assert(testElseIf(5) === 'Between 5 and 10');"},{"text":"<p><code>testElseIf(7)</code> treba da vrati string <code>Between 5 and 10</code></p>","testString":"assert(testElseIf(7) === 'Between 5 and 10');"},{"text":"<p><code>testElseIf(10)</code> treba da vrati string <code>Between 5 and 10</code></p>","testString":"assert(testElseIf(10) === 'Between 5 and 10');"},{"text":"<p><code>testElseIf(12)</code> treba da vrati string <code>Greater than 10</code></p>","testString":"assert(testElseIf(12) === 'Greater than 10');"}]}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/javascript-algorithms-and-data-structures/#basic-javascript","dashedName":"introducing-else-if-statements","certification":"javascript-algorithms-and-data-structures","disableLoopProtectTests":false,"disableLoopProtectPreview":false,"superBlock":"javascript-algorithms-and-data-structures","chapter":null,"module":null,"block":"basic-javascript","isFirstStep":false,"template":null,"required":[],"isLastChallengeInBlock":false,"nextChallengePath":"/learn/javascript-algorithms-and-data-structures/basic-javascript/logical-order-in-if-else-statements","prevChallengePath":"/learn/javascript-algorithms-and-data-structures/basic-javascript/introducing-else-statements","id":"56533eb9ac21ba0edf2244db","saveSubmissionToDB":null},"projectPreview":{"challengeData":{"challengeType":1,"challengeFiles":[{"name":"script","ext":"js","contents":"function rangeOfNumbers(startNum, endNum) {\n  if (endNum - startNum === 0) {\n    return [startNum];\n  } else {\n    const numbers = rangeOfNumbers(startNum, endNum - 1);\n    numbers.push(endNum);\n    return numbers;\n  }\n}","history":["script.js"],"fileKey":"scriptjs"}]}},"id":"/learn/javascript-algorithms-and-data-structures/basic-javascript/introducing-else-if-statements"}},"staticQueryHashes":["3858520367"],"slicesMap":{}}