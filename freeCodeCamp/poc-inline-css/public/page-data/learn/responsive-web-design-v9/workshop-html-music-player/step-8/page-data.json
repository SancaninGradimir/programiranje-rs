{"componentChunkName":"component---src-templates-challenges-classic-show-tsx","path":"/learn/responsive-web-design-v9/workshop-html-music-player/step-8","result":{"data":{"challengeNode":{"challenge":{"block":"workshop-html-music-player","demoType":null,"title":"Korak 8","description":"<section id=\"description\">\n<p>Ispod elementa <code>p</code>, dodajte element <code>audio</code>, dodelite mu atribut <code>src</code> sa vrednošću <code>https://cdn.freecodecamp.org/curriculum/js-music-player/cruising-for-a-musing.mp3</code>, i atribute <code>loop</code> i <code>controls</code>.</p>\n</section>","id":"698c5710136539797f296098","hasEditableBoundaries":true,"instructions":"","notes":null,"challengeType":0,"helpCategory":"HTML-CSS","videoUrl":null,"superBlock":"responsive-web-design-v9","translationPending":false,"forumTopicId":null,"hooks":null,"fields":{"slug":"/learn/responsive-web-design-v9/workshop-html-music-player/step-8"},"required":[],"usesMultifileEditor":true,"challengeFiles":[{"fileKey":"indexhtml","ext":"html","name":"index","contents":"<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Working with the HTML Audio Element</title>\n</head>\n<body>\n  <h1>freeCodeCamp Tunes</h1>\n\n  <h2>Can't Stay Down</h2>\n  <p>Artist: Quincy Larson</p>\n  \n  <audio src=\"https://cdn.freecodecamp.org/curriculum/js-music-player/can't-stay-down.mp3\" loop controls></audio>\n  \n  <h2>Cruising for a Musing</h2>\n  <p>Artist: Quincy Larson</p>\n  \n  \n\n</body>\n</html>","head":null,"tail":null,"editableRegionBoundaries":[18,20],"history":["index.html"]}],"saveSubmissionToDB":null,"tests":[{"text":"<p>You should have a second <code>audio</code> element.</p>","testString":"assert.exists(document.querySelector('audio:nth-of-type(2)'));"},{"text":"<p>The new <code>audio</code> element should be below the <code>p</code> element.</p>","testString":"assert.exists(document