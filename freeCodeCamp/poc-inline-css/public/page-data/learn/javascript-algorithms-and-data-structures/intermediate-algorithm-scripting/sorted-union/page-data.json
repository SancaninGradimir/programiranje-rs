{"componentChunkName":"component---src-templates-challenges-classic-show-tsx","path":"/learn/javascript-algorithms-and-data-structures/intermediate-algorithm-scripting/sorted-union","result":{"data":{"challengeNode":{"challenge":{"block":"intermediate-algorithm-scripting","demoType":null,"title":"Planirano spajanje","description":"<section id=\"description\">\n<p>Napišite funkciju koja prima dva ili više nizova podataka i vraća novi niz sa jedinstvenim vrednostima, zadržavajući redosled prvobitno unetih nizova.</p>\n<p>Drugim rečima, sve vrednosti koje se nalaze u svim redovima podataka treba da budu uključene u njihov originalni redosled, ali bez ponavljanja u poslednjem redu.</p>\n<p>Jedinstveni brojevi treba da se sortiraju prema njihovom prvobitnom redosledu, ali konačni red ne bi trebalo da se sortira po numeričkom redosledu.</p>\n<p>Proverite testove validacije za primere.</p>\n</section>","id":"a105e963526e7de52b219be9","hasEditableBoundaries":false,"instructions":"","notes":null,"challengeType":1,"helpCategory":"JavaScript","videoUrl":null,"superBlock":"javascript-algorithms-and-data-structures","translationPending":false,"forumTopicId":16077,"hooks":null,"fields":{"slug":"/learn/javascript-algorithms-and-data-structures/intermediate-algorithm-scripting/sorted-union"},"required":[],"usesMultifileEditor":false,"challengeFiles":[{"fileKey":"scriptjs","ext":"js","name":"script","contents":"function uniteUnique(arr) {\r\n  return arr;\r\n}\r\n\r\nuniteUnique([1, 3, 2], [5, 2, 1, 4], [2, 1]);","head":null,"tail":null,"editableRegionBoundaries":[],"history":["script.js"]}],"saveSubmissionToDB":null,"tests":[{"text":"<p><code>uniteUnique([1, 3, 2], [5, 2, 1, 4], [2, 1])</code> trebalo bi da vrati <code>[1, 3, 2, 5, 4]</code>.</p>","testString":"assert.deepEqual(uniteUnique([1, 3, 2], [5, 2, 1, 4], [2, 1]), [1, 3, 2, 5, 4]);"},{"text":"<p><code>uniteUnique([1, 2, 3], [5, 2, 1])</code> trebalo bi da vrati <code>[1, 2, 3, 5]</code>.</p>","testString":"assert.deepEqual(uniteUnique([1, 2, 3], [5, 2, 1]), [1, 2, 3, 5]);"},{"text":"<p><code>uniteUnique([1, 2, 3], [5, 2, 1, 4], [2, 1], [6, 7, 8])</code> trebalo bi vratiti <code>[1, 2, 3, 5, 4, 6, 7, 8]</code>.</p>","testString":"assert.deepEqual(uniteUnique([1, 2, 3], [5, 2, 1, 4], [2, 1], [6, 7, 8]), [\r\n  1,\r\n  2,\r\n  3,\r\n  5,\r\n  4,\r\n  6,\r\n  7,\r\n  8\r\n]);"},{"text":"<p><code>uniteUnique([1, 3, 2], [5, 4], [5, 6])</code> trebao bi da vrati <code>[1, 3, 2, 5, 4, 6]</code>.</p>","testString":"assert.deepEqual(uniteUnique([1, 3, 2], [5, 4], [5, 6]), [1, 3, 2, 5, 4, 6]);"},{"text":"<p><code>uniteUnique([1, 3, 2, 3], [5, 2, 1, 4], [2, 1])</code> trebalo bi da vrati <code>[1, 3, 2, 5, 4]</code>.</p>","testString":"assert.deepEqual(uniteUnique([1, 3, 2, 3], [5, 2, 1, 4], [2, 1]), [1, 3, 2, 5, 4]);"}]}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/javascript-algorithms-and-data-structures/#intermediate-algorithm-scripting","dashedName":"sorted-union","certification":"javascript-algorithms-and-data-structures","disableLoopProtectTests":false,"disableLoopProtectPreview":false,"superBlock":"javascript-algorithms-and-data-structures","chapter":null,"module":null,"block":"intermediate-algorithm-scripting","isFirstStep":false,"template":null,"required":[],"isLastChallengeInBlock":false,"nextChallengePath":"/learn/javascript-algorithms-and-data-structures/intermediate-algorithm-scripting/convert-html-entities","prevChallengePath":"/learn/javascript-algorithms-and-data-structures/intermediate-algorithm-scripting/missing-letters","id":"a105e963526e7de52b219be9","saveSubmissionToDB":null},"projectPreview":{"challengeData":{"challengeType":1,"challengeFiles":[{"name":"script","ext":"js","contents":"function orbitalPeriod(arr) {\n  const GM = 398600.4418;\n  const earthRadius = 6367.4447;\n  const TAU = 2 * Math.PI;\n  return arr.map(function(obj) {\n    return {\n      name: obj.name,\n      orbitalPeriod: Math.round(TAU * Math.sqrt(Math.pow(obj.avgAlt+earthRadius, 3)/GM))\n    };\n  });\n}","history":["script.js"],"fileKey":"scriptjs"}]}},"id":"/learn/javascript-algorithms-and-data-structures/intermediate-algorithm-scripting/sorted-union"}},"staticQueryHashes":["3858520367"],"slicesMap":{}}