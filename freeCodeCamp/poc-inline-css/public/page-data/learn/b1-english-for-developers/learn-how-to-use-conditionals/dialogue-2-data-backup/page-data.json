{"componentChunkName":"component---src-templates-challenges-generic-show-tsx","path":"/learn/b1-english-for-developers/learn-how-to-use-conditionals/dialogue-2-data-backup","result":{"data":{"challengeNode":{"challenge":{"assignments":["<p>Gledaj video.</p>"],"bilibiliIds":null,"block":"learn-how-to-use-conditionals","challengeType":21,"description":"<section id=\"description\">\n<p>Pogledajte video dole/ispod kako biste razumeli kontekst predstojećih lekcija.</p>\n</section>","nodules":null,"explanation":null,"helpCategory":"English","instructions":"","fields":{"slug":"/learn/b1-english-for-developers/learn-how-to-use-conditionals/dialogue-2-data-backup"},"questions":[],"scene":{"setup":{"background":"company2-boardroom.png","characters":[{"character":"Bob","position":{"x":-25,"y":0,"z":1},"opacity":null},{"character":"Maria","position":{"x":125,"y":0,"z":1},"opacity":null}],"audio":{"filename":"B1_7-2.mp3","startTime":1,"startTimestamp":null,"finishTimestamp":null},"alwaysShowDialogue":true},"commands":[{"background":null,"character":"Bob","position":{"x":25,"y":0,"z":1},"opacity":null,"startTime":0,"finishTime":null,"dialogue":null},{"background":null,"character":"Maria","position":{"x":70,"y":0,"z":1},"opacity":null,"startTime":0.5,"finishTime":null,"dialogue":null},{"background":null,"character":"Bob","position":null,"opacity":null,"startTime":1,"finishTime":4.56,"dialogue":{"text":"Hi Maria, have you checked our data backup procedures recently?","align":"left"}},{"background":null,"character":"Bob","position":null,"opacity":null,"startTime":4.96,"finishTime":9,"dialogue":{"text":"If we don't backup regularly, we could lose important information, right?","align":"left"}},{"background":null,"character":"Maria","position":null,"opacity":null,"startTime":9.46,"finishTime":12.58,"dialogue":{"text":"Yes, you're correct. If someone forgets, it could be a disaster.","align":"right"}},{"background":null,"character":"Maria","position":null,"opacity":null,"startTime":13.02,"finishTime":14.72,"dialogue":{"text":"But I think we are pretty solid here.","align":"right"}},{"background":null,"character":"Maria","position":null,"opacity":null,"startTime":15.26,"finishTime":19.2,"dialogue":{"text":"Brian helped us set up a reminder to backup our work daily along with some other tasks.","align":"right"}},{"background":null,"character":"Bob","position":null,"opacity":null,"startTime":19.74,"finishTime":23.18,"dialogue":{"text":"Oh, I see. So you don't need to rely on your memory. That's clever.","align":"left"}},{"background":null,"character":"Maria","position":null,"opacity":null,"startTime":23.64,"finishTime":26.36,"dialogue":{"text":"I agree. But why did you ask? Did you notice something wrong?","align":"right"}},{"background":null,"character":"Bob","position":null,"opacity":null,"startTime":26.84,"finishTime":32.02,"dialogue":{"text":"No, not really. I was in a meeting where the stakeholders were talking about it, and I just wanted to double check.","align":"left"}},{"background":null,"character":"Bob","position":null,"opacity":null,"startTime":32.48,"finishTime":34.92,"dialogue":{"text":"If we lose critical data, it could set us back weeks.","align":"left"}},{"background":null,"character":"Bob","position":null,"opacity":null,"startTime":35.6,"finishTime":38.36,"dialogue":{"text":"Is there anything else we could do besides these reminders?","align":"left"}},{"background":null,"character":"Maria","position":null,"opacity":null,"startTime":39.14,"finishTime":42.26,"dialogue":{"text":"Besides the daily reminders, we could also set up automatic backups.","align":"right"}},{"background":null,"character":"Maria","position":null,"opacity":null,"startTime":42.78,"finishTime":46.22,"dialogue":{"text":"If we automate the process, there's less chance of human error. What do you think?","align":"right"}},{"background":null,"character":"Bob","position":null,"opacity":null,"startTime":46.54,"finishTime":47.68,"dialogue":{"text":"I think that's a great idea.","align":"left"}},{"background":null,"character":"Bob","position":null,"opacity":null,"startTime":47.9,"finishTime":52.04,"dialogue":{"text":"If we automate it, we don't have to worry about people forgetting. How can we set it up?","align":"left"}},{"background":null,"character":"Maria","position":null,"opacity":null,"startTime":52.6,"finishTime":55.8,"dialogue":{"text":"Brian mentioned we can schedule automatic backups at the end of each day.","align":"right"}},{"background":null,"character":"Maria","position":null,"opacity":null,"startTime":56.04,"finishTime":58,"dialogue":{"text":"If we do that, it should cover most of our bases.","align":"right"}},{"background":null,"character":"Maria","position":{"x":125,"y":0,"z":1},"opacity":null,"startTime":58.5,"finishTime":null,"dialogue":null},{"background":null,"character":"Bob","position":{"x":-25,"y":0,"z":1},"opacity":null,"startTime":59,"finishTime":null,"dialogue":null}]},"superBlock":"b1-english-for-developers","tests":[],"title":"Dijalog 2: Rezervna kopija podataka","transcript":null,"translationPending":false,"videoId":null,"videoLocaleIds":null}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/b1-english-for-developers/#learn-how-to-use-conditionals","dashedName":"dialogue-2-data-backup","certification":"b1-english-for-developers","disableLoopProtectTests":false,"disableLoopProtectPreview":false,"superBlock":"b1-english-for-developers","chapter":null,"module":null,"block":"learn-how-to-use-conditionals","isFirstStep":false,"template":null,"required":[],"isLastChallengeInBlock":false,"nextChallengePath":"/learn/b1-english-for-developers/learn-how-to-use-conditionals/task-46","prevChallengePath":"/learn/b1-english-for-developers/learn-how-to-use-conditionals/task-45","id":"677faf6117b76b18c736b49c","saveSubmissionToDB":null},"projectPreview":{"challengeData":{"challengeType":19,"challengeFiles":[]}},"id":"/learn/b1-english-for-developers/learn-how-to-use-conditionals/dialogue-2-data-backup"}},"stat