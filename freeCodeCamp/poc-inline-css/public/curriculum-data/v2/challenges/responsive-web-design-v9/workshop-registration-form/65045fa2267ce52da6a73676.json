    {
      "text": "<p>Prvi element <code>input</code> bi trebalo da ima <code>id</code> od <code>personal-account</code>.</p>",
      "testString": "assert.isTrue(document.querySelectorAll('fieldset:nth-of-type(2) input')?.[0]?.matches('#personal-account'))"
    },
    {
      "text": "<p>Drugi element od <code>input</code> treba da ima <code>id</code> od <code>business-account</code>.</p>",
      "testString": "assert.isTrue(document.querySelectorAll('fieldset:nth-of-type(2) input')?.[1]?.matches('#business-account'))"
    },
    {
      "text": "<p>Prvi element <code>label</code> treba da ima svojstvo elemenata <code>for</code> sa vrednošću <code>personal-account</code>.</p>",
      "testString": "assert.isTrue(document.querySelectorAll('fieldset:nth-of-type(2) label')?.[0]?.matches('label[for=\"personal-account\"]'))"
