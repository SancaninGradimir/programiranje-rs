{"componentChunkName":"component---src-templates-challenges-classic-show-tsx","path":"/learn/project-euler/project-euler-problems-1-to-100/problem-46-goldbachs-other-conjecture","result":{"data":{"challengeNode":{"challenge":{"block":"project-euler-problems-1-to-100","demoType":null,"title":"Zadatak 46: Još jedna Goldbach teorija","description":"<section id=\"description\">\n<p>Christian Goldbach predložio je da svaki neparan broj može biti napisan kao zbir prostog broja i dvostrukog kvadrata.</p>\n<div style='margin-left: 2em;'>\n  9 = 7 + 2×1<sup>2</sup><br>\n  15 = 7 + 2×2<sup>2</sup><br>\n  21 = 3 + 2×3<sup>2</sup><br>\n  25 = 7 + 2×3<sup>2</sup><br>\n  27 = 19 + 2×2<sup>2</sup><br>\n  33 = 31 + 2×1<sup>2</sup>\n</div>\n<p>Potvrđeno je da ta teorija nije bila istinitost.</p>\n<p>Koji je najmanji kompozitni broj koji ne može biti predstavljen kao zbir premijnog broja i dva puta kvadrat?</p>\n</section>","id":"5900f39a1000cf542c50fead","hasEditableBoundaries":false,"instructions":"","notes":null,"challengeType":1,"helpCategory":"Euler","videoUrl":null,"superBlock":"project-euler","translationPending":false,"forumTopicId":302134,"hooks":null,"fields":{"slug":"/learn/project-euler/project-euler-problems-1-to-100/problem-46-goldbachs-other-conjecture"},"required":[],"usesMultifileEditor":false,"challengeFiles":[{"fileKey":"scriptjs","ext":"js","name":"script","contents":"function goldbachsOtherConjecture() {\n\n  return true;\n}\n\ngoldbachsOtherConjecture();","head":null,"tail":null,"editableRegionBoundaries":[],"history":["script.js"]}],"saveSubmissionToDB":null,"tests":[{"text":"<p><code>goldbachsOtherConjecture()</code> Trebalo bi da vrati broj.</p>","testString":"assert(typeof goldbachsOtherConjecture() === 'number');"},{"text":"<p><code>goldbachsOtherConjecture()</code> trebalo bi da vrati 5777.</p>","testString":"assert.strictEqual(goldbachsOtherConjecture(), 5777);"}]}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/project-euler/#project-euler-problems-1-to-100","dashedName":"problem-46-goldbachs-other-conjecture","certification":"project-euler","disableLoopProtectTests":true,"disableLoopProtectPreview":false,"superBlock":"project-euler","chapter":null,"module":null,"block":"project-euler-problems-1-to-100","isFirstStep":false,"template":null,"required":[],"isLastChallengeInBlock":false,"nextChallengePath":"/learn/project-euler/project-euler-problems-1-to-100/problem-47-distinct-primes-factors","prevChallengePath":"/learn/project-euler/project-euler-problems-1-to-100/problem-45-triangular-pentagonal-and-hexagonal","id":"5900f39a1000cf542c50fead","saveSubmissionToDB":null},"projectPreview":{"challengeData":{"challengeType":1,"challengeFiles":[{"name":"script","ext":"js","contents":"function arrangedProbability(limit) {\n  // Based on https://www.mathblog.dk/project-euler-100-blue-discs-two-blue/\n  let blue = 15;\n  let discs = 21;\n\n  while (discs < limit) {\n    const nextBlue = 3 * blue + 2 * discs - 2;\n    const nextDiscs = 4 * blue + 3 * discs - 3;\n\n    blue = nextBlue;\n    discs = nextDiscs;\n  }\n  return blue;\n}","history":["script.js"],"fileKey":"scriptjs"}]}},"id":"/learn/project-euler/project-euler-problems-1-to-100/problem-46-goldbachs-other-conjecture"}},"staticQueryHashes":["3858520367"],"slicesMap":{}}