        "fileKey": "scriptjs",
        "contents": "function mutation(arr) {\r\n  let hash = Object.create(null);\r\n\r\n  arr[0]\r\n    .toLowerCase()\r\n    .split('')\r\n    .forEach(c => (hash[c] = true));\r\n\r\n  return !arr[1]\r\n    .toLowerCase()\r\n    .split('')\r\n    .filter(c => !hash[c]).length;\r\n}\r\n\r\nmutation(['hello', 'hey']);",
        "error": null,
        "seed": "function mutation(arr) {\r\n  let hash = Object.create(null);\r\n\r\n  arr[0]\r\n    .toLowerCase()\r\n    .split('')\r\n    .forEach(c => (hash[c] = true));\r\n\r\n  return !arr[1]\r\n    .toLowerCase()\r\n    .split('')\r\n    .filter(c => !hash[c]).length;\r\n}\r\n\r\nmutation(['hello', 'hey']);"
