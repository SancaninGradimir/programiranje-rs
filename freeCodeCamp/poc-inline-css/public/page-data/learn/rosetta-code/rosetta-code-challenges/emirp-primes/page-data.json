{"componentChunkName":"component---src-templates-challenges-classic-show-tsx","path":"/learn/rosetta-code/rosetta-code-challenges/emirp-primes","result":{"data":{"challengeNode":{"challenge":{"block":"rosetta-code-challenges","demoType":null,"title":"Osnovni broj emirp","description":"<section id=\"description\">\n<p>Emirp (prosti broj napisan u obrnutom redosledu) su prosti brojevi koji, kada se preokrenu (u njihovom decimalnom zapisu), postaju drugi prost broj.</p>\n</section>","id":"599d0ba974141b0f508b37d5","hasEditableBoundaries":false,"instructions":"<section id=\"instructions\">\n<p>Napiši funkciju koja:</p>\n<ul>\n<li>Prikaži prvih <code>n</code> emirp brojeva.</li>\n<li>Prikaži emirp brojeve u nizu.</li>\n<li>Prikaži broj emirp brojeva u nizu.</li>\n  <li>Inaonyesha nambari emirp ya <code>n<sup>th</sup></code>.</li>\n</ul>\n<p>Funkcija treba da prihvati dva argumenta. Prvi prima <code>n</code> ili niz. Drugi prima logičku vrednost koja određuje da li funkcija vraća emirp brojeve kao niz ili jednu vrednost (broj emirp brojeva u nizu ili <code>n</code>-ti emirp broj). U zavisnosti od argumenata, funkcija treba da vrati niz ili broj.</p>\n</section>","notes":null,"challengeType":1,"helpCategory":"Rosetta","videoUrl":null,"superBlock":"rosetta-code","translationPending":false,"forumTopicId":302253,"hooks":null,"fields":{"slug":"/learn/rosetta-code/rosetta-code-challenges/emirp-primes"},"required":[],"usesMultifileEditor":false,"challengeFiles":[{"fileKey":"scriptjs","ext":"js","name":"script","contents":"function emirps(n) {\n\n}","head":null,"tail":null,"editableRegionBoundaries":[],"history":["script.js"]}],"saveSubmissionToDB":null,"tests":[{"text":"<p><code>emirps</code> Trebalo bi da bude funkcija.</p>","testString":"assert(typeof emirps === 'function');"},{"text":"<p><code>emirps(20,true)</code> inapaswa kurudisha <code>[13,17,31,37,71,73,79,97,107,113,149,157,167,179,199,311,337,347,359,389]</code></p>","testString":"assert.deepEqual(emirps(20, true), [\n  13,\n  17,\n  31,\n  37,\n  71,\n  73,\n  79,\n  97,\n  107,\n  113,\n  149,\n  157,\n  167,\n  179,\n  199,\n  311,\n  337,\n  347,\n  359,\n  389\n]);"},{"text":"<p><code>emirps(1000)</code> inapaswa kurudisha <code>70529</code></p>","testString":"assert.deepEqual(emirps(1000), 70529);"},{"text":"<p><code>emirps([7700,8000],true)</code> treba vratiti <code>[7717,7757,7817,7841,7867,7879,7901,7927,7949,7951,7963]</code></p>","testString":"assert.deepEqual(emirps([7700, 8000], true), [\n  7717,\n  7757,\n  7817,\n  7841,\n  7867,\n  7879,\n  7901,\n  7927,\n  7949,\n  7951,\n  7963\n]);"},{"text":"<p><code>emirps([7700,8000],false)</code> treba da vrati <code>11</code></p>","testString":"assert.deepEqual(emirps([7700, 8000], false), 11);"}]}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/rosetta-code/#rosetta-code-challenges","dashedName":"emirp-primes","certification":"rosetta-code","disableLoopProtectTests":true,"disableLoopProtectPreview":false,"superBlock":"rosetta-code","chapter":null,"module":null,"block":"rosetta-code-challenges","isFirstStep":false,"template":null,"required":[],"isLastChallengeInBlock":false,"nextChallengePath":"/learn/rosetta-code/rosetta-code-challenges/entropy","prevChallengePath":"/learn/rosetta-code/rosetta-code-challenges/element-wise-operations","id":"599d0ba974141b0f508b37d5","saveSubmissionToDB":null},"projectPreview":{"challengeData":{"challengeType":1,"challengeFiles":[{"name":"script","ext":"js","contents":"function ZigZagMatrix(n) {\n  const mtx = [];\n  for (let i = 0; i < n; i++) {\n    mtx[i] = [];\n  }\n\n  let i = 1;\n  let j = 1;\n  for (let e = 0; e < n * n; e++) {\n    mtx[i - 1][j - 1] = e;\n    if ((i + j) % 2 === 0) {\n      // Even stripes\n      if (j < n) j++;\n      else i += 2;\n      if (i > 1) i--;\n    } else {\n      // Odd stripes\n      if (i < n) i++;\n      else j += 2;\n      if (j > 1) j--;\n    }\n  }\n  return mtx;\n}","history":["script.js"],"fileKey":"scriptjs"}]}},"id":"/learn/rosetta-code/rosetta-code-challenges/emirp-primes"}},"staticQueryHashes":["3858520367"],"slicesMap":{}}