  "tests": [
    {
      "text": "<p><code>largestOfFour([[4, 5, 1, 3], [13, 27, 18, 26], [32, 35, 37, 39], [1000, 1001, 857, 1]])</code> treba da vrati niz.</p>",
      "testString": "assert.isArray(\n  largestOfFour([\n    [4, 5, 1, 3],\n    [13, 27, 18, 26],\n    [32, 35, 37, 39],\n    [1000, 1001, 857, 1]\n  ])\n);"
    },
    {
      "text": "<p><code>largestOfFour([[13, 27, 18, 26], [4, 5, 1, 3], [32, 35, 37, 39], [1000, 1001, 857, 1]])</code> treba da vrati <code>[27, 5, 39, 1001]</code>.</p>",
      "testString": "assert.deepEqual(\n  largestOfFour([\n    [13, 27, 18, 26],\n    [4, 5, 1, 3],\n    [32, 35, 37, 39],\n    [1000, 1001, 857, 1]\n  ]),\n  [27, 5, 39, 1001]\n);"
    },
    {
      "text": "<p><code>largestOfFour([[4, 9, 1, 3], [13, 35, 18, 26], [32, 35, 97, 39], [1000000, 1001, 857, 1]])</code> treba da vrati <code>[9, 35, 97, 1000000]</code>.</p>",
      "testString": "assert.deepEqual(\n  largestOfFour([\n    [4, 9, 1, 3],\n    [13, 35, 18, 26],\n    [32, 35, 97, 39],\n    [1000000, 1001, 857, 1]\n  ]),\n  [9, 35, 97, 1000000]\n);"
    },
    {
      "text": "<p><code>largestOfFour([[17, 23, 25, 12], [25, 7, 34, 48], [4, -10, 18, 21], [-72, -3, -17, -10]])</code> treba da vrati <code>[25, 48, 21, -3]</code>.</p>",
      "testString": "assert.deepEqual(\n  largestOfFour([\n    [17, 23, 25, 12],\n    [25, 7, 34, 48],\n    [4, -10, 18, 21],\n    [-72, -3, -17, -10]\n  ]),\n  [25, 48, 21, -3]\n);"
    }
  ],
  "description": "<section id=\"description\">\n<p>Vratite niz koji sadrzi najveci broj iz svakog prosledjenog podniza. Radi jednostavnosti, dati niz ce imati tacno 4 podniza.</p>\n<p>Napomena: mozete prolaziti kroz niz pomocu jednostavne for petlje i pristupati svakom elementu sintaksom <code>arr[i]</code>.</p>\n</section>",
