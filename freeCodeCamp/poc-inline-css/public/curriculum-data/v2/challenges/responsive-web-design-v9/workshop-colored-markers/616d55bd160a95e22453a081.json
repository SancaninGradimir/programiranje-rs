      "text": "<p>Vaša druga nova komponenta za <code>div</code> mora imati zatvarajući tag.</p>",
      "testString": "assert.exists([...code.matchAll(/<\\/div\\s*>/gi)][3]);"
    },
    {
      "text": "<p>Tvoji novi elementi <code>div</code> bi trebalo da budu unutar <code>div</code> sa klasom <code>container</code>.</p>",
      "testString": "const containerChildren = [...document.querySelector('.container')?.children];\ncontainerChildren.forEach(child => assert.strictEqual(child?.localName, 'div'));\nassert.lengthOf(containerChildren, 3);"
