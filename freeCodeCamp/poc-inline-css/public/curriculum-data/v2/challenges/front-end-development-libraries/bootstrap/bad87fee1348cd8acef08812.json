      "contents": "<link href=\"https://fonts.googleapis.com/css?family=Lobster\" rel=\"stylesheet\" type=\"text/css\">\r\n<style>\r\n  .red-text {\r\n    color: red;\r\n  }\r\n\r\n  h2 {\r\n    font-family: Lobster, Monospace;\r\n  }\r\n\r\n  p {\r\n    font-size: 16px;\r\n    font-family: Monospace;\r\n  }\r\n\r\n  .thick-green-border {\r\n    border-color: green;\r\n    border-width: 10px;\r\n    border-style: solid;\r\n    border-radius: 50%;\r\n  }\r\n\r\n  .smaller-image {\r\n    width: 100px;\r\n  }\r\n</style>\r\n\r\n<div class=\"container-fluid\">\r\n  <h2 class=\"red-text text-center\">CatPhotoApp</h2>\r\n\r\n  <p>Click here for <a href=\"#\">cat photos</a>.</p>\r\n\r\n  <a href=\"#\"><img class=\"smaller-image thick-green-border\" src=\"https://cdn.freecodecamp.org/curriculum/cat-photo-app/relaxing-cat.jpg\" alt=\"A cute orange cat lying on its back.\"></a>\r\n\r\n  <img src=\"https://cdn.freecodecamp.org/curriculum/cat-photo-app/running-cats.jpg\" class=\"img-responsive\" alt=\"Tuxedo cats running on dirt ground.\">\r\n  <button class=\"btn btn-default\">Like</button>\r\n  <p>Things cats love:</p>\r\n  <ul>\r\n    <li>catnip</li>\r\n    <li>laser pointers</li>\r\n    <li>lasagna</li>\r\n  </ul>\r\n  <p>Top 3 things cats hate:</p>\r\n  <ol>\r\n    <li>flea treatment</li>\r\n    <li>thunder</li>\r\n    <li>other cats</li>\r\n  </ol>\r\n  <form action=\"https://freecatphotoapp.com/submit-cat-photo\">\r\n    <label><input type=\"radio\" name=\"indoor-outdoor\"> Indoor</label>\r\n    <label><input type=\"radio\" name=\"indoor-outdoor\"> Outdoor</label>\r\n    <label><input type=\"checkbox\" name=\"personality\"> Loving</label>\r\n    <label><input type=\"checkbox\" name=\"personality\"> Lazy</label>\r\n    <label><input type=\"checkbox\" name=\"personality\"> Crazy</label>\r\n    <input type=\"text\" placeholder=\"cat photo URL\" required>\r\n    <button type=\"submit\">Submit</button>\r\n  </form>\r\n</div >",
