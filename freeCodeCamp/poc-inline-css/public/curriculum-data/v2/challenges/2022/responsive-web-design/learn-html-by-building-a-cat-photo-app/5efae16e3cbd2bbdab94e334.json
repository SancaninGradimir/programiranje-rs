  "tests": [
    {
      "text": "<p>Tvoja komponenta <code>figcaption</code> mora imati otvorenu oznaku. Otvarajuće oznake imaju sledeću sintaksu: <code>&#x3C;elementName></code>.</p>",
      "testString": "assert(document.querySelectorAll('figcaption').length === 2);"
    },
    {
      "text": "<p>Vaš element za <code>figcaption</code> mora imati zatvarajući tag. Zatvarajući tagovi su <code>/</code> odmah nakon karaktera <code>&#x3C;</code>.</p>",
      "testString": "assert(code.match(/<\\/figcaption\\>/g).length === 2);"
    },
    {
      "text": "<p>Nakon oznake zatvaranja drugog elementa od <code>figure</code>, treba da postoji element <code>section</code> iznad njega.</p>",
      "testString": "assert.strictEqual(document.querySelectorAll('main > section')?.[1]?.lastElementChild?.nodeName, 'FIGURE');"
    },
    {
      "text": "<p>Poslednji element od <code>img</code> treba da bude postavljen unutar elementa <code>figure</code>.</p>",
      "testString": "const catsImg = document.querySelectorAll('figure > img')[1];\nassert(\n  catsImg &&\n    catsImg.getAttribute('src').toLowerCase() === 'https://cdn.freecodecamp.org/curriculum/cat-photo-app/cats.jpg'\n);"
    },
    {
      "text": "<p>Tvoj element <code>figure</code> mora imati labelu za otvaranje. Labeli za otvaranje imaju sledeću sintaksu: <code>&#x3C;elementName></code>.</p>",
      "testString": "assert(document.querySelectorAll('figure').length === 2);"
    },
    {
      "text": "<p>Vaš element za <code>figure</code> treba da ima zatvarajući tag. Zatvarajući tagovi imaju <code>/</code> odmah nakon karaktera <code>&#x3C;</code>.</p>",
      "testString": "assert(code.match(/<\\/figure\\>/g).length === 2);"
    },
    {
      "text": "<p>Element za <code>figcaption</code> treba biti postavljen unutar elementa <code>figure</code>.</p>",
      "testString": "assert(document.querySelectorAll('figure > figcaption').length === 2);"
    },
    {
      "text": "<p>Element <code>figcaption</code> koji je postavljen unutar elementa <code>figure</code> treba da bude ispod elementa <code>img</code>. Postavili ste element <code>img</code> i element <code>figcaption</code> u netačan redosled.</p>",
      "testString": "assert(\n  document.querySelectorAll('figcaption')[1].previousElementSibling.nodeName ===\n    'IMG'\n);"
    },
    {
      "text": "<p>Element <code>figcaption</code> bi trebalo da ima tekst <code>Cats hate other cats.</code>. Izostavili ste reč ili napravili pravopisne greške.</p>",
      "testString": "assert(\n  document\n    .querySelectorAll('figcaption')[1]\n    .innerText.toLowerCase()\n    .match(/Cats hate other cats\\.?$/i)\n);"
    }
  ],
