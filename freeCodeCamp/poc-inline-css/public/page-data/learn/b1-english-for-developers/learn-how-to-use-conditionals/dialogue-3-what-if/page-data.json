{"componentChunkName":"component---src-templates-challenges-generic-show-tsx","path":"/learn/b1-english-for-developers/learn-how-to-use-conditionals/dialogue-3-what-if","result":{"data":{"challengeNode":{"challenge":{"assignments":["<p>Gledaj video.</p>"],"bilibiliIds":null,"block":"learn-how-to-use-conditionals","challengeType":21,"description":"<section id=\"description\">\n<p>Pogledajte video dole/ispod kako biste razumeli kontekst predstojećih lekcija.</p>\n</section>","nodules":null,"explanation":null,"helpCategory":"English","instructions":"","fields":{"slug":"/learn/b1-english-for-developers/learn-how-to-use-conditionals/dialogue-3-what-if"},"questions":[],"scene":{"setup":{"background":"company2-breakroom.png","characters":[{"character":"Lisa","position":{"x":-25,"y":0,"z":1},"opacity":null},{"character":"Tom","position":{"x":125,"y":0,"z":1},"opacity":null}],"audio":{"filename":"B1_7-3.mp3","startTime":1,"startTimestamp":null,"finishTimestamp":null},"alwaysShowDialogue":true},"commands":[{"background":null,"character":"Lisa","position":{"x":25,"y":0,"z":1},"opacity":null,"startTime":0,"finishTime":null,"dialogue":null},{"background":null,"character":"Tom","position":{"x":70,"y":0,"z":1},"opacity":null,"startTime":0.5,"finishTime":null,"dialogue":null},{"background":null,"character":"Lisa","position":null,"opacity":null,"startTime":1,"finishTime":5.08,"dialogue":{"text":"Hey Tom, have you ever thought about what would happen if TechCorp went out of business?","align":"left"}},{"background":null,"character":"Tom","position":null,"opacity":null,"startTime":5.86,"finishTime":8.4,"dialogue":{"text":"If TechCorp went out of business, it would be a big shock.","align":"right"}},{"background":null,"character":"Tom","position":null,"opacity":null,"startTime":8.76,"finishTime":11.08,"dialogue":{"text":"They work with so many companies. Why do you ask?","align":"right"}},{"background":null,"character":"Lisa","position":null,"opacity":null,"startTime":11.62,"finishTime":13.46,"dialogue":{"text":"I read they might be having money problems.","align":"left"}},{"background":null,"character":"Lisa","position":null,"opacity":null,"startTime":13.72,"finishTime":16.5,"dialogue":{"text":"If they closed, it would affect a lot of tech companies, wouldn't it?","align":"left"}},{"background":null,"character":"Tom","position":null,"opacity":null,"startTime":16.94,"finishTime":20.68,"dialogue":{"text":"Yes, it would. If they shut down, a lot of people would lose their jobs","align":"right"}},{"background":null,"character":"Tom","position":null,"opacity":null,"startTime":20.68,"finishTime":23.5,"dialogue":{"text":"and their current projects would stop, wouldn't they?","align":"right"}},{"background":null,"character":"Lisa","position":null,"opacity":null,"startTime":23.86,"finishTime":27.56,"dialogue":{"text":"That's right. If that happened, a lot of smaller companies would be in trouble too.","align":"left"}},{"background":null,"character":"Lisa","position":null,"opacity":null,"startTime":27.96,"finishTime":29.86,"dialogue":{"text":"TechCorp helps fund some of their projects.","align":"left"}},{"background":null,"character":"Tom","position":null,"opacity":null,"startTime":29.86,"finishTime":33.42,"dialogue":{"text":"True. If that money goes away, those companies might not survive.","align":"right"}},{"background":null,"character":"Tom","position":null,"opacity":null,"startTime":33.68,"finishTime":35.26,"dialogue":{"text":"It would be a big change for everyone.","align":"right"}},{"background":null,"character":"Lisa","position":null,"opacity":null,"startTime":35.88,"finishTime":37.6,"dialogue":{"text":"Do you think they can fix their money problems?","align":"left"}},{"background":null,"character":"Tom","position":null,"opacity":null,"startTime":38.22,"finishTime":43.02,"dialogue":{"text":"Maybe, but it's hard to know. If they get new investors, it might help, but it doesn't look likely.","align":"right"}},{"background":null,"character":"Lisa","position":null,"opacity":null,"startTime":43.6,"finishTime":46.28,"dialogue":{"text":"I hope they do. If they go out of business, it would change everything.","align":"left"}},{"background":null,"character":"Tom","position":null,"opacity":null,"startTime":46.72,"finishTime":49.5,"dialogue":{"text":"It definitely would. Let's watch the news and see what happens.","align":"right"}},{"background":null,"character":"Tom","position":{"x":125,"y":0,"z":1},"opacity":null,"startTime":50,"finishTime":null,"dialogue":null},{"background":null,"character":"Lisa","position":{"x":-25,"y":0,"z":1},"opacity":null,"startTime":50.5,"finishTime":null,"dialogue":null}]},"superBlock":"b1-english-for-developers","tests":[],"title":"Dijalog 3: Šta ako...","transcript":null,"translationPending":false,"videoId":null,"videoLocaleIds":null}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/b1-english-for-developers/#learn-how-to-use-conditionals","dashedName":"dialogue-3-what-if","certification":"b1-english-for-developers","disableLoopProtectTests":false,"disableLoopProtectPreview":false,"superBlock":"b1-english-for-developers","chapter":null,"module":null,"block":"learn-how-to-use-conditionals","isFirstStep":false,"template":null,"required":[],"isLastChallengeInBlock":false,"nextChallengePath":"/learn/b1-english-for-developers/learn-how-to-use-conditionals/task-90","prevChallengePath":"/learn/b1-english-for-developers/learn-how-to-use-conditionals/task-89","id":"6784c41edae95d51056f51d4","saveSubmissionToDB":null},"projectPreview":{"challengeData":{"challengeType":19,"challengeFiles":[]}},"id":"/learn/b1-english-for-developers/learn-how-to-use-conditionals/dialogue-3-what-if"}},"staticQueryHashes":["3858520367"],"slicesMap":{}}