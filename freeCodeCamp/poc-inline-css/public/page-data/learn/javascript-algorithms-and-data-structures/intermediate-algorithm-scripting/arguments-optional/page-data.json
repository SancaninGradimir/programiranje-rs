{"componentChunkName":"component---src-templates-challenges-classic-show-tsx","path":"/learn/javascript-algorithms-and-data-structures/intermediate-algorithm-scripting/arguments-optional","result":{"data":{"challengeNode":{"challenge":{"block":"intermediate-algorithm-scripting","demoType":null,"title":"Nije neophodno","description":"<section id=\"description\">\n<p>Kreiraj funkciju koja sabira dva argumenta zajedno. Ako se pruži samo jedan argument, onda vrati funkciju koja očekuje jedan argument i vraća zbir.</p>\n<p>Na primer, <code>addTogether(2, 3)</code> treba da vrati <code>5</code>, i <code>addTogether(2)</code> treba da vrati funkciju.</p>\n<p>Pozivanje funkcije koja vraća jedan argument dodaje i vraća zbir:</p>\n<pre><code class=\"language-js\">var sumTwoAnd = addTogether(2);\n</code></pre>\n<p><code>sumTwoAnd(3)</code> vraća <code>5</code>.</p>\n<p>Ako je bilo koji argument nevažeći broj, vratite undefined.</p>\n</section>","id":"a97fd23d9b809dac9921074f","hasEditableBoundaries":false,"instructions":"","notes":null,"challengeType":1,"helpCategory":"JavaScript","videoUrl":null,"superBlock":"javascript-algorithms-and-data-structures","translationPending":false,"forumTopicId":14271,"hooks":null,"fields":{"slug":"/learn/javascript-algorithms-and-data-structures/intermediate-algorithm-scripting/arguments-optional"},"required":[],"usesMultifileEditor":false,"challengeFiles":[{"fileKey":"scriptjs","ext":"js","name":"script","contents":"function addTogether() {\r\n  return false;\r\n}\r\n\r\naddTogether(2,3);","head":null,"tail":null,"editableRegionBoundaries":[],"history":["script.js"]}],"saveSubmissionToDB":null,"tests":[{"text":"<p><code>addTogether(2, 3)</code> trebalo bi da vrati 5.</p>","testString":"assert.deepEqual(addTogether(2, 3), 5);"},{"text":"<p><code>addTogether(23.4, 30)</code> treba da vrati 53.4.</p>","testString":"assert.deepEqual(addTogether(23.4, 30), 53.4);"},{"text":"<p><code>addTogether(\"2\", 3)</code> trebalo bi vratiti <code>undefined</code>.</p>","testString":"assert.isUndefined(addTogether('2', 3));"},{"text":"<p><code>addTogether(5, undefined)</code> treba da vrati <code>undefined</code>.</p>","testString":"assert.isUndefined(addTogether(5, undefined));"},{"text":"<p><code>addTogether(\"https://www.youtube.com/watch?v=dQw4w9WgXcQ\")</code> trebalo bi da vrati <code>undefined</code>.</p>","testString":"assert.isUndefined(addTogether('https://www.youtube.com/watch?v=dQw4w9WgXcQ'));"},{"text":"<p><code>addTogether(5)</code> Trebalo bi da vrati funkciju.</p>","testString":"assert.deepEqual(typeof(addTogether(5)), 'function');"},{"text":"<p><code>addTogether(5)(7)</code> Trebalo bi da vrati 12.</p>","testString":"assert.deepEqual(addTogether(5)(7), 12);"},{"text":"<p><code>addTogether(2)([3])</code> trebalo bi vratiti <code>undefined</code>.</p>","testString":"assert.isUndefined(addTogether(2)([3]));"},{"text":"<p><code>addTogether(2, \"3\")</code> trebalo bi da vrati <code>undefined</code>.</p>","testString":"assert.isUndefined(addTogether(2, '3'));"}]}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/javascript-algorithms-and-data-structures/#intermediate-algorithm-scripting","dashedName":"arguments-optional","certification":"javascript-algorithms-and-data-structures","disableLoopProtectTests":false,"disableLoopProtectPreview":false,"superBlock":"javascript-algorithms-and-data-structures","chapter":null,"module":null,"block":"intermediate-algorithm-scripting","isFirstStep":false,"template":null,"required":[],"isLastChallengeInBlock":false,"nextChallengePath":"/learn/javascript-algorithms-and-data-structures/intermediate-algorithm-scripting/make-a-person","prevChallengePath":"/learn/javascript-algorithms-and-data-structures/intermediate-algorithm-scripting/everything-be-true","id":"a97fd23d9b809dac9921074f","saveSubmissionToDB":null},"projectPreview":{"challengeData":{"challengeType":1,"challengeFiles":[{"name":"script","ext":"js","contents":"function orbitalPeriod(arr) {\n  const GM = 398600.4418;\n  const earthRadius = 6367.4447;\n  const TAU = 2 * Math.PI;\n  return arr.map(function(obj) {\n    return {\n      name: obj.name,\n      orbitalPeriod: Math.round(TAU * Math.sqrt(Math.pow(obj.avgAlt+earthRadius, 3)/GM))\n    };\n  });\n}","history":["script.js"],"fileKey":"scriptjs"}]}},"id":"/learn/javascript-algorithms-and-data-structures/intermediate-algorithm-scripting/arguments-optional"}},"staticQueryHashes":["3858520367"],"slicesMap":{}}