  "tests": [
    {
      "text": "<p>You should have a total of three <code>label</code> elements on the page.</p>",
      "testString": "assert.lengthOf(document.querySelectorAll(\"label\"), 3);"
    },
    {
      "text": "<p>Your third <code>label</code> element should have the text <code>Parent/Guardian Name: </code>. Don't forget the space after the colon.</p>",
      "testString": "assert.match(code, /Parent\\/Guardian\\s+Name:\\s+<\\/label>/);"
    },
    {
      "text": "<p>Your third <code>label</code> element should have a <code>for</code> attribute.</p>",
      "testString": "assert.isTrue(document.querySelector(\"label:last-of-type\")?.hasAttribute(\"for\"));"
    },
    {
      "text": "<p>Your third <code>label</code> element's <code>for</code> attribute should have the value <code>\"parent-name\"</code>.</p>",
      "testString": "assert.strictEqual(document.querySelector(\"fieldset:last-of-type label\")?.getAttribute(\"for\"), \"parent-name\");"
    },
    {
      "text": "<p>You should have three <code>input</code> elements on the page.</p>",
      "testString": "assert.lengthOf(document.querySelectorAll(\"input\"), 3);"
    },
    {
      "text": "<p>Your third <code>input</code> element should be below your third <code>label</code> element.</p>",
      "testString": "const fieldsetChildren = [...document.querySelector(\"fieldset:last-of-type\")?.children];\nconst inputEl = document.querySelector(\"fieldset:last-of-type input\");\nconst labelEl = document.querySelector(\"fieldset:last-of-type label\");\n\nassert.isBelow(fieldsetChildren.indexOf(labelEl), fieldsetChildren.indexOf(inputEl));"
    },
    {
      "text": "<p>Your third <code>input</code> element should have a <code>type</code> attribute set to <code>\"text\"</code>.</p>",
      "testString": "const inputEl = document.querySelector(\"fieldset:last-of-type input\");\nassert.strictEqual(inputEl?.getAttribute(\"type\"), \"text\");"
    },
    {
      "text": "<p>Tvoj treći element <code>input</code> treba da ima atribut <code>name</code> postavljen na <code>\"parent-name\"</code>.</p>",
      "testString": "const inputEl = document.querySelector(\"fieldset:last-of-type input\");\nassert.strictEqual(inputEl?.getAttribute(\"name\"), \"parent-name\");"
    },
    {
      "text": "<p>Your third <code>input</code> element should have an <code>id</code> attribute set to <code>\"parent-name\"</code>.</p>",
      "testString": "const inputEl = document.querySelector(\"fieldset:last-of-type input\");\nassert.strictEqual(inputEl?.getAttribute(\"id\"), \"parent-name\");"
    },
    {
      "text": "<p>Your third <code>input</code> element should have a <code>placeholder</code> attribute set to <code>\"E.g., Nancy Doe\"</code>.</p>",
