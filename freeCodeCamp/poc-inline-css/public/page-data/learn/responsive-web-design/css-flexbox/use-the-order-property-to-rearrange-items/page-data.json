{"componentChunkName":"component---src-templates-challenges-classic-show-tsx","path":"/learn/responsive-web-design/css-flexbox/use-the-order-property-to-rearrange-items","result":{"data":{"challengeNode":{"challenge":{"block":"css-flexbox","demoType":null,"title":"Koristi atribut 'order' za ponovno uređenje delova","description":"<section id=\"description\">\n<p>Svojstvo <code>order</code> se koristi za određivanje CSS redos u kojem izgledaju promenljivi delovi u promenljivom kontejneru. Podrazumevano, delovi će se pojaviti u istom redosledu kakav je bio u izvoru od HTML. Ovo svojstvo prima broj kao vrednost, i mogu se koristiti negativni brojevi.</p>\n</section>","id":"587d78ae367417b2b2512aff","hasEditableBoundaries":false,"instructions":"<section id=\"instructions\">\n<p>Povećajte atribut/svojstvo CSS <code>order</code> za <code>#box-1</code> na <code>#box-2</code>. Postavi <code>#box-1</code> vrednost za <code>2</code> i <code>#box-2</code> vrednost za <code>1</code>.</p>\n</section>","notes":null,"challengeType":0,"helpCategory":"HTML-CSS","videoUrl":"https://scrimba.com/p/pVaDAv/cMbvNAG","superBlock":"responsive-web-design","translationPending":false,"forumTopicId":301116,"hooks":null,"fields":{"slug":"/learn/responsive-web-design/css-flexbox/use-the-order-property-to-rearrange-items"},"required":[],"usesMultifileEditor":false,"challengeFiles":[{"fileKey":"indexhtml","ext":"html","name":"index","contents":"<style>\r\n  #box-container {\r\n    display: flex;\r\n    height: 500px;\r\n  }\r\n  #box-1 {\r\n    background-color: dodgerblue;\r\n\r\n    height: 200px;\r\n    width: 200px;\r\n  }\r\n\r\n  #box-2 {\r\n    background-color: orangered;\r\n\r\n    height: 200px;\r\n    width: 200px;\r\n  }\r\n</style>\r\n\r\n<div id=\"box-container\">\r\n  <div id=\"box-1\"></div>\r\n  <div id=\"box-2\"></div>\r\n</div>","head":null,"tail":null,"editableRegionBoundaries":[],"history":["index.html"]}],"saveSubmissionToDB":null,"tests":[{"text":"<p>Dinamički deo <code>#box-1</code> mora imati svojstvo <code>order</code> ako ima vrednost od <code>2</code>.</p>","testString":"const boxOne = document.querySelector('#box-1');\r\nconst order = window.getComputedStyle(boxOne)['order'];\r\nassert.strictEqual(order, '2');"},{"text":"<p>Dinamički deo <code>#box-2</code> treba da ima svojstvo <code>order</code> sa vrednošću <code>1</code>.</p>","testString":"const boxTwo = document.querySelector('#box-2');\r\nconst order = window.getComputedStyle(boxTwo)['order'];\r\nassert.strictEqual(order, '1');"}]}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/responsive-web-design/#css-flexbox","dashedName":"use-the-order-property-to-rearrange-items","certification":"responsive-web-design","disableLoopProtectTests":false,"disableLoopProtectPreview":false,"superBlock":"responsive-web-design","chapter":null,"module":null,"block":"css-flexbox","isFirstStep":false,"template":null,"required":[],"isLastChallengeInBlock":false,"nextChallengePath":"/learn/responsive-web-design/css-flexbox/use-the-align-self-property","prevChallengePath":"/learn/responsive-web-design/css-flexbox/use-the-flex-shorthand-property","id":"587d78ae367417b2b2512aff","saveSubmissionToDB":null},"projectPreview":{"challengeData":{"challengeType":0,"challengeFiles":[{"name":"index","ext":"html","contents":"<style>\r\n  #box-container {\r\n    display: flex;\r\n    height: 500px;\r\n  }\r\n  #box-1 {\r\n    background-color: dodgerblue;\r\n    align-self: center;\r\n    height: 200px;\r\n    width: 200px;\r\n  }\r\n\r\n  #box-2 {\r\n    background-color: orangered;\r\n    align-self: flex-end;\r\n    height: 200px;\r\n    width: 200px;\r\n  }\r\n</style>\r\n\r\n<div id=\"box-container\">\r\n  <div id=\"box-1\"></div>\r\n  <div id=\"box-2\"></div>\r\n</div>","history":["index.html"],"fileKey":"indexhtml"}]}},"id":"/learn/responsive-web-design/css-flexbox/use-the-order-property-to-rearrange-items"}},"staticQueryHashes":["3858520367"],"slicesMap":{}}