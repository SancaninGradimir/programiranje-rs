      "text": "<p>Vaš <code>div</code> element treba da ima klasu <code>container-fluid</code>.</p>",
      "testString": "assert.isTrue(document.querySelector('div')?.classList?.contains('container-fluid'));"
    },
    {
      "text": "<p>Vaš <code>div</code> element mora imati zatvarajući tag.</p>",
      "testString": "assert.match(code,/<\\/div>/g);\r\nassert.match(code,/<div/g);\r\nassert.equal(code.match(/<\\/div>/g).length ,code.match(/<div/g).length);"
    },
    {
      "text": "<p>Svi HTML elementi nakon zatvarajućeg taga <code>style</code> moraju biti obuhvaćeni unutar <code>.container-fluid</code>.</p>",
      "testString": "const fluidContainer = document.querySelector('.container-fluid');\r\nconst possibleStyleElements = fluidContainer?.querySelectorAll(`:scope ${'style'}`);\r\nconst possibleLinkElements = fluidContainer?.querySelectorAll(`:scope ${'link'}`);\r\n\r\nassert.lengthOf(fluidContainer?.children,8);\r\nassert.isEmpty(possibleStyleElements);\r\nassert.isEmpty(possibleLinkElements);"
    }
