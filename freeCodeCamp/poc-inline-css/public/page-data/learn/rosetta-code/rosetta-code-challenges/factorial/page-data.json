{"componentChunkName":"component---src-templates-challenges-classic-show-tsx","path":"/learn/rosetta-code/rosetta-code-challenges/factorial","result":{"data":{"challengeNode":{"challenge":{"block":"rosetta-code-challenges","demoType":null,"title":"Faktoria","description":"<section id=\"description\">\n<p>Napiši funkciju za vraćanje fabrike broja.</p>\n<p>Generator brojeva se dobija od:</p>\n<pre><big>n! = n * (n-1) * (n-2) * ..... * 1</big>\n</pre>\n<p>Na primer:</p>\n<ul>\n  <li><code>3! = 3 * 2 * 1 = 6</code></li>\n  <li><code>4! = 4 * 3 * 2 * 1 = 24</code></li>\n</ul>\n<p><strong>Napomena:</strong> <code>0! = 1</code></p>\n</section>","id":"597b2b2a2702b44414742771","hasEditableBoundaries":false,"instructions":"","notes":null,"challengeType":1,"helpCategory":"Rosetta","videoUrl":null,"superBlock":"rosetta-code","translationPending":false,"forumTopicId":302263,"hooks":null,"fields":{"slug":"/learn/rosetta-code/rosetta-code-challenges/factorial"},"required":[],"usesMultifileEditor":false,"challengeFiles":[{"fileKey":"scriptjs","ext":"js","name":"script","contents":"function factorial(n) {\n\n}","head":null,"tail":null,"editableRegionBoundaries":[],"history":["script.js"]}],"saveSubmissionToDB":null,"tests":[{"text":"<p><code>factorial</code> Trebalo bi da bude funkcija.</p>","testString":"assert(typeof factorial === 'function');"},{"text":"<p><code>factorial(2)</code> Trebalo bi da vrati broj.</p>","testString":"assert(typeof factorial(2) === 'number');"},{"text":"<p><code>factorial(3)</code> Trebalo bi da vrati 6.</p>","testString":"assert.equal(factorial(3), 6);"},{"text":"<p><code>factorial(5)</code> trebalo bi da vrati 120.</p>","testString":"assert.equal(factorial(5), 120);"},{"text":"<p><code>factorial(10)</code> trebalo bi da vrati 3,628,800.</p>","testString":"assert.equal(factorial(10), 3628800);"}]}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/rosetta-code/#rosetta-code-challenges","dashedName":"factorial","certification":"rosetta-code","disableLoopProtectTests":true,"disableLoopProtectPreview":false,"superBlock":"rosetta-code","chapter":null,"module":null,"block":"rosetta-code-challenges","isFirstStep":false,"template":null,"required":[],"isLastChallengeInBlock":false,"nextChallengePath":"/learn/rosetta-code/rosetta-code-challenges/factors-of-a-mersenne-number","prevChallengePath":"/learn/rosetta-code/rosetta-code-challenges/extensible-prime-generator","id":"597b2b2a2702b44414742771","saveSubmissionToDB":null},"projectPreview":{"challengeData":{"challengeType":1,"challengeFiles":[{"name":"script","ext":"js","contents":"function ZigZagMatrix(n) {\n  const mtx = [];\n  for (let i = 0; i < n; i++) {\n    mtx[i] = [];\n  }\n\n  let i = 1;\n  let j = 1;\n  for (let e = 0; e < n * n; e++) {\n    mtx[i - 1][j - 1] = e;\n    if ((i + j) % 2 === 0) {\n      // Even stripes\n      if (j < n) j++;\n      else i += 2;\n      if (i > 1) i--;\n    } else {\n      // Odd stripes\n      if (i < n) i++;\n      else j += 2;\n      if (j > 1) j--;\n    }\n  }\n  return mtx;\n}","history":["script.js"],"fileKey":"scriptjs"}]}},"id":"/learn/rosetta-code/rosetta-code-challenges/factorial"}},"staticQueryHashes":["3858520367"],"slicesMap":{}}