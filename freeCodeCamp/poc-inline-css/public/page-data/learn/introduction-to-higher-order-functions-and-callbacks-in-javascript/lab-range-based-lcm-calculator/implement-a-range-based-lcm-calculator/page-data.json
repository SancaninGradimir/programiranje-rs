{"componentChunkName":"component---src-templates-challenges-classic-show-tsx","path":"/learn/introduction-to-higher-order-functions-and-callbacks-in-javascript/lab-range-based-lcm-calculator/implement-a-range-based-lcm-calculator","result":{"data":{"challengeNode":{"challenge":{"block":"lab-range-based-lcm-calculator","demoType":null,"title":"Kalkulator za najmanji zajednički sadržalnik (LCM) koji zavisi od reda brojeva","description":"<section id=\"description\">\n<p>U ovoj laboratoriji, kreiraćete funkciju koja prima niz podataka sa dva broja i vraća najmanji zajednički sadržalj (NZS) tih dva broja i svih brojeva između njih.</p>\n<p><strong>Cilj</strong>: Popunite priče korisnika ispod i prođite sve testove kako biste završili ovaj rad.</p>\n<p><strong>Priče korisnika:</strong></p>\n<ol>\n<li>Trebalo bi da postoji funkcija <code>smallestCommons</code> koja prima niz od dve brojeve kao argumente.</li>\n<li>Funkcija <code>smallestCommons</code> treba da vrati najmanji zajednički broj koji je deljiv sa oba broja, zajedno sa svim uzastopnim brojevima u opsegu između njih.</li>\n<li>Funkcija treba da obradi ulaz gde ta dva broja nisu u numeričkom redosledu.</li>\n</ol>\n</section>","id":"ae9defd7acaf69703ab432ea","hasEditableBoundaries":false,"instructions":"","notes":null,"challengeType":26,"helpCategory":"JavaScript","videoUrl":null,"superBlock":"introduction-to-higher-order-functions-and-callbacks-in-javascript","translationPending":false,"forumTopicId":null,"hooks":null,"fields":{"slug":"/learn/introduction-to-higher-order-functions-and-callbacks-in-javascript/lab-range-based-lcm-calculator/implement-a-range-based-lcm-calculator"},"required":[],"usesMultifileEditor":true,"challengeFiles":[{"fileKey":"scriptjs","ext":"js","name":"script","contents":"","head":null,"tail":null,"editableRegionBoundaries":[],"history":["script.js"]}],"saveSubmissionToDB":null,"tests":[{"text":"<p>Trebalo bi da imaš funkciju <code>smallestCommons</code>.</p>","testString":"assert.isFunction(smallestCommons);"},{"text":"<p><code>smallestCommons([1, 5])</code> Trebalo bi da vrati broj.</p>","testString":"assert.isNumber(smallestCommons([1, 5]));"},{"text":"<p><code>smallestCommons([1, 5])</code> trebalo bi da vrati <code>60</code>.</p>","testString":"assert.strictEqual(smallestCommons([1, 5]), 60);"},{"text":"<p><code>smallestCommons([5, 1])</code> treba da vrati <code>60</code>.</p>","testString":"assert.strictEqual(smallestCommons([5, 1]), 60);"},{"text":"<p><code>smallestCommons([2, 10])</code> treba da vrati <code>2520</code>.</p>","testString":"assert.strictEqual(smallestCommons([2, 10]), 2520);"},{"text":"<p><code>smallestCommons([1, 13])</code> treba da vrati <code>360360</code>.</p>","testString":"assert.strictEqual(smallestCommons([1, 13]), 360360);"},{"text":"<p><code>smallestCommons([23, 18])</code> trebalo bi da vrati <code>6056820</code>.</p>","testString":"assert.strictEqual(smallestCommons([23, 18]), 6056820);"}]}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/introduction-to-higher-order-functions-and-callbacks-in-javascript/#lab-range-based-lcm-calculator","dashedName":"implement-a-range-based-lcm-calculator","certification":"introduction-to-higher-order-functions-and-callbacks-in-javascript","disableLoopProtectTests":false,"disableLoopProtectPreview":false,"superBlock":"introduction-to-higher-order-functions-and-callbacks-in-javascript","chapter":null,"module":null,"block":"lab-range-based-lcm-calculator","isFirstStep":true,"template":null,"required":[],"isLastChallengeInBlock":true,"nextChallengePath":"/learn/introduction-to-higher-order-functions-and-callbacks-in-javascript/lab-deep-flattening-tool/create-a-deep-flattening-tool","prevChallengePath":"/learn/introduction-to-higher-order-functions-and-callbacks-in-javascript/lab-prime-number-sum-calculator/build-a-prime-number-sum-calculator","id":"ae9defd7acaf69703ab432ea","saveSubmissionToDB":null},"projectPreview":{"challengeData":{"challengeType":26,"challengeFiles":[{"name":"script","ext":"js","contents":"function smallestCommons(arr) {\r\n  let [min, max] = arr.sort((a, b) => a - b);\r\n\r\n  function gcd(a, b) {\r\n    return b === 0 ? a : gcd(b, a % b);\r\n  }\r\n\r\n  function lcm(a, b) {\r\n    return (a * b) / gcd(a, b);\r\n  }\r\n\r\n  let multiple = min;\r\n\r\n  for (let i = min + 1; i <= max; i++) {\r\n    multiple = lcm(multiple, i);\r\n  }\r\n\r\n  return multiple;\r\n}","history":["script.js"],"fileKey":"scriptjs"}]}},"id":"/learn/introduction-to-higher-order-functions-and-callbacks-in-javascript/lab-range-based-lcm-calculator/implement-a-range-based-lcm-calculator"}},"staticQueryHashes":["3858520367"],"slicesMap":{}}