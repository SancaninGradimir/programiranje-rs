{"componentChunkName":"component---src-templates-challenges-classic-show-tsx","path":"/learn/rosetta-code/rosetta-code-challenges/loop-over-multiple-arrays-simultaneously","result":{"data":{"challengeNode":{"challenge":{"block":"rosetta-code-challenges","demoType":null,"title":"Obrađujte više redova podataka istovremeno","description":"<section id=\"description\">\n<p>Obradite više redova podataka i kreirajte novi red čiji element je kombinacija elemenata svih navedenih, gde je $i^{th}$ i $i^{th}$.</p>\n<p>Za ovaj primer, ukoliko vam se da ova struktura podataka:</p>\n<pre><code class=\"language-js\">[ [\"a\", \"b\", \"c\"], [\"A\", \"B\", \"C\"], [1, 2, 3] ]\n</code></pre>\n<p>Rezultati bi trebalo da budu:</p>\n<pre><code class=\"language-js\">[\"aA1\",\"bB2\",\"cC3\"]\n</code></pre>\n</section>","id":"5e6dd15004c88cf00d2a78b3","hasEditableBoundaries":false,"instructions":"<section id=\"instructions\">\n<p>Definisać funkciju koja prima listu lista podataka kao parametar i vraća sekvencu karaktera koja zadovoljava zadate specifikacije.</p>\n</section>","notes":null,"challengeType":1,"helpCategory":"Rosetta","videoUrl":null,"superBlock":"rosetta-code","translationPending":false,"forumTopicId":385279,"hooks":null,"fields":{"slug":"/learn/rosetta-code/rosetta-code-challenges/loop-over-multiple-arrays-simultaneously"},"required":[],"usesMultifileEditor":false,"challengeFiles":[{"fileKey":"scriptjs","ext":"js","name":"script","contents":"function loopSimult(A) {\n\n}","head":null,"tail":null,"editableRegionBoundaries":[],"history":["script.js"]}],"saveSubmissionToDB":null,"tests":[{"text":"<p><code>loopSimult</code> Ovo bi trebalo da bude funkcija.</p>","testString":"assert(typeof loopSimult == 'function');"},{"text":"<p><code>loopSimult([[\"a\", \"b\", \"c\"], [\"A\", \"B\", \"C\"], [1, 2, 3]])</code> Trebalo bi da vrati red podataka.</p>","testString":"assert(\n  Array.isArray(\n    loopSimult([\n      ['a', 'b', 'c'],\n      ['A', 'B', 'C'],\n      [1, 2, 3]\n    ])\n  )\n);"},{"text":"<p><code>loopSimult([[\"a\", \"b\", \"c\"], [\"A\", \"B\", \"C\"], [1, 2, 3]])</code> treba da vrati <code>[\"aA1\", \"bB2\", \"cC3\"]</code>.</p>","testString":"assert.deepEqual(\n  loopSimult([\n    ['a', 'b', 'c'],\n    ['A', 'B', 'C'],\n    [1, 2, 3]\n  ]),\n  ['aA1', 'bB2', 'cC3']\n);"},{"text":"<p><code>loopSimult([[\"c\", \"b\", \"c\"], [\"4\", \"5\", \"C\"], [7, 7, 3]])</code> treba da vrati <code>[\"c47\", \"b57\", \"cC3\"]</code>.</p>","testString":"assert.deepEqual(\n  loopSimult([\n    ['c', 'b', 'c'],\n    ['4', '5', 'C'],\n    [7, 7, 3]\n  ]),\n  ['c47', 'b57', 'cC3']\n);"},{"text":"<p><code>loopSimult([[\"a\", \"b\", \"c\", \"d\"], [\"A\", \"B\", \"C\", \"d\"], [1, 2, 3, 4]])</code> trebalo bi da vrati <code>[\"aA1\", \"bB2\", \"cC3\", \"dd4\"]</code>.</p>","testString":"assert.deepEqual(\n  loopSimult([\n    ['a', 'b', 'c', 'd'],\n    ['A', 'B', 'C', 'd'],\n    [1, 2, 3, 4]\n  ]),\n  ['aA1', 'bB2', 'cC3', 'dd4']\n);"},{"text":"<p><code>loopSimult([[\"a\", \"b\"], [\"A\", \"B\"], [1, 2]])</code> treba da vrati <code>[\"aA1\", \"bB2\"]</code>.</p>","testString":"assert.deepEqual(\n  loopSimult([\n    ['a', 'b'],\n    ['A', 'B'],\n    [1, 2]\n  ]),\n  ['aA1', 'bB2']\n);"},{"text":"<p><code>loopSimult([[\"b\", \"c\"], [\"B\", \"C\"], [2, 3]])</code> bi trebalo da vrati <code>[\"bB2\", \"cC3\"]</code>.</p>","testString":"assert.deepEqual(\n  loopSimult([\n    ['b', 'c'],\n    ['B', 'C'],\n    [2, 3]\n  ]),\n  ['bB2', 'cC3']\n);"}]}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/rosetta-code/#rosetta-code-challenges","dashedName":"loop-over-multiple-arrays-simultaneously","certification":"rosetta-code","disableLoopProtectTests":true,"disableLoopProtectPreview":false,"superBlock":"rosetta-code","chapter":null,"module":null,"block":"rosetta-code-challenges","isFirstStep":false,"template":null,"required":[],"isLastChallengeInBlock":false,"nextChallengePath":"/learn/rosetta-code/rosetta-code-challenges/lu-decomposition","prevChallengePath":"/learn/rosetta-code/rosetta-code-challenges/look-and-say-sequence","id":"5e6dd15004c88cf00d2a78b3","saveSubmissionToDB":null},"projectPreview":{"challengeData":{"challengeType":1,"challengeFiles":[{"name":"script","ext":"js","contents":"function ZigZagMatrix(n) {\n  const mtx = [];\n  for (let i = 0; i < n; i++) {\n    mtx[i] = [];\n  }\n\n  let i = 1;\n  let j = 1;\n  for (let e = 0; e < n * n; e++) {\n    mtx[i - 1][j - 1] = e;\n    if ((i + j) % 2 === 0) {\n      // Even stripes\n      if (j < n) j++;\n      else i += 2;\n      if (i > 1) i--;\n    } else {\n      // Odd stripes\n      if (i < n) i++;\n      else j += 2;\n      if (j > 1) j--;\n    }\n  }\n  return mtx;\n}","history":["script.js"],"fileKey":"scriptjs"}]}},"id":"/learn/rosetta-code/rosetta-code-challenges/loop-over-multiple-arrays-simultaneously"}},"staticQueryHashes":["3858520367"],"slicesMap":{}}