{"componentChunkName":"component---src-templates-challenges-classic-show-tsx","path":"/learn/javascript-fundamentals-review/lab-falsy-remover/implement-a-falsy-remover","result":{"data":{"challengeNode":{"challenge":{"block":"lab-falsy-remover","demoType":null,"title":"Izvršiti funkciju za uklanjanje lažnih vrednosti","description":"<section id=\"description\">\n<p>U ovoj laboratoriji ćete kreirati funkciju koja uklanja sve lažne vrednosti iz skupa podataka.</p>\n<p>Vrednost laži u JavaScript je <code>false</code>, <code>null</code>, <code>0</code>, <code>\"\"</code>, <code>undefined</code>, i <code>NaN</code>.</p>\n<p><strong>Cilj</strong>: Popunite priče korisnika ispod i prođite sve testove kako biste završili ovaj rad.</p>\n<p><strong>Priče korisnika:</strong></p>\n<ol>\n<li>Trebalo bi da postoji funkcija <code>bouncer</code> koja prima red podataka kao argument.</li>\n<li>Funkcija <code>bouncer</code> treba da vrati novi red sa istim elementima kao i red dostavljen kao argument, ali uklonjenim lažnim vrednostima (false).</li>\n<li>Funkcija <code>bouncer</code> ne sme da modifikuje red dostavljen kao argument.</li>\n</ol>\n<p>Napomena: Pokušajte da konvertujete svaku vrednost u tačno ili nije tačno.</p>\n</section>","id":"adf08ec01beb4f99fc7a68f2","hasEditableBoundaries":false,"instructions":"","notes":null,"challengeType":26,"helpCategory":"JavaScript","videoUrl":null,"superBlock":"javascript-fundamentals-review","translationPending":false,"forumTopicId":null,"hooks":null,"fields":{"slug":"/learn/javascript-fundamentals-review/lab-falsy-remover/implement-a-falsy-remover"},"required":[],"usesMultifileEditor":true,"challengeFiles":[{"fileKey":"scriptjs","ext":"js","name":"script","contents":"","head":null,"tail":null,"editableRegionBoundaries":[],"history":["script.js"]}],"saveSubmissionToDB":null,"tests":[{"text":"<p>Trebalo bi da imaš funkciju <code>bouncer</code>.</p>","testString":"assert.isFunction(bouncer);"},{"text":"<p><code>bouncer([7, \"ate\", \"\", false, 9])</code> bi trebalo da vrati <code>[7, \"ate\", 9]</code>.</p>","testString":"assert.deepEqual(bouncer([7, 'ate', '', false, 9]), [7, 'ate', 9]);"},{"text":"<p><code>bouncer([\"a\", \"b\", \"c\"])</code> treba da vrati <code>[\"a\", \"b\", \"c\"]</code>.</p>","testString":"assert.deepEqual(bouncer(['a', 'b', 'c']), ['a', 'b', 'c']);"},{"text":"<p><code>bouncer([false, null, 0, NaN, undefined, \"\"])</code> trebalo bi da vrati <code>[]</code>.</p>","testString":"assert.deepEqual(bouncer([false, null, 0, NaN, undefined, '']), []);"},{"text":"<p><code>bouncer([null, NaN, 1, 2, undefined])</code> treba da vrati <code>[1, 2]</code>.</p>","testString":"assert.deepEqual(bouncer([null, NaN, 1, 2, undefined]), [1, 2]);"},{"text":"<p>Funkcija <code>bouncer</code> ne sme menjati red koji je dostavljen kao argument.</p>","testString":"const arr = ['a', false, 0, 'Naomi'];\r\nbouncer(arr);\r\nassert.deepEqual(arr, ['a', false, 0, 'Naomi']);"},{"text":"<p><code>bouncer([])</code> trebalo bi da vrati <code>[]</code>.</p>","testString":"assert.deepEqual(bouncer([]), []);  "}]}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/javascript-fundamentals-review/#lab-falsy-remover","dashedName":"implement-a-falsy-remover","certification":"javascript-fundamentals-review","disableLoopProtectTests":false,"disableLoopProtectPreview":false,"superBlock":"javascript-fundamentals-review","chapter":null,"module":null,"block":"lab-falsy-remover","isFirstStep":true,"template":null,"required":[],"isLastChallengeInBlock":true,"nextChallengePath":"/learn/javascript-fundamentals-review/lab-inventory-management-program/build-an-inventory-management-program","prevChallengePath":"/learn/javascript-fundamentals-review/lab-title-case-converter/build-a-title-case-converter","id":"adf08ec01beb4f99fc7a68f2","saveSubmissionToDB":null},"projectPreview":{"challengeData":{"challengeType":26,"challengeFiles":[{"name":"script","ext":"js","contents":"function bouncer(arr) {\r\n  return arr.filter(e => e);\r\n}","history":["script.js"],"fileKey":"scriptjs"}]}},"id":"/learn/javascript-fundamentals-review/lab-falsy-remover/implement-a-falsy-remover"}},"staticQueryHashes":["3858520367"],"slicesMap":{}}