  "tests": [
    {
      "text": "<p><code>destroyer([1, 2, 3, 1, 2, 3], 2, 3)</code> treba da vrati <code>[1, 1]</code>.</p>",
      "testString": "assert.deepEqual(destroyer([1, 2, 3, 1, 2, 3], 2, 3), [1, 1]);"
    },
    {
      "text": "<p><code>destroyer([1, 2, 3, 5, 1, 2, 3], 2, 3)</code> treba vratiti <code>[1, 5, 1]</code>.</p>",
      "testString": "assert.deepEqual(destroyer([1, 2, 3, 5, 1, 2, 3], 2, 3), [1, 5, 1]);"
    },
    {
      "text": "<p><code>destroyer([3, 5, 1, 2, 2], 2, 3, 5)</code> treba vratiti <code>[1]</code>.</p>",
      "testString": "assert.deepEqual(destroyer([3, 5, 1, 2, 2], 2, 3, 5), [1]);"
    },
    {
      "text": "<p><code>destroyer([2, 3, 2, 3], 2, 3)</code> trebalo bi vratiti <code>[]</code>.</p>",
      "testString": "assert.deepEqual(destroyer([2, 3, 2, 3], 2, 3), []);"
    },
    {
      "text": "<p><code>destroyer([\"tree\", \"hamburger\", 53], \"tree\", 53)</code> trebalo bi da vrati <code>[\"hamburger\"]</code>.</p>",
      "testString": "assert.deepEqual(destroyer(['tree', 'hamburger', 53], 'tree', 53), [\r\n  'hamburger'\r\n]);"
