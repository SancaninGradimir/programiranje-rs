    {
      "text": "<p>Trebalo bi da dodate <code>div</code> element ispod vašeg <code>h3</code> elementa.</p>",
      "testString": "assert.lengthOf(document.querySelectorAll('div'),2);\r\nassert.lengthOf(document.querySelectorAll('div.row h3.text-primary'),0);\r\nassert.lengthOf(document.querySelectorAll('div.row + h3.text-primary'),0)\r\nassert.lengthOf(document.querySelectorAll('h3.text-primary + div.row'),1);"
    },
    {
      "text": "<p>Vaš <code>div</code> element treba da ima klasu elemenata <code>row</code></p>",
      "testString": "const newDiv = document.querySelectorAll('div')?.[1]; \r\nassert.isTrue(newDiv?.classList?.contains('row'));"
    },
    {
      "text": "<p>Vaš <code>row div</code> treba da bude unutar <code>container-fluid div</code></p>",
      "testString": "assert.lengthOf(document.querySelectorAll('div.container-fluid div.row'),1);"
    },
    {
      "text": "<p>Vaš <code>div</code> element treba da ima zatvarajuću etiku.</p>",
      "testString": "assert.match(code,/<\\/div>/g);\r\nassert.match(code,/<div/g);\r\nassert.equal(code.match(/<\\/div>/g).length ,code.match(/<div/g).length);"
    }
  ],
