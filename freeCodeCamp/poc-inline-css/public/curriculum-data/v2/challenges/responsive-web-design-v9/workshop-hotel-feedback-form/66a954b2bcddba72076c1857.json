  "tests": [
    {
      "text": "<p>You should have an <code>input</code> element below your first <code>label</code> element.</p>",
      "testString": "assert.isNotNull(document.querySelector('fieldset:nth-of-type(2) label + input'));"
    },
    {
      "text": "<p>Your <code>input</code> element should have a <code>type</code> attribute of <code>radio</code>.</p>",
      "testString": "assert.strictEqual(document.querySelector('fieldset:nth-of-type(2) label + input')?.getAttribute('type'), 'radio');"
    },
    {
      "text": "<p>Your <code>input</code> element should have an <code>id</code> attribute of <code>\"no-option\"</code>.</p>",
      "testString": "assert.strictEqual(document.querySelector('fieldset:nth-of-type(2) label + input')?.id, 'no-option');"
    },
    {
      "text": "<p>Your <code>input</code> element should have a <code>name</code> attribute of <code>\"hotel-stay\"</code>.</p>",
      "testString": "assert.strictEqual(document.querySelector('fieldset:nth-of-type(2) label + input')?.name, 'hotel-stay');"
    },
    {
      "text": "<p>Your input element should have a <code>value</code> attribute set to <code>\"no\"</code>.</p>",
      "testString": "assert.strictEqual(\n  document.querySelector('fieldset:nth-of-type(2) label + input')?.value,\n  'no'\n);"
    },
    {
      "text": "<p>You should have a second <code>label</code> element below your second <code>input</code> element.</p>",
      "testString": "assert.isNotNull(document.querySelector('fieldset:nth-of-type(2) input:nth-of-type(2) + label'));"
    },
    {
      "text": "<p>Your <code>label</code> element should have a <code>for</code> attribute set to <code>\"no-option\"</code>.</p>",
      "testString": "assert.strictEqual(document.querySelector('fieldset:nth-of-type(2) input:nth-of-type(2) + label')?.htmlFor, \"no-option\");"
    },
    {
      "text": "<p>Your <code>label</code> element should have the text <code>No</code>.</p>",
      "testString": "assert.strictEqual(document.querySelector('fieldset:nth-of-type(2) input:nth-of-type(2) + label')?.textContent?.trim(), 'No');"
