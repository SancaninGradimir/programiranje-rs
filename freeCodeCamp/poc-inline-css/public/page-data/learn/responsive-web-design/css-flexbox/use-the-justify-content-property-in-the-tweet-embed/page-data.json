{"componentChunkName":"component---src-templates-challenges-classic-show-tsx","path":"/learn/responsive-web-design/css-flexbox/use-the-justify-content-property-in-the-tweet-embed","result":{"data":{"challengeNode":{"challenge":{"block":"css-flexbox","demoType":null,"title":"Koristi svojstvo `justify-content` u polju za unos tvita","description":"<section id=\"description\">\n<p>Poslednji izazov je pokazao primer funkcije <code>justify-content</code>. Za unos tvita, ova funkcija se može koristiti za organizovanje stvari u sekciji <code>.profile-name</code>.</p>\n</section>","id":"587d78ac367417b2b2512af7","hasEditableBoundaries":false,"instructions":"<section id=\"instructions\">\n<p>Dodajte atribut CSS <code>justify-content</code> na polje <code>.profile-name</code> zaglavlja i postavite vrednost na jednu od opcija iz poslednjeg izazova.</p>\n</section>","notes":null,"challengeType":0,"helpCategory":"HTML-CSS","videoUrl":"https://scrimba.com/p/pVaDAv/c43GgTa","superBlock":"responsive-web-design","translationPending":false,"forumTopicId":301115,"hooks":null,"fields":{"slug":"/learn/responsive-web-design/css-flexbox/use-the-justify-content-property-in-the-tweet-embed"},"required":[],"usesMultifileEditor":false,"challengeFiles":[{"fileKey":"indexhtml","ext":"html","name":"index","contents":"<style>\r\n  body {\r\n    font-family: Arial, sans-serif;\r\n  }\r\n  header,\r\n  footer {\r\n    display: flex;\r\n    flex-direction: row;\r\n  }\r\n  header .profile-thumbnail {\r\n    width: 50px;\r\n    height: 50px;\r\n    border-radius: 4px;\r\n  }\r\n  header .profile-name {\r\n    display: flex;\r\n    flex-direction: column;\r\n\r\n    margin-left: 10px;\r\n  }\r\n  header .follow-btn {\r\n    display: flex;\r\n    margin: 0 0 0 auto;\r\n  }\r\n  header .follow-btn button {\r\n    border: 0;\r\n    border-radius: 3px;\r\n    padding: 5px;\r\n  }\r\n  header h3,\r\n  header h4 {\r\n    display: flex;\r\n    margin: 0;\r\n  }\r\n  #inner p {\r\n    margin-bottom: 10px;\r\n    font-size: 20px;\r\n  }\r\n  #inner hr {\r\n    margin: 20px 0;\r\n    border-style: solid;\r\n    opacity: 0.1;\r\n  }\r\n  footer .stats {\r\n    display: flex;\r\n    font-size: 15px;\r\n  }\r\n  footer .stats strong {\r\n    font-size: 18px;\r\n  }\r\n  footer .stats .likes {\r\n    margin-left: 10px;\r\n  }\r\n  footer .cta {\r\n    margin-left: auto;\r\n  }\r\n  footer .cta button {\r\n    border: 0;\r\n    background: transparent;\r\n  }\r\n</style>\r\n<header>\r\n  <img\r\n    src=\"https://cdn.freecodecamp.org/curriculum/legacy-css-flexbox/quincy-twitter-photo.jpg\"\r\n    alt=\"Quincy Larson's profile picture\"\r\n    class=\"profile-thumbnail\"\r\n  />\r\n  <div class=\"profile-name\">\r\n    <h3>Quincy Larson</h3>\r\n    <h4>@ossia</h4>\r\n  </div>\r\n  <div class=\"follow-btn\">\r\n    <button>Follow</button>\r\n  </div>\r\n</header>\r\n<div id=\"inner\">\r\n  <p>\r\n    I meet so many people who are in search of that one trick that will help\r\n    them work smart. Even if you work smart, you still have to work hard.\r\n  </p>\r\n  <span class=\"date\">1:32 PM - 12 Jan 2018</span>\r\n  <hr />\r\n</div>\r\n<footer>\r\n  <div class=\"stats\">\r\n    <div class=\"Retweets\"><strong>107</strong> Retweets</div>\r\n    <div class=\"likes\"><strong>431</strong> Likes</div>\r\n  </div>\r\n  <div class=\"cta\">\r\n    <button class=\"share-btn\">Share</button>\r\n    <button class=\"retweet-btn\">Retweet</button>\r\n    <button class=\"like-btn\">Like</button>\r\n  </div>\r\n</footer>","head":null,"tail":null,"editableRegionBoundaries":[],"history":["index.html"]}],"saveSubmissionToDB":null,"tests":[{"text":"<p><code>.follow-btn</code> Trebalo bi da se prikaže na stranici. Proverite da ste onemogućili sve ekstenzije, kao što su blokatori oglasa.</p>","testString":"const followButton = document.querySelector('.follow-btn');\r\nconst displayStyle = window.getComputedStyle(followButton)['display'];\r\nassert.isNotNull(followButton);\r\nassert.notStrictEqual(displayStyle, 'none');"},{"text":"<p>Element za <code>.profile-name</code> mora imati atribut <code>justify-content</code> sa jednim od ovih vrednosti: <code>center</code>, <code>flex-start</code>, <code>flex-end</code>, <code>space-between</code>, <code>space-around</code>, ili <code>space-evenly</code>.</p>","testString":"assert.match(\r\n  code,\r\n  /header\\s.profile-name\\s*{\\s*?.*?\\s*?.*?\\s*?\\s*?.*?\\s*?justify-content\\s*:\\s*(center|flex-start|flex-end|space-between|space-around|space-evenly)\\s*;/g\r\n);"}]}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/responsive-web-design/#css-flexbox","dashedName":"use-the-justify-content-property-in-the-tweet-embed","certification":"responsive-web-design","disableLoopProtectTests":false,"disableLoopProtectPreview":false,"superBlock":"responsive-web-design","chapter":null,"module":null,"block":"css-flexbox","isFirstStep":false,"template":null,"required":[],"isLastChallengeInBlock":false,"nextChallengePath":"/learn/responsive-web-design/css-flexbox/align-elements-using-the-align-items-property","prevChallengePath":"/learn/responsive-web-design/css-flexbox/align-elements-using-the-justify-content-property","id":"587d78ac367417b2b2512af7","saveSubmissionToDB":null},"projectPreview":{"challengeData":{"challengeType":0,"challengeFiles":[{"name":"index","ext":"html","contents":"<style>\r\n  #box-container {\r\n    display: flex;\r\n    height: 500px;\r\n  }\r\n  #box-1 {\r\n    background-color: dodgerblue;\r\n    align-self: center;\r\n    height: 200px;\r\n    width: 200px;\r\n  }\r\n\r\n  #box-2 {\r\n    background-color: orangered;\r\n    align-self: flex-end;\r\n    height: 200px;\r\n    width: 200px;\r\n  }\r\n</style>\r\n\r\n<div id=\"box-container\">\r\n  <div id=\"box-1\"></div>\r\n  <div id=\"box-2\"></div>\r\n</div>","history":["index.html"],"fileKey":"indexhtml"}]}},"id":"/learn/responsive-web-design/css-flexbox/use-the-justify-content-property-in-the-tweet-embed"}},"staticQueryHashes":["3858520367"