{"componentChunkName":"component---src-templates-challenges-classic-show-tsx","path":"/learn/rosetta-code/rosetta-code-challenges/entropy","result":{"data":{"challengeNode":{"challenge":{"block":"rosetta-code-challenges","demoType":null,"title":"Entropija","description":"<section id=\"description\">\n<p>Izračunaj Šanonovu entropiju H sekvence znakova iz dato ulaznog teksta.</p>\n<p>Ako postoji fiksna slučajna promenljiva $X$ koja je sekvenca \"simbola\" $N$ (ukupno slova) koji sadrži $n$ različitih simbola (n=2 za binarni sistem), Šanonova entropija $X$ u bitovima po simbolu je:</p>\n<p>$H_2(X) = -\\sum_{i=1}^n \\frac{count_i}{N} \\log_2 \\left(\\frac{count_i}{N}\\right)$</p>\n<p>gde $count_i$ je broj slova $n_i$.</p>\n</section>","id":"599d15309e88c813a40baf58","hasEditableBoundaries":false,"instructions":"","notes":null,"challengeType":1,"helpCategory":"Rosetta","videoUrl":null,"superBlock":"rosetta-code","translationPending":false,"forumTopicId":302254,"hooks":null,"fields":{"slug":"/learn/rosetta-code/rosetta-code-challenges/entropy"},"required":[],"usesMultifileEditor":false,"challengeFiles":[{"fileKey":"scriptjs","ext":"js","name":"script","contents":"function entropy(s) {\n\n}","head":null,"tail":null,"editableRegionBoundaries":[],"history":["script.js"]}],"saveSubmissionToDB":null,"tests":[{"text":"<p><code>entropy</code> Trebalo bi da bude funkcija.</p>","testString":"assert(typeof entropy === 'function');"},{"text":"<p><code>entropy(\"0\")</code> trebalo bi da vrati <code>0</code></p>","testString":"assert.equal(entropy('0'), 0);"},{"text":"<p><code>entropy(\"01\")</code> trebalo bi vratiti <code>1</code></p>","testString":"assert.equal(entropy('01'), 1);"},{"text":"<p><code>entropy(\"0123\")</code> treba da vrati <code>2</code></p>","testString":"assert.equal(entropy('0123'), 2);"},{"text":"<p><code>entropy(\"01234567\")</code> treba da vrati <code>3</code></p>","testString":"assert.equal(entropy('01234567'), 3);"},{"text":"<p><code>entropy(\"0123456789abcdef\")</code> trebalo bi da vrati <code>4</code></p>","testString":"assert.equal(entropy('0123456789abcdef'), 4);"},{"text":"<p><code>entropy(\"1223334444\")</code> trebalo bi vratiti <code>1.8464393446710154</code></p>","testString":"assert.equal(entropy('1223334444'), 1.8464393446710154);"}]}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/rosetta-code/#rosetta-code-challenges","dashedName":"entropy","certification":"rosetta-code","disableLoopProtectTests":true,"disableLoopProtectPreview":false,"superBlock":"rosetta-code","chapter":null,"module":null,"block":"rosetta-code-challenges","isFirstStep":false,"template":null,"required":[],"isLastChallengeInBlock":false,"nextChallengePath":"/learn/rosetta-code/rosetta-code-challenges/equilibrium-index","prevChallengePath":"/learn/rosetta-code/rosetta-code-challenges/emirp-primes","id":"599d15309e88c813a40baf58","saveSubmissionToDB":null},"projectPreview":{"challengeData":{"challengeType":1,"challengeFiles":[{"name":"script","ext":"js","contents":"function ZigZagMatrix(n) {\n  const mtx = [];\n  for (let i = 0; i < n; i++) {\n    mtx[i] = [];\n  }\n\n  let i = 1;\n  let j = 1;\n  for (let e = 0; e < n * n; e++) {\n    mtx[i - 1][j - 1] = e;\n    if ((i + j) % 2 === 0) {\n      // Even stripes\n      if (j < n) j++;\n      else i += 2;\n      if (i > 1) i--;\n    } else {\n      // Odd stripes\n      if (i < n) i++;\n      else j += 2;\n      if (j > 1) j--;\n    }\n  }\n  return mtx;\n}","history":["script.js"],"fileKey":"scriptjs"}]}},"id":"/learn/rosetta-code/rosetta-code-challenges/entropy"}},"staticQueryHashes":["3858520367"],"slicesMap":{}}