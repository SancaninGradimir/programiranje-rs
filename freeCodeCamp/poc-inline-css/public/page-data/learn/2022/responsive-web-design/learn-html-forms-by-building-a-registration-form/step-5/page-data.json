{"componentChunkName":"component---src-templates-challenges-classic-show-tsx","path":"/learn/2022/responsive-web-design/learn-html-forms-by-building-a-registration-form/step-5","result":{"data":{"challengeNode":{"challenge":{"block":"learn-html-forms-by-building-a-registration-form","demoType":null,"title":"Korak 5","description":"<section id=\"description\">\n<p>Postavi unutar elementa <code>link</code> unutar elementa <code>head</code>. Dodeli mu atribut/svojstvo <code>rel</code> sa vrednošću <code>stylesheet</code> i atribut/svojstvo <code>href</code> sa vrednošću <code>styles.css</code>.</p>\n</section>","id":"62cc5b1779e4d313466f73c5","hasEditableBoundaries":true,"instructions":"","notes":null,"challengeType":0,"helpCategory":"HTML-CSS","videoUrl":null,"superBlock":"2022/responsive-web-design","translationPending":false,"forumTopicId":null,"hooks":null,"fields":{"slug":"/learn/2022/responsive-web-design/learn-html-forms-by-building-a-registration-form/step-5"},"required":[],"usesMultifileEditor":true,"challengeFiles":[{"fileKey":"indexhtml","ext":"html","name":"index","contents":"<!DOCTYPE html>\n<html lang=\"en\">\n  <head>\n    <meta charset=\"UTF-8\">\n    <title>Registration Form</title>\n  </head>\n  <body>\n  </body>\n</html>","head":null,"tail":null,"editableRegionBoundaries":[2,7],"history":["index.html"]}],"saveSubmissionToDB":null,"tests":[{"text":"<p>Vaš kod mora imati element <code>link</code>.</p>","testString":"assert.isNotNull(document.querySelector('link'));"},{"text":"<p>Ne smete da menjate vaše postojeće oznake za <code>head</code>. Proverite da niste izbrisali oznaku za zatvaranje.</p>","testString":"const heads = document.querySelectorAll('head');\nassert.strictEqual(heads?.length, 1);"},{"text":"<p>Trebalo bi da imate jedan element <code>link</code>.</p>","testString":"assert.strictEqual(document.querySelectorAll('link')?.length, 1);"},{"text":"<p>Tvoje polje za <code>link</code> treba da bude prazno polje, ne bi trebalo da ima zatvarajuću oznaku <code>&#x3C;/link></code>.</p>","testString":"assert.notMatch(code, /<\\/link>/);"},{"text":"<p>Tvoj element <code>link</code> treba da bude unutar tvog elementa <code>head</code>.</p>","testString":"const headContentRegex = /(?<=<head\\s*>)[\\S|\\s]*(?=<\\/head\\s*>)/;\nconst headElementContent = code.match(headContentRegex);\n\nconst headElement = document.createElement(\"head\");\nheadElement.innerHTML = headElementContent;\nassert.isNotNull(headElement.querySelector('link'));"},{"text":"<p>Vaš element od <code>link</code> treba da ima svojstvo atributa <code>rel</code> sa vrednošću <code>stylesheet</code>.</p>","testString":"const linkElement = document.querySelector('link');\nconst rel = linkElement?.getAttribute(\"rel\");\nassert.strictEqual(rel, \"stylesheet\");"},{"text":"<p>Vaš element za <code>link</code> mora imati atribut elementa <code>href</code> sa vrednošću <code>styles.css</code>.</p>","testString":"const link = document.querySelector('link');\nassert.strictEqual(link?.dataset.href, \"styles.css\");"}]}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/2022/responsive-web-design/#learn-html-forms-by-building-a-registration-form","dashedName":"step-5","certification":"responsive-web-design","disableLoopProtectTests":false,"disableLoopProtectPreview":false,"superBlock":"2022/responsive-web-design","chapter":null,"module":null,"block":"learn-html-forms-by-building-a-registration-form","isFirstStep":false,"template":null,"required":[],"isLastChallengeInBlock":false,"nextChallengePath":"/learn/2022/responsive-web-design/learn-html-forms-by-building-a-registration-form/step-6","prevChallengePath":"/learn/2022/responsive-web-design/learn-html-forms-by-building-a-registration-form/step-4","id":"62cc5b1779e4d313466f73c5","saveSubmissionToDB":null},"projectPreview":{"challengeData":{"challengeType":0,"challengeFiles":[{"name":"index","ext":"html","contents":"<!DOCTYPE html>\n<html lang=\"en\">\n  <head>\n    <meta charset=\"UTF-8\">\n    <title>Registration Form</title>\n    <link rel=\"stylesheet\" href=\"styles.css\" />\n  </head>\n  <body>\n    <h1>Registration Form</h1>\n    <p>Please fill out this form with the required information</p>\n    <form method=\"post\" action='https://register-demo.freecodecamp.org'>\n      <fieldset>\n        <label for=\"first-name\">Enter Your First Name: <input id=\"first-name\" type=\"text\" name=\"first-name\" required /></label>\n        <label for=\"last-name\">Enter Your Last Name: <input id=\"last-name\" type=\"text\" name=\"last-name\" required /></label>\n        <label for=\"email\">Enter Your Email: <input id=\"email\" type=\"email\" name=\"email\" required /></label>\n        <label for=\"new-password\">Create a New Password: <input id=\"new-password\" type=\"password\" name=\"password\" pattern=\"[a-z0-5]{8,}\" required /></label>\n      </fieldset>\n      <fieldset>\n        <legend>Account type (required)</legend>\n        <label for=\"personal-account\"><input id=\"personal-account\" type=\"radio\" name=\"account-type\" class=\"inline\" checked /> Personal</label>\n        <label for=\"business-account\"><input id=\"business-account\" type=\"radio\" name=\"account-type\" class=\"inline\" /> Business</label>\n      </fieldset>\n      <fieldset>\n        <label for=\"profile-picture\">Upload a profile picture: <input id=\"profile-picture\" type=\"file\" name=\"file\" /></label>\n        <label for=\"age\">Input your age (years): <input id=\"age\" type=\"number\" name=\"age\" min=\"13\" max=\"120\" /></label>\n        <label for=\"referrer\">How did you hear about us?\n          <select id=\"referrer\" name=\"referrer\">\n            <option value=\"\">(select one)</option>\n            <option value=\"1\">freeCodeCamp News</option>\n            <option value=\"2\">freeCodeCamp YouTube Channel</option>\n            <option value=\"3\">freeCodeCamp Forum</option>\n            <option value=\"4\">Other</option>\n          </select>\n        </label>\n        <label for=\"bio\">Provide a bio:\n          <textarea id=\"bio\" name=\"bio\" rows=\"3\" cols=\"30\" placeholder=\"I like coding on the beach...\"></textarea>\n        </label>\n      </fieldset>\n      <label for=\"terms-and-conditions\">\n        <input id=\"terms-and-conditions\" type=\"checkbox\" name=\"terms\" class=\"inline\" required /> I accept the <a href=\"https://www.freecodecamp.org/news/terms-of-service/\">terms and conditions</a>\n      </label>\n      <input type=\"submit\" value=\"Submit\" />\n    </form>\n  </body>\n</html>","history":["index.html"],"fileKey":"indexhtml"},{"name":"styles","ext":"css","contents":"body {\n  width: 100%;\n  height: 100vh;\n  margin: 0;\n  background-color: #1b1b32;\n  color: #f5f6f7;\n  font-family: Tahoma;\n  font-size: 16px;\n}\n\nh1, p {\n  margin: 1em auto;\n  text-align: center;\n}\n\nform {\n  width: 60vw;\n  max-width: 500px;\n  min-width: 300px;\n  margin: 0 auto;\n  padding-bottom: 2em;\n}\n\nfieldset {\n  border: none;\n  padding: 2rem 0;\n  border-bottom: 3px solid #3b3b4f;\n}\n\nfieldset:last-of-type {\n  border-bottom: none;\n}\n\nlabel {\n  display: block;\n  margin: 0.5rem 0;\n}\n\ninput,\ntextarea,\nselect {\n  margin: 10px 0 0 0;\n  width: 100%;\n  min-height: 2em;\n}\n\ninput, textarea {\n  background-color: #0a0a23;\n  border: 1px solid #0a0a23;\n  color: #ffffff;\n}\n\n.inline {\n  width: unset;\n  margin: 0 0.5em 0 0;\n  vertical-align: middle;\n}\n\ninput[type=\"submit\"] {\n  display: block;\n  width: 60%;\n  margin: 1em auto;\n  height: 2em;\n  font-size: 1.1rem;\n  background-color: #3b3b4f;\n  border-color: white;\n  min-width: 300px;\n}\n\ninput[type=\"file\"] {\n  padding: 1px 2px;\n}\n\na {\n  color: #dfdfe2;\n}\n","history":["styles.css"],"fileKey":"stylescss"}]}},"id":"/learn/2022/responsive-web-design/learn-html-forms-by-building-a-registration-form/step-5"}},"staticQueryHashes":["3858520367"],"slicesMap":{}}