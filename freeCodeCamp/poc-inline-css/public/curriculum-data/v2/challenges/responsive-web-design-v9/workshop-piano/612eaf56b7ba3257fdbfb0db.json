    {
      "text": "<p>Your <code>img</code> element should have an <code>alt</code> attribute set to <code>freeCodeCamp Logo</code>.</p>",
      "testString": "assert.equal(document.querySelector('img')?.getAttribute('alt')?.toLowerCase(), 'freecodecamp logo');"
    },
    {
      "text": "<p>Remember that casing and spelling matter.</p>",
      "testString": "assert.equal(document.querySelector('img')?.getAttribute('alt'), 'freeCodeCamp Logo');"
