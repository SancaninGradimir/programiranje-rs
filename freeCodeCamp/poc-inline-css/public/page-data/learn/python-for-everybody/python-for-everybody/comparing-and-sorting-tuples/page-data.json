{"componentChunkName":"component---src-templates-challenges-generic-show-tsx","path":"/learn/python-for-everybody/python-for-everybody/comparing-and-sorting-tuples","result":{"data":{"challengeNode":{"challenge":{"assignments":[],"bilibiliIds":{"aid":931886163,"bvid":"BV1HM4y1T7TK","cid":376533673},"block":"python-for-everybody","challengeType":11,"description":"<section id=\"description\">\n<p>Više resursa:</p>\n<p>- <a href=\"https://www.youtube.com/watch?v=EhQxwzyT16E\" target=\"_blank\" rel=\"noopener noreferrer nofollow\">Zoezi</a></p>\n</section>","nodules":null,"explanation":null,"helpCategory":"Python","instructions":"","fields":{"slug":"/learn/python-for-everybody/python-for-everybody/comparing-and-sorting-tuples"},"questions":[{"text":"<p>Koja radi isto kao sledeći kod?:</p>\n<pre><code class=\"language-python\">lst = []\nfor key, val in counts.items():\n    newtup = (val, key)\n    lst.append(newtup)\nlst = sorted(lst, reverse=True)\nprint(lst)\n</code></pre>","answers":[{"answer":"<pre><code class=\"language-python\">print( sorted( [ (v,k) for k,v in counts.items() ], reverse=True ) )\n</code></pre>","feedback":null,"audioId":null},{"answer":"<pre><code class=\"language-python\">print( [ (k,v) for k,v in counts.items().sorted() ] )\n</code></pre>","feedback":null,"audioId":null},{"answer":"<pre><code class=\"language-python\">print( sorted( [ (v,k) for k,v in counts.keys() ] ) )\n</code></pre>","feedback":null,"audioId":null},{"answer":"<pre><code class=\"language-python\">print( [ (k,v) for k,v in counts.values().sort() ] )\n</code></pre>","feedback":null,"audioId":null}],"solution":1}],"scene":null,"superBlock":"python-for-everybody","tests":[],"title":"Upoređivanje i Sortiranje Tuple","transcript":null,"translationPending":false,"videoId":"dZXzBXUxxCs","videoLocaleIds":null}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/python-for-everybody/#python-for-everybody","dashedName":"comparing-and-sorting-tuples","certification":"python-for-every