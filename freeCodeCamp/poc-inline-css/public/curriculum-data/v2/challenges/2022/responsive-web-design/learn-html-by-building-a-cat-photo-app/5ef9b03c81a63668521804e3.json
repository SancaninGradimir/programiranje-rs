put id=\"loving\" type=\"checkbox\" name=\"personality\"> <label for=\"loving\">Loving</label>\n          </fieldset>\n          <input type=\"text\" name=\"catphotourl\" placeholder=\"cat photo URL\" required>\n          <button type=\"submit\">Submit</button>\n        </form>\n      </section>\n    </main>\n  </body>\n</html>"
