        "contents": "function sumAll(arr) {\r\n  var sum = 0;\r\n  arr.sort(function(a,b) {return a-b;});\r\n  for (var i = arr[0]; i <= arr[1]; i++) {\r\n    sum += i;\r\n  }\r\n  return sum;\r\n}",
