{"componentChunkName":"component---src-templates-challenges-classic-show-tsx","path":"/learn/rosetta-code/rosetta-code-challenges/cusip","result":{"data":{"challengeNode":{"challenge":{"block":"rosetta-code-challenges","demoType":null,"title":"Cusip","description":"<section id=\"description\">\n<p><strong>CUSIP</strong> je devetoznakovni alfanumerički kod koji identifikuje finansijske hartije od vrednosti u Severnoj Americi radi lakšeg poravnanja i namirenja trgovine. CUSIP je usvojen kao američki nacionalni standard prema standardu Accredited Standards X9.6.</p>\n</section>","id":"5a23c84252665b21eecc7e05","hasEditableBoundaries":false,"instructions":"<section id=\"instructions\">\n<p>Napiši funkciju koja prima niz znakova kao argument i proverava da li je taj niz validan CUSIP.</p>\n</section>","notes":null,"challengeType":1,"helpCategory":"Rosetta","videoUrl":null,"superBlock":"rosetta-code","translationPending":false,"forumTopicId":302241,"hooks":null,"fields":{"slug":"/learn/rosetta-code/rosetta-code-challenges/cusip"},"required":[],"usesMultifileEditor":false,"challengeFiles":[{"fileKey":"scriptjs","ext":"js","name":"script","contents":"function isCusip(s) {\n\n}","head":null,"tail":null,"editableRegionBoundaries":[],"history":["script.js"]}],"saveSubmissionToDB":null,"tests":[{"text":"<p><code>isCusip</code> Trebalo bi da bude funkcija.</p>","testString":"assert(typeof isCusip == 'function');"},{"text":"<p><code>isCusip(\"037833100\")</code> trebalo bi da vrati vrednost tačno ili netačno.</p>","testString":"assert(typeof isCusip('037833100') == 'boolean');"},{"text":"<p><code>isCusip(\"037833100\")</code> inapaswa kurudisha <code>true</code>.</p>","testString":"assert.equal(isCusip('037833100'), true);"},{"text":"<p><code>isCusip(\"17275R102\")</code> trebalo bi da vrati <code>true</code>.</p>","testString":"assert.equal(isCusip('17275R102'), true);"},{"text":"<p><code>isCusip(\"38259P50a\")</code> inapaswa kurudisha <code>false</code>.</p>","testString":"assert.equal(isCusip('38259P50a'), false);"},{"text":"<p><code>isCusip(\"38259P508\")</code> trebalo bi da vrati <code>true</code>.</p>","testString":"assert.equal(isCusip('38259P508'), true);"},{"text":"<p><code>isCusip(\"38259P50#\")</code> inapaswa kurudisha <code>false</code>.</p>","testString":"assert.equal(isCusip('38259P50#'), false);"},{"text":"<p><code>isCusip(\"68389X105\")</code> treba da vrati <code>true</code>.</p>","testString":"assert.equal(isCusip('68389X105'), true);"},{"text":"<p><code>isCusip(\"68389X106\")</code> inapaswa kurudisha <code>false</code>.</p>","testString":"assert.equal(isCusip('68389X106'), false);"},{"text":"<p><code>isCusip(\"5949181\")</code> inapaswa kurudisha <code>false</code>.</p>","testString":"assert.equal(isCusip('5949181'), false);"}]}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/rosetta-code/#rosetta-code-challenges","dashedName":"cusip","certification":"rosetta-code","disableLoopProtectTests":true,"disableLoopProtectPreview":false,"superBlock":"rosetta-code","chapter":null,"module":null,"block":"rosetta-code-challenges","isFirstStep":false,"template":null,"required":[],"isLastChallengeInBlock":false,"nextChallengePath":"/learn/rosetta-code/rosetta-code-challenges/cut-a-rectangle","prevChallengePath":"/learn/rosetta-code/rosetta-code-challenges/cumulative-standard-deviation","id":"5a23c84252665b21eecc7e05","saveSubmissionToDB":null},"projectPreview":{"challengeData":{"challengeType":1,"challengeFiles":[{"name":"script","ext":"js","contents":"function ZigZagMatrix(n) {\n  const mtx = [];\n  for (let i = 0; i < n; i++) {\n    mtx[i] = [];\n  }\n\n  let i = 1;\n  let j = 1;\n  for (let e = 0; e < n * n; e++) {\n    mtx[i - 1][j - 1] = e;\n    if ((i + j) % 2 === 0) {\n      // Even stripes\n      if (j < n) j++;\n      else i += 2;\n      if (i > 1) i--;\n    } else {\n      // Odd stripes\n      if (i < n) i++;\n      else j += 2;\n      if (j > 1) j--;\n    }\n  }\n  return mtx;\n}","history":["script.js"],"fileKey":"scriptjs"}]}},"id":"/learn/rosetta-code/rosetta-code-challenges/cusip"}},"staticQueryHashes":["3858520367"],"slicesMap":{}}