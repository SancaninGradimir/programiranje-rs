  "tests": [
    {
      "text": "<p>Trebalo bi da imaš element <code>div</code> ispod tvog elementa <code>button</code>.</p>",
      "testString": "assert.exists(document.querySelector('button + div'));"
    },
    {
      "text": "<p>Trebalo bi da imaš element <code>span</code> unutar svog elementa <code>div</code>.</p>",
      "testString": "assert.exists(document.querySelector('button + div > span'));"
    },
    {
      "text": "<p>Tvoj element od <code>span</code> mora imati svojstvo <code>id</code>.</p>",
      "testString": "const spanEl = document.querySelector('button + div > span');\nassert.isTrue(spanEl?.hasAttribute('id'));"
    },
    {
      "text": "<p>Vaš element <code>span</code> mora imati svojstvo <code>id</code> sa vrednošću postavljenu na <code>volume-label</code>.</p>",
      "testString": "const spanEl = document.querySelector('button + div > span');\nassert.equal(spanEl?.getAttribute('id'), 'volume-label');"
    },
    {
      "text": "<p>Vaše polje <code>span</code> mora imati tekst od <code>Volume</code>.</p>",
      "testString": "const spanEl = document.querySelector('button + div > span');\nassert.equal(spanEl?.innerText.trim(), 'Volume');"
    }
