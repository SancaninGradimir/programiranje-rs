{"componentChunkName":"component---src-templates-challenges-classic-show-tsx","path":"/learn/responsive-web-design-v9/workshop-html-video-player/step-10","result":{"data":{"challengeNode":{"challenge":{"block":"workshop-html-video-player","demoType":null,"title":"Korak 10","description":"<section id=\"description\">\n<p>Koristili ste video fajl sa ekstenzijom <code>mp4</code>, i morate reći pretraživaču da bi znao kako da pročita taj fajl.</p>\n<p>Koristićete atribut <code>type</code> za specifikovanje MIME tipa <code>video/mp4</code>.</p>\n<p>MIME (Multipurpose Internet Mail Extensions) je standard za opisivanje dokumenata u oblicima različitim od ASCII teksta, na primer, audio, video i slike.</p>\n<p>MP4, zvanično poznat kao MPEG-4 Deo 14, digitalni multimedijski kontejnerski format je. Široko se koristi za skladištenje videa i zvuka, ali može da uključuje i druge tipove podataka poput titlova i statičnih slika. MP4 fajlovi su dizajnirani za striming preko Interneta i kompatibilni su sa mnogim uređajima i platformama.</p>\n<p>Sada dodajte atribut <code>type</code> i vrednost <code>video/mp4</code>.</p>\n</section>","id":"68f26a5f79e97c5032c10642","hasEditableBoundaries":true,"instructions":"","notes":null,"challengeType":0,"helpCategory":"HTML-CSS","videoUrl":null,"superBlock":"responsive-web-design-v9","translationPending":false,"forumTopicId":null,"hooks":null,"fields":{"slug":"/learn/responsive-web-design-v9/workshop-html-video-player/step-10"},"required":[],"usesMultifileEditor":true,"challengeFiles":[{"fileKey":"indexhtml","ext":"html","name":"index","contents":"<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Working with the HTML Video Element</title>\n</head>\n<body>\n  <h1>Working with the HTML Video Element</h1>\n  <video\n    width=\"640\"\n    loop\n    controls\n    muted\n    poster=\"https://cdn.freecodecamp.org/curriculum/labs/past-event2.jpg\"\n  >\n    <source\n      src=\"https://cdn.freecodecamp.org/curriculum/labs/what-is-the-map-method-and-how-does-it-work.mp4\"\n      \n    >\n  </video>\n</body>\n</html>","head":null,"tail":null,"editableRegionBoundaries":[18,20],"history":["index.html"]}],"saveSubmissionToDB":null,"tests":[{"text":"<p>Your <code>source</code> element should have a <code>type</code> attribute.</p>","testString":"const source = document.querySelector('source');\nassert.isTrue(source?.hasAttribute('type'));"},{"text":"<p>Your <code>source</code> element should have a <code>type</code> attribute with the value <code>video/mp4</code>.</p>","testString":"const source = document.querySelector('source');\nassert.strictEqual(source?.getAttribute('type'), 'video/mp4');"}]}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/responsive-web-design-v9/#workshop-html-video-player","dashedName":"step-10","certification":"responsive-web-design-v9","disableLoopProtectTests":false,"disableLoopProtectPreview":false,"superBlock":"responsive-web-design-v9","chapter":"html","module":"basic-html","block":"workshop-html-video-player","isFirstStep":false,"template":null,"required":[],"isLastChallengeInBlock":false,"nextChallengePath":"/learn/responsive-web-design-v9/workshop-html-video-player/step-11","prevChallengePath":"/learn/responsive-web-design-v9/workshop-html-video-player/step-9","id":"68f26a5f79e97c5032c10642","saveSubmissionToDB":null},"projectPreview":{"challengeData":{"challengeType":0,"challengeFiles":[{"name":"index","ext":"html","contents":"<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Working with the HTML Video Element</title>\n</head>\n<body>\n  <h1>Working with the HTML Video Element</h1>\n  <video\n    width=\"640\"\n    controls\n    loop\n    muted\n    poster=\"https://cdn.freecodecamp.org/curriculum/labs/past-event2.jpg\"\n  >\n    <source\n       src=