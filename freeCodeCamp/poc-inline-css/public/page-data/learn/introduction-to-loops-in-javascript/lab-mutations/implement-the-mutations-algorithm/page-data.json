{"componentChunkName":"component---src-templates-challenges-classic-show-tsx","path":"/learn/introduction-to-loops-in-javascript/lab-mutations/implement-the-mutations-algorithm","result":{"data":{"challengeNode":{"challenge":{"block":"lab-mutations","demoType":null,"title":"Implementiraj algoritam promena","description":"<section id=\"description\">\n<p><strong>Cilj:</strong> Popunite korisničke priče ispod i prođite sve testove kako biste završili laboratorijum.</p>\n<p><strong>Priče korisnika:</strong></p>\n<ol>\n<li>Funkciju nazvanu <code>mutation</code> koja prima niz podataka kao svoj argument.</li>\n<li><code>mutation</code> bi trebalo da vrati <code>true</code> ako niz slova u prvom elementu niza podataka sadrži sva slova sekvence slova iz drugog elementa niza podataka, i <code>false</code> inače. Primer:\n<ul>\n<li><code>mutation([\"hello\", \"Hello\"])</code> bi trebalo da vrati <code>true</code> jer sva slova u sekvenci slova iz drugog su u prvom, bez obzira na veličinu (velika ili mala slova).</li>\n<li><code>mutation([\"hello\", \"hey\"])</code> bi trebalo da vrati <code>false</code> jer sekvenca slova <code>hello</code> nema <code>y</code>.</li>\n<li><code>mutation([\"Alien\", \"line\"])</code> bi trebalo da vrati <code>true</code> jer sva slova u <code>line</code> su u <code>Alien</code>.</li>\n</ul>\n</li>\n</ol>\n</section>","id":"af2170cad53daa0770fabdea","hasEditableBoundaries":false,"instructions":"","notes":null,"challengeType":26,"helpCategory":"JavaScript","videoUrl":null,"superBlock":"introduction-to-loops-in-javascript","translationPending":false,"forumTopicId":null,"hooks":null,"fields":{"slug":"/learn/introduction-to-loops-in-javascript/lab-mutations/implement-the-mutations-algorithm"},"required":[],"usesMultifileEditor":true,"challengeFiles":[{"fileKey":"scriptjs","ext":"js","name":"script","contents":"","head":null,"tail":null,"editableRegionBoundaries":[],"history":["script.js"]}],"saveSubmissionToDB":null,"tests":[{"text":"<p><code>mutation([\"hello\", \"hey\"])</code> treba da vrati <code>false</code>.</p>","testString":"assert.isFalse(mutation(['hello', 'hey']));"},{"text":"<p><code>mutation([\"hello\", \"Hello\"])</code> treba da vrati <code>true</code>.</p>","testString":"assert.isTrue(mutation(['hello', 'Hello']));"},{"text":"<p><code>mutation([\"zyxwvutsrqponmlkjihgfedcba\", \"qrstu\"])</code> treba da vrati <code>true</code>.</p>","testString":"assert.isTrue(mutation(['zyxwvutsrqponmlkjihgfedcba', 'qrstu']));"},{"text":"<p><code>mutation([\"Mary\", \"Army\"])</code> treba da vrati <code>true</code>.</p>","testString":"assert.isTrue(mutation(['Mary', 'Army']));"},{"text":"<p><code>mutation([\"Mary\", \"Aarmy\"])</code> treba da vrati <code>true</code>.</p>","testString":"assert.isTrue(mutation(['Mary', 'Aarmy']));"},{"text":"<p><code>mutation([\"Alien\", \"line\"])</code> treba da vrati <code>true</code>.</p>","testString":"assert.isTrue(mutation(['Alien', 'line']));"},{"text":"<p><code>mutation([\"floor\", \"for\"])</code> treba da vrati <code>true</code>.</p>","testString":"assert.isTrue(mutation(['floor', 'for']));"},{"text":"<p><code>mutation([\"hello\", \"neo\"])</code> trebalo bi da vrati <code>false</code>.</p>","testString":"assert.isFalse(mutation(['hello', 'neo']));"},{"text":"<p><code>mutation([\"voodoo\", \"no\"])</code> trebalo bi da vrati <code>false</code>.</p>","testString":"assert.isFalse(mutation(['voodoo', 'no']));"},{"text":"<p><code>mutation([\"ate\", \"date\"])</code> trebalo bi da vrati <code>false</code>.</p>","testString":"assert.isFalse(mutation(['ate', 'date']));"},{"text":"<p><code>mutation([\"Tiger\", \"Zebra\"])</code> treba da vrati <code>false</code>.</p>","testString":"assert.isFalse(mutation(['Tiger', 'Zebra']));"},{"text":"<p><code>mutation([\"Noel\", \"Ole\"])</code> treba vratiti <code>true</code>.</p>","testString":"assert.isTrue(mutation(['Noel', 'Ole']));"}]}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/introduction-to-loops-in-javascript/#lab-mutations","dashedName":"implement-the-mutations-algorithm","certification":"introduction-to-loops-in-javascript","disableLoopProtectTests":false,"disableLoopProtectPreview":false,"superBlock":"introduction-to-loops-in-javascript","chapter":null,"module":null,"block":"lab-mutations","isFirstStep":true,"template":null,"required":[],"isLastChallengeInBlock":true,"nextChallengePath":"/learn/introduction-to-loops-in-javascript/lab-chunky-monkey/implement-the-chunky-monkey-algorithm","prevChallengePath":"/learn/introduction-to-loops-in-javascript/lab-factorial-calculator/build-a-factorial-calculator","id":"af2170cad53daa0770fabdea","saveSubmissionToDB":null},"projectPreview":{"challengeData":{"challengeType":26,"challengeFiles":[{"name":"script","ext":"js","contents":"function mutation(arr) {\r\n  let hash = Object.create(null);\r\n\r\n  arr[0]\r\n    .toLowerCase()\r\n    .split('')\r\n    .forEach(c => (hash[c] = true));\r\n\r\n  return !arr[1]\r\n    .toLowerCase()\r\n    .split('')\r\n    .filter(c => !hash[c]).length;\r\n}\r\n\r\nmutation(['hello', 'hey']);","history":["script.js"],"fileKey":"scriptjs"}]}},"id":"/learn/introduction-to-loops-in-javascript/lab-mutations/implement-the-mutations-algorithm"}},"staticQueryHashes":["3858520367"],"slicesMap":{}}