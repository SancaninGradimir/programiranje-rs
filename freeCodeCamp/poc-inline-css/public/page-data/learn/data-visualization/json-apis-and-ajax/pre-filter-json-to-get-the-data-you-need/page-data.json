{"componentChunkName":"component---src-templates-challenges-classic-show-tsx","path":"/learn/data-visualization/json-apis-and-ajax/pre-filter-json-to-get-the-data-you-need","result":{"data":{"challengeNode":{"challenge":{"block":"json-apis-and-ajax","demoType":null,"title":"Filtriraj početni JSON ili dobiti podatke koji su ti potrebni","description":"<section id=\"description\">\n<p>Ako ne želiš da prikažeš svaku sliku mačke koju dobiješ od freeCodeCamp Cat Photo API, možeš prethodno filtrirati JSON pre nego što ih pregledaš.</p>\n<p>Pošto su podaci za JSON sačuvani u redovima podataka, možete koristiti metodu <code>filter</code> da filtrirate zapis čiji ključ <code>id</code> ima vrednost <code>1</code>.</p>\n<p>Evo koda da se to učini:</p>\n<pre><code class=\"language-js\">json = json.filter(function (val) {\r\n  return val.id !== 1;\r\n});\n</code></pre>\n</section>","id":"587d7fae367417b2b2512be7","hasEditableBoundaries":false,"instructions":"<section id=\"instructions\">\n<p>Dodajte kod za <code>filter</code> JSON podatke ili uklonite objekat sa vrednošću <code>id</code> od <code>1</code>.</p>\n</section>","notes":null,"challengeType":6,"helpCategory":"JavaScript","videoUrl":null,"superBlock":"data-visualization","translationPending":false,"forumTopicId":18257,"hooks":null,"fields":{"slug":"/learn/data-visualization/json-apis-and-ajax/pre-filter-json-to-get-the-data-you-need"},"required":[{"link":"https://cdnjs.cloudflare.com/ajax/libs/twitter-bootstrap/3.3.7/css/bootstrap.css","src":null}],"usesMultifileEditor":false,"challengeFiles":[{"fileKey":"indexhtml","ext":"html","name":"index","contents":"<script>\r\n  document.addEventListener('DOMContentLoaded', function () {\r\n    document.getElementById('getMessage').onclick = function () {\r\n      const req = new XMLHttpRequest();\r\n      req.open('GET', '/json/cats.json', true);\r\n      req.send();\r\n      req.onload = function () {\r\n        let json = JSON.parse(req.responseText);\r\n        let html = '';\r\n        // Add your code below this line\r\n\r\n        // Add your code above this line\r\n        json.forEach(function (val) {\r\n          html += \"<div class = 'cat'>\";\r\n\r\n          html +=\r\n            \"<img src = '\" +\r\n            val.imageLink +\r\n            \"' \" +\r\n            \"alt='\" +\r\n            val.altText +\r\n            \"'>\";\r\n\r\n          html += '</div>';\r\n        });\r\n        document.getElementsByClassName('message')[0].innerHTML = html;\r\n      };\r\n    };\r\n  });\r\n</script>\r\n\r\n<style>\r\n  body {\r\n    text-align: center;\r\n    font-family: 'Helvetica', sans-serif;\r\n  }\r\n  h1 {\r\n    font-size: 2em;\r\n    font-weight: bold;\r\n  }\r\n  .box {\r\n    border-radius: 5px;\r\n    background-color: #eee;\r\n    padding: 20px 5px;\r\n  }\r\n  button {\r\n    color: white;\r\n    background-color: #4791d0;\r\n    border-radius: 5px;\r\n    border: 1px solid #4791d0;\r\n    padding: 5px 10px 8px 10px;\r\n  }\r\n  button:hover {\r\n    background-color: #0f5897;\r\n    border: 1px solid #0f5897;\r\n  }\r\n</style>\r\n\r\n<h1>Cat Photo Finder</h1>\r\n<p class=\"message box\">The message will go here</p>\r\n<p>\r\n  <button id=\"getMessage\">Get Message</button>\r\n</p>","head":null,"tail":null,"editableRegionBoundaries":[],"history":["index.html"]}],"saveSubmissionToDB":null,"tests":[{"text":"<p>Tvoj kod treba da koristi putanju <code>filter</code>.</p>","testString":"assert.match(code, /json\\.filter/g);"}]}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/data-visualization/#json-apis-and-ajax","dashedName":"pre-filter-json-to-get-the-data-you-need","certification":"data-visualization","disableLoopProtectTests":false,"disableLoopProtectPreview":false,"superBlock":"data-visualization","chapter":null,"module":null,"block":"json-apis-and-ajax","isFirstStep":false,"template":null,"required":[{"link":"https://cdnjs.cloudflare.com/ajax/libs/twitter-bootstrap/3.3.7/css/bootstrap.css","src":null}],"isLastChallengeInBlock":false,"nextChallengePath":"/learn/data-visualization/json-apis-and-ajax/get-geolocation-data-to-find-a-users-gps-coordinates","prevChallengePath":"/learn/data-visualization/json-apis-and-ajax/render-images-from-data-sources","id":"587d7fae367417b2b2512be7","saveSubmissionToDB":null},"projectPreview":{"challengeData":{"challengeType":6,"challengeFiles":[{"name":"index","ext":"html","contents":"<script>\r\n  document.addEventListener('DOMContentLoaded', function () {\r\n    document.getElementById('sendMessage').onclick = function () {\r\n      const userName = document.getElementById('name').value;\r\n      const url = 'https://jsonplaceholder.typicode.com/posts';\r\n      // Add your code below this line\r\n      const xhr = new XMLHttpRequest();\r\n      xhr.open('POST', url, true);\r\n      xhr.setRequestHeader('Content-Type', 'application/json; charset=UTF-8');\r\n      xhr.onreadystatechange = function () {\r\n        if (xhr.readyState === 4 && xhr.status === 201) {\r\n          const serverResponse = JSON.parse(xhr.response);\r\n          document.getElementsByClassName('message')[0].textContent =\r\n            serverResponse.userName + serverResponse.suffix;\r\n        }\r\n      };\r\n      const body = JSON.stringify({\r\n        userName: userName,\r\n        suffix: ' loves cats!'\r\n      });\r\n      xhr.send(body);\r\n      // Add your code above this line\r\n    };\r\n  });\r\n</script>\r\n\r\n<style>\r\n  body {\r\n    text-align: center;\r\n    font-family: 'Helvetica', sans-serif;\r\n  }\r\n  h1 {\r\n    font-size: 2em;\r\n    font-weight: bold;\r\n  }\r\n  .box {\r\n    border-radius: 5px;\r\n    background-color: #eee;\r\n    padding: 20px 5px;\r\n  }\r\n  button {\r\n    color: white;\r\n    background-color: #4791d0;\r\n    border-radius: 5px;\r\n    border: 1px solid #4791d0;\r\n    padding: 5px 10px 8px 10px;\r\n  }\r\n  button:hover {\r\n    background-color: #0f5897;\r\n    border: 1px solid #0f5897;\r\n  }\r\n</style>\r\n\r\n<h1>Cat Friends</h1>\r\n<p class=\"message\">Reply from Server will be here</p>\r\n<p>\r\n  <label for=\"name\"\r\n    >Your name:\r\n    <input type=\"text\" id=\"name\" />\r\n  </label>\r\n  <button id=\"sendMessage\">Send Message</button>\r\n</p>","history":["index.html"],"fileKey":"indexhtml"}]}},"id":"/learn/data-visualization/json-apis-and-ajax/pre-filter-json-to-get-the-data-you-need"}},"staticQueryHashes":["3858520367"],"slicesMap":{}}