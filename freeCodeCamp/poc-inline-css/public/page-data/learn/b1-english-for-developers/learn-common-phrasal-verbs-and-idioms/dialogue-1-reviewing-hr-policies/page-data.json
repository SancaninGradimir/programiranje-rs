{"componentChunkName":"component---src-templates-challenges-generic-show-tsx","path":"/learn/b1-english-for-developers/learn-common-phrasal-verbs-and-idioms/dialogue-1-reviewing-hr-policies","result":{"data":{"challengeNode":{"challenge":{"assignments":["<p>Gledaj video.</p>"],"bilibiliIds":null,"block":"learn-common-phrasal-verbs-and-idioms","challengeType":21,"description":"<section id=\"description\">\n<p>Pogledajte video ispod da biste razumeli kontekst sledećih lekcija.</p>\n</section>","nodules":null,"explanation":null,"helpCategory":"English","instructions":"","fields":{"slug":"/learn/b1-english-for-developers/learn-common-phrasal-verbs-and-idioms/dialogue-1-reviewing-hr-policies"},"questions":[],"scene":{"setup":{"background":"interview-room2.png","characters":[{"character":"Anna","position":{"x":-25,"y":0,"z":1},"opacity":null},{"character":"Brian","position":{"x":125,"y":0,"z":1},"opacity":null}],"audio":{"filename":"B1_24-1.mp3","startTime":1,"startTimestamp":null,"finishTimestamp":null},"alwaysShowDialogue":true},"commands":[{"background":null,"character":"Anna","position":{"x":25,"y":0,"z":1},"opacity":null,"startTime":0,"finishTime":null,"dialogue":null},{"background":null,"character":"Brian","position":{"x":70,"y":0,"z":1},"opacity":null,"startTime":0.5,"finishTime":null,"dialogue":null},{"background":null,"character":"Anna","position":null,"opacity":null,"startTime":1,"finishTime":7.48,"dialogue":{"text":"Brian, we really need to hash out the updates to our remote work policy. There's been a lot of back and forth on what should be included.","align":"left"}},{"background":null,"character":"Brian","position":null,"opacity":null,"startTime":8.32,"finishTime":16.36,"dialogue":{"text":"Absolutely, Anna. It's crucial that we iron out these details soon. Let's start by phasing out the old clause about mandatory in-office days.","align":"right"}},{"background":null,"character":"Brian","position":null,"opacity":null,"startTime":16.54,"finishTime":18.06,"dialogue":{"text":"It's not fitting our current model.","align":"right"}},{"background":null,"character":"Anna","position":null,"opacity":null,"startTime":18.6,"finishTime":22.74,"dialogue":{"text":"I agree. We should also lay down some guidelines for communication during remote work.","align":"left"}},{"background":null,"character":"Anna","position":null,"opacity":null,"startTime":22.9,"finishTime":26.48,"dialogue":{"text":"Making sure that everyone is on the same page will help streamline our operations.","align":"left"}},{"background":null,"character":"Brian","position":null,"opacity":null,"startTime":26.48,"finishTime":32.48,"dialogue":{"text":"Definitely. On another note, we need to touch base on the employee feedback regarding annual leave.","align":"right"}},{"background":null,"character":"Brian","position":null,"opacity":null,"startTime":32.7,"finishTime":36.18,"dialogue":{"text":"Some people feel like the process to apply is a bit inefficient.","align":"right"}},{"background":null,"character":"Anna","position":null,"opacity":null,"startTime":36.96,"finishTime":41.08,"dialogue":{"text":"That's a good point. Perhaps we can simplify it by cutting down unnecessary steps.","align":"left"}},{"background":null,"character":"Anna","position":null,"opacity":null,"startTime":41.54,"finishTime":46.68,"dialogue":{"text":"Making it easy to apply should encourage more people to take the time off they need without feeling bogged down.","align":"left"}},{"background":null,"character":"Brian","position":null,"opacity":null,"startTime":47.18,"finishTime":51.26,"dialogue":{"text":"Right. And while we're at it, let's wrap up the section on professional development.","align":"right"}},{"background":null,"character":"Brian","position":null,"opacity":null,"startTime":51.5,"finishTime":56,"dialogue":{"text":"We should encourage staff to branch out in their skills without making it sound too daunting.","align":"right"}},{"background":null,"character":"Anna","position":null,"opacity":null,"startTime":56.48,"finishTime":64.38,"dialogue":{"text":"Great idea, Brian. Encouraging growth is key. How about we put together a draft of these changes and run it by the team leads before we roll it out company-wide?","align":"left"}},{"background":null,"character":"Brian","position":null,"opacity":null,"startTime":64.64,"finishTime":73.66,"dialogue":{"text":"Sounds like a plan. I'll draft up the changes and set up a meeting with the team leads next week. We can iron out any kinks, then get everyone's buy-in.","align":"right"}},{"background":null,"character":"Anna","position":null,"opacity":null,"startTime":74.28,"finishTime":81.02,"dialogue":{"text":"Perfect, Brian. Thanks for helping to make these policies clearer. It's important that they reflect our company's values and current work environment.","align":"left"}},{"background":null,"character":"Brian","position":null,"opacity":null,"startTime":81.4,"finishTime":84.82,"dialogue":{"text":"My pleasure, Anna. Let's make sure these policies do just that.","align":"right"}},{"background":null,"character":"Brian","position":{"x":125,"y":0,"z":1},"opacity":null,"startTime":85.32,"finishTime":null,"dialogue":null},{"background":null,"character":"Anna","position":{"x":-25,"y":0,"z":1},"opacity":null,"startTime":85.82,"finishTime":null,"dialogue":null}]},"superBlock":"b1-english-for-developers","tests":[],"title":"Dijalog 1: Pregledanje politika Ljudskih Resursa","transcript":null,"translationPending":false,"videoId":null,"videoLocaleIds":null}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/b1-english-for-developers/#learn-common-phrasal-verbs-and-idioms","dashedName":"dialogue-1-reviewing-hr-policies","certification":"b1-english-for-developers","disableLoopProtectTests":false,"disableLoopProtectPreview":false,"superBlock":"b1-english-for-developers","chapter":null,"module":null,"block":"learn-common-phrasal-verbs-and-idioms","isFirstStep":true,"template":null,"required":[],"isLastChallengeInBlock":false,"ne