        "fileKey": "scriptjs",
        "contents": "function idMatrix(n) {\n    return Array.apply(null, new Array(n)).map(function (x, i, xs) {\n        return xs.map(function (_, k) {\n            return i === k ? 1 : 0;\n        })\n    });\n}",
