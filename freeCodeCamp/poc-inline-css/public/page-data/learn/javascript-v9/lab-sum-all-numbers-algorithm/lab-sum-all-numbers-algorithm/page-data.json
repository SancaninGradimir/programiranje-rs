{"componentChunkName":"component---src-templates-challenges-classic-show-tsx","path":"/learn/javascript-v9/lab-sum-all-numbers-algorithm/lab-sum-all-numbers-algorithm","result":{"data":{"challengeNode":{"challenge":{"block":"lab-sum-all-numbers-algorithm","demoType":null,"title":"Napravi algoritam za sabiranje svih brojeva","description":"<section id=\"description\">\n<p>U ovoj laboratoriji ćeš morati da napraviš algoritam za sabiranje svih brojeva.</p>\n<p><strong>Cilj:</strong> Popunite korisničke priče ispod i prođite sve testove da biste završili ovu laboratoriju.</p>\n<p><strong>Priče korisnika:</strong></p>\n<ol>\n<li>Trebalo bi da postoji funkcija pod nazivom <code>sumAll</code> koja prima niz od dve brojeve.</li>\n<li><code>sumAll([n, m])</code> treba da vrati zbir <code>n</code> i <code>m</code> zajedno sa zbirom svih brojeva između njih. Manji broj neće uvek biti prvi. Na primer, <code>sumAll([4,1])</code> treba da vrati <code>10</code> jer je zbir svih brojeva između <code>1</code> i <code>4</code> (uključujući sve) <code>10</code>.</li>\n</ol>\n</section>","id":"a3566b1109230028080c9345","hasEditableBoundaries":false,"instructions":"","notes":null,"challengeType":26,"helpCategory":"JavaScript","videoUrl":null,"superBlock":"javascript-v9","translationPending":false,"forumTopicId":null,"hooks":null,"fields":{"slug":"/learn/javascript-v9/lab-sum-all-numbers-algorithm/lab-sum-all-numbers-algorithm"},"required":[],"usesMultifileEditor":true,"challengeFiles":[{"fileKey":"scriptjs","ext":"js","name":"script","contents":"","head":null,"tail":null,"editableRegionBoundaries":[],"history":["script.js"]}],"saveSubmissionToDB":null,"tests":[{"text":"<p>Trebalo bi da imaš funkciju koja se zove <code>sumAll</code>.</p>","testString":"assert.isFunction(sumAll);"},{"text":"<p><code>sumAll([1, 4])</code> Trebalo bi da vrati broj.</p>","testString":"assert.isNumber(sumAll([1, 4]));"},{"text":"<p><code>sumAll([1, 4])</code> treba da vrati <code>10</code>.</p>","testString":"assert.equal(sumAll([1, 4]), 10);"},{"text":"<p><code>sumAll([4, 1])</code> trebalo bi da vrati <code>10</code>.</p>","testString":"assert.equal(sumAll([4, 1]), 10);"},{"text":"<p><code>sumAll([5, 10])</code> treba da vrati <code>45</code>.</p>","testString":"assert.equal(sumAll([5, 10]), 45);"},{"text":"<p><code>sumAll([10, 5])</code> treba da vrati <code>45</code>.</p>","testString":"assert.equal(sumAll([10, 5]), 45);"}]}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/javascript-v9/#lab-sum-all-numbers-algorithm","dashedName":"lab-sum-all-numbers-algorithm","certification":"javascript-v9","disableLoopProtectTests":false,"disableLoopProtectPreview":false,"superBlock":"javascript-v9","chapter":"javascript","module":"review-javascript-fundamentals","block":"lab-sum-all-numbers-algorithm","isFirstStep":true,"template":null,"required":[],"isLastChallengeInBlock":true,"nextChallengePath":"/learn/javascript-v9/lab-dna-pair-generator/implement-a-dna-pair-generator","prevChallengePath":"/learn/javascript-v9/lab-password-generator/lab-password-generator","id":"a3566b1109230028080c9345","saveSubmissionToDB":null},"projectPreview":{"challengeData":{"challengeType":26,"challengeFiles":[{"name":"script","ext":"js","contents":"function sumAll(arr) {\r\n  let sum = 0;\r\n  \r\n  arr.sort((a, b) => a - b);\r\n\r\n  for (var i = arr[0]; i <= arr[1]; i++) {\r\n    sum += i;\r\n  }\r\n\r\n  return sum;\r\n}","history":["script.js"],"fileKey":"scriptjs"}]}},"id":"/learn/javascript-v9/lab-sum-all-numbers-algorithm/lab-sum-all-numbers-algorithm"}},"staticQueryHashes":["3858520367"],"slicesMap":{}}