{"componentChunkName":"component---src-templates-challenges-classic-show-tsx","path":"/learn/rosetta-code/rosetta-code-challenges/jortsort","result":{"data":{"challengeNode":{"challenge":{"block":"rosetta-code-challenges","demoType":null,"title":"JortSort","description":"<section id=\"description\">\n<p>jortSort je alat za sortiranje koji omogućava korisniku da radi i osigurava efikasnost jer više nikada neće morati ponovo da sortiraju. Originalno je predstavljen od strane Jen \"Moneydollars\" Schiffer na poznatom kongresu JSConf2014.</p>\n<p>jortSort bi trebalo da bude funkcija koja prima niz uporedivih elemenata kao svoj argument. Zatim sortira taj niz u uzlaznom redosledu i upoređuje sortirani niz sa prvobitnim nizom. Ako su nizovi identični (što znači da je originalni niz već bio sortiran), funkcija vraća true. Ako nisu identični (što znači da originalni niz nije bio sortiran), funkcija vraća false.</p>\n</section>","id":"5a23c84252665b21eecc7ec4","hasEditableBoundaries":false,"instructions":"","notes":null,"challengeType":1,"helpCategory":"Rosetta","videoUrl":null,"superBlock":"rosetta-code","translationPending":false,"forumTopicId":302293,"hooks":null,"fields":{"slug":"/learn/rosetta-code/rosetta-code-challenges/jortsort"},"required":[],"usesMultifileEditor":false,"challengeFiles":[{"fileKey":"scriptjs","ext":"js","name":"script","contents":"function jortsort(array) {\n\n}","head":null,"tail":null,"editableRegionBoundaries":[],"history":["script.js"]}],"saveSubmissionToDB":null,"tests":[{"text":"<p><code>jortsort</code> Trebalo bi da bude funkcija.</p>","testString":"assert(typeof jortsort == 'function');"},{"text":"<p><code>jortsort([1,2,3,4,5])</code> treba da vrati vrednost tačno ili netačno.</p>","testString":"assert(typeof jortsort([1, 2, 3, 4, 5]) == 'boolean');"},{"text":"<p><code>jortsort([1,2,3,4,5])</code> treba da restaurira <code>true</code>.</p>","testString":"assert.equal(jortsort([1, 2, 3, 4, 5]), true);"},{"text":"<p><code>jortsort([1,2,13,4,5])</code> treba da restaurira <code>false</code>.</p>","testString":"assert.equal(jortsort([1, 2, 13, 4, 5]), false);"},{"text":"<p><code>jortsort([12,4,51,2,4])</code> treba da vrati <code>false</code>.</p>","testString":"assert.equal(jortsort([12, 4, 51, 2, 4]), false);"},{"text":"<p><code>jortsort([1,2])</code> treba da vrati <code>true</code>.</p>","testString":"assert.equal(jortsort([1, 2]), true);"},{"text":"<p><code>jortsort([5,4,3,2,1])</code> treba da resta/vrati <code>false</code>.</p>","testString":"assert.equal(jortsort([5, 4, 3, 2, 1]), false);"},{"text":"<p><code>jortsort([1,1,1,1,1])</code> treba da vrati <code>true</code>.</p>","testString":"assert.equal(jortsort([1, 1, 1, 1, 1]), true);"}]}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/rosetta-code/#rosetta-code-challenges","dashedName":"jortsort","certification":"rosetta-code","disableLoopProtectTests":true,"disableLoopProtectPreview":false,"superBlock":"rosetta-code","chapter":null,"module":null,"block":"rosetta-code-challenges","isFirstStep":false,"template":null,"required":[],"isLastChallengeInBlock":false,"nextChallengePath":"/learn/rosetta-code/rosetta-code-challenges/josephus-problem","prevChallengePath":"/learn/rosetta-code/rosetta-code-challenges/jaro-distance","id":"5a23c84252665b21eecc7ec4","saveSubmissionToDB":null},"projectPreview":{"challengeData":{"challengeType":1,"challengeFiles":[{"name":"script","ext":"js","contents":"function ZigZagMatrix(n) {\n  const mtx = [];\n  for (let i = 0; i < n; i++) {\n    mtx[i] = [];\n  }\n\n  let i = 1;\n  let j = 1;\n  for (let e = 0; e < n * n; e++) {\n    mtx[i - 1][j - 1] = e;\n    if ((i + j) % 2 === 0) {\n      // Even stripes\n      if (j < n) j++;\n      else i += 2;\n      if (i > 1) i--;\n    } else {\n      // Odd stripes\n      if (i < n) i++;\n      else j += 2;\n      if (j > 1) j--;\n    }\n  }\n  return mtx;\n}","history":["script.js"],"fileKey":"scriptjs"}]}},"id":"/learn/rosetta-code/rosetta-code-challenges/jortsort"}},"s