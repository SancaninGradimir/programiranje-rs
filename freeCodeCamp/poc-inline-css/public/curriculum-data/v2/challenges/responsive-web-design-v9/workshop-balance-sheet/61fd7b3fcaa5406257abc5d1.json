      "text": "<p>Element vašeg <code>caption</code> treba da ima tekst od <code>Liabilities</code>.</p>",
      "testString": "assert.strictEqual(\n  document.querySelectorAll('table')?.[1]?.querySelector('caption')\n    ?.textContent.trim(),\n  'Liabilities'\n);"
