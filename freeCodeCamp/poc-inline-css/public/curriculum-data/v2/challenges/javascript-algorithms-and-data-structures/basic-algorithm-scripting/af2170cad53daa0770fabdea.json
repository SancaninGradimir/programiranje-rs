        "path": "script.js",
        "fileKey": "scriptjs",
        "contents": "function mutation(arr) {\n  let hash = Object.create(null);\n\n  arr[0]\n    .toLowerCase()\n    .split('')\n    .forEach(c => (hash[c] = true));\n\n  return !arr[1]\n    .toLowerCase()\n    .split('')\n    .filter(c => !hash[c]).length;\n}\n\nmutation(['hello', 'hey']);",
        "error": null,
        "seed": "function mutation(arr) {\n  let hash = Object.create(null);\n\n  arr[0]\n    .toLowerCase()\n    .split('')\n    .forEach(c => (hash[c] = true));\n\n  return !arr[1]\n    .toLowerCase()\n    .split('')\n    .filter(c => !hash[c]).length;\n}\n\nmutation(['hello', 'hey']);"
      }
    ]
  ],
