{"componentChunkName":"component---src-templates-challenges-generic-show-tsx","path":"/learn/a2-english-for-developers/learn-how-to-talk-about-a-typical-workday-and-tasks/dialogue-2-anna-from-hr-tells-tom-about-the-company-routine","result":{"data":{"challengeNode":{"challenge":{"assignments":["<p>Gledaj video.</p>"],"bilibiliIds":null,"block":"learn-how-to-talk-about-a-typical-workday-and-tasks","challengeType":21,"description":"<section id=\"description\">\n<p>Pogledajte video dole/ispod kako biste razumeli kontekst predstojećih lekcija.</p>\n</section>","nodules":null,"explanation":null,"helpCategory":"English","instructions":"","fields":{"slug":"/learn/a2-english-for-developers/learn-how-to-talk-about-a-typical-workday-and-tasks/dialogue-2-anna-from-hr-tells-tom-about-the-company-routine"},"questions":[],"scene":{"setup":{"background":"interview-room3.png","characters":[{"character":"Anna","position":{"x":-25,"y":0,"z":1},"opacity":null},{"character":"Tom","position":{"x":125,"y":0,"z":1},"opacity":null}],"audio":{"filename":"2.1-2.mp3","startTime":1,"startTimestamp":null,"finishTimestamp":null},"alwaysShowDialogue":true},"commands":[{"background":null,"character":"Anna","position":{"x":25,"y":0,"z":1},"opacity":null,"startTime":0,"finishTime":null,"dialogue":null},{"background":null,"character":"Tom","position":{"x":70,"y":0,"z":1},"opacity":null,"startTime":0.5,"finishTime":null,"dialogue":null},{"background":null,"character":"Anna","position":null,"opacity":null,"startTime":1.5,"finishTime":5,"dialogue":{"text":"Hi, Tom. Let me tell you what a regular day at our company normally looks like.","align":"left"}},{"background":null,"character":"Anna","position":null,"opacity":null,"startTime":5.2,"finishTime":6.4,"dialogue":{"text":"We start at 9.","align":"left"}},{"background":null,"character":"Anna","position":null,"opacity":null,"startTime":6.6,"finishTime":10.1,"dialogue":{"text":"The first thing to do is log in to your computer and check your emails.","align":"left"}},{"background":null,"character":"Tom","position":null,"opacity":null,"startTime":10.8,"finishTime":13.3,"dialogue":{"text":"Sounds good. What do I do after checking emails?","align":"right"}},{"background":null,"character":"Anna","position":null,"opacity":null,"startTime":13.5,"finishTime":17,"dialogue":{"text":"After that, you'll probably attend the daily team meeting at 9:30.","align":"left"}},{"background":null,"character":"Anna","position":null,"opacity":null,"startTime":17.2,"finishTime":19.8,"dialogue":{"text":"During the meeting, the team discusses project updates.","align":"left"}},{"background":null,"character":"Tom","position":null,"opacity":null,"startTime":20,"finishTime":22.8,"dialogue":{"text":"I see. What about the rest of the day?","align":"right"}},{"background":null,"character":"Anna","position":null,"opacity":null,"startTime":23,"finishTime":26.6,"dialogue":{"text":"During the rest of the day, you usually work on your design projects,","align":"left"}},{"background":null,"character":"Anna","position":null,"opacity":null,"startTime":26.6,"finishTime":27.9,"dialogue":{"text":"collaborate with the team,","align":"left"}},{"background":null,"character":"Anna","position":null,"opacity":null,"startTime":28,"finishTime":30.5,"dialogue":{"text":"and attend meetings with clients when there are those meetings.","align":"left"}},{"background":null,"character":"Tom","position":null,"opacity":null,"startTime":30.7,"finishTime":32.7,"dialogue":{"text":"What time do we have our lunch break?","align":"right"}},{"background":null,"character":"Anna","position":null,"opacity":null,"startTime":33.4,"finishTime":35.9,"dialogue":{"text":"You have a one-hour lunch break around noon every day.","align":"left"}},{"background":null,"character":"Anna","position":null,"opacity":null,"startTime":36.1,"finishTime":38.6,"dialogue":{"text":"Bring your lunch or go to one of the cafés nearby.","align":"left"}},{"background":null,"character":"Anna","position":null,"opacity":null,"startTime":38.8,"finishTime":40.8,"dialogue":{"text":"The people from the team often do this.","align":"left"}},{"background":null,"character":"Tom","position":null,"opacity":null,"startTime":41,"finishTime":43.7,"dialogue":{"text":"How long are our workdays?","align":"right"}},{"background":null,"character":"Anna","position":null,"opacity":null,"startTime":43.9,"finishTime":48.4,"dialogue":{"text":"We typically finish at about 5, but that depends on project deadlines.","align":"left"}},{"background":null,"character":"Tom","position":null,"opacity":null,"startTime":48.6,"finishTime":50.4,"dialogue":{"text":"Thanks for explaining, Anna.","align":"right"}},{"background":null,"character":"Tom","position":null,"opacity":null,"startTime":50.8,"finishTime":52.8,"dialogue":{"text":"It helps me to understand what to expect.","align":"right"}},{"background":null,"character":"Anna","position":null,"opacity":null,"startTime":53,"finishTime":54.2,"dialogue":{"text":"You're welcome, Tom.","align":"left"}},{"background":null,"character":"Tom","position":{"x":125,"y":0,"z":1},"opacity":null,"startTime":54.7,"finishTime":null,"dialogue":null},{"background":null,"character":"Anna","position":{"x":-25,"y":0,"z":1},"opacity":null,"startTime":55.2,"finishTime":null,"dialogue":null}]},"superBlock":"a2-english-for-developers","tests":[],"title":"Dijalog 2: Anna iz HR-a priča Tomu o rutini u kompaniji","transcript":null,"translationPending":false,"videoId":null,"videoLocaleIds":null}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/a2-english-for-developers/#learn-how-to-talk-about-a-typical-workday-and-tasks","dashedName":"dialogue-2-anna-from-hr-tells-tom-about-the-company-routine","certification":"a2-english-for-developers","disableLoopProtectTests":false,"disableLoopProtectPreview":false,"superBlock":"a2-english-for-developers","chapter":null,"module":null,"block":"learn-how-to-talk-about-a-typical-workday-and-tasks","isFirstStep":false,"template":null,"required":[],