    {
      "text": "<p><code>addTogether(5)(7)</code> Trebalo bi da vrati 12.</p>",
      "testString": "assert.deepEqual(addTogether(5)(7), 12);"
    },
    {
      "text": "<p><code>addTogether(2)([3])</code> trebalo bi vratiti <code>undefined</code>.</p>",
      "testString": "assert.isUndefined(addTogether(2)([3]));"
