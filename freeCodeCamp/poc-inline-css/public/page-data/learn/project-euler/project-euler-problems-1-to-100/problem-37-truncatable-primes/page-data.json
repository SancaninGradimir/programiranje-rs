{"componentChunkName":"component---src-templates-challenges-classic-show-tsx","path":"/learn/project-euler/project-euler-problems-1-to-100/problem-37-truncatable-primes","result":{"data":{"challengeNode":{"challenge":{"block":"project-euler-problems-1-to-100","demoType":null,"title":"Vežba 37: osnovni brojevi koje je moguće izrezati","description":"<section id=\"description\">\n<p>Broj 3797 ima zanimljivo svojstvo. Iako je sam po sebi prost broj, moguće je uklanjati jednu po jednu cifru sleva nadesno i svaki dobijeni broj ostaje prost: 3797, 797, 97 i 7. Isto važi i kada se cifre uklanjaju zdesna nalevo: 3797, 379, 37 i 3.</p>\n<p>Pronađite ceo skup osnovnih brojeva <code>n</code> samo (8 ≤ <code>n</code> ≤ 11) koji se mogu čitati od leve ka desnoj i takođe od desne ka levoj.</p>\n<p>NAPOMENA: 2, 3, 5 i 7 smatraju se premi brojevima koji mogu biti faktorizovani.</p>\n</section>","id":"5900f3911000cf542c50fea4","hasEditableBoundaries":false,"instructions":"","notes":null,"challengeType":1,"helpCategory":"Euler","videoUrl":null,"superBlock":"project-euler","translationPending":false,"forumTopicId":302031,"hooks":null,"fields":{"slug":"/learn/project-euler/project-euler-problems-1-to-100/problem-37-truncatable-primes"},"required":[],"usesMultifileEditor":false,"challengeFiles":[{"fileKey":"scriptjs","ext":"js","name":"script","contents":"function truncatablePrimes(n) {\n\n  return n;\n}\n\ntruncatablePrimes(11);","head":null,"tail":null,"editableRegionBoundaries":[],"history":["script.js"]}],"saveSubmissionToDB":null,"tests":[{"text":"<p><code>truncatablePrimes(8)</code> treba da vrati broj.</p>","testString":"assert(typeof truncatablePrimes(8) === 'number');"},{"text":"<p><code>truncatablePrimes(8)</code> inapaswa kurudisha 1986.</p>","testString":"assert(truncatablePrimes(8) == 1986);"},{"text":"<p><code>truncatablePrimes(9)</code> inapaswa kurudisha 5123.</p>","testString":"assert(truncatablePrimes(9) == 5123);"},{"text":"<p><code>truncatablePrimes(10)</code> trebalo bi da vrati 8920.</p>","testString":"assert(truncatablePrimes(10) == 8920);"},{"text":"<p><code>truncatablePrimes(11)</code> treba da vrati 748317.</p>","testString":"assert(truncatablePrimes(11) == 748317);"}]}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/project-euler/#project-euler-problems-1-to-100","dashedName":"problem-37-truncatable-primes","certification":"project-euler","disableLoopProtectTests":true,"disableLoopProtectPreview":false,"superBlock":"project-euler","chapter":null,"module":null,"block":"project-euler-problems-1-to-100","isFirstStep":false,"template":null,"required":[],"isLastChallengeInBlock":false,"nextChallengePath":"/learn/project-euler/project-euler-problems-1-to-100/problem-38-pandigital-multiples","prevChallengePath":"/learn/project-euler/project-euler-problems-1-to-100/problem-36-double-base-palindromes","id":"5900f3911000cf542c50fea4","saveSubmissionToDB":null},"projectPreview":{"challengeData":{"challengeType":1,"challengeFiles":[{"name":"script","ext":"js","contents":"function arrangedProbability(limit) {\n  // Based on https://www.mathblog.dk/project-euler-100-blue-discs-two-blue/\n  let blue = 15;\n  let discs = 21;\n\n  while (discs < limit) {\n    const nextBlue = 3 * blue + 2 * discs - 2;\n    const nextDiscs = 4 * blue + 3 * discs - 3;\n\n    blue = nextBlue;\n    discs = nextDiscs;\n  }\n  return blue;\n}","history":["script.js"],"fileKey":"scriptjs"}]}},"id":"/learn/project-euler/project-euler-problems-1-to-100/problem-37-truncatable-primes"}},"staticQueryHashes":["3858520367"],"slicesMap":{}}