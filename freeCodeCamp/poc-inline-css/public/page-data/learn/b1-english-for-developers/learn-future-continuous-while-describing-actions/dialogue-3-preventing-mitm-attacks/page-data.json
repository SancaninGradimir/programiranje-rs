{"componentChunkName":"component---src-templates-challenges-generic-show-tsx","path":"/learn/b1-english-for-developers/learn-future-continuous-while-describing-actions/dialogue-3-preventing-mitm-attacks","result":{"data":{"challengeNode":{"challenge":{"assignments":["<p>Gledaj video.</p>"],"bilibiliIds":null,"block":"learn-future-continuous-while-describing-actions","challengeType":21,"description":"<section id=\"description\">\n<p>Pogledajte video ispod da biste razumeli kontekst sledećih lekcija.</p>\n</section>","nodules":null,"explanation":null,"helpCategory":"English","instructions":"","fields":{"slug":"/learn/b1-english-for-developers/learn-future-continuous-while-describing-actions/dialogue-3-preventing-mitm-attacks"},"questions":[],"scene":{"setup":{"background":"interview-room1.png","characters":[{"character":"Anna","position":{"x":-25,"y":0,"z":1},"opacity":null},{"character":"Brian","position":{"x":125,"y":0,"z":1},"opacity":null}],"audio":{"filename":"B1_6-3.mp3","startTime":1,"startTimestamp":null,"finishTimestamp":null},"alwaysShowDialogue":true},"commands":[{"background":null,"character":"Anna","position":{"x":25,"y":0,"z":1},"opacity":null,"startTime":0,"finishTime":null,"dialogue":null},{"background":null,"character":"Brian","position":{"x":70,"y":0,"z":1},"opacity":null,"startTime":0.5,"finishTime":null,"dialogue":null},{"background":null,"character":"Anna","position":null,"opacity":null,"startTime":1,"finishTime":5.22,"dialogue":{"text":"Hi, Brian. I've heard about these Man-in-the-Middle attacks. When do they usually happen?","align":"left"}},{"background":null,"character":"Brian","position":null,"opacity":null,"startTime":5.86,"finishTime":9.94,"dialogue":{"text":"Typically, they occur when you're using public Wi-Fi or unsecured networks.","align":"right"}},{"background":null,"character":"Brian","position":null,"opacity":null,"startTime":10.26,"finishTime":15.3,"dialogue":{"text":"It's crucial to be careful, especially during peak travel times like holidays or weekends.","align":"right"}},{"background":null,"character":"Anna","position":null,"opacity":null,"startTime":15.72,"finishTime":19.18,"dialogue":{"text":"I see. How often should we remind employees to use secure connections?","align":"left"}},{"background":null,"character":"Brian","position":null,"opacity":null,"startTime":19.6,"finishTime":21.12,"dialogue":{"text":"We send out reminders every month,","align":"right"}},{"background":null,"character":"Brian","position":null,"opacity":null,"startTime":21.12,"finishTime":24.68,"dialogue":{"text":"but we're planning to increase that to every two weeks to keep everyone vigilant.","align":"right"}},{"background":null,"character":"Brian","position":null,"opacity":null,"startTime":24.94,"finishTime":29.02,"dialogue":{"text":"By the end of this week, we'll have new job aids with updated security tips.","align":"right"}},{"background":null,"character":"Anna","position":null,"opacity":null,"startTime":29.6,"finishTime":32.7,"dialogue":{"text":"That sounds like a good approach. When is our next security review meeting?","align":"left"}},{"background":null,"character":"Brian","position":null,"opacity":null,"startTime":33.3,"finishTime":37.36,"dialogue":{"text":"It's scheduled for tomorrow afternoon. We'll discuss the current security protocols","align":"right"}},{"background":null,"character":"Brian","position":null,"opacity":null,"startTime":37.36,"finishTime":41.12,"dialogue":{"text":"and the steps we're taking to prevent Man-in-the-Middle attacks.","align":"right"}},{"background":null,"character":"Anna","position":null,"opacity":null,"startTime":41.84,"finishTime":46,"dialogue":{"text":"Got it. We have our summit coming next week and many team members are coming from other countries.","align":"left"}},{"background":null,"character":"Anna","position":null,"opacity":null,"startTime":46.44,"finishTime":49.02,"dialogue":{"text":"What should they do to protect themselves while traveling for work?","align":"left"}},{"background":null,"character":"Brian","position":null,"opacity":null,"startTime":49.56,"finishTime":54.6,"dialogue":{"text":"Everyone should always use a VPN, especially when accessing sensitive information.","align":"right"}},{"background":null,"character":"Brian","position":null,"opacity":null,"startTime":54.6,"finishTime":61,"dialogue":{"text":"They should also avoid using public Wi-Fi for important tasks like banking or accessing corporate emails.","align":"right"}},{"background":null,"character":"Anna","position":null,"opacity":null,"startTime":61.76,"finishTime":65.54,"dialogue":{"text":"Thanks for the advice. Let's ensure everyone gets these updates before they travel next week.","align":"left"}},{"background":null,"character":"Brian","position":{"x":125,"y":0,"z":1},"opacity":null,"startTime":66.04,"finishTime":null,"dialogue":null},{"background":null,"character":"Anna","position":{"x":-25,"y":0,"z":1},"opacity":null,"startTime":66.54,"finishTime":null,"dialogue":null}]},"superBlock":"b1-english-for-developers","tests":[],"title":"Dialog 3: Sprečavanje napada tipa Man-in-the-Middle","transcript":null,"translationPending":false,"videoId":null,"videoLocaleIds":null}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/b1-english-for-developers/#learn-future-continuous-while-describing-actions","dashedName":"dialogue-3-preventing-mitm-attacks","certification":"b1-english-for-developers","disableLoopProtectTests":false,"disableLoopProtectPreview":false,"superBlock":"b1-english-for-developers","chapter":null,"module":null,"block":"learn-future-continuous-while-describing-actions","isFirstStep":false,"template":null,"required":[],"isLastChallengeInBlock":false,"nextChallengePath":"/learn/b1-english-for-developers/learn-future-continuous-while-describing-actions/task-76","prevChallengePath":"/learn/b1-english-for-developers/learn-future-continuous-while-describing-actions/task-75","id":"675ecdef47179ea4653c2b9f","saveSubmissionToDB":null},"projectPreview":{"