  "tests": [
    {
      "text": "<p>Klasa za <code>container</code> bi trebalo da ima svojstvo <code>grid-template-areas</code> kao primer, ali sa oblastima/regionom <code>footer</code> koji pokriva ceo donji red.</p>",
