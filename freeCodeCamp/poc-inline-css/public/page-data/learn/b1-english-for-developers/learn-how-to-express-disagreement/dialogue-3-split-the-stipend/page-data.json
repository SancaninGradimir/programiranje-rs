{"componentChunkName":"component---src-templates-challenges-generic-show-tsx","path":"/learn/b1-english-for-developers/learn-how-to-express-disagreement/dialogue-3-split-the-stipend","result":{"data":{"challengeNode":{"challenge":{"assignments":["<p>Gledaj video.</p>"],"bilibiliIds":null,"block":"learn-how-to-express-disagreement","challengeType":21,"description":"<section id=\"description\">\n<p>Pogledajte video ispod da biste razumeli kontekst sledećih lekcija.</p>\n</section>","nodules":null,"explanation":null,"helpCategory":"English","instructions":"","fields":{"slug":"/learn/b1-english-for-developers/learn-how-to-express-disagreement/dialogue-3-split-the-stipend"},"questions":[],"scene":{"setup":{"background":"company1-boardroom.png","characters":[{"character":"Bob","position":{"x":-25,"y":0,"z":1},"opacity":null},{"character":"Anna","position":{"x":125,"y":0,"z":1},"opacity":null}],"audio":{"filename":"B1_11-3.mp3","startTime":1,"startTimestamp":null,"finishTimestamp":null},"alwaysShowDialogue":true},"commands":[{"background":null,"character":"Bob","position":{"x":25,"y":0,"z":1},"opacity":null,"startTime":0,"finishTime":null,"dialogue":null},{"background":null,"character":"Anna","position":{"x":70,"y":0,"z":1},"opacity":null,"startTime":0.5,"finishTime":null,"dialogue":null},{"background":null,"character":"Bob","position":null,"opacity":null,"startTime":1,"finishTime":5.12,"dialogue":{"text":"Anna, do you remember our last discussion about the remote work stipend?","align":"left"}},{"background":null,"character":"Bob","position":null,"opacity":null,"startTime":5.42,"finishTime":8.44,"dialogue":{"text":"I've talked again with the team and we still have the same issue.","align":"left"}},{"background":null,"character":"Bob","position":null,"opacity":null,"startTime":8.86,"finishTime":13.62,"dialogue":{"text":"Some people think it should be used for technology while others suggest office furniture.","align":"left"}},{"background":null,"character":"Bob","position":null,"opacity":null,"startTime":14.1,"finishTime":16.7,"dialogue":{"text":"Do you have any ideas on how to solve this?","align":"left"}},{"background":null,"character":"Anna","position":null,"opacity":null,"startTime":17.76,"finishTime":20.14,"dialogue":{"text":"How about we split the stipend into two parts?","align":"right"}},{"background":null,"character":"Anna","position":null,"opacity":null,"startTime":20.48,"finishTime":26,"dialogue":{"text":"That way people can use part of it for technology upgrades and part for office furniture or other home office needs.","align":"right"}},{"background":null,"character":"Bob","position":null,"opacity":null,"startTime":26.54,"finishTime":32.08,"dialogue":{"text":"That's a good idea, but wouldn't it complicate the budget? It might be easier to stick with one category.","align":"left"}},{"background":null,"character":"Anna","position":null,"opacity":null,"startTime":32.78,"finishTime":36.08,"dialogue":{"text":"I see your point, but flexibility might be better. Think about it.","align":"right"}},{"background":null,"character":"Anna","position":null,"opacity":null,"startTime":36.18,"finishTime":40.64,"dialogue":{"text":"Wouldn't it be simpler to let people decide how to use their stipend based on their individual needs?","align":"right"}},{"background":null,"character":"Bob","position":null,"opacity":null,"startTime":41.5,"finishTime":46.4,"dialogue":{"text":"Maybe, but we also need to ensure that everyone has the basic equipment to work remotely.","align":"left"}},{"background":null,"character":"Bob","position":null,"opacity":null,"startTime":46.88,"finishTime":52.04,"dialogue":{"text":"What if we set a minimum requirement and anything beyond that can be used for personal preferences?","align":"left"}},{"background":null,"character":"Anna","position":null,"opacity":null,"startTime":52.64,"finishTime":57.88,"dialogue":{"text":"That could work. If we create a list of essential items like a laptop, webcam, and headset,","align":"right"}},{"background":null,"character":"Anna","position":null,"opacity":null,"startTime":57.88,"finishTime":60.36,"dialogue":{"text":"then anything extra could be allocated as they wish.","align":"right"}},{"background":null,"character":"Bob","position":null,"opacity":null,"startTime":60.76,"finishTime":62.18,"dialogue":{"text":"That's a reasonable suggestion.","align":"left"}},{"background":null,"character":"Bob","position":null,"opacity":null,"startTime":62.48,"finishTime":66.84,"dialogue":{"text":"If we do that, people will have the essentials while still having some freedom to choose.","align":"left"}},{"background":null,"character":"Anna","position":{"x":125,"y":0,"z":1},"opacity":null,"startTime":67.34,"finishTime":null,"dialogue":null},{"background":null,"character":"Bob","position":{"x":-25,"y":0,"z":1},"opacity":null,"startTime":67.84,"finishTime":null,"dialogue":null}]},"superBlock":"b1-english-for-developers","tests":[],"title":"Dijalog 3: Podela stipendije","transcript":null,"translationPending":false,"videoId":null,"videoLocaleIds":null}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/b1-english-for-developers/#learn-how-to-express-disagreement","dashedName":"dialogue-3-split-the-stipend","certification":"b1-english-for-developers","disableLoopProtectTests":false,"disableLoopProtectPreview":false,"superBlock":"b1-english-for-developers","chapter":null,"module":null,"block":"learn-how-to-express-disagreement","isFirstStep":false,"template":null,"required":[],"isLastChallengeInBlock":false,"nextChallengePath":"/learn/b1-english-for-developers/learn-how-to-express-disagreement/task-96","prevChallengePath":"/learn/b1-english-for-developers/learn-how-to-express-disagreement/task-95","id":"67bb19f5e9a76019b7d2dbf7","saveSubmissionToDB":null},"projectPreview":{"challengeData":{"challengeType":19,"challengeFiles":[]}},"id":"/learn/b1-english-for-developers/learn-how-to-express-disagreement/dialogue-3-split-the-stipend"}},"staticQueryHashes":["38585203