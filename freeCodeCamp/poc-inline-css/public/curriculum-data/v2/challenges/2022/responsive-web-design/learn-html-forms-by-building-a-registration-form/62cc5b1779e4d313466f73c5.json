    {
      "text": "<p>Tvoj element <code>link</code> treba da bude unutar tvog elementa <code>head</code>.</p>",
      "testString": "const headContentRegex = /(?<=<head\\s*>)[\\S|\\s]*(?=<\\/head\\s*>)/;\nconst headElementContent = code.match(headContentRegex);\n\nconst headElement = document.createElement(\"head\");\nheadElement.innerHTML = headElementContent;\nassert.isNotNull(headElement.querySelector('link'));"
    },
    {
      "text": "<p>Vaš element od <code>link</code> treba da ima svojstvo atributa <code>rel</code> sa vrednošću <code>stylesheet</code>.</p>",
      "testString": "const linkElement = document.querySelector('link');\nconst rel = linkElement?.getAttribute(\"rel\");\nassert.strictEqual(rel, \"stylesheet\");"
    },
