{"componentChunkName":"component---src-templates-challenges-classic-show-tsx","path":"/learn/javascript-algorithms-and-data-structures/intermediate-algorithm-scripting/sum-all-odd-fibonacci-numbers","result":{"data":{"challengeNode":{"challenge":{"block":"intermediate-algorithm-scripting","demoType":null,"title":"Saberi sve nepoznate brojeve za Fibonacci","description":"<section id=\"description\">\n<p>Ako uzmete pozitivan savršeni broj <code>num</code>, vratite zbir svih nepoznatih brojeva Fibonaccija koji su manji ili jednaki <code>num</code>.</p>\n<p>Prve dve brojeve u Fibonaccijevoj sekvenci su 0 i 1. Svaki sledeći broj u sekvenci je zbir prethodnih dva broja. Prvih sedam brojeva u Fibonaccijevoj sekvenci su 0, 1, 1, 2, 3, 5 i 8.</p>\n<p>Na primer, <code>sumFibs(10)</code> treba da vrati <code>10</code> jer su svi Fibonacci brojevi manji ili jednaki <code>10</code> broj 1, 1, 3 i 5.</p>\n</section>","id":"a5229172f011153519423690","hasEditableBoundaries":false,"instructions":"","notes":null,"challengeType":1,"helpCategory":"JavaScript","videoUrl":null,"superBlock":"javascript-algorithms-and-data-structures","translationPending":false,"forumTopicId":16084,"hooks":null,"fields":{"slug":"/learn/javascript-algorithms-and-data-structures/intermediate-algorithm-scripting/sum-all-odd-fibonacci-numbers"},"required":[],"usesMultifileEditor":false,"challengeFiles":[{"fileKey":"scriptjs","ext":"js","name":"script","contents":"function sumFibs(num) {\r\n  return num;\r\n}\r\n\r\nsumFibs(4);","head":null,"tail":null,"editableRegionBoundaries":[],"history":["script.js"]}],"saveSubmissionToDB":null,"tests":[{"text":"<p><code>sumFibs(1)</code> trebalo bi da vrati broj.</p>","testString":"assert(typeof sumFibs(1) === 'number');"},{"text":"<p><code>sumFibs(1000)</code> treba da vrati 1785.</p>","testString":"assert(sumFibs(1000) === 1785);"},{"text":"<p><code>sumFibs(4000000)</code> trebalo bi da vrati 4613732.</p>","testString":"assert(sumFibs(4000000) === 4613732);"},{"text":"<p><code>sumFibs(4)</code> trebalo bi da vrati 5.</p>","testString":"assert(sumFibs(4) === 5);"},{"text":"<p><code>sumFibs(75024)</code> trebalo bi da vrati 60696.</p>","testString":"assert(sumFibs(75024) === 60696);"},{"text":"<p><code>sumFibs(75025)</code> treba da vrati 135721.</p>","testString":"assert(sumFibs(75025) === 135721);"}]}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/javascript-algorithms-and-data-structures/#intermediate-algorithm-scripting","dashedName":"sum-all-odd-fibonacci-numbers","certification":"javascript-algorithms-and-data-structures","disableLoopProtectTests":false,"disableLoopProtectPreview":false,"superBlock":"javascript-algorithms-and-data-structures","chapter":null,"module":null,"block":"intermediate-algorithm-scripting","isFirstStep":false,"template":null,"required":[],"isLastChallengeInBlock":false,"nextChallengePath":"/learn/javascript-algorithms-and-data-structures/intermediate-algorithm-scripting/sum-all-primes","prevChallengePath":"/learn/javascript-algorithms-and-data-structures/intermediate-algorithm-scripting/convert-html-entities","id":"a5229172f011153519423690","saveSubmissionToDB":null},"projectPreview":{"challengeData":{"challengeType":1,"challengeFiles":[{"name":"script","ext":"js","contents":"function orbitalPeriod(arr) {\n  const GM = 398600.4418;\n  const earthRadius = 6367.4447;\n  const TAU = 2 * Math.PI;\n  return arr.map(function(obj) {\n    return {\n      name: obj.name,\n      orbitalPeriod: Math.round(TAU * Math.sqrt(Math.pow(obj.avgAlt+earthRadius, 3)/GM))\n    };\n  });\n}","history":["script.js"],"fileKey":"scriptjs"}]}},"id":"/learn/javascript-algorithms-and-data-structures/intermediate-algorithm-scripting/sum-all-odd-fibonacci-numbers"}},"staticQueryHashes":["3858520367"],"slicesMap":{}}