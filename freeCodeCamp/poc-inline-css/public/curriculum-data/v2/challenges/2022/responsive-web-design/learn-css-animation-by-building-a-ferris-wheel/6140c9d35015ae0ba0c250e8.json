    {
      "text": "<p><code>div</code> tvoj unutar elementa od <code>body</code> treba imati <code>class</code> od <code>wheel</code>.</p>",
      "testString": "assert(document.querySelector('body div')?.classList?.contains('wheel'));"
    },
    {
      "text": "<p>Vaš element za <code>.wheel</code> treba da ima šest elemenata <code>span</code> unutar sebe.</p>",
      "testString": "assert(document.querySelectorAll('.wheel span')?.length === 6);"
    },
    {
      "text": "<p>Šest vaših elemenata <code>span</code> unutar elementa <code>.wheel</code> treba da ima <code>class</code> od <code>line</code>.</p>",
      "testString": "const spans = [...document.querySelectorAll('.wheel span')];\r\nassert(spans?.every(span => span?.classList?.contains('line')));\r\nassert(document.querySelectorAll('.line')?.length === 6);"
