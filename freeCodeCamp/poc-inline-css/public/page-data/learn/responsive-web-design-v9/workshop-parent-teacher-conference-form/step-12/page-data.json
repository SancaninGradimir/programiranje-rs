{"componentChunkName":"component---src-templates-challenges-classic-show-tsx","path":"/learn/responsive-web-design-v9/workshop-parent-teacher-conference-form/step-12","result":{"data":{"challengeNode":{"challenge":{"block":"workshop-parent-teacher-conference-form","demoType":null,"title":"Korak 12","description":"<section id=\"description\">\n<p>Zatim, dodajte još jednu oznaku sa klasom <code>\"contact-method\"</code> i atributom <code>for</code> postavljenim na <code>\"phone\"</code>. Tekst oznake treba da bude <code>Phone: </code>.</p>\n<p>Ispod vašeg <code>label</code> elementa, dodajte radio dugme sa atributima <code>id</code> i <code>value</code> postavljenim na <code>\"phone\"</code>. Atribut <code>name</code> treba da bude postavljen na <code>\"contact-method\"</code>, a klasa treba da bude postavljena na <code>\"contact-method-radio-btn\"</code>.</p>\n</section>","id":"68ea9f01c51b66b937793611","hasEditableBoundaries":true,"instructions":"","notes":null,"challengeType":0,"helpCategory":"HTML-CSS","videoUrl":null,"superBlock":"responsive-web-design-v9","translationPending":false,"forumTopicId":null,"hooks":null,"fields":{"slug":"/learn/responsive-web-design-v9/workshop-parent-teacher-conference-form/step-12"},"required":[],"usesMultifileEditor":true,"challengeFiles":[{"fileKey":"indexhtml","ext":"html","name":"index","contents":"<!DOCTYPE html>\n<html lang=\"en\">\n\n<head>\n  <meta charset=\"utf-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Parent Teacher Conference Form</title>\n  <link rel=\"stylesheet\" href=\"./styles.css\" />\n</head>\n\n<body>\n  <main class=\"container\">\n    <h1 class=\"title center\">Parent Teacher Conference Form</h1>\n    <p class=\"description center\">Please fill out the form below to help schedule your parent-teacher conference.</p>\n\n    <form>\n      <fieldset>\n        <legend>Student Information</legend>\n        <label for=\"student-name\">Full Name: </label>\n        <input\n            type=\"text\"\n            name=\"student-name\"\n            id=\"student-name\"\n            required\n            placeholder=\"E.g., Jane Doe\"\n          />\n\n\n        <label for=\"grade\">Student Grade: </label>\n        <input\n            type=\"number\"\n            name=\"grade\"\n            id=\"grade\"\n            required\n            placeholder=\"E.g., 4\"\n          />\n      </fieldset>\n\n      <fieldset>\n        <legend>Parent/Guardian Information</legend>\n        <label for=\"parent-name\">Parent/Guardian Name: </label>\n        <input\n            type=\"text\"\n            name=\"parent-name\"\n            id=\"parent-name\"\n            required\n            placeholder=\"E.g., Nancy Doe\"\n          />\n      </fieldset>\n\n      <fieldset>\n        <legend>Preferred Contact Method</legend>\n        <label class=\"contact-method\" for=\"email\">Email: </label>\n        <input\n            id=\"email\"\n            class=\"contact-method-radio-btn\"\n            type=\"radio\"\n            name=\"contact-method\"\n            value=\"email\"\n            checked\n          />\n        \n      </fieldset>\n    </form>\n  </main>\n</body>\n\n</html>","head":null,"tail":null,"editableRegionBoundaries":[61,63],"history":["index.html"]}],"saveSubmissionToDB":null,"tests":[{"text":"<p>You should have two <code>label</code> elements in the last <code>fieldset</code>.</p>","testString":"assert.lengthOf(document.querySelectorAll(\"fieldset:last-of-type label\"), 2);"},{"text":"<p>The <code>label</code> element should have a class of <code>\"contact-method\"</code>.</p>","testString":"assert.exists(document.querySelector(\"fieldset:last-of-type label.contact-method\"));"},{"text":"<p>The <code>label</code> element's <code>for</code> attribute should be set to <code>\"phone\"</code>.</p>","testString":"assert.exists(document.querySelector(\"fieldset:last-of-type label[for='phone']\"));"},{"text":"<p>The <code>label</code> element should have the text <code>Phone: </code>.</p>","testString":"const label = document.querySelector(\"fieldset:last-of-type label[for='phone']\");\nassert.match(label?.innerText, /Phone:\\s?/);"},{"text":"<p>You should have two <code>input</code> elements inside the last <code>fieldset</code>.</p>","testString":"assert.lengthOf(document.querySelectorAll(\"fieldset:last-of-type input\"), 2);"},{"text":"<p>Your <code>input</code> element should have a <code>type</code> attribute set to <code>radio</code>.</p>","testString":"const input = document.querySelector(\"fieldset:last-of-type input:last-of-type\");\nassert.strictEqual(input?.getAttribute(\"type\"), \"radio\");"},{"text":"<p>The <code>input</code> element should have an <code>id</code> attribute set to <code>\"phone\"</code>.</p>","testString":"const input = document.querySelector(\"fieldset:last-of-type input:last-of-type\");\nassert.strictEqual(input?.getAttribute(\"id\"), \"phone\");"},{"text":"<p>The <code>input</code> element should have a <code>value</code> attribute set to <code>\"phone\"</code>.</p>","testString":"const input = document.querySelector(\"fieldset:last-of-type input:last-of-type\");\nassert.strictEqual(input?.getAttribute(\"value\"), \"phone\");"},{"text":"<p>The <code>input</code> element should have a <code>name</code> attribute set to <code>\"contact-method\"</code>.</p>","testString":"const input = document.querySelector(\"fieldset:last-of-type input:last-of-type\");\nassert.strictEqual(input?.getAttribute(\"name\"), \"contact-method\");"},{"text":"<p>The <code>input</code> element should have a class of <code>\"contact-method-radio-btn\"</code>.</p>","testString":"assert.exists(document.querySelector(\"fieldset:last-of-type input[id='phone'].contact-method-radio-btn\"));"}]}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/responsive-web-design-v9/#workshop-parent-teacher-conference-form","dashedName":"step-12","certification":"responsive-web-design-v9","disableLoopProtectTests":false,"disableLoopProtectPreview":false,"superBlock":"responsive-web-design-v9","chapter":"css","module":"pseudo-classes-and-elements","block":"workshop-parent-teacher-conference-form","isFirstStep":false,"template":null,"required":[],"isLastChallengeInBlock":false,"nextChallengePath":"/learn/responsive-web-design-v9/workshop-parent-teacher-conference-form/step-13","prevChallengePath":"/learn/responsive-web-design-v9/workshop-parent-teacher-conference-form/step-11","id":"68ea9f01c51b66b937793611","saveSubmissionToDB":null},"projectPreview":{"challengeData":{"challengeType":0,"challengeFiles":[{"name":"index","ext":"html","contents":"<!DOCTYPE html>\n<html lang=\"en\">\n  <head>\n    <meta charset=\"utf-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Parent Teacher Conference Form</title>\n    <link rel=\"stylesheet\" href=\"./styles.css\" />\n  </head>\n  <body>\n  <main class=\"container\">\n    <h1 class=\"title center\">Parent Teacher Conference Form</h1>\n    <p class=\"description center\">Please fill out the form below to help schedule your parent-teacher conference.</p>\n\n     <form>\n        <fieldset>\n          <legend>Student Information</legend>\n          <label for=\"student-name\">Full Name: </label>\n          <input\n            type=\"text\"\n            name=\"student-name\"\n            id=\"student-name\"\n            required\n            placeholder=\"E.g., Jane Doe\"\n          />\n\n          <label for=\"grade\">Student Grade: </label>\n          <input\n            type=\"number\"\n            name=\"grade\"\n            id=\"grade\"\n            required\n            placeholder=\"E.g., 4\"\n          />\n        </fieldset>\n        \n        <fieldset>\n          <legend>Parent/Guardian Information</legend>\n          <label for=\"parent-name\">Parent/Guardian Name: </label>\n          <input\n            type=\"text\"\n            name=\"parent-name\"\n            id=\"parent-name\"\n            required\n            placeholder=\"E.g., Nancy Doe\"\n          />\n        </fieldset>\n\n        <fieldset>\n          <legend>Preferred Contact Method</legend>\n          <label class=\"contact-method\" for=\"email\">Email: </label>\n          <input\n            id=\"email\"\n            class=\"contact-method-radio-btn\"\n            type=\"radio\"\n            name=\"contact-method\"\n            value=\"email\"\n            checked\n          />\n\n          <label class=\"contact-method\" for=\"phone\">Phone: </label>\n          <input\n            id=\"phone\"\n            class=\"contact-method-radio-btn\"\n            type=\"radio\"\n            name=\"contact-method\"\n            value=\"phone\"\n          />\n        </fieldset>\n\n        <fieldset>\n          <legend>Additional Notes</legend>\n          <label for=\"notes\"\n            >Any specific concerns or topics you'd like to discuss?</label\n          >\n          <textarea id=\"notes\" name=\"notes\" rows=\"4\" cols=\"50\"></textarea>\n        </fieldset>\n\n        <button class=\"submit-btn\" type=\"submit\">Submit Form</button>\n      </form>\n  </main>\n  </body>\n</html>","history":["index.html"],"fileKey":"indexhtml"},{"name":"styles","ext":"css","contents":"body {\n  background-color: MidnightBlue;\n  color: whitesmoke;\n}\n\n.container {\n    background-color: #ffffff1a;\n    width: 80%;\n    max-width: 600px;\n    border-radius: 10px;\n    margin: 20px auto;\n    padding: 10px 20px;\n    box-shadow: 0 5px 15px black;  \n}\n\n.center {\n  text-align: center;\n}\n\n.description {\n  font-size: 1.2rem;\n}\n\nfieldset {\n  border: 1px solid gray;\n  border-radius: 5px;\n  margin: 20px 0;\n  padding: 20px;\n}\n\nfieldset legend {\n  font-size: 1.3rem;\n  font-weight: 600;\n}\n\nlabel {\n  font-size: 1.2rem;\n}\n\nlabel:not(.contact-method) {\n  display: block;\n  margin: 10px 0;\n}\n\ninput:not(.contact-method-radio-btn),\ntextarea {\n  background-color: #ffffff1a;\n  width: 95%;\n  border: 1px solid gray;\n  border-radius: 5px;\n  padding: 10px;\n}\n\ninput,\ninput::placeholder,\ntextarea {\n  color: whitesmoke;\n}\n\n\n.contact-method-radio-btn {\n  appearance: none;\n  width: 20px;\n  height: 20px;\n  border-radius: 50%;\n  border: 2px solid gray;\n  vertical-align: bottom;\n}\n\n.contact-method-radio-btn::before {\n  display: block;\n  content: \" \";\n  width: 10px;\n  height: 10px;\n  border-radius: 50%;\n  transform: translate(3px, 3px) scale(0);\n  transition: all 0.3s ease-in;\n}\n\n.contact-method-radio-btn:checked::before {\n  transform: translate(3px, 3px) scale(1);\n  background-color: lightgreen;\n}\n\n.submit-btn {\n  cursor: pointer;\n  background-color: royalblue;\n  color: whitesmoke;\n  border: none;\n  border-radius: 6px;\n  padding: 12px 20px;\n  font-size: 1.1rem;\n  display: block;\n  margin: auto;\n}\n\n.submit-btn:hover {\n  background-color: midnightblue;\n}\n","history":["styles.css"],"fileKey":"stylescss"}]}},"id":"/learn/responsive-web-design-v9/workshop-parent-teacher-conference-form/step-12"}},"staticQueryHashes":["3858520367"],"slicesMap":{}}