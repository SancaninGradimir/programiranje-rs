  "hooks": {
    "beforeEach": "let results=[\n  [ 'a', 'b', 'c', 'd' ],\n  [ 'c', 'd', 'e', 'f', 'g', 'h', 'i' ],\n  [ 'm', 'n', 'o', 'p', 'q' ],\n  [ 'k', 'l', 'm', 'n' ],\n  [ 't', 'u', 'v', 'w', 'x', 'y', 'z' ]\n]"
