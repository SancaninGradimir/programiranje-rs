{"componentChunkName":"component---src-templates-challenges-classic-show-tsx","path":"/learn/rosetta-code/rosetta-code-challenges/combinations","result":{"data":{"challengeNode":{"challenge":{"block":"rosetta-code-challenges","demoType":null,"title":"Mešavina","description":"<section id=\"description\">\n<p>Za nenegativne cele brojeve <code>m</code> i <code>n</code>, generiši sve kombinacije veličine <code>m</code> sastavljene od celih brojeva od <code>0</code> do <code>n-1</code>, u rastućem redosledu (svaka kombinacija je sortirana, kao i cela tabela).</p>\n<p><strong>Primer:</strong></p>\n<p><code>3</code> comb <code>5</code> ni:</p>\n<pre>0 1 2\n0 1 3\n0 1 4\n0 2 3\n0 2 4\n0 3 4\n1 2 3\n1 2 4\n1 3 4\n2 3 4\n</pre>\n</section>","id":"5958469238c0d8d2632f46db","hasEditableBoundaries":false,"instructions":"","notes":null,"challengeType":1,"helpCategory":"Rosetta","videoUrl":null,"superBlock":"rosetta-code","translationPending":false,"forumTopicId":302233,"hooks":{"beforeAll":null,"beforeEach":"const testInput1 = [3, 5];\nconst testOutput1 = [[0, 1, 2], [0, 1, 3], [0, 1, 4], [0, 2, 3], [0, 2, 4], [0, 3, 4], [1, 2, 3], [1, 2, 4], [1, 3, 4], [2, 3, 4]];\n\nconst testInput2 = [4, 6];\nconst testOutput2 = [[0, 1, 2, 3], [0, 1, 2, 4], [0, 1, 2, 5], [0, 1, 3, 4], [0, 1, 3, 5], [0, 1, 4, 5], [0, 2, 3, 4], [0, 2, 3, 5], [0, 2, 4, 5], [0, 3, 4, 5], [1, 2, 3, 4], [1, 2, 3, 5], [1, 2, 4, 5], [1, 3, 4, 5], [2, 3, 4, 5]];","afterEach":null,"afterAll":null},"fields":{"slug":"/learn/rosetta-code/rosetta-code-challenges/combinations"},"required":[],"usesMultifileEditor":false,"challengeFiles":[{"fileKey":"scriptjs","ext":"js","name":"script","contents":"function combinations(m, n) {\n\n  return true;\n}","head":null,"tail":null,"editableRegionBoundaries":[],"history":["script.js"]}],"saveSubmissionToDB":null,"tests":[{"text":"<p><code>combinations</code> Trebalo bi da bude funkcija.</p>","testString":"assert(typeof combinations === 'function');"},{"text":"<p><code>combinations(3, 5