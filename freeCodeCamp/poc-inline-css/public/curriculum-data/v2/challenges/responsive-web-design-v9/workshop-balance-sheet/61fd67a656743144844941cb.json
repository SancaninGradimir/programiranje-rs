    {
      "text": "<p>Vaš element <code>span</code> koji postoji mora imati svojstvo <code>class</code> sa vrednošću <code>flex</code>.</p>",
      "testString": "assert.isTrue(\n  document.querySelector('h1')?.children?.[0]?.classList?.contains('flex')\n);"
    },
    {
      "text": "<p>Tvoja komponenta sa <code>span</code> koja postoji mora imati dve nove komponente od <code>span</code> unutar sebe.</p>",
      "testString": "assert.strictEqual(\n  document.querySelector('.flex')?.children?.[0]?.localName,\n  'span'\n);\nassert.strictEqual(\n  document.querySelector('.flex')?.children?.[1]?.localName,\n  'span'\n);"
    },
    {
      "text": "<p>Vaši novi elementi <code>span</code> ne bi trebalo da imaju svojstvo <code>class</code>.</p>",
      "testString": "assert.isEmpty(document.querySelector('.flex')?.children?.[0]?.classList);\nassert.isEmpty(document.querySelector('.flex')?.children?.[1]?.classList);"
    },
    {
      "text": "<p>Tvoja nova prva komponenta za <code>span</code> mora imati tekst <code>AcmeWidgetCorp</code>.</p>",
      "testString": "assert.strictEqual(\n  document.querySelector('.flex')?.children?.[0]?.textContent.trim(),\n  'AcmeWidgetCorp'\n);"
