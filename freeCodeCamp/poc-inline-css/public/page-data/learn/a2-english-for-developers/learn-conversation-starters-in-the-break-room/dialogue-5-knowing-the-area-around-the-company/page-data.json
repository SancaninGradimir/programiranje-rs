8.4,"dialogue":{"text":"Hmm... There isn't any theater around here that I know of.","align":"right"}},{"background":null,"character":"Maria","position":null,"opacity":null,"startTime":38.9,"finishTime":40.9,"dialogue":{"text":"The bookstores I remember are all downtown.","align":"right"}},{"background":null,"character":"Maria","position":null,"opacity":null,"startTime":41.1,"finishTime":43.1,"dialogue":{"text":"But there's a bus that stops two blocks away.","align":"right"}},{"background":null,"character":"Tom","position":null,"opacity":null,"startTime":43.3,"finishTime":45.3,"dialogue":{"text":"Oh, how about a shopping mall?","align":"left"}},{"background":null,"character":"Maria","position":null,"opacity":null,"startTime":45.5,"finishTime":47.5,"dialogue":{"text":"Malls are everywhere.","align":"right"}},{"background":null,"character":"Maria","position":null,"opacity":null,"startTime":47.7,"finishTime":49.7,"dialogue":{"text":"I'm sure you can find them just by walking around a bit.","align":"right"}},{"background":null,"character":"Tom","position":null,"opacity":null,"startTime":49.9,"finishTime":51.4,"dialogue":{"text":"Thanks for your help, Maria.","align":"left"}},{"background":null,"character":"Maria","position":null,"opacity":null,"startTime":51.9,"finishTime":52.7,"dialogue":{"text":"You're welcome, Tom.","align":"right"}},{"background":null,"character":"Maria","position":{"x":125,"y":0,"z":1},"opacity":null,"startTime":52.8,"finishTime":null,"dialogue":null},{"background":null,"character":"Tom","position":{"x":-25,"y":0,"z":1},"opacity":null,"startTime":53.3,"finishTime":null,"dialogue":null}]},"superBlock":"a2-english-for-developers","tests":[],"title":"Dialogue 5: Poznavanje Okoline Kompanije","transcript":null,"translationPending":false,"videoId":null,"videoLocaleIds":null}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/a2-english-for-developers/#learn-conversation-starters-in-the-break-room","dashedName":"dialogue-5-knowing-the-area-around-t