    {
      "text": "<p>You should have a fifth checkbox <code>input</code>.</p>",
      "testString": "assert.exists(document.querySelector('fieldset:nth-of-type(3) input[type=\"checkbox\"]:nth-of-type(5)'));"
    },
    {
      "text": "<p>Your fifth checkbox <code>input</code> should have an <code>id</code> attribute set to <code>\"price\"</code>.</p>",
      "testString": "assert.strictEqual(document.querySelector(\"fieldset:nth-of-type(3) input[type='checkbox']:nth-of-type(5)\")?.getAttribute('id'), 'price');"
    },
    {
      "text": "<p>Your fifth checkbox <code>input</code> should have a <code>name</code> attribute set to <code>\"choice\"</code>.</p>",
      "testString": "assert.strictEqual(document.querySelector(\"fieldset:nth-of-type(3) input[type='checkbox']:nth-of-type(5)\")?.getAttribute('name'), 'choice');"
    },
    {
      "text": "<p>Your fifth checkbox <code>input</code> should have a <code>value</code> attribute set to <code>\"price\"</code>.</p>",
      "testString": "assert.strictEqual(document.querySelector(\"fieldset:nth-of-type(3) input[type='checkbox']:nth-of-type(5)\")?.getAttribute('value'), 'price');"
    },
    {
      "text": "<p>You should have a <code>label</code> element after your checkbox <code>input</code> with the text <code>Price</code>.</p>",
      "testString": "assert.strictEqual(document.querySelector('fieldset:nth-of-type(3) input[value=\"price\"] + label')?.textContent?.trim(), 'Price');"
    },
    {
      "text": "<p>Your <code>label</code> should have the <code>for</code> attribute set to <code>\"price\"</code>.</p>",
      "testString": "assert.strictEqual(document.querySelector('fieldset:nth-of-type(3) input[value=\"price\"] + label')?.getAttribute('for'), 'price');"
    }
