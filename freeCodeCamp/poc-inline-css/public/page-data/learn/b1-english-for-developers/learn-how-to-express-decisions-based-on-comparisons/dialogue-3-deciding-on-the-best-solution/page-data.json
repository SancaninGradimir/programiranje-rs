{"componentChunkName":"component---src-templates-challenges-generic-show-tsx","path":"/learn/b1-english-for-developers/learn-how-to-express-decisions-based-on-comparisons/dialogue-3-deciding-on-the-best-solution","result":{"data":{"challengeNode":{"challenge":{"assignments":["<p>Gledaj video.</p>"],"bilibiliIds":null,"block":"learn-how-to-express-decisions-based-on-comparisons","challengeType":21,"description":"<section id=\"description\">\n<p>Pogledajte video ispod da biste razumeli kontekst sledećih lekcija.</p>\n</section>","nodules":null,"explanation":null,"helpCategory":"English","instructions":"","fields":{"slug":"/learn/b1-english-for-developers/learn-how-to-express-decisions-based-on-comparisons/dialogue-3-deciding-on-the-best-solution"},"questions":[],"scene":{"setup":{"background":"company2-center.png","characters":[{"character":"Brian","position":{"x":-25,"y":0,"z":1},"opacity":null},{"character":"Sarah","position":{"x":125,"y":0,"z":1},"opacity":null}],"audio":{"filename":"B1_13-3.mp3","startTime":1,"startTimestamp":null,"finishTimestamp":null},"alwaysShowDialogue":true},"commands":[{"background":null,"character":"Brian","position":{"x":25,"y":0,"z":1},"opacity":null,"startTime":0,"finishTime":null,"dialogue":null},{"background":null,"character":"Sarah","position":{"x":70,"y":0,"z":1},"opacity":null,"startTime":0.5,"finishTime":null,"dialogue":null},{"background":null,"character":"Brian","position":null,"opacity":null,"startTime":1,"finishTime":5.72,"dialogue":{"text":"Hey Sarah, we need to decide on the best solution for our new software development project.","align":"left"}},{"background":null,"character":"Brian","position":null,"opacity":null,"startTime":6.06,"finishTime":9.14,"dialogue":{"text":"We've been discussing a few options and I'd like to get your opinion.","align":"left"}},{"background":null,"character":"Sarah","position":null,"opacity":null,"startTime":9.66,"finishTime":11.06,"dialogue":{"text":"Sure, Brian. What are the choices?","align":"right"}},{"background":null,"character":"Brian","position":null,"opacity":null,"startTime":11.54,"finishTime":14.18,"dialogue":{"text":"The first option is to build the software in-house.","align":"left"}},{"background":null,"character":"Brian","position":null,"opacity":null,"startTime":14.56,"finishTime":20.5,"dialogue":{"text":"The second option is to outsource part of the project to an external team. What do you think would work best?","align":"left"}},{"background":null,"character":"Sarah","position":null,"opacity":null,"startTime":21.6,"finishTime":25.4,"dialogue":{"text":"Well, building in-house is probably the best way to maintain control over the project.","align":"right"}},{"background":null,"character":"Sarah","position":null,"opacity":null,"startTime":25.82,"finishTime":29.38,"dialogue":{"text":"We would have more flexibility and we could ensure the quality is up to our standards.","align":"right"}},{"background":null,"character":"Brian","position":null,"opacity":null,"startTime":29.38,"finishTime":35.4,"dialogue":{"text":"That's true, but outsourcing might be more cost-effective. It could save us time and resources.","align":"left"}},{"background":null,"character":"Brian","position":null,"opacity":null,"startTime":36,"finishTime":38.52,"dialogue":{"text":"What about timelines? Which option is faster?","align":"left"}},{"background":null,"character":"Sarah","position":null,"opacity":null,"startTime":39.32,"finishTime":43.82,"dialogue":{"text":"Outsourcing is usually faster because the external team can focus solely on our project.","align":"right"}},{"background":null,"character":"Sarah","position":null,"opacity":null,"startTime":44.3,"finishTime":47.62,"dialogue":{"text":"Building in-house might take longer because we have other tasks to handle.","align":"right"}},{"background":null,"character":"Sarah","position":null,"opacity":null,"startTime":48.18,"finishTime":52.34,"dialogue":{"text":"However, outsourcing can lead to communication issues which might delay the project.","align":"right"}},{"background":null,"character":"Brian","position":null,"opacity":null,"startTime":53.28,"finishTime":58.86,"dialogue":{"text":"I see. So on the one hand, outsourcing is faster, but it could also cause communication problems.","align":"left"}},{"background":null,"character":"Brian","position":null,"opacity":null,"startTime":58.86,"finishTime":63.62,"dialogue":{"text":"On the other hand, building in-house gives us more control, but it might take longer.","align":"left"}},{"background":null,"character":"Brian","position":null,"opacity":null,"startTime":64.02,"finishTime":65.72,"dialogue":{"text":"Which one do you think is more reliable?","align":"left"}},{"background":null,"character":"Sarah","position":null,"opacity":null,"startTime":66.22,"finishTime":69.98,"dialogue":{"text":"Building in-house is more reliable because we can oversee the entire process.","align":"right"}},{"background":null,"character":"Sarah","position":null,"opacity":null,"startTime":70.42,"finishTime":74.12,"dialogue":{"text":"However, outsourcing has its advantages, especially when it comes to speed.","align":"right"}},{"background":null,"character":"Sarah","position":null,"opacity":null,"startTime":74.58,"finishTime":77.46,"dialogue":{"text":"It depends on what you value more, control or speed.","align":"right"}},{"background":null,"character":"Brian","position":null,"opacity":null,"startTime":77.74,"finishTime":82.64,"dialogue":{"text":"That makes sense. So if we build in-house, we have more control, but it could take longer.","align":"left"}},{"background":null,"character":"Brian","position":null,"opacity":null,"startTime":82.82,"finishTime":87.82,"dialogue":{"text":"If we outsource, it's faster, but there might be communication issues. It's a tough call.","align":"left"}},{"background":null,"character":"Sarah","position":null,"opacity":null,"startTime":87.82,"finishTime":92.72,"dialogue":{"text":"Yes, it is. We might need to balance both approaches to get the best of both worlds.","align":"right"}},{"background":null,"character":"Sarah","position":null,"opacity":null,"startTime":93.22,"finishTime":97.3,"dialogue":{"text":"How about we build the core components in-house and outsource the less critical parts?","align":"right"}},{"background":null,"character":"Sarah","position":null,"opacity":null,"startTime":97.76,"finishTime":100.42,"dialogue":{"text":"That way, we maintain control while speeding up the project.","align":"right"}},{"background":null,"character":"Brian","position":null,"opacity":null,"startTime":100.96,"finishTime":104.92,"dialogue":{"text":"That's a great idea. It could work. Thanks for the suggestion, Sarah.","align":"left"}},{"background":null,"character":"Sarah","position":{"x":125,"y":0,"z":1},"opacity":null,"startTime":105.42,"finishTime":null,"dialogue":null},{"background":null,"character":"Brian","position":{"x":-25,"y":0,"z":1},"opacity":null,"startTime":105.92,"finishTime":null,"dialogue":null}]},"superBlock":"b1-english-for-developers","tests":[],"title":"Dijalog 3: Donošenje odluke o najboljem rešenju","transcript":null,"translationPending":false,"videoId":null,"videoLocaleIds":null}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/b1-english-for-developers/#learn-how-to-express-decisions-based-on-comparisons","dashedName":"dialogue-3-deciding-on-the-best-solution","certification":"b1-english-for-developers","disableLoopProtectTests":false,"disableLoopProtectPreview":false,"superBlock":"b1-english-for-developers","chapter":null,"module":null,"block":"learn-how-to-express-decisions-based-on-comparisons","isFirstStep":false,"template":null,"required":[],"isLastChallengeInBlock":false,"nextChallengePath":"/learn/b1-english-for-developers/learn-how-to-express-decisions-based-on-comparisons/task-102","prevChallengePath":"/learn/b1-english-for-developers/learn-how-to-express-decisions-based-on-comparisons/task-101","id":"67d57db13cd7aa1c85a6bae0","saveSubmissionToDB":null},"projectPrevi