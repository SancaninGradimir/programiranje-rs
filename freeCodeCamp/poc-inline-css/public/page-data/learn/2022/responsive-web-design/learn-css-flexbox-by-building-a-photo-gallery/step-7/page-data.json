ter;\r\n  gap: 16px;\r\n  max-width: 1400px;\r\n  margin: 0 auto;\r\n  padding: 20px 10px;\r\n}\r\n\r\n.gallery img {\r\n  width: 100%;\r\n  max-width: 350px;\r\n  height: 300px;\r\n  object-fit: cover;\r\n  border-radius: 10px;\r\n}\r\n\r\n.gallery::after {\r\n  content: \"\";\r\n  width: 350px;\r\n}","history":["styles.css"],"fileKey":"stylescss"}]}},"id":"/learn/2022/responsive-web-design/learn-css-flexbox-by-building-a-photo-gallery/step-7"}},"staticQueryHashes":["3858520367"],"slicesMap":{}}