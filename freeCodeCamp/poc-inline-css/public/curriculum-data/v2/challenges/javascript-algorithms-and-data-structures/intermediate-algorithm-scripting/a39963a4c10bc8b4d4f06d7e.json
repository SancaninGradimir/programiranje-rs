        "fileKey": "scriptjs",
        "contents": "function destroyer(arr) {\r\n  var hash = Object.create(null);\r\n  [].slice.call(arguments, 1).forEach(function(e) {\r\n    hash[e] = true;\r\n  });\r\n  return arr.filter(function(e) { return !(e in hash);});\r\n}\r\n\r\ndestroyer([1, 2, 3, 1, 2, 3], 2, 3);",
        "error": null,
        "seed": "function destroyer(arr) {\r\n  var hash = Object.create(null);\r\n  [].slice.call(arguments, 1).forEach(function(e) {\r\n    hash[e] = true;\r\n  });\r\n  return arr.filter(function(e) { return !(e in hash);});\r\n}\r\n\r\ndestroyer([1, 2, 3, 1, 2, 3], 2, 3);"
      }
