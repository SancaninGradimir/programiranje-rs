{"componentChunkName":"component---src-templates-challenges-classic-show-tsx","path":"/learn/rosetta-code/rosetta-code-challenges/zig-zag-matrix","result":{"data":{"challengeNode":{"challenge":{"block":"rosetta-code-challenges","demoType":null,"title":"Zigzag matrica","description":"<section id=\"description\">\n<p>Zig-zag matrica podataka je raspored kvadrata prvih prirodnih brojeva $N^2$, gde se brojevi povećavaju sekvencijalno kada idete u zig-zag pravcu duž anti-diyagonala podatkovne matrice.</p>\n<p>Na primer, za unos <code>5</code>, sledeći rezultati bi trebalo da se generišu:</p>\n<pre>\n 0  1  5  6 14\n 2  4  7 13 15\n 3  8 12 16 21\n 9 11 17 20 22\n10 18 19 23 24\n</pre>\n</section>","id":"594810f028c0303b75339ad8","hasEditableBoundaries":false,"instructions":"<section id=\"instructions\">\n<p>Implementirajte funkciju koja prima veličinu zizzag matrice i vraća odgovarajuću matricu kao dvodimenzionalni niz podataka.</p>\n</section>","notes":null,"challengeType":1,"helpCategory":"Rosetta","videoUrl":null,"superBlock":"rosetta-code","translationPending":false,"forumTopicId":302348,"hooks":{"beforeAll":null,"beforeEach":"const zm1 = [[0]];\nconst zm2 = [[0, 1], [2, 3]];\nconst zm5 = [\n  [0, 1, 5, 6, 14],\n  [2, 4, 7, 13, 15],\n  [3, 8, 12, 16, 21],\n  [9, 11, 17, 20, 22],\n  [10, 18, 19, 23, 24]\n];","afterEach":null,"afterAll":null},"fields":{"slug":"/learn/rosetta-code/rosetta-code-challenges/zig-zag-matrix"},"required":[],"usesMultifileEditor":false,"challengeFiles":[{"fileKey":"scriptjs","ext":"js","name":"script","contents":"function ZigZagMatrix(n) {\n\n  return [[], []];\n}","head":null,"tail":null,"editableRegionBoundaries":[],"history":["script.js"]}],"saveSubmissionToDB":null,"tests":[{"text":"<p>ZigZagMatrix treba da bude funkcija.</p>","testString":"assert.equal(typeof ZigZagMatrix, 'function');"},{"text":"<p>ZigZagMatrix treba da vrati red podataka.</p>","testString":"assert.equal(typeof ZigZagMatrix(1), 'object');"},{"text":"<p>ZigZagMatrix treba da vrati red podataka interni organizovane redove podataka.</p>","testString":"assert.equal(typeof ZigZagMatrix(1)[0], 'object');"},{"text":"<p>ZigZagMatrix(1) trebalo bi da vrati [[0]].</p>","testString":"assert.deepEqual(ZigZagMatrix(1), zm1);"},{"text":"<p>ZigZagMatrix(2) trebalo bi da vrati [[0, 1], [2, 3]].</p>","testString":"assert.deepEqual(ZigZagMatrix(2), zm2);"},{"text":"<p>ZigZagMatrix(5) treba da vrati spomenutu matricu.</p>","testString":"assert.deepEqual(ZigZagMatrix(5), zm5);"}]}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/rosetta-code/#rosetta-code-challenges","dashedName":"zig-zag-matrix","certification":"rosetta-code","disableLoopProtectTests":true,"disableLoopProtectPreview":false,"superBlock":"rosetta-code","chapter":null,"module":null,"block":"rosetta-code-challenges","isFirstStep":false,"template":null,"required":[],"isLastChallengeInBlock":true,"nextChallengePath":"/learn/2022/responsive-web-design/learn-html-by-building-a-cat-photo-app/step-1","prevChallengePath":"/learn/rosetta-code/rosetta-code-challenges/zhang-suen-thinning-algorithm","id":"594810f028c0303b75339ad8","saveSubmissionToDB":null},"projectPreview":{"challengeData":{"challengeType":1,"challengeFiles":[{"name":"script","ext":"js","contents":"function ZigZagMatrix(n) {\n  const mtx = [];\n  for (let i = 0; i < n; i++) {\n    mtx[i] = [];\n  }\n\n  let i = 1;\n  let j = 1;\n  for (let e = 0; e < n * n; e++) {\n    mtx[i - 1][j - 1] = e;\n    if ((i + j) % 2 === 0) {\n      // Even stripes\n      if (j < n) j++;\n      else i += 2;\n      if (i > 1) i--;\n    } else {\n      // Odd stripes\n      if (i < n) i++;\n      else j += 2;\n      if (j > 1) j--;\n    }\n  }\n  return mtx;\n}","history":["script.js"],"fileKey":"scriptjs"}]}},"id":"/learn/rosetta-code/rosetta-code-challenges/zig-zag-matrix"}},"staticQueryHashes":["3858520367"],"slicesMap":{}}