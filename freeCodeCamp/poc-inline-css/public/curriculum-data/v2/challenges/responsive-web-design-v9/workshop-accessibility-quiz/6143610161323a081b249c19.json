  "tests": [
    {
      "text": "<p>Treba da postavite unutar tri elementa <code>div</code> ispod polja <code>h2#student-info</code>.</p>",
      "testString": "assert.equal(document.querySelectorAll('h2#student-info ~ div')?.length, 3);"
    },
    {
      "text": "<p>Treba da mu daš prvi <code>div</code> od <code>class</code> za <code>info</code>.</p>",
      "testString": "assert.equal(document.querySelectorAll('h2#student-info ~ div')?.[0]?.className, 'info');"
    },
    {
      "text": "<p>Trebalo bi mu dati <code>div</code> od pili <code>class</code> za <code>info</code>.</p>",
      "testString": "assert.equal(document.querySelectorAll('h2#student-info ~ div')?.[1]?.className, 'info');"
    },
    {
      "text": "<p>Trebalo bi mu dati treći <code>div</code> od <code>class</code> za <code>info</code>.</p>",
      "testString": "assert.equal(document.querySelectorAll('h2#student-info ~ div')?.[2]?.className, 'info');"
    },
    {
      "text": "<p>Trebalo bi da ga postavite unutar jednog elementa od <code>label</code> unutar <code>div</code> prvog.</p>",
      "testString": "assert.equal(document.querySelectorAll('h2#student-info ~ div')?.[0]?.querySelectorAll('label')?.length, 1);"
    },
    {
      "text": "<p>Treba da smestiš unutar jednog polja od <code>input</code> unutar <code>div</code> prvog, nakon <code>label</code>.</p>",
      "testString": "assert.equal(document.querySelectorAll('h2#student-info ~ div')?.[0]?.querySelectorAll('input')?.length, 1);\nassert.exists(document.querySelectorAll('h2#student-info ~ div')?.[0]?.querySelector('label + input'));"
    },
    {
      "text": "<p>Trebali biste da postavite unutar jednog elementa od <code>label</code>, u drugom <code>div</code>.</p>",
      "testString": "assert.equal(document.querySelectorAll('h2#student-info ~ div')?.[1]?.querySelectorAll('label')?.length, 1);"
    },
    {
      "text": "<p>Trebalo bi da ga smestiš unutar jedne sekcije <code>input</code> u <code>div</code>, nakon <code>label</code>.</p>",
      "testString": "assert.equal(document.querySelectorAll('h2#student-info ~ div')?.[1]?.querySelectorAll('input')?.length, 1);\nassert.exists(document.querySelectorAll('h2#student-info ~ div')?.[1]?.querySelector('label + input'));"
    },
    {
      "text": "<p>Trebalo bi da ga smestiš unutar jedne sekcije <code>label</code> unutar trećeg <code>div</code>.</p>",
      "testString": "assert.equal(document.querySelectorAll('h2#student-info ~ div')?.[2]?.querySelectorAll('label')?.length, 1);"
    },
    {
      "text": "<p>Trebalo bi da ga smestiš unutar jednog elementa <code>input</code> u trećem <code>div</code>, nakon <code>label</code>.</p>",
      "testString": "assert.equal(document.querySelectorAll('h2#student-info ~ div')?.[2]?.querySelectorAll('input')?.length, 1);\nassert.exists(document.querySelectorAll('h2#student-info ~ div')?.[2]?.querySelector('label + input'));"
    }
  ],
  "description": "<section id=\"description\">\n<p>Popuni sadržaj kratkog testa, ispod <code>#student-info</code>, dodaj tri elementa od <code>div</code> sa <code>class</code> iz <code>info</code>.</p>\n<p>Zatim, unutar svakog <code>div</code>, postavite jedan element od <code>label</code> i jedan element od <code>input</code>.</p>\n</section>",
