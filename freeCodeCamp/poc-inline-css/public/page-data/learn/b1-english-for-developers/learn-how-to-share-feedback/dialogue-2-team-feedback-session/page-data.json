{"componentChunkName":"component---src-templates-challenges-generic-show-tsx","path":"/learn/b1-english-for-developers/learn-how-to-share-feedback/dialogue-2-team-feedback-session","result":{"data":{"challengeNode":{"challenge":{"assignments":["<p>Gledaj video</p>"],"bilibiliIds":null,"block":"learn-how-to-share-feedback","challengeType":21,"description":"<section id=\"description\">\n<p>Pogledajte video dole/ispod kako biste razumeli kontekst predstojećih lekcija.</p>\n</section>","nodules":null,"explanation":null,"helpCategory":"English","instructions":"","fields":{"slug":"/learn/b1-english-for-developers/learn-how-to-share-feedback/dialogue-2-team-feedback-session"},"questions":[],"scene":{"setup":{"background":"company2-center.png","characters":[{"character":"Brian","position":{"x":-25,"y":0,"z":1},"opacity":null},{"character":"Lisa","position":{"x":125,"y":0,"z":1},"opacity":null}],"audio":{"filename":"B1_8-2.mp3","startTime":1,"startTimestamp":null,"finishTimestamp":null},"alwaysShowDialogue":true},"commands":[{"background":null,"character":"Brian","position":{"x":25,"y":0,"z":1},"opacity":null,"startTime":0,"finishTime":null,"dialogue":null},{"background":null,"character":"Lisa","position":{"x":70,"y":0,"z":1},"opacity":null,"startTime":0.5,"finishTime":null,"dialogue":null},{"background":null,"character":"Brian","position":null,"opacity":null,"startTime":1,"finishTime":3.84,"dialogue":{"text":"Hi, Lisa. What do you think about the recent team meeting?","align":"left"}},{"background":null,"character":"Brian","position":null,"opacity":null,"startTime":4.24,"finishTime":8.1,"dialogue":{"text":"Some people seem to have strong opinions about our approach to the project.","align":"left"}},{"background":null,"character":"Lisa","position":null,"opacity":null,"startTime":8.66,"finishTime":9.74,"dialogue":{"text":"I noticed that too.","align":"right"}},{"background":null,"character":"Lisa","position":null,"opacity":null,"startTime":9.86,"finishTime":13,"dialogue":{"text":"If everyone has a different opinion, it could be difficult to make progress.","align":"right"}},{"background":null,"character":"Brian","position":null,"opacity":null,"startTime":13.48,"finishTime":16.02,"dialogue":{"text":"Yes, but I think it's healthy to have some disagreement.","align":"left"}},{"background":null,"character":"Brian","position":null,"opacity":null,"startTime":16.4,"finishTime":20.24,"dialogue":{"text":"If we all agreed on everything, we might miss important details. Don't you think?","align":"left"}},{"background":null,"character":"Lisa","position":null,"opacity":null,"startTime":20.84,"finishTime":24.32,"dialogue":{"text":"I understand, but sometimes too much disagreement can slow things down.","align":"right"}},{"background":null,"character":"Lisa","position":null,"opacity":null,"startTime":24.56,"finishTime":26.96,"dialogue":{"text":"If we want to meet our deadlines, we need to work together.","align":"right"}},{"background":null,"character":"Brian","position":null,"opacity":null,"startTime":26.96,"finishTime":32.72,"dialogue":{"text":"True, but if we ignore different perspectives, we could end up with a less effective solution.","align":"left"}},{"background":null,"character":"Lisa","position":null,"opacity":null,"startTime":33.36,"finishTime":36.52,"dialogue":{"text":"I guess you're right. I just feel that if we focus too much on debating,","align":"right"}},{"background":null,"character":"Lisa","position":null,"opacity":null,"startTime":36.88,"finishTime":39.1,"dialogue":{"text":"we won't have enough time to get the actual work done.","align":"right"}},{"background":null,"character":"Brian","position":null,"opacity":null,"startTime":39.52,"finishTime":43.1,"dialogue":{"text":"Perhaps, but it's also important to make sure everyone feels heard.","align":"left"}},{"background":null,"character":"Brian","position":null,"opacity":null,"startTime":43.54,"finishTime":47.1,"dialogue":{"text":"If people don't feel valued, they might lose motivation, right?","align":"left"}},{"background":null,"character":"Lisa","position":null,"opacity":null,"startTime":47.64,"finishTime":48.36,"dialogue":{"text":"That's a good point.","align":"right"}},{"background":null,"character":"Lisa","position":null,"opacity":null,"startTime":48.64,"finishTime":52.16,"dialogue":{"text":"Maybe we can find a balance between listening to feedback and keeping things on track.","align":"right"}},{"background":null,"character":"Lisa","position":{"x":125,"y":0,"z":1},"opacity":null,"startTime":52.66,"finishTime":null,"dialogue":null},{"background":null,"character":"Brian","position":{"x":-25,"y":0,"z":1},"opacity":null,"startTime":53.16,"finishTime":null,"dialogue":null}]},"superBlock":"b1-english-for-developers","tests":[],"title":"Dijalog 2: Sesija za povratne informacije tima","transcript":null,"translationPending":false,"videoId":null,"videoLocaleIds":null}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/b1-english-for-developers/#learn-how-to-share-feedback","dashedName":"dialogue-2-team-feedback-session","certification":"b1-english-for-developers","disableLoopProtectTests":false,"disableLoopProtectPreview":false,"superBlock":"b1-english-for-developers","chapter":null,"module":null,"block":"learn-how-to-share-feedback","isFirstStep":false,"template":null,"required":[],"isLastChallengeInBlock":false,"nextChallengePath":"/learn/b1-english-for-developers/learn-how-to-share-feedback/task-38","prevChallengePath":"/learn/b1-english-for-developers/learn-how-to-share-feedback/task-37","id":"6798e758b24230c27d1cc44c","saveSubmissionToDB":null},"projectPreview":{"challengeData":{"challengeType":19,"challengeFiles":[]}},"id":"/learn/b1-english-for-developers/learn-how-to-share-feedback/dialogue-2-team-feedback-session"}},"staticQueryHashes":["3858520367"],"slicesMap":{}}