    {
      "text": "<p>Trebalo bi da imate jedan element <code>link</code>.</p>",
      "testString": "assert.strictEqual(document.querySelectorAll('link')?.length, 1);"
    },
    {
      "text": "<p>Tvoj element za <code>link</code> treba da bude element bez zatvarajuće oznake <code>&#x3C;/link></code>.</p>",
      "testString": "assert.notMatch(code, /<\\/link>/i);"
    },
    {
      "text": "<p>Element za <code>link</code> mora imati atribut elementa <code>rel</code> sa vrednošću <code>\"stylesheet\"</code>.</p>",
      "testString": "const linkElement = document.querySelector('link');\r\nconst rel = linkElement?.getAttribute(\"rel\")?.toLowerCase();\r\nassert.strictEqual(rel, \"stylesheet\");"
    },
    {
      "text": "<p>Element vašeg <code>link</code> treba da ima svojstvo polja <code>href</code> sa vrednošću <code>\"styles.css\"</code>.</p>",
      "testString": "const linkElement = document.querySelector('link');\r\nassert.strictEqual(linkElement?.dataset?.href, \"styles.css\");"
    },
    {
      "text": "<p>Element vašeg <code>link</code> treba da bude unutar elementa <code>head</code>.</p>",
      "testString": "const linkElementRegex = /<head\\s*>(?:.|\\r|\\n)*?<link(?:.|\\r|\\n)*?<\\/head\\s*>/i;\r\nassert.match(code, linkElementRegex);"
