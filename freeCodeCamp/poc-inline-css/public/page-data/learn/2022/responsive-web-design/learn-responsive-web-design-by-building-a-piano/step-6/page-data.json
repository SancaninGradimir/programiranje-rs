{"componentChunkName":"component---src-templates-challenges-classic-show-tsx","path":"/learn/2022/responsive-web-design/learn-responsive-web-design-by-building-a-piano/step-6","result":{"data":{"challengeNode":{"challenge":{"block":"learn-responsive-web-design-by-building-a-piano","demoType":null,"title":"Korak 6","description":"<section id=\"description\">\n<p>Zapamtite da atribut elementa <code>class</code> može imati više vrednosti. Da biste razdvojili vaše bele i crne tastere, dodaćete drugu vrednost <code>class</code> od <code>black--key</code>. Dodajte ovo na vaše elemente drugi, treći, peti, šesti i sedmi od <code>.key</code>.</p>\n</section>","id":"612e813b3ba67633222cbe54","hasEditableBoundaries":true,"instructions":"","notes":null,"challengeType":0,"helpCategory":"HTML-CSS","videoUrl":null,"superBlock":"2022/responsive-web-design","translationPending":false,"forumTopicId":null,"hooks":null,"fields":{"slug":"/learn/2022/responsive-web-design/learn-responsive-web-design-by-building-a-piano/step-6"},"required":[],"usesMultifileEditor":true,"challengeFiles":[{"fileKey":"indexhtml","ext":"html","name":"index","contents":"<!DOCTYPE html>\n<html lang=\"en\">\n  <head>\n    <meta charset=\"UTF-8\" />\n    <title>Piano</title>\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" />\n  </head>\n  <body>\n    <div id=\"piano\">\n      <div class=\"keys\">\n        <div class=\"key\"></div>\n        <div class=\"key\"></div>\n        <div class=\"key\"></div>\n        <div class=\"key\"></div>\n        <div class=\"key\"></div>\n        <div class=\"key\"></div>\n        <div class=\"key\"></div>\n      </div>\n    </div>\n  </body>\n</html>","head":null,"tail":null,"editableRegionBoundaries":[8,20],"history":["index.html"]},{"fileKey":"stylescss","ext":"css","name":"styles","contents":"","head":null,"tail":null,"editableRegionBoundaries":[],"history":["styles.css"]}],"saveSubmissionToDB":null,"tests":[{"text":"<p>Tvoj drugi element za <code>.key</code> takođe bi trebalo da ima <code>class</code> od <code>black--key</code>.</p>","testString":"const key = document.querySelectorAll('.key')?.[1];\nassert(key?.className?.includes('black--key'));"},{"text":"<p>Treći vaš element od <code>.key</code> mora da ima <code>black--key</code> u <code>class</code>.</p>","testString":"const third = document.querySelectorAll('.key')?.[2];\nassert(third?.classList?.contains('black--key'));"},{"text":"<p>Tvoj peti element od <code>.key</code> mora imati <code>black--key</code> u <code>class</code>.</p>","testString":"const fifth = document.querySelectorAll('.key')?.[4];\nassert(fifth?.classList?.contains('black--key'));"},{"text":"<p>Šesta karakteristika vašeg <code>.key</code> mora biti <code>black--key</code> u <code>class</code>.</p>","testString":"const sixth = document.querySelectorAll('.key')?.[5];\nassert(sixth?.classList?.contains('black--key'));"},{"text":"<p>Tvoj sedmi element od <code>.key</code> treba da ima <code>black--key</code> u <code>class</code>.</p>","testString":"const seventh = document.querySelectorAll('.key')?.[6];\nassert(seventh?.classList?.contains('black--key'));"},{"text":"<p>Treba ti pet komponenti od <code>.black--key</code>.</p>","testString":"const blackKeys = document.querySelectorAll('.black--key');\nassert(blackKeys?.length === 5);"},{"text":"<p>Trebalo bi da ima sedam komponenti <code>.key</code>.</p>","testString":"const keys = document.querySelectorAll('.key');\nassert(keys?.length === 7);"}]}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/2022/responsive-web-design/#learn-responsive-web-design-by-building-a-piano","dashedName":"step-6","certification":"responsive-web-design","disableLoopProtectTests":false,"disableLoopProtectPreview":false,"superBlock":"2022/responsive-web-design","chapter":null,"module":null,"block":"learn-responsive-web-design-by-building-a-piano","isFirstStep":false,"template":null,"required":[],"isLastChallengeInBlock":false,"nextChallengePath":"/lear