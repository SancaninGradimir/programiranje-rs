  "tests": [
    {
      "text": "<p>Trebalo bi da prenesete deo <code>Footer</code>.</p>",
      "testString": "assert.isFunction(window.index.Footer);"
    },
    {
      "text": "<p>Vaš deo <code>Footer</code> treba da vrati funkcionalnost/element <code>footer</code>.</p>",
      "testString": "const footer = document.getElementById('root').firstElementChild;\r\nassert.equal(footer.tagName, 'FOOTER');"
    },
    {
      "text": "<p>Vaš deo <code>Footer</code> treba da ima samo jedan element od <code>footer</code>.</p>",
      "testString": "assert.lengthOf(document.querySelectorAll('footer'), 1);"
    },
    {
      "text": "<p>Element vašeg <code>footer</code> ne sme da ima nijednog brata.</p>",
      "testString": "assert.lengthOf(document.getElementById('root').children, 1);"
    },
    {
      "text": "<p>Vaš element od <code>footer</code> mora imati najmanje tri neuređene liste.</p>",
      "testString": "assert.isAtLeast(document.querySelectorAll('ul').length, 3);"
    },
    {
      "text": "<p>Svaka neuređeni lista mora imati najmanje dva stavke liste.</p>",
      "testString": "const uls = [...document.querySelectorAll('ul')];\r\nuls.forEach(ul => {\r\n    assert.isAtLeast(ul.querySelectorAll('li').length, 2);\r\n  }\r\n);"
    },
    {
      "text": "<p><code>footer</code> Trebalo bi da ima barem jedan element paragrafa.</p>",
      "testString": "assert.isAtLeast(document.querySelectorAll('p').length, 1);"
    },
    {
      "text": "<p>Trebalo bi da imaš znak autorskog prava (<code>©</code>) u jednom od svojih pasusa.</p>",
      "testString": "const texts = [...document.querySelectorAll('p')].map(p => p.textContent);\r\nconst hasCopyright = texts.some(text => text.includes('©'));\r\nassert.isTrue(hasCopyright);"
    },
    {
      "text": "<p><code>footer</code> mora imati najmanje tri polja sa vrednošću od <code>href</code> postavljena na <code>#</code>.</p>",
      "testString": "const links = document.querySelectorAll('a[href=\"#\"]');\r\nassert.isAtLeast(links.length, 3);"
    },
    {
      "text": "<p>Nijedan vaš element/poveznica ne sme biti prazan.</p>",
      "testString": "const links = [...document.querySelectorAll('a[href=\"#\"]')];\r\nlinks.forEach(link => {\r\n    assert.isNotEmpty(link.textContent);\r\n  }\r\n);"
    }
