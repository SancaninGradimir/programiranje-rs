{"componentChunkName":"component---src-templates-challenges-generic-show-tsx","path":"/learn/b1-english-for-developers/learn-how-to-talk-about-past-experiences/dialogue-2-project-post-mortem","result":{"data":{"challengeNode":{"challenge":{"assignments":["<p>Gledaj video</p>"],"bilibiliIds":null,"block":"learn-how-to-talk-about-past-experiences","challengeType":21,"description":"<section id=\"description\">\n<p>Pogledajte video dole/ispod kako biste razumeli kontekst predstojećih lekcija.</p>\n</section>","nodules":null,"explanation":null,"helpCategory":"English","instructions":"","fields":{"slug":"/learn/b1-english-for-developers/learn-how-to-talk-about-past-experiences/dialogue-2-project-post-mortem"},"questions":[],"scene":{"setup":{"background":"company2-center.png","characters":[{"character":"Linda","position":{"x":-25,"y":0,"z":1},"opacity":null},{"character":"Jake","position":{"x":125,"y":0,"z":1},"opacity":null}],"audio":{"filename":"B1_2-2.mp3","startTime":1,"startTimestamp":null,"finishTimestamp":null},"alwaysShowDialogue":true},"commands":[{"background":null,"character":"Linda","position":{"x":25,"y":0,"z":1},"opacity":null,"startTime":0,"finishTime":null,"dialogue":null},{"background":null,"character":"Jake","position":{"x":70,"y":0,"z":1},"opacity":null,"startTime":0.5,"finishTime":null,"dialogue":null},{"background":null,"character":"Linda","position":null,"opacity":null,"startTime":1,"finishTime":4.88,"dialogue":{"text":"I was thinking we could do a quick post-mortem of the design project.","align":"left"}},{"background":null,"character":"Jake","position":null,"opacity":null,"startTime":5.42,"finishTime":10.42,"dialogue":{"text":"Sure. I was reviewing our security protocols for the project just yesterday. What's on your mind?","align":"right"}},{"background":null,"character":"Linda","position":null,"opacity":null,"startTime":11.08,"finishTime":14.44,"dialogue":{"text":"Well, during the project, I was working closely with the development team,","align":"left"}},{"background":null,"character":"Linda","position":null,"opacity":null,"startTime":14.58,"finishTime":17.94,"dialogue":{"text":"and we were constantly updating the user interface based on user feedback.","align":"left"}},{"background":null,"character":"Jake","position":null,"opacity":null,"startTime":18.58,"finishTime":20.78,"dialogue":{"text":"I noticed that. But there was a time","align":"right"}},{"background":null,"character":"Jake","position":null,"opacity":null,"startTime":20.78,"finishTime":24.26,"dialogue":{"text":"when we weren't considering security implications during those updates, right?","align":"right"}},{"background":null,"character":"Linda","position":null,"opacity":null,"startTime":24.66,"finishTime":29.14,"dialogue":{"text":"Yes, that's true. We used to focus solely on design aspects and user experience.","align":"left"}},{"background":null,"character":"Linda","position":null,"opacity":null,"startTime":29.14,"finishTime":32.18,"dialogue":{"text":"Did you use to check the updates for security vulnerabilities?","align":"left"}},{"background":null,"character":"Jake","position":null,"opacity":null,"startTime":32.9,"finishTime":35.5,"dialogue":{"text":"I did, but not always in real time.","align":"right"}},{"background":null,"character":"Jake","position":null,"opacity":null,"startTime":35.78,"finishTime":39.12,"dialogue":{"text":"Sometimes I was checking them a day later, which wasn't ideal.","align":"right"}},{"background":null,"character":"Linda","position":null,"opacity":null,"startTime":39.68,"finishTime":42.66,"dialogue":{"text":"I remember there was a week when we were all working overtime.","align":"left"}},{"background":null,"character":"Linda","position":null,"opacity":null,"startTime":43,"finishTime":45.1,"dialogue":{"text":"You were fixing a security issue, weren't you?","align":"left"}},{"background":null,"character":"Jake","position":null,"opacity":null,"startTime":45.88,"finishTime":49.48,"dialogue":{"text":"Exactly. There was a major vulnerability that needed immediate action.","align":"right"}},{"background":null,"character":"Jake","position":null,"opacity":null,"startTime":49.68,"finishTime":53.2,"dialogue":{"text":"While I was addressing that, the team was waiting for my green light to proceed.","align":"right"}},{"background":null,"character":"Linda","position":null,"opacity":null,"startTime":53.72,"finishTime":55.56,"dialogue":{"text":"It was quite a learning curve for us.","align":"left"}},{"background":null,"character":"Linda","position":null,"opacity":null,"startTime":55.74,"finishTime":58.92,"dialogue":{"text":"We didn't use to integrate security and design as much as we should.","align":"left"}},{"background":null,"character":"Jake","position":null,"opacity":null,"startTime":59.7,"finishTime":65.94,"dialogue":{"text":"Agreed. Moving forward, we should ensure that security checks are happening while the design updates are being made.","align":"right"}},{"background":null,"character":"Jake","position":null,"opacity":null,"startTime":66.06,"finishTime":68.64,"dialogue":{"text":"We can't afford to overlook this aspect again.","align":"right"}},{"background":null,"character":"Jake","position":{"x":125,"y":0,"z":1},"opacity":null,"startTime":69.14,"finishTime":null,"dialogue":null},{"background":null,"character":"Linda","position":{"x":-25,"y":0,"z":1},"opacity":null,"startTime":69.64,"finishTime":null,"dialogue":null}]},"superBlock":"b1-english-for-developers","tests":[],"title":"Dijalog 2: Projekat post-mortem","transcript":null,"translationPending":false,"videoId":null,"videoLocaleIds":null}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/b1-english-for-developers/#learn-how-to-talk-about-past-experiences","dashedName":"dialogue-2-project-post-mortem","certification":"b1-english-for-developers","disableLoopProtectTests":false,"disableLoopProtectPreview":false,"superBlock":"b1-english-for-developers","chapter":null,"module":null,"block":"learn-how-to-talk-about-past-experiences","isFirstStep":false,"template":null,"required":[],"isLastChallengeInBlock":false,"nextChallengePath":"/learn/b1-english-for-developers/learn-how-to-talk-about-past-experiences/task-49","prevChallengePath":"/learn/b1-english-for-developers/learn-how-to-talk-about-past-experiences/task-48","id":"670f6ca334a541048d0e9a76","saveSubmissionToDB":null},"projectPreview":{"challengeData":{"challengeType":19,"challengeFiles":[]}},"id":"/learn/b1-english-for-developers/learn-how-to-talk-about-past-experiences/dialogue-2-project-post-mortem"}},"staticQueryHashes":["3858520367"],"slicesMap":{}}