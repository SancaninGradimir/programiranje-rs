able>\n            <caption>Assets</caption>\n            <thead>\n              <tr>\n                <td></td>\n                <th><span class=\"sr-only year\">2019</span></th>\n                <th><span class=\"sr-only year\">2020</span></th>\n                <th class=\"current\"><span class=\"sr-only year\">2021</span></th>\n              </tr>\n            </thead>\n            <tbody>\n              <tr class=\"data\">\n                <th>Cash <span class=\"description\">This is the cash we currently have on hand.</span></th>\n                <td>$25</td>\n                <td>$30</td>\n                <td class=\"current\">$28</td>\n              </tr>\n              <tr class=\"data\">\n                <th>Checking <span class=\"description\">Our primary transactional account.</span></th>\n                <td>$54</td>\n                <td>$56</td>\n                <td class=\"current\">$53</td>\n              </tr>\n              <tr class=\"data\">\n                <th>Savings <span class=\"description\">Funds set aside for emergencies.</span></th>\n                <td>$500</td>\n                <td>$650</td>\n                <td class=\"current\">$728</td>\n              </tr>\n              <tr class=\"total\">\n                <th>Total <span class=\"sr-only\">Assets</span></th>\n                <td>$579</td>\n                <td>$736</td>\n                <td class=\"current\">$809</td>\n              </tr>\n            </tbody>\n          </table>\n          <table>\n            <caption>Liabilities</caption>\n            <thead>\n              <tr>\n              <td></td>\n              <th><span class=\"sr-only\">2019</span></th>\n              <th><span class=\"sr-only\">2020</span></th>\n              <th><span class=\"sr-only\">2021</span></th>\n              </tr>\n            </thead>\n            <tbody>\n              <tr class=\"data\">\n                <th>Loans <span class=\"description\">The outstanding balance on our startup loan.</span></th>\n                <td>$500</td>\n                <td>$250</td>\n                <td class=\"current\">$0</td>\n              </tr>\n              <tr class=\"data\">\n                <th>Expenses <span class=\"description\">Annual anticipated expenses, such as payroll.</span></th>\n                <td>$200</td>\n                <td>$300</td>\n                <td class=\"current\">$400</td>\n              </tr>\n              <tr class=\"data\">\n                <th>Credit <span class=\"description\">The outstanding balance on our credit card.</span></th>\n                <td>$50</td>\n                <td>$50</td>\n                <td class=\"current\">$75</td>\n              </tr>\n              <tr class=\"total\">\n                <th>Total <span class=\"sr-only\">Liabilities</span></th>\n                <td>$750</td>\n                <td>$600</td>\n                <td class=\"current\">$475</td>\n              </tr>\n            </tbody>\n          </table>\n          <table>\n            <caption>Net Worth</caption>\n            <thead>\n            </thead>\n            <tbody>\n            </tbody>\n          </table>\n        </div>\n      </section>\n    </main>\n  </body>\n</html>","head":null,"tail":null,"editableRegionBoundaries":[97,105],"history":["index.html"]},{"fileKey":"stylescss","ext":"css","name":"styles","contents":"","head":null,"tail":null,"editableRegionBoundaries":[],"history":["styles.css"]}],"saveSubmissionToDB":null,"tests":[{"text":"<p>Vaš element za <code>thead</code> treba da ima element za <code>tr</code>.</p>","testString":"assert(document.querySelectorAll('table')?.[2]?.querySelector('thead')?.children?.[0]?.localName === 'tr');"},{"text":"<p>Tvoj element <code>tr</code> treba da ima element <code>td</code> kao prvo dete.</p>","testString":"assert(document.querySelectorAll('table')?.[2]?.querySelector('tr')?.children?.[0]?.localName === 'td');"},{"text":"<p>Tvoj element <code>tr</code> treba da ima tri elementa od <code>th</code>, nakon elementa <code>td</code>.</p>","testString":"assert(document.querySelectorAll('table')?.[2]?.querySelector('tr')?.children?.[1]?.localName === 'th');\nassert(document.querySelectorAll('table')?.[2]?.querySelector('tr')?.children?.[2]?.localName === 'th');\nassert(document.querySelectorAll('table')?.[2]?.querySelector('tr')?.children?.[3]?.localName === 'th');"},{"text":"<p>Svaki element vašeg <code>th</code> mora imati element <code>span</code>.</p>","testString":"const ths = [...document.querySelectorAll('table')?.[2]?.querySelectorAll('th')];\nths?.forEach(th => {\n  assert(th?.children?.length === 1);\n  assert(th?.children?.[0]?.localName === 'span');\n});"},{"text":"<p>Svaki tvoj novi element <code>span</code> mora imati svojstvo elementa <code>class</code> postavljeno na <code>sr-only</code>.</p>","testString":"const ths = [...document.querySelectorAll('table')?.[2]?.querySelectorAll('th')];\nths?.forEach(th => {\n  assert(th?.children?.[0]?.classList?.contains('sr-only'));\n});"},{"text":"<p>Prvi element vašeg <code>span</code> treba da ima tekst <code>2019</code>.</p>","testString":"assert(document.querySelectorAll('table')?.[2]?.querySelectorAll('th')?.[0]?.children?.[0]?.textContent === '2019');"},{"text":"<p>Vaš drugi element za <code>span</code> treba da ima tekst <code>2020</code>.</p>","testString":"assert(document.querySelectorAll('table')?.[2]?.querySelectorAll('th')?.[1]?.children?.[0]?.textContent === '2020');"},{"text":"<p>Tvoje treće polje za <code>span</code> bi trebalo da ima tekst <code>2021</code>.</p>","testString":"assert(document.querySelectorAll('table')?.[2]?.querySelectorAll('th')?.[2]?.children?.[0]?.textContent === '2021');"},{"text":"<p>Vaše polje za <code>td</code> treba da bude prazno.</p>","testString":"assert(document.querySelectorAll('table')?.[2]?.querySelectorAll('td')?.[0]?.textContent === '');\nassert(document.querySelectorAll('table')?.[2]?.querySelectorAll('td')?.[0]?.children?.length === 0);"}]}}},"pageContext