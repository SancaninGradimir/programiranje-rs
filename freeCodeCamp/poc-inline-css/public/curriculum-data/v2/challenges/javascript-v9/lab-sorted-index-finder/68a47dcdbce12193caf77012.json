        "contents": "function getIndexToIns(arr, num) {\r\n  const sorted = [...arr].sort((a, b) => a - b);\r\n  const index = sorted.findIndex(el => el >= num);\r\n\r\n  return index === -1 ? sorted.length : index;\r\n}",
