{"componentChunkName":"component---src-templates-challenges-classic-show-tsx","path":"/learn/rosetta-code/rosetta-code-challenges/sorting-algorithmscocktail-sort","result":{"data":{"challengeNode":{"challenge":{"block":"rosetta-code-challenges","demoType":null,"title":"Algoritmi za sortiranje/aranžiranje koktela","description":"<section id=\"description\">\n<p><a href=\"https://rosettacode.org/wiki/Sorting_algorithms/Cocktail_sort\" target=\"_blank\" rel=\"noopener noreferrer nofollow\">Koktel sortiranje</a> je poboljšanje Bubble Sort-a. Ako postoji niz brojeva, Koktel sortiranje prolazi kroz taj niz od početka do kraja, pomerajući najveći broj na kraj. Zatim, prolazi unazad kroz niz i pomera najmanji broj na početak. Ponavlja ove dve ciklusa, pomerajući sledeći najveći/najmanji broj na njegovo pravo mesto u nizu dok nije sortiran.</p>\n</section>","id":"5a23c84252665b21eecc8004","hasEditableBoundaries":false,"instructions":"<section id=\"instructions\">\n<p>Napišite funkciju koja sortira niz podataka dati korišćenjem koktel sort-a.</p>\n</section>","notes":null,"challengeType":1,"helpCategory":"Rosetta","videoUrl":null,"superBlock":"rosetta-code","translationPending":false,"forumTopicId":302312,"hooks":null,"fields":{"slug":"/learn/rosetta-code/rosetta-code-challenges/sorting-algorithmscocktail-sort"},"required":[],"usesMultifileEditor":false,"challengeFiles":[{"fileKey":"scriptjs","ext":"js","name":"script","contents":"function cocktailSort(arr) {\n\n}","head":null,"tail":null,"editableRegionBoundaries":[],"history":["script.js"]}],"saveSubmissionToDB":null,"tests":[{"text":"<p><code>cocktailSort</code> trebalo bi da bude funkcija.</p>","testString":"assert(typeof cocktailSort == 'function');"},{"text":"<p><code>cocktailSort([25, 32, 12, 7, 20])</code> Trebalo bi da vrati red podataka.</p>","testString":"assert(Array.isArray(cocktailSort([25, 32, 12, 7, 20])));"},{"text":"<p><code>cocktailSort([25, 32, 12, 7, 20])</code> treba da vrati <code>[7, 12, 20, 25, 32]</code>.</p>","testString":"assert.deepEqual(cocktailSort([25, 32, 12, 7, 20]), [7, 12, 20, 25, 32]);"},{"text":"<p><code>cocktailSort([38, 45, 35, 8, 13])</code> treba da vrati <code>[8, 13, 35, 38, 45]</code>.</p>","testString":"assert.deepEqual(cocktailSort([38, 45, 35, 8, 13]), [8, 13, 35, 38, 45]);"},{"text":"<p><code>cocktailSort([43, 36, 20, 34, 24])</code> treba da vrati <code>[20, 24, 34, 36, 43]</code>.</p>","testString":"assert.deepEqual(cocktailSort([43, 36, 20, 34, 24]), [20, 24, 34, 36, 43]);"},{"text":"<p><code>cocktailSort([12, 33, 26, 18, 1, 16, 38])</code> treba da vrati <code>[1, 12, 16, 18, 26, 33, 38]</code>.</p>","testString":"assert.deepEqual(cocktailSort([12, 33, 26, 18, 1, 16, 38]), [\n  1,\n  12,\n  16,\n  18,\n  26,\n  33,\n  38\n]);"},{"text":"<p><code>cocktailSort([3, 39, 48, 16, 1, 4, 29])</code> treba da vrati <code>[1, 3, 4, 16, 29, 39, 48]</code>.</p>","testString":"assert.deepEqual(cocktailSort([3, 39, 48, 16, 1, 4, 29]), [\n  1,\n  3,\n  4,\n  16,\n  29,\n  39,\n  48\n]);"}]}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/rosetta-code/#rosetta-code-challenges","dashedName":"sorting-algorithmscocktail-sort","certification":"rosetta-code","disableLoopProtectTests":true,"disableLoopProtectPreview":false,"superBlock":"rosetta-code","chapter":null,"module":null,"block":"rosetta-code-challenges","isFirstStep":false,"template":null,"required":[],"isLastChallengeInBlock":false,"nextChallengePath":"/learn/rosetta-code/rosetta-code-challenges/sorting-algorithmscomb-sort","prevChallengePath":"/learn/rosetta-code/rosetta-code-challenges/sorting-algorithmsbogosort","id":"5a23c84252665b21eecc8004","saveSubmissionToDB":null},"projectPreview":{"challengeData":{"challengeType":1,"challengeFiles":[{"name":"script","ext":"js","contents":"function ZigZagMatrix(n) {\n  const mtx = [];\n  for (let i = 0; i < n; i++) {\n    mtx[i] = [];\n  }\n\n  let i = 1;\n  let j = 1;\n  for (let e = 0; e < n * n; e++) {\n    mtx[i - 1][j - 1] = e;\n    if ((i + j) % 2 === 0) {\n      // Even stripes\n      if (j < n) j++;\n      else i += 2;\n      if (i > 1) i--;\n    } else {\n      // Odd stripes\n      if (i < n) i++;\n      else j += 2;\n      if (j > 1) j--;\n    }\n  }\n  return mtx;\n}","history":["script.js"],"fileKey":"scriptjs"}]}},"id":"/learn/rosetta-code/rosetta-code-challenges/sorting-algorithmscocktail-sort"}},"staticQueryHashes":["3858520367"],"slicesMap":{}}