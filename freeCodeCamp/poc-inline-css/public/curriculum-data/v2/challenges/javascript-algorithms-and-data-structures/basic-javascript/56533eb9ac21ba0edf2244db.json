      "text": "<p>Treba da imate bar dva <code>else</code> iskaza</p>",
      "testString": "assert(__helpers.removeJSComments(code).match(/else/g).length > 1);"
    },
    {
      "text": "<p>Treba da imate bar dva <code>if</code> iskaza</p>",
      "testString": "assert(__helpers.removeJSComments(code).match(/if/g).length > 1);"
    },
    {
      "text": "<p>Treba da imate odgovarajuce vitičaste zagrade za svaki <code>if else</code> blok.</p>",
      "testString": "assert(\n  __helpers.removeJSComments(code).match(\n    /if\\s*\\((.+)\\)\\s*\\{[\\s\\S]+\\}\\s*else\\s+if\\s*\\((.+)\\)\\s*\\{[\\s\\S]+\\}\\s*else\\s*\\{[\\s\\S]+\\s*\\}/\n  )\n);"
    },
    {
      "text": "<p><code>testElseIf(0)</code> treba da vrati string <code>Smaller than 5</code></p>",
      "testString": "assert(testElseIf(0) === 'Smaller than 5');"
    },
    {
      "text": "<p><code>testElseIf(5)</code> treba da vrati string <code>Between 5 and 10</code></p>",
      "testString": "assert(testElseIf(5) === 'Between 5 and 10');"
    },
    {
      "text": "<p><code>testElseIf(7)</code> treba da vrati string <code>Between 5 and 10</code></p>",
