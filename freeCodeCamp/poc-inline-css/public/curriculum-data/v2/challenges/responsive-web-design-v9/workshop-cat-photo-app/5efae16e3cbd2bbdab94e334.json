  "tests": [
    {
      "text": "<p>Vaša komponenta za <code>figcaption</code> mora imati oznaku za otvaranje. Oznake za otvaranje imaju sledeću sintaksu: <code>&#x3C;elementName></code>.</p>",
      "testString": "assert.lengthOf(document.querySelectorAll('figcaption'), 2);"
    },
    {
      "text": "<p>Vaš element za <code>figcaption</code> treba da ima zatvarajući label/tag. Zatvarajući tagovi su na <code>/</code> odmah nakon slova <code>&#x3C;</code>.</p>",
      "testString": "assert.lengthOf(code.match(/<\\/figcaption\\>/g), 2);"
    },
    {
      "text": "<p>Nakon oznake zatvaranja drugog elementa od <code>figure</code>, treba da postoji element <code>section</code> iznad njega.</p>",
      "testString": "assert.equal(document.querySelectorAll('main > section')[1]?.lastElementChild.nodeName, 'FIGURE');"
    },
    {
      "text": "<p>Poslednji element od <code>img</code> treba biti smešten unutar elementa <code>figure</code>.</p>",
      "testString": "const catsImg = document.querySelectorAll('figure > img')[1];\nassert.equal(\n    catsImg?.getAttribute('src')?.toLowerCase(), 'https://cdn.freecodecamp.org/curriculum/cat-photo-app/cats.jpg'\n);"
    },
    {
      "text": "<p>Vaša komponenta od <code>figure</code> treba da ima oznaku za otvaranje. Oznake za otvaranje imaju sledeću sintaksu: <code>&#x3C;elementName></code>.</p>",
      "testString": "assert.lengthOf(document.querySelectorAll('figure'), 2);"
    },
    {
      "text": "<p>Vaš element <code>figure</code> treba da ima zatvarajući tag. Zatvarajući tagovi su <code>/</code> odmah nakon karaktera <code>&#x3C;</code>.</p>",
      "testString": "assert.lengthOf(code.match(/<\\/figure\\>/g), 2);"
    },
    {
      "text": "<p>Element <code>figcaption</code> mora biti smješten unutar elementa <code>figure</code>.</p>",
      "testString": "assert.lengthOf(document.querySelectorAll('figure > figcaption'), 2);"
    },
    {
      "text": "<p>Element <code>figcaption</code>, koji je postavljen unutar elementa <code>figure</code>, treba da bude ispod elementa <code>img</code>. Postavili ste element <code>img</code> i element <code>figcaption</code> u pogrešnom redosledu.</p>",
      "testString": "assert.equal(\n  document.querySelectorAll('figcaption')[1]?.previousElementSibling.nodeName,\n    'IMG'\n);"
    },
    {
      "text": "<p>Element <code>figcaption</code> bi trebalo da ima tekst od <code>Cats hate other cats.</code>. Ostavili ste reč ili napravili je greške u pravopisu.</p>",
      "testString": "assert.match(\n  document\n    .querySelectorAll('figcaption')[1]\n    ?.innerText?.trim().replace(/\\s+/g, ' ').toLowerCase(),\n    /^Cats hate other cats\\.?$/i\n);"
    }
  ],
  "description": "<section id=\"description\">\n<p>Nakon poslednjeg elementa od <code>img</code>, dodaj element sa <code>figcaption</code> sa tekstom <code>Cats hate other cats.</code></p>\n</section>",
