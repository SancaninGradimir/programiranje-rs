    {
      "text": "<p><code>form</code> trebao bi imati samo element <code>input</code>. Izbrišite druge elemente od HTML ili tekst unutar elementa <code>form</code>.</p>",
      "testString": "assert.isTrue(\n  document.querySelector('form')?.children?.length === 1 &&\n    document.querySelector('form')?.innerText?.trim()?.length === 0\n);"
