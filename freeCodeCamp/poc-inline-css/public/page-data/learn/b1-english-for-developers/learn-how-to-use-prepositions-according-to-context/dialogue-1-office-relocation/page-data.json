{"componentChunkName":"component---src-templates-challenges-generic-show-tsx","path":"/learn/b1-english-for-developers/learn-how-to-use-prepositions-according-to-context/dialogue-1-office-relocation","result":{"data":{"challengeNode":{"challenge":{"assignments":["<p>Gledaj video.</p>"],"bilibiliIds":null,"block":"learn-how-to-use-prepositions-according-to-context","challengeType":21,"description":"<section id=\"description\">\n<p>Pogledajte video dole/ispod kako biste razumeli kontekst predstojećih lekcija.</p>\n</section>","nodules":null,"explanation":null,"helpCategory":"English","instructions":"","fields":{"slug":"/learn/b1-english-for-developers/learn-how-to-use-prepositions-according-to-context/dialogue-1-office-relocation"},"questions":[],"scene":{"setup":{"background":"company1-boardroom.png","characters":[{"character":"Anna","position":{"x":-25,"y":0,"z":1},"opacity":null},{"character":"Bob","position":{"x":125,"y":0,"z":1},"opacity":null}],"audio":{"filename":"B1_22-1.mp3","startTime":1,"startTimestamp":null,"finishTimestamp":null},"alwaysShowDialogue":true},"commands":[{"background":null,"character":"Anna","position":{"x":25,"y":0,"z":1},"opacity":null,"startTime":0,"finishTime":null,"dialogue":null},{"background":null,"character":"Bob","position":{"x":70,"y":0,"z":1},"opacity":null,"startTime":0.5,"finishTime":null,"dialogue":null},{"background":null,"character":"Anna","position":null,"opacity":null,"startTime":1,"finishTime":7.02,"dialogue":{"text":"Good morning, Bob. Have you seen the layout plan for our new office? I need your input on where to place each department.","align":"left"}},{"background":null,"character":"Bob","position":null,"opacity":null,"startTime":7.5,"finishTime":13.74,"dialogue":{"text":"Yes, I've looked at the plans. Let's start with the IT department. I think it should be next to the server room for easy access.","align":"right"}},{"background":null,"character":"Anna","position":null,"opacity":null,"startTime":14.32,"finishTime":16.96,"dialogue":{"text":"That makes sense. The server room is in the back, right?","align":"left"}},{"background":null,"character":"Bob","position":null,"opacity":null,"startTime":17.4,"finishTime":23.36,"dialogue":{"text":"Exactly. It's in the back, next to the emergency exit. Now, where do you think we should put the HR department?","align":"right"}},{"background":null,"character":"Anna","position":null,"opacity":null,"startTime":24.02,"finishTime":30.98,"dialogue":{"text":"HR should be near the entrance. It's easier for visitors and new employees to find us. How about the space right across from the reception?","align":"left"}},{"background":null,"character":"Bob","position":null,"opacity":null,"startTime":31.46,"finishTime":38.54,"dialogue":{"text":"Sounds good. That's very accessible. And the marketing team? They need a quiet area, but also want to be close to the sales department.","align":"right"}},{"background":null,"character":"Anna","position":null,"opacity":null,"startTime":39.18,"finishTime":46.06,"dialogue":{"text":"There's an area on the left side of the building, right next to the sales office. It's a bit isolated from the main walkways, so it should be quieter.","align":"left"}},{"background":null,"character":"Bob","position":null,"opacity":null,"startTime":46.46,"finishTime":50.56,"dialogue":{"text":"Perfect. Let's put them there. What about the customer support team?","align":"right"}},{"background":null,"character":"Anna","position":null,"opacity":null,"startTime":51.06,"finishTime":56.68,"dialogue":{"text":"Let's place them near the middle of the floor. They need to be easily reachable. Maybe right behind the conference rooms?","align":"left"}},{"background":null,"character":"Bob","position":null,"opacity":null,"startTime":57.32,"finishTime":64.3,"dialogue":{"text":"That works. They'll be central, but the conference rooms will buffer some of the noise. Last, where should we set up the break room?","align":"right"}},{"background":null,"character":"Anna","position":null,"opacity":null,"startTime":64.74,"finishTime":70.92,"dialogue":{"text":"It should be centrally located so it's equally accessible to everyone. How about between the IT department and HR?","align":"left"}},{"background":null,"character":"Anna","position":null,"opacity":null,"startTime":71.2,"finishTime":73.34,"dialogue":{"text":"That way, it's just a short walk for most teams.","align":"left"}},{"background":null,"character":"Bob","position":null,"opacity":null,"startTime":73.66,"finishTime":76.96,"dialogue":{"text":"I agree. That's a convenient spot for everyone. Thanks, Anna.","align":"right"}},{"background":null,"character":"Bob","position":null,"opacity":null,"startTime":77.08,"finishTime":81.34,"dialogue":{"text":"I'll update the layout draft with these changes and send it over to you for your final review.","align":"right"}},{"background":null,"character":"Anna","position":null,"opacity":null,"startTime":81.98,"finishTime":85.78,"dialogue":{"text":"Thanks, Bob. I'll look out for that, and we can discuss it further if there are any tweaks needed.","align":"left"}},{"background":null,"character":"Bob","position":{"x":125,"y":0,"z":1},"opacity":null,"startTime":86.28,"finishTime":null,"dialogue":null},{"background":null,"character":"Anna","position":{"x":-25,"y":0,"z":1},"opacity":null,"startTime":86.78,"finishTime":null,"dialogue":null}]},"superBlock":"b1-english-for-developers","tests":[],"title":"Dijalog 1: Selidba kancelarije","transcript":null,"translationPending":false,"videoId":null,"videoLocaleIds":null}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/b1-english-for-developers/#learn-how-to-use-prepositions-according-to-context","dashedName":"dialogue-1-office-relocation","certification":"b1-english-for-developers","disableLoopProtectTests":false,"disableLoopProtectPreview":false,"superBlock":"b1-english-for-developers","chapter":null,"module":null,"block":"learn-how-to-use-prepositions-according-to-context","isFirstStep":tru