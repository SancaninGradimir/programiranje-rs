    {
      "text": "<p><code>IBeforeExceptC(\"inconceivable\")</code> inapaswa kurudisha <code>true</code>.</p>",
      "testString": "assert.equal(IBeforeExceptC('inconceivable'), true);"
    },
    {
      "text": "<p><code>IBeforeExceptC(\"insufficient\")</code> treba vratiti <code>false</code>.</p>",
      "testString": "assert.equal(IBeforeExceptC('insufficient'), false);"
