        "path": "script.js",
        "fileKey": "scriptjs",
        "contents": "const uniteUnique = (...arrays) => {\n  return arrays.reduce((a, b) => {\n    return [\n      ...a,\n      ...b.filter((e, currentIndex) => b.indexOf(e) === currentIndex && a.indexOf(e) === -1)\n    ];\n  }, []);\n};",
        "error": null,
        "seed": "const uniteUnique = (...arrays) => {\n  return arrays.reduce((a, b) => {\n    return [\n      ...a,\n      ...b.filter((e, currentIndex) => b.indexOf(e) === currentIndex && a.indexOf(e) === -1)\n    ];\n  }, []);\n};"
      }
    ]
  ],
