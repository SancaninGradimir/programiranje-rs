{"componentChunkName":"component---src-templates-challenges-classic-show-tsx","path":"/learn/basic-html/workshop-html-video-player/step-11","result":{"data":{"challengeNode":{"challenge":{"block":"workshop-html-video-player","demoType":null,"title":"Korak 11","description":"<section id=\"description\">\n<p>Drugi uobičajeni MIME tip je MIME tip <code>video/webm</code>.</p>\n<p>WebM je open-source audiovizuelni format medijskih fajlova koji je razvila kompanija Google, prvenstveno dizajniran za web sadržaj. Podržava video kodeke kao što su VP8, VP9 i AV1, kao i audio kodeke kao što su Vorbis i Opus, što ga čini popularnim izborom za HTML5 video i audio elemente.</p>\n<p>Ispod vašeg prvog <code>source</code> elementa, dodajte još jedan <code>source</code> element i dodelite mu atribut <code>src</code> sa vrednošću <code>https://cdn.freecodecamp.org/curriculum/labs/mapmethod.webm</code> i atribut <code>type</code> sa vrednošću <code>video/webm</code>.</p>\n</section>","id":"68f26d52b13e0f5b6e2d2e09","hasEditableBoundaries":true,"instructions":"","notes":null,"challengeType":0,"helpCategory":"HTML-CSS","videoUrl":null,"superBlock":"basic-html","translationPending":false,"forumTopicId":null,"hooks":null,"fields":{"slug":"/learn/basic-html/workshop-html-video-player/step-11"},"required":[],"usesMultifileEditor":true,"challengeFiles":[{"fileKey":"indexhtml","ext":"html","name":"index","contents":"<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Working with the HTML Video Element</title>\n</head>\n<body>\n  <h1>Working with the HTML Video Element</h1>\n  <video\n    width=\"640\"\n    loop\n    controls\n    muted\n    poster=\"https://cdn.freecodecamp.org/curriculum/labs/past-event2.jpg\"\n  >\n    <source\n      src=\"https://cdn.freecodecamp.org/curriculum/labs/what-is-the-map-method-and-how-does-it-work.mp4\"\n      type=\"video/mp4\"\n    >\n    \n  </video>\n</body>\n</html>","head":null,"tail":null,"editableRegionBoundaries":[20,22],"history":["index.html"]}],"saveSubmissionToDB":null,"tests":[{"text":"<p>You should have a second <code>source</code> element.</p>","testString":"assert.exists(document.querySelector('video > source:nth-of-type(2)'));"},{"text":"<p>Your second <code>source</code> element should have a <code>src</code> attribute.</p>","testString":"const source = document.querySelector('source:nth-of-type(2)');\nassert.isTrue(source?.hasAttribute('src'));"},{"text":"<p>Your second <code>source</code> element should have a <code>src</code> attribute with a value of <code>https://cdn.freecodecamp.org/curriculum/labs/mapmethod.webm</code>.</p>","testString":"const source = document.querySelector('source:nth-of-type(2)');\nassert.strictEqual(source?.getAttribute('src'), 'https://cdn.freecodecamp.org/curriculum/labs/mapmethod.webm');"},{"text":"<p>Your second <code>source</code> element should have a <code>type</code> attribute.</p>","testString":"const source = document.querySelector('source:nth-of-type(2)');\nassert.isTrue(source?.hasAttribute('type'));"},{"text":"<p>Your second <code>source</code> element should have a <code>type</code> attribute with a value of <code>video/webm</code>.</p>","testString":"const source = document.querySelector('source:nth-of-type(2)');\nassert.strictEqual(source?.getAttribute('type'), 'video/webm');"}]}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/basic-html/#workshop-html-video-player","dashedName":"step-11","certification":"basic-html","disableLoopProtectTests":false,"disableLoopProtectPreview":false,"superBlock":"basic-html","chapter":null,"module":null,"block":"workshop-html-video-player","isFirstStep":false,"template":null,"required":[],"isLastChallengeInBlock":false,"nextChallengePath":"/learn/basic-html/workshop-html-video-player/step-12","prevChallengePath":"/learn/basic-html/workshop-html-video-player/step-10","id":"68f26d52b13e0f5b6e2d2e09","saveSubmissi