    {
      "text": "<p>Trebalo bi da kreirate element <code>h1</code>.</p>",
      "testString": "assert.exists(document.querySelector('h1'));"
    },
    {
      "text": "<p>Vaš element od <code>h1</code> mora da dođe nakon vašeg elementa od <code>img</code>.</p>",
      "testString": "assert(document.querySelector('h1')?.previousElementSibling?.localName === 'img');"
    },
    {
      "text": "<p>Element vašeg <code>h1</code> mora imati <code>class</code> podešen na <code>hero-title</code>.</p>",
      "testString": "assert(document.querySelector('h1')?.className === 'hero-title');"
    },
    {
      "text": "<p>Vaš element za <code>h1</code> mora imati tekst koji je <code>OUR NEW CURRICULUM</code>.</p>",
      "testString": "assert(document.querySelector('h1')?.textContent === 'OUR NEW CURRICULUM');"
    },
    {
      "text": "<p>Treba da kreiraš novi element za <code>p</code>.</p>",
      "testString": "assert.exists(document.querySelector('p'));"
    },
    {
      "text": "<p>Tvoj element <code>p</code> mora da sledi nakon tvog elementa <code>h1</code>.</p>",
      "testString": "assert(document.querySelector('p')?.previousElementSibling?.localName === 'h1');"
    },
    {
      "text": "<p>Vaša funkcija od <code>p</code> trebalo bi da ima <code>class</code> postavljeno na <code>hero-subtitle</code>.</p>",
      "testString": "assert(document.querySelector('p')?.className === 'hero-subtitle');"
    },
    {
      "text": "<p>Vaša sekcija za <code>p</code> treba da ima tekst koji je <code>Our efforts to restructure our curriculum with a more project-based focus</code>.</p>",
      "testString": "assert.equal(document.querySelector('p')?.textContent?.trim()?.replace(/\\s{2,}/, ' '), 'Our efforts to restructure our curriculum with a more project-based focus');"
    }
  ],
