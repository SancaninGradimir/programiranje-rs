        "fileKey": "scriptjs",
        "contents": "function uniteUnique(arr) {\r\n  return [].slice.call(arguments).reduce(function(a, b) {\r\n    return [].concat(\r\n      a, \r\n      b.filter(function(e, currentIndex) {\r\n        return b.indexOf(e) === currentIndex && a.indexOf(e) === -1;\r\n      }));\r\n  }, []);\r\n}",
        "error": null,
