{"componentChunkName":"component---src-templates-challenges-classic-show-tsx","path":"/learn/rosetta-code/rosetta-code-challenges/i-before-e-except-after-c","result":{"data":{"challengeNode":{"challenge":{"block":"rosetta-code-challenges","demoType":null,"title":"I kabl za E, osim nakon C","description":"<section id=\"description\">\n<p><strong><a href=\"http://www.rosettacode.org/wiki/I_before_E_except_after_C\" target=\"_blank\" rel=\"noopener noreferrer nofollow\">„I pre E, osim posle C“</a></strong> predstavlja opšte pravilo engleskog pravopisa. Ako nisi siguran da li se reč piše sa <code>ei</code> ili <code>ie</code>, pravilo kaže da je ispravno <code>ie</code>, osim kada se ispred nalazi slovo <code>c</code>, kada može biti <code>ei</code>.</p>\n<p>Koristeći date reči, proverite da li oba manja dela fraze mogu biti istinita sama po sebi:</p>\n<ol>\n  <li>\n    <i>\"I kabla ya E wakati haikutanguliwi na C\".</i>\n  </li>\n  <li>\n    <i>\"E kabla ya I wakati ikitanguliwa na C\".</i>\n  </li>\n</ol>\n<p>Ako su oba manja predikata tačna, onda se može reći da je početna teza istinita.</p>\n</section>","id":"5a23c84252665b21eecc7eb0","hasEditableBoundaries":false,"instructions":"<section id=\"instructions\">\n<p>Napiši funkciju koja prihvata reč i proverava da li ona prati ovo pravilo. Funkcija treba da vrati <code>true</code> ako ga poštuje, odnosno <code>false</code> ako ga ne poštuje.</p>\n</section>","notes":null,"challengeType":1,"helpCategory":"Rosetta","videoUrl":null,"superBlock":"rosetta-code","translationPending":false,"forumTopicId":302288,"hooks":null,"fields":{"slug":"/learn/rosetta-code/rosetta-code-challenges/i-before-e-except-after-c"},"required":[],"usesMultifileEditor":false,"challengeFiles":[{"fileKey":"scriptjs","ext":"js","name":"script","contents":"function IBeforeExceptC(word) {\n\n}","head":null,"tail":null,"editableRegionBoundaries":[],"history":["script.js"]}],"saveSubmissionToDB":null,"tests":[{"text":"<p><code>IBeforeExceptC</code> treba da bude funkcija.</p>","testString":"assert(typeof IBeforeExceptC == 'function');"},{"text":"<p><code>IBeforeExceptC(\"receive\")</code> treba da vrati <code>true</code> ili <code>false</code>.</p>","testString":"assert(typeof IBeforeExceptC('receive') == 'boolean');"},{"text":"<p><code>IBeforeExceptC(\"receive\")</code> inapaswa kurudisha <code>true</code>.</p>","testString":"assert.equal(IBeforeExceptC('receive'), true);"},{"text":"<p><code>IBeforeExceptC(\"science\")</code> inapaswa kurudisha <code>false</code>.</p>","testString":"assert.equal(IBeforeExceptC('science'), false);"},{"text":"<p><code>IBeforeExceptC(\"imperceivable\")</code> inapaswa kurudisha <code>true</code>.</p>","testString":"assert.equal(IBeforeExceptC('imperceivable'), true);"},{"text":"<p><code>IBeforeExceptC(\"inconceivable\")</code> inapaswa kurudisha <code>true</code>.</p>","testString":"assert.equal(IBeforeExceptC('inconceivable'), true);"},{"text":"<p><code>IBeforeExceptC(\"insufficient\")</code> treba vratiti <code>false</code>.</p>","testString":"assert.equal(IBeforeExceptC('insufficient'), false);"},{"text":"<p><code>IBeforeExceptC(\"omniscient\")</code> trebalo bi da vrati <code>false</code>.</p>","testString":"assert.equal(IBeforeExceptC('omniscient'), false);"}]}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/rosetta-code/#rosetta-code-challenges","dashedName":"i-before-e-except-after-c","certification":"rosetta-code","disableLoopProtectTests":true,"disableLoopProtectPreview":false,"superBlock":"rosetta-code","chapter":null,"module":null,"block":"rosetta-code-challenges","isFirstStep":false,"template":null,"required":[],"isLastChallengeInBlock":false,"nextChallengePath":"/learn/rosetta-code/rosetta-code-challenges/iban","prevChallengePath":"/learn/rosetta-code/rosetta-code-challenges/hofstadter-q-sequence","id":"5a23c84252665b21eecc7eb0","saveSubmissionToDB":null},"projectPreview":{"challengeData":{"challengeType":1,"challengeFiles":[{"name":"script","ext":"js","contents":"function ZigZagMatrix(n) {\n  const mtx = [];\n  for (let i = 0; i < n; i++) {\n    mtx[i] = [];\n  }\n\n  let i = 1;\n  let j = 1;\n  for (let e = 0; e < n * n; e++) {\n    mtx[i - 1][j - 1] = e;\n    if ((i + j) % 2 === 0) {\n      // Even stripes\n      if (j < n) j++;\n      else i += 2;\n      if (i > 1) i--;\n    } else {\n      // Odd stripes\n      if (i < n) i++;\n      else j += 2;\n      if (j > 1) j--;\n    }\n  }\n  return mtx;\n}","history":["script.js"],"fileKey":"scriptjs"}]}},"id":"/learn/rosetta-code/rosetta-code-challenges/i-before-e-except-after-c"}},"staticQueryHashes":["3858520367"],"slicesMap":{}}