  "tests": [
    {
      "text": "<p>Vaš kod treba da ima referencu na <code>DOCTYPE</code>.</p>",
      "testString": "assert(code.match(/<!DOCTYPE/gi));"
    },
    {
      "text": "<p>Trebalo bi da uključite razmak nakon reference na <code>DOCTYPE</code>.</p>",
      "testString": "assert(code.match(/<!DOCTYPE\\s+/gi));"
    },
    {
      "text": "<p>Trebalo bi da definišete tip dokumenta kao <code>html</code>.</p>",
      "testString": "assert(code.match(/<!DOCTYPE\\s+html/gi));"
    },
    {
      "text": "<p>Trebalo bi da zatvorite deklaraciju <code>DOCTYPE</code> sa etiketom za zatvaranje <code>></code> nakon tipa.</p>",
      "testString": "assert(code.match(/<!DOCTYPE\\s+html\\s*>/gi));"
    },
    {
      "text": "<p>Tvoj element <code>html</code> treba da ima labelu za otvaranje sa svojstvom elementa <code>lang</code> od <code>en</code>.</p>",
      "testString": "assert(code.match(/<html\\s+lang\\s*=\\s*('|\")en\\1\\s*>/gi));"
    },
    {
      "text": "<p>Element vašeg <code>html</code> treba da ima zatvarajući tag.</p>",
      "testString": "assert(code.match(/<\\/html\\s*>/));"
    },
    {
      "text": "<p>Tvoje saopštenje za <code>DOCTYPE</code> trebalo bi biti na početku tvog HTML.</p>",
      "testString": "assert(__helpers.removeHtmlComments(code).match(/^\\s*<!DOCTYPE\\s+html\\s*>/i));"
    },
    {
      "text": "<p>Trebalo bi da imaš etiketu za otvaranje <code>head</code>.</p>",
      "testString": "assert(code.match(/<head\\s*>/i));"
    },
    {
      "text": "<p>Trebalo bi da ima oznaku za zatvaranje <code>head</code>.</p>",
      "testString": "assert(code.match(/<\\/head\\s*>/i));"
    },
    {
      "text": "<p>Trebalo bi da imaš etiketu za otvaranje <code>body</code>.</p>",
      "testString": "assert(code.match(/<body\\s*>/i));"
    },
    {
      "text": "<p>Trebalo bi da ima oznaku za zatvaranje <code>body</code>.</p>",
      "testString": "assert(code.match(/<\\/body\\s*>/i));"
    },
    {
      "text": "<p>Elementi za <code>head</code> i <code>body</code> bi trebalo da budu sestrinski elementi.</p>",
      "testString": "assert(document.querySelector('head')?.nextElementSibling?.localName === 'body');"
