        "path": "script.js",
        "fileKey": "scriptjs",
        "contents": "function diffArray(arr1, arr2) {\r\n  return arr1\r\n    .filter(item => !arr2.includes(item))\r\n    .concat(arr2.filter(item => !arr1.includes(item)));\r\n}",
        "error": null,
        "seed": "function diffArray(arr1, arr2) {\r\n  return arr1\r\n    .filter(item => !arr2.includes(item))\r\n    .concat(arr2.filter(item => !arr1.includes(item)));\r\n}"
      }
