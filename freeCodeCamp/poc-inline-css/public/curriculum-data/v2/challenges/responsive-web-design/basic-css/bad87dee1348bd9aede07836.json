      "text": "<p>Vas <code>form</code> element treba da ima <code>id</code> <code>cat-photo-form</code>.</p>",
      "testString": "assert.strictEqual(document.querySelector('form').getAttribute('id'), 'cat-photo-form');"
    },
    {
      "text": "<p>Vas <code>form</code> element treba da ima zeleni <code>background-color</code>.</p>",
      "testString": "const catPhotoForm = document.querySelector('#cat-photo-form');\nconst backgroundColor = window.getComputedStyle(catPhotoForm)['background-color'];\nassert.strictEqual(backgroundColor, 'rgb(0, 128, 0)');"
