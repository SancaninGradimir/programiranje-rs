    {
      "text": "<p>Svaki element tvog <code>th</code> mora imati element <code>span</code>.</p>",
      "testString": "const ths = [\n  ...document.querySelectorAll('table')?.[1]?.querySelectorAll('th')\n];\nths?.forEach(th => {\n  assert.lengthOf(th?.children, 1);\n  assert.strictEqual(th?.children?.[0]?.localName, 'span');\n});"
    },
    {
      "text": "<p>Svaki novi element <code>span</code> treba da ima atribut <code>class</code> postavljen na <code>sr-only</code>.</p>",
      "testString": "const ths = [\n  ...document.querySelectorAll('table')?.[1]?.querySelectorAll('th')\n];\nths?.forEach(th => {\n  assert.isTrue(th?.children?.[0]?.classList?.contains('sr-only'));\n});"
    },
    {
      "text": "<p>Tvoj prvi element <code>span</code> treba da sadrži tekst <code>2019</code>.</p>",
      "testString": "const table = document.querySelectorAll('table')?.[1];\nconst th = table.querySelectorAll('th')?.[0];\nassert.strictEqual(th.children?.[0]?.textContent.trim(), '2019');"
    },
    {
      "text": "<p>Tvoj drugi element <code>span</code> treba da sadrži tekst <code>2020</code>.</p>",
      "testString": "const table = document.querySelectorAll('table')?.[1];\nconst th = table.querySelectorAll('th')?.[1];\nassert.strictEqual(th?.children?.[0]?.textContent.trim(), '2020');"
