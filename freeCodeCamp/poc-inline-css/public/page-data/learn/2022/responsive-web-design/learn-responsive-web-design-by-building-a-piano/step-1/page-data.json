{"componentChunkName":"component---src-templates-challenges-classic-show-tsx","path":"/learn/2022/responsive-web-design/learn-responsive-web-design-by-building-a-piano/step-1","result":{"data":{"challengeNode":{"challenge":{"block":"learn-responsive-web-design-by-building-a-piano","demoType":"onLoad","title":"Korak 1","description":"<section id=\"description\">\n<p>Počni sa osnovnim dizajnom HTML. Dodaj deklaraciju <code>DOCTYPE</code> na elemente <code>html</code>, <code>head</code>, <code>body</code>, i <code>title</code>.</p>\n<p>Postavite jezik ove stranice na engleski. Zamenite <code>title</code> sa <code>Piano</code>.</p>\n</section>","id":"612e6afc009b450a437940a1","hasEditableBoundaries":true,"instructions":"","notes":null,"challengeType":0,"helpCategory":"HTML-CSS","videoUrl":null,"superBlock":"2022/responsive-web-design","translationPending":false,"forumTopicId":null,"hooks":null,"fields":{"slug":"/learn/2022/responsive-web-design/learn-responsive-web-design-by-building-a-piano/step-1"},"required":[],"usesMultifileEditor":true,"challengeFiles":[{"fileKey":"indexhtml","ext":"html","name":"index","contents":"","head":null,"tail":null,"editableRegionBoundaries":[0,2],"history":["index.html"]},{"fileKey":"stylescss","ext":"css","name":"styles","contents":"","head":null,"tail":null,"editableRegionBoundaries":[],"history":["styles.css"]}],"saveSubmissionToDB":null,"tests":[{"text":"<p>Vaš kod treba da ima referencu na <code>DOCTYPE</code>.</p>","testString":"assert(code.match(/<!DOCTYPE/gi));"},{"text":"<p>Trebalo bi da uključite razmak nakon reference na <code>DOCTYPE</code>.</p>","testString":"assert(code.match(/<!DOCTYPE\\s+/gi));"},{"text":"<p>Trebalo bi da definišete tip dokumenta kao <code>html</code>.</p>","testString":"assert(code.match(/<!DOCTYPE\\s+html/gi));"},{"text":"<p>Trebalo bi da zatvorite deklaraciju <code>DOCTYPE</code> sa etiketom za zatvaranje <code>></code> nakon tipa.</p>","testString":"assert(code.match(/<!DOCTYPE\\s+html\\s*>/gi));"},{"text":"<p>Tvoj element <code>html</code> treba da ima labelu za otvaranje sa svojstvom elementa <code>lang</code> od <code>en</code>.</p>","testString":"assert(code.match(/<html\\s+lang\\s*=\\s*('|\")en\\1\\s*>/gi));"},{"text":"<p>Element vašeg <code>html</code> treba da ima zatvarajući tag.</p>","testString":"assert(code.match(/<\\/html\\s*>/));"},{"text":"<p>Tvoje saopštenje za <code>DOCTYPE</code> trebalo bi biti na početku tvog HTML.</p>","testString":"assert(__helpers.removeHtmlComments(code).match(/^\\s*<!DOCTYPE\\s+html\\s*>/i));"},{"text":"<p>Trebalo bi da imaš etiketu za otvaranje <code>head</code>.</p>","testString":"assert(code.match(/<head\\s*>/i));"},{"text":"<p>Trebalo bi da ima oznaku za zatvaranje <code>head</code>.</p>","testString":"assert(code.match(/<\\/head\\s*>/i));"},{"text":"<p>Trebalo bi da imaš etiketu za otvaranje <code>body</code>.</p>","testString":"assert(code.match(/<body\\s*>/i));"},{"text":"<p>Trebalo bi da ima oznaku za zatvaranje <code>body</code>.</p>","testString":"assert(code.match(/<\\/body\\s*>/i));"},{"text":"<p>Elementi za <code>head</code> i <code>body</code> bi trebalo da budu sestrinski elementi.</p>","testString":"assert(document.querySelector('head')?.nextElementSibling?.localName === 'body');"},{"text":"<p>Element <code>head</code> treba da bude unutar elementa <code>html</code>.</p>","testString":"assert([...document.querySelector('html')?.children].some(x => x?.localName === 'head'));"},{"text":"<p>Element za <code>body</code> treba da bude unutar elementa <code>html</code>.</p>","testString":"assert([...document.querySelector('html')?.children].some(x => x?.localName === 'body'));"},{"text":"<p>Vaš kod mora imati karakteristiku <code>title</code>.</p>","testString":"const title = document.querySelector('title');\nassert.exists(title);"},{"text":"<p>Vaš projekat treba da ima zaglavlje <code>Piano</code>.</p>","testString":"const title = document.querySelector('title');\nassert.equal(title?.text?.trim()?.toLowerCase(), 'piano')"},{"text":"<p>Zapamtite, velika i mala slova zajedno sa pravopisom su važne za naslov.</p>","testString":"const title = document.querySelector('title');\nassert.equal(title?.text?.trim(), 'Piano');"}]}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/2022/responsive-web-design/#learn-responsive-web-design-by-building-a-piano","dashedName":"step-1","certification":"responsive-web-design","disableLoopProtectTests":false,"disableLoopProtectPreview":false,"superBlock":"2022/responsive-web-design","chapter":null,"module":null,"block":"learn-responsive-web-design-by-building-a-piano","isFirstStep":true,"template":null,"required":[],"isLastChallengeInBlock":false,"nextChallengePath":"/learn/2022/responsive-web-design/learn-responsive-web-design-by-building-a-piano/step-2","prevChallengePath":"/learn/2022/responsive-web-design/learn-intermediate-css-by-building-a-cat-painting/step-82","id":"612e6afc009b450a437940a1","saveSubmissionToDB":null},"projectPreview":{"challengeData":{"challengeType":0,"challengeFiles":[{"name":"index","ext":"html","contents":"<!DOCTYPE html>\n<html lang=\"en\">\n  <head>\n    <meta charset=\"UTF-8\" />\n    <title>Piano</title>\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" />\n    <link rel=\"stylesheet\" href=\"./styles.css\">\n  </head>\n  <body>\n    <div id=\"piano\">\n      <img class=\"logo\" src=\"https://cdn.freecodecamp.org/platform/universal/fcc_primary.svg\" alt=\"freeCodeCamp Logo\" />\n      <div class=\"keys\">\n        <div class=\"key\"></div>\n        <div class=\"key black--key\"></div>\n        <div class=\"key black--key\"></div>\n        <div class=\"key\"></div>\n        <div class=\"key black--key\"></div>\n        <div class=\"key black--key\"></div>\n        <div class=\"key black--key\"></div>\n\n        <div class=\"key\"></div>\n        <div class=\"key black--key\"></div>\n        <div class=\"key black--key\"></div>\n        <div class=\"key\"></div>\n        <div class=\"key black--key\"></div>\n        <div class=\"key black--key\"></div>\n        <div class=\"key black--key\"></div>\n\n        <div class=\"key\"></div>\n        <div class=\"key black--key\"></div>\n        <div class=\"key black--key\"></div>\n        <div class=\"key\"></div>\n        <div class=\"key black--key\"></div>\n        <div class=\"key black--key\"></div>\n        <div class=\"key black--key\"></div>\n      </div>\n    </div>\n  </body>\n</html>","history":["index.html"],"fileKey":"indexhtml"},{"name":"styles","ext":"css","contents":"html {\n  box-sizing: border-box;\n}\n\n*, *::before, *::after {\n  box-sizing: inherit;\n}\n\n#piano {\n  background-color: #00471b;\n  width: 992px;\n  height: 290px;\n  margin: 80px auto;\n  padding: 90px 20px 0 20px;\n  position: relative;\n  border-radius: 10px;\n}\n\n.keys {\n  background-color: #040404;\n  width: 949px;\n  height: 180px;\n  padding-left: 2px;\n  overflow: hidden;\n}\n\n.key {\n  background-color: #ffffff;\n  position: relative;\n  width: 41px;\n  height: 175px;\n  margin: 2px;\n  float: left;\n  border-radius: 0 0 3px 3px;\n}\n\n.key.black--key::after {\n  background-color: #1d1e22;\n  content: \"\";\n  position: absolute;\n  left: -18px;\n  width: 32px;\n  height: 100px;\n  border-radius: 0 0 3px 3px;\n}\n\n.logo {\n  width: 200px;\n  position: absolute;\n  top: 23px;\n}\n\n@media (max-width: 768px) {\n  #piano {\n    width: 358px;\n  }\n\n  .keys {\n    width: 318px;\n  }\n\n  .logo {\n    width: 150px;\n  }\n}\n\n@media (max-width: 1199px) and (min-width: 769px) {\n  #piano {\n    width: 675px;\n  }\n\n  .keys {\n    width: 633px;\n  }\n}","history":["styles.css"],"fileKey":"stylescss"}]}},"id":"/learn/2022/responsive-web-design/learn-responsive-web-design-by-building-a-piano/step-1"}},"staticQueryHashes":["3858520367"],"slicesMap":{}}