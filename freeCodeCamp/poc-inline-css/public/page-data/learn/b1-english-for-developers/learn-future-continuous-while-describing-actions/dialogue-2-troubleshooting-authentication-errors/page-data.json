{"componentChunkName":"component---src-templates-challenges-generic-show-tsx","path":"/learn/b1-english-for-developers/learn-future-continuous-while-describing-actions/dialogue-2-troubleshooting-authentication-errors","result":{"data":{"challengeNode":{"challenge":{"assignments":["<p>Gledaj video.</p>"],"bilibiliIds":null,"block":"learn-future-continuous-while-describing-actions","challengeType":21,"description":"<section id=\"description\">\n<p>Pogledajte video ispod da biste razumeli kontekst sledećih lekcija.</p>\n</section>","nodules":null,"explanation":null,"helpCategory":"English","instructions":"","fields":{"slug":"/learn/b1-english-for-developers/learn-future-continuous-while-describing-actions/dialogue-2-troubleshooting-authentication-errors"},"questions":[],"scene":{"setup":{"background":"company2-center.png","characters":[{"character":"Alice","position":{"x":-25,"y":0,"z":1},"opacity":null},{"character":"Mark","position":{"x":125,"y":0,"z":1},"opacity":null}],"audio":{"filename":"B1_6-2.mp3","startTime":1,"startTimestamp":null,"finishTimestamp":null},"alwaysShowDialogue":true},"commands":[{"background":null,"character":"Alice","position":{"x":25,"y":0,"z":1},"opacity":null,"startTime":0,"finishTime":null,"dialogue":null},{"background":null,"character":"Mark","position":{"x":70,"y":0,"z":1},"opacity":null,"startTime":0.5,"finishTime":null,"dialogue":null},{"background":null,"character":"Alice","position":null,"opacity":null,"startTime":1,"finishTime":4.7,"dialogue":{"text":"Hey, Mark. We've been having some trouble with our user authentication, haven't we?","align":"left"}},{"background":null,"character":"Mark","position":null,"opacity":null,"startTime":5.6,"finishTime":9.16,"dialogue":{"text":"Yes, we have. Some users are complaining that they can't log in.","align":"right"}},{"background":null,"character":"Mark","position":null,"opacity":null,"startTime":9.38,"finishTime":11.02,"dialogue":{"text":"Did you figure out what's causing the problem?","align":"right"}},{"background":null,"character":"Alice","position":null,"opacity":null,"startTime":11.46,"finishTime":13.44,"dialogue":{"text":"I think it's related to our session management.","align":"left"}},{"background":null,"character":"Alice","position":null,"opacity":null,"startTime":13.76,"finishTime":15.9,"dialogue":{"text":"The tokens aren't being refreshed properly, are they?","align":"left"}},{"background":null,"character":"Mark","position":null,"opacity":null,"startTime":16.32,"finishTime":17.62,"dialogue":{"text":"That seems to be the case.","align":"right"}},{"background":null,"character":"Mark","position":null,"opacity":null,"startTime":17.86,"finishTime":21.38,"dialogue":{"text":"The system is supposed to renew tokens every 30 minutes, isn't it?","align":"right"}},{"background":null,"character":"Alice","position":null,"opacity":null,"startTime":21.8,"finishTime":23.82,"dialogue":{"text":"Yes, it should, but something's going wrong.","align":"left"}},{"background":null,"character":"Alice","position":null,"opacity":null,"startTime":24.02,"finishTime":26.36,"dialogue":{"text":"Are you going to check the server logs to find out what happened?","align":"left"}},{"background":null,"character":"Mark","position":null,"opacity":null,"startTime":26.36,"finishTime":31.24,"dialogue":{"text":"I already did. There's nothing unusual in the logs. This is strange, isn't it?","align":"right"}},{"background":null,"character":"Alice","position":null,"opacity":null,"startTime":31.58,"finishTime":34.88,"dialogue":{"text":"It is. Let's run a few more tests to see if we can replicate the issue.","align":"left"}},{"background":null,"character":"Alice","position":null,"opacity":null,"startTime":34.98,"finishTime":36.1,"dialogue":{"text":"Will you help me with that?","align":"left"}},{"background":null,"character":"Mark","position":null,"opacity":null,"startTime":36.64,"finishTime":39.96,"dialogue":{"text":"Sure. We can do some tests on the staging server, can't we?","align":"right"}},{"background":null,"character":"Alice","position":null,"opacity":null,"startTime":40.54,"finishTime":42.86,"dialogue":{"text":"Yes, we can. That should give us more information.","align":"left"}},{"background":null,"character":"Alice","position":null,"opacity":null,"startTime":43.22,"finishTime":46.46,"dialogue":{"text":"By the way, have the support tickets been piling up because of this?","align":"left"}},{"background":null,"character":"Mark","position":null,"opacity":null,"startTime":47.8,"finishTime":51.06,"dialogue":{"text":"Unfortunately, yes. We need to resolve this quickly, don't we?","align":"right"}},{"background":null,"character":"Alice","position":null,"opacity":null,"startTime":51.48,"finishTime":53.86,"dialogue":{"text":"Absolutely. Let's work together to find a solution.","align":"left"}},{"background":null,"character":"Alice","position":null,"opacity":null,"startTime":54.16,"finishTime":56.06,"dialogue":{"text":"We don't want our users getting frustrated, do we?","align":"left"}},{"background":null,"character":"Mark","position":null,"opacity":null,"startTime":56.48,"finishTime":60.22,"dialogue":{"text":"No, we don't. Okay, let's get to work and see if we can sort this out.","align":"right"}},{"background":null,"character":"Mark","position":{"x":125,"y":0,"z":1},"opacity":null,"startTime":60.72,"finishTime":null,"dialogue":null},{"background":null,"character":"Alice","position":{"x":-25,"y":0,"z":1},"opacity":null,"startTime":61.22,"finishTime":null,"dialogue":null}]},"superBlock":"b1-english-for-developers","tests":[],"title":"Dialog 2: Rešavanje problema sa greškama autentifikacije","transcript":null,"translationPending":false,"videoId":null,"videoLocaleIds":null}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/b1-english-for-developers/#learn-future-continuous-while-describing-actions","dashedName":"dialogue-2-troubleshooting-authentication-errors","certification":"b1-english-for-developers","disableLoopProtectTests":false,"disableLoopPr