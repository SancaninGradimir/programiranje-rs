  "tests": [
    {
      "text": "<p><code>animation-iteration-count</code> svojstvo treba da ima vrednost <code>infinite</code>.</p>",
      "testString": "const ballElement = document.querySelector('#ball');\nconst ballStyle = window.getComputedStyle(ballElement); \nassert.equal(ballStyle?.animationIterationCount, 'infinite');"
    }
