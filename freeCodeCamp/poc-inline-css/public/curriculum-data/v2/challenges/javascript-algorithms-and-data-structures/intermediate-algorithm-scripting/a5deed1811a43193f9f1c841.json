      "text": "<p><code>dropElements([1, 2, 3, 4], function(n) {return n >= 3;})</code> trebalo bi vratiti <code>[3, 4]</code>.</p>",
      "testString": "assert.deepEqual(\r\n  dropElements([1, 2, 3, 4], function (n) {\r\n    return n >= 3;\r\n  }),\r\n  [3, 4]\r\n);"
    },
