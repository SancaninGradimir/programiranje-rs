      "text": "<p>Trebalo bi da ima pet komponenti <code>i</code>.</p>",
      "testString": "assert(document.querySelectorAll('i')?.length === 5);"
    },
    {
      "text": "<p>Svaki element <code>a</code> mora imati samo jedan element <code>i</code>.</p>",
      "testString": "const aaaaa = [...document.querySelectorAll('.social-icons a')];\r\nassert(aaaaa?.every(a => a?.children?.length === 1 && a?.children?.[0]?.localName === 'i'));"
    },
    {
      "text": "<p>Svaki element <code>i</code> mora imati atribut elementa <code>class</code> koji uključuje <code>fab</code>.</p>",
      "testString": "const iiiii = [...document.querySelectorAll('i')];\r\nassert(iiiii?.every(i => i?.classList?.contains('fab')));"
    },
    {
      "text": "<p>Prvi element <code>i</code> treba da ima svojstvo elementa <code>class</code> koje uključuje <code>fa-facebook-f</code>.</p>",
      "testString": "assert(document.querySelectorAll('i')?.[0]?.classList?.contains('fa-facebook-f'));"
    },
    {
      "text": "<p>Drugi element od <code>i</code> treba da ima svojstvo polja/elementa <code>class</code> koje uključuje <code>fa-twitter</code>.</p>",
      "testString": "assert(document.querySelectorAll('i')?.[1]?.classList?.contains('fa-twitter'));"
    },
    {
      "text": "<p>Treće polje <code>i</code> treba da ima svojstvo polja <code>class</code> koje uključuje <code>fa-instagram</code>.</p>",
      "testString": "assert(document.querySelectorAll('i')?.[2]?.classList?.contains('fa-instagram'));"
