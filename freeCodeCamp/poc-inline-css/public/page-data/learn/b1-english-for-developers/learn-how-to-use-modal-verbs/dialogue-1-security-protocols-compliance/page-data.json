{"componentChunkName":"component---src-templates-challenges-generic-show-tsx","path":"/learn/b1-english-for-developers/learn-how-to-use-modal-verbs/dialogue-1-security-protocols-compliance","result":{"data":{"challengeNode":{"challenge":{"assignments":["<p>Gledaj video.</p>"],"bilibiliIds":null,"block":"learn-how-to-use-modal-verbs","challengeType":21,"description":"<section id=\"description\">\n<p>Pogledajte video dole/ispod kako biste razumeli kontekst predstojećih lekcija.</p>\n</section>","nodules":null,"explanation":null,"helpCategory":"English","instructions":"","fields":{"slug":"/learn/b1-english-for-developers/learn-how-to-use-modal-verbs/dialogue-1-security-protocols-compliance"},"questions":[],"scene":{"setup":{"background":"company2-center.png","characters":[{"character":"Jessica","position":{"x":-25,"y":0,"z":1},"opacity":null},{"character":"Mark","position":{"x":125,"y":0,"z":1},"opacity":null}],"audio":{"filename":"B1_14-1.mp3","startTime":1,"startTimestamp":null,"finishTimestamp":null},"alwaysShowDialogue":true},"commands":[{"background":null,"character":"Jessica","position":{"x":25,"y":0,"z":1},"opacity":null,"startTime":0,"finishTime":null,"dialogue":null},{"background":null,"character":"Mark","position":{"x":70,"y":0,"z":1},"opacity":null,"startTime":0.5,"finishTime":null,"dialogue":null},{"background":null,"character":"Jessica","position":null,"opacity":null,"startTime":1,"finishTime":4.74,"dialogue":{"text":"Hi, Mark. We need to talk about security protocols for the new project.","align":"left"}},{"background":null,"character":"Jessica","position":null,"opacity":null,"startTime":5.22,"finishTime":7.62,"dialogue":{"text":"There are a few things you must do to ensure compliance.","align":"left"}},{"background":null,"character":"Mark","position":null,"opacity":null,"startTime":8,"finishTime":10.08,"dialogue":{"text":"Sure, Jessica. What do I need to do?","align":"right"}},{"background":null,"character":"Jessica","position":null,"opacity":null,"startTime":10.68,"finishTime":15.84,"dialogue":{"text":"First, you must update your software tools to the latest versions. This is crucial for maintaining security.","align":"left"}},{"background":null,"character":"Mark","position":null,"opacity":null,"startTime":15.84,"finishTime":19.74,"dialogue":{"text":"Okay, I can do that. Is there anything else I need to be aware of?","align":"right"}},{"background":null,"character":"Jessica","position":null,"opacity":null,"startTime":20.52,"finishTime":25.84,"dialogue":{"text":"Yes, you have to set up multi factor authentication for all user accounts. It's mandatory for this project.","align":"left"}},{"background":null,"character":"Mark","position":null,"opacity":null,"startTime":26.12,"finishTime":29.22,"dialogue":{"text":"Got it. Does that apply to the development team as well?","align":"right"}},{"background":null,"character":"Jessica","position":null,"opacity":null,"startTime":29.86,"finishTime":35.74,"dialogue":{"text":"Yes, everyone must use multi factor authentication, including QA. It's a non negotiable requirement.","align":"left"}},{"background":null,"character":"Mark","position":null,"opacity":null,"startTime":36.18,"finishTime":42.9,"dialogue":{"text":"Understood. I'll make sure to update the team. By the way, do we have to follow any specific guidelines for data encryption?","align":"right"}},{"background":null,"character":"Jessica","position":null,"opacity":null,"startTime":43.82,"finishTime":49.24,"dialogue":{"text":"Yes, all sensitive data must be encrypted, and you have to ensure that the encryption keys are stored securely.","align":"left"}},{"background":null,"character":"Jessica","position":null,"opacity":null,"startTime":49.58,"finishTime":52.18,"dialogue":{"text":"This is essential for preventing data breaches.","align":"left"}},{"background":null,"character":"Mark","position":null,"opacity":null,"startTime":52.42,"finishTime":56.54,"dialogue":{"text":"Okay, thanks for letting me know. I'll handle it. Is there anything else I need to do?","align":"right"}},{"background":null,"character":"Jessica","position":null,"opacity":null,"startTime":57.1,"finishTime":59.66,"dialogue":{"text":"Besides that, you should run regular security audits.","align":"left"}},{"background":null,"character":"Jessica","position":null,"opacity":null,"startTime":59.88,"finishTime":63.24,"dialogue":{"text":"It's not mandatory, but it's a good idea to catch vulnerabilities early.","align":"left"}},{"background":null,"character":"Mark","position":null,"opacity":null,"startTime":63.24,"finishTime":66.9,"dialogue":{"text":"Sounds like a plan. I'll start with the updates and set up the authentication.","align":"right"}},{"background":null,"character":"Mark","position":null,"opacity":null,"startTime":67.32,"finishTime":68.58,"dialogue":{"text":"Thanks for the guidance, Jessica.","align":"right"}},{"background":null,"character":"Jessica","position":null,"opacity":null,"startTime":69.34,"finishTime":72.4,"dialogue":{"text":"No problem, Mark. Let me know if you need any help or have more questions.","align":"left"}},{"background":null,"character":"Mark","position":{"x":125,"y":0,"z":1},"opacity":null,"startTime":72.9,"finishTime":null,"dialogue":null},{"background":null,"character":"Jessica","position":{"x":-25,"y":0,"z":1},"opacity":null,"startTime":73.4,"finishTime":null,"dialogue":null}]},"superBlock":"b1-english-for-developers","tests":[],"title":"Dijalog 1: Usklađenost sa sigurnosnim protokolima","transcript":null,"translationPending":false,"videoId":null,"videoLocaleIds":null}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/b1-english-for-developers/#learn-how-to-use-modal-verbs","dashedName":"dialogue-1-security-protocols-compliance","certification":"b1-english-for-developers","disableLoopProtectTests":false,"disableLoopProtectPreview":false,"superBlock":"b1-english-for-developers","chapter":null,"module":null,"block":"learn-how-to-use-modal-verbs","isFirstStep":true,"template":null,"requi