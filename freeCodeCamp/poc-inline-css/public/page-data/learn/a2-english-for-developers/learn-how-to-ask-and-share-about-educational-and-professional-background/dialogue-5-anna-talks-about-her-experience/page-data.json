ech companies appreciate innovation and care for the employees' well-being.","align":"right"}},{"background":null,"character":"Anna","position":null,"opacity":null,"startTime":38.9,"finishTime":42,"dialogue":{"text":"This is directly related to what made me want to become a psychologist.","align":"right"}},{"background":null,"character":"Anna","position":null,"opacity":null,"startTime":42.5,"finishTime":44.2,"dialogue":{"text":"So basically, that's what brought me here.","align":"right"}},{"background":null,"character":"Tom","position":null,"opacity":null,"startTime":44.8,"finishTime":47.4,"dialogue":{"text":"Awesome. It was great to get to know you better.","align":"left"}},{"background":null,"character":"Anna","position":{"x":125,"y":0,"z":1},"opacity":null,"startTime":47.9,"finishTime":null,"dialogue":null},{"background":null,"character":"Tom","position":{"x":-25,"y":0,"z":1},"opacity":null,"startTime":48.4,"finishTime":null,"dialogue":null}]},"superBlock":"a2-english-for-developers","tests":[],"title":"Dialog 5: Anna priča o svom iskustvu","transcript":null,"translationPending":false,"videoId":null,"videoLocaleIds":null}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/a2-english-for-developers/#learn-how-to-ask-and-share-about-educational-and-professional-background","dashedName":"dialogue-5-anna-talks-about-her-experience","certification":"a2-english-for-developers","disableLoopProtectTests":false,"disableLoopProtectPreview":false,"superBlock":"a2-english-for-developers","chapter":null,"module":null,"block":"learn-how-to-ask-and-share-about-educational-and-professional-background","isFirstStep":false,"template":null,"required":[],"isLastChallengeInBlock":false,"nextChallengePath":"/learn/a2-english-for-developers/learn-how-to-ask-and-share-about-educational-and-professional-background/task-83","prevChallengePath":"/learn/a2-english-for-developers/learn-how-to-ask-and-share-about-educational-and-professional-background/task-82","id":"657b2dd7745fdcd03e