{"componentChunkName":"component---src-templates-challenges-classic-show-tsx","path":"/learn/javascript-algorithms-and-data-structures-v8/learn-introductory-javascript-by-building-a-pyramid-generator/step-29","result":{"data":{"challengeNode":{"challenge":{"block":"learn-introductory-javascript-by-building-a-pyramid-generator","demoType":null,"title":"Korak 29","description":"<section id=\"description\">\n<p>Da li ste očekivali da vidite <code>4</code> na konzoli? <code>.push()</code> obnavlja novu dužinu niza podataka, nakon dodavanja vrednosti koju unosite.</p>\n<p>Važno je razumeti koju vrednost metoda vraća. Odvojite vreme da testirate <code>.push()</code> i <code>.pop()</code>. Kada budete spremni, uklonite sve pozive ka <code>.push()</code> i <code>.pop()</code>, zajedno sa vašim podacima o <code>console.log</code>.</p>\n</section>","id":"660f0ee51d7460ce88cd248d","hasEditableBoundaries":true,"instructions":"","notes":null,"challengeType":1,"helpCategory":"JavaScript","videoUrl":null,"superBlock":"javascript-algorithms-and-data-structures-v8","translationPending":false,"forumTopicId":null,"hooks":null,"fields":{"slug":"/learn/javascript-algorithms-and-data-structures-v8/learn-introductory-javascript-by-building-a-pyramid-generator/step-29"},"required":[],"usesMultifileEditor":true,"challengeFiles":[{"fileKey":"scriptjs","ext":"js","name":"script","contents":"let character = 'Hello';\nlet count = 8;\nlet rows = [\"Naomi\", \"Quincy\", \"CamperChan\"];\nlet pushed = rows.push(\"freeCodeCamp\");\nconsole.log(pushed);\nlet popped = rows.pop();\nconsole.log(popped);\nconsole.log(rows);","head":null,"tail":null,"editableRegionBoundaries":[3,9],"history":["script.js"]}],"saveSubmissionToDB":null,"tests":[{"text":"<p>Ne bi trebalo da imaš poziv za <code>.push()</code>.</p>","testString":"assert.notMatch(__helpers.removeJSComments(code), /\\.push\\(/);"},{"text":"<p>Nema poziva za <code>.pop()</code>.</p>","testString":"assert.notMatch(__helpers.removeJSComments(code), /\\.pop\\(/);"},{"text":"<p>Nema informacija o log fajlovima.</p>","testString":"assert.notMatch(__helpers.removeJSComments(code), /console\\.log/);"},{"text":"<p>Ne smeš da imaš parametar <code>popped</code>.</p>","testString":"assert.notMatch(__helpers.removeJSComments(code), /popped/);"},{"text":"<p>Ne sme da ima parametar od <code>pushed</code>.</p>","testString":"assert.notMatch(__helpers.removeJSComments(code), /pushed/);"}]}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/javascript-algorithms-and-data-structures-v8/#learn-introductory-javascript-by-building-a-pyramid-generator","dashedName":"step-29","certification":"javascript-algorithms-and-data-structures-v8","disableLoopProtectTests":false,"disableLoopProtectPreview":false,"superBlock":"javascript-algorithms-and-data-structures-v8","chapter":null,"module":null,"block":"learn-introductory-javascript-by-building-a-pyramid-generator","isFirstStep":false,"template":null,"required":[],"isLastChallengeInBlock":false,"nextChallengePath":"/learn/javascript-algorithms-and-data-structures-v8/learn-introductory-javascript-by-building-a-pyramid-generator/step-30","prevChallengePath":"/learn/javascript-algorithms-and-data-structures-v8/learn-introductory-javascript-by-building-a-pyramid-generator/step-28","id":"660f0ee51d7460ce88cd248d","saveSubmissionToDB":null},"projectPreview":{"challengeData":{"challengeType":1,"challengeFiles":[{"name":"script","ext":"js","contents":"const character = \"!\";\nconst count = 10;\nconst rows = [];\nlet inverted = false;\n\nfunction padRow(rowNumber, rowCount) {\n  return \" \".repeat(rowCount - rowNumber) + character.repeat(2 * rowNumber - 1) + \" \".repeat(rowCount - rowNumber);\n}\n\nfor (let i = 1; i <= count; i++) {\n  if (inverted) {\n    rows.unshift(padRow(i, count));\n  } else {\n    rows.push(padRow(i, count));\n  }\n}\n\nlet result = \"\"\n\nfor (const row of rows) {\n  result = result + row + \"\\n\";\n}\n\nconsole.log(result);","history":["script.js"],"fileKey":"scriptjs"}]}},"id":"/learn/javascript-algorithms-and-data-structures-v8/learn-introductory-javascript-by-building-a-pyramid-generator/step-29"}},"staticQueryHashes":["3858520367"],"slicesMap":{}}