{"componentChunkName":"component---src-templates-challenges-generic-show-tsx","path":"/learn/b1-english-for-developers/learn-how-to-use-reported-speech/dialogue-2-website-redesign-feedback","result":{"data":{"challengeNode":{"challenge":{"assignments":["<p>Gledaj video.</p>"],"bilibiliIds":null,"block":"learn-how-to-use-reported-speech","challengeType":21,"description":"<section id=\"description\">\n<p>Pogledajte video dole/ispod kako biste razumeli kontekst predstojećih lekcija.</p>\n</section>","nodules":null,"explanation":null,"helpCategory":"English","instructions":"","fields":{"slug":"/learn/b1-english-for-developers/learn-how-to-use-reported-speech/dialogue-2-website-redesign-feedback"},"questions":[],"scene":{"setup":{"background":"company2-center.png","characters":[{"character":"Linda","position":{"x":-25,"y":0,"z":1},"opacity":null},{"character":"Tom","position":{"x":125,"y":0,"z":1},"opacity":null}],"audio":{"filename":"B1_21-2.mp3","startTime":1,"startTimestamp":null,"finishTimestamp":null},"alwaysShowDialogue":true},"commands":[{"background":null,"character":"Linda","position":{"x":25,"y":0,"z":1},"opacity":null,"startTime":0,"finishTime":null,"dialogue":null},{"background":null,"character":"Tom","position":{"x":70,"y":0,"z":1},"opacity":null,"startTime":0.5,"finishTime":null,"dialogue":null},{"background":null,"character":"Linda","position":null,"opacity":null,"startTime":1,"finishTime":5.74,"dialogue":{"text":"Hey, Tom. I've compiled the user feedback on our latest website redesign. It was quite insightful.","align":"left"}},{"background":null,"character":"Tom","position":null,"opacity":null,"startTime":6.2,"finishTime":8.18,"dialogue":{"text":"Awesome. What were some of the major points?","align":"right"}},{"background":null,"character":"Linda","position":null,"opacity":null,"startTime":8.64,"finishTime":13.68,"dialogue":{"text":"Well, the new navigation menu was really appreciated. It was mentioned that it's much easier to use.","align":"left"}},{"background":null,"character":"Linda","position":null,"opacity":null,"startTime":14.06,"finishTime":17.94,"dialogue":{"text":"Several users noted how the simplified layout helped them find information faster.","align":"left"}},{"background":null,"character":"Tom","position":null,"opacity":null,"startTime":18.44,"finishTime":21.44,"dialogue":{"text":"That's good to hear. Was there anything that didn't go over well?","align":"right"}},{"background":null,"character":"Linda","position":null,"opacity":null,"startTime":22.28,"finishTime":27.68,"dialogue":{"text":"Yes, the color scheme was brought up a few times. It seems it was found to be a bit overwhelming by some users.","align":"left"}},{"background":null,"character":"Linda","position":null,"opacity":null,"startTime":27.9,"finishTime":29.86,"dialogue":{"text":"They suggested it could be toned down a bit.","align":"left"}},{"background":null,"character":"Tom","position":null,"opacity":null,"startTime":29.86,"finishTime":35.58,"dialogue":{"text":"Interesting. We could look at softer colors then. Were the changes in the contact page noticed?","align":"right"}},{"background":null,"character":"Linda","position":null,"opacity":null,"startTime":36.02,"finishTime":42.56,"dialogue":{"text":"They were. The new form was described as very user friendly, and the additional contact options were highlighted as a great improvement.","align":"left"}},{"background":null,"character":"Linda","position":null,"opacity":null,"startTime":42.96,"finishTime":45.08,"dialogue":{"text":"The faster response times were also acknowledged.","align":"left"}},{"background":null,"character":"Tom","position":null,"opacity":null,"startTime":45.76,"finishTime":49.2,"dialogue":{"text":"That's excellent. How about the images and graphics we updated?","align":"right"}},{"background":null,"character":"Linda","position":null,"opacity":null,"startTime":49.66,"finishTime":57.46,"dialogue":{"text":"The new images were well received, but the size of some images was mentioned as being too large, which apparently slowed down the page loading for some users.","align":"left"}},{"background":null,"character":"Tom","position":null,"opacity":null,"startTime":57.78,"finishTime":63.86,"dialogue":{"text":"Okay, we need to optimize those images then. Let's prepare a list of modifications based on this feedback.","align":"right"}},{"background":null,"character":"Tom","position":null,"opacity":null,"startTime":64.16,"finishTime":68.26,"dialogue":{"text":"We should prioritize the color scheme and image sizes for the next update.","align":"right"}},{"background":null,"character":"Tom","position":{"x":125,"y":0,"z":1},"opacity":null,"startTime":68.76,"finishTime":null,"dialogue":null},{"background":null,"character":"Linda","position":{"x":-25,"y":0,"z":1},"opacity":null,"startTime":69.26,"finishTime":null,"dialogue":null}]},"superBlock":"b1-english-for-developers","tests":[],"title":"Dijalog 2: Povratne informacije o redizajnu veb-sajta","transcript":null,"translationPending":false,"videoId":null,"videoLocaleIds":null}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/b1-english-for-developers/#learn-how-to-use-reported-speech","dashedName":"dialogue-2-website-redesign-feedback","certification":"b1-english-for-developers","disableLoopProtectTests":false,"disableLoopProtectPreview":false,"superBlock":"b1-english-for-developers","chapter":null,"module":null,"block":"learn-how-to-use-reported-speech","isFirstStep":false,"template":null,"required":[],"isLastChallengeInBlock":false,"nextChallengePath":"/learn/b1-english-for-developers/learn-how-to-use-reported-speech/task-50","prevChallengePath":"/learn/b1-english-for-developers/learn-how-to-use-reported-speech/task-49","id":"682f53b846cb3b122ad85e34","saveSubmissionToDB":null},"projectPreview":{"challengeData":{"challengeType":19,"challengeFiles":[]}},"id":"/learn/b1-english-for-developers/learn-how-to-use-reported-speech/dialogue-2-website-redesign-feedback"}},"staticQueryHashes":["3858520