et3</button>\r\n      </div>\r\n    </div>\r\n    <div class=\"col-xs-6\">\r\n      <h4>#right-well</h4>\r\n      <div class=\"well\" id=\"right-well\">\r\n        <button class=\"btn btn-default target\" id=\"target4\">#target4</button>\r\n        <button class=\"btn btn-default target\" id=\"target5\">#target5</button>\r\n        <button class=\"btn btn-default target\" id=\"target6\">#target6</button>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</div>","history":["index.html"],"fileKey":"indexhtml"}]}},"id":"/learn/front-end-development-libraries/jquery/target-elements-by-id-using-jquery"}},"staticQueryHashes":["3858520367"],"slicesMap":{}}