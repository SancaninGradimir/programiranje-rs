{"componentChunkName":"component---src-templates-challenges-classic-show-tsx","path":"/learn/javascript-algorithms-and-data-structures/basic-javascript/shopping-list","result":{"data":{"challengeNode":{"challenge":{"block":"basic-javascript","demoType":null,"title":"Lista Za Kupovinu","description":"<section id=\"description\">\n<p>Napravite listu za kupovinu u promenljivoj <code>myList</code>. Lista treba da bude visedimenzionalni niz koji sadrzi vise podnizova.</p>\n<p>Prvi element svakog podniza treba da bude string koji predstavlja naziv proizvoda. Drugi element treba da bude broj koji predstavlja kolicinu, na primer</p>\n<pre><code class=\"language-js\">[\"Chocolate Bar\", 15]\n</code></pre>\n<p>Lista treba da sadrzi najmanje 5 podnizova.</p>\n</section>","id":"56533eb9ac21ba0edf2244bc","hasEditableBoundaries":false,"instructions":"","notes":null,"challengeType":1,"helpCategory":"JavaScript","videoUrl":null,"superBlock":"javascript-algorithms-and-data-structures","translationPending":false,"forumTopicId":18280,"hooks":null,"fields":{"slug":"/learn/javascript-algorithms-and-data-structures/basic-javascript/shopping-list"},"required":[],"usesMultifileEditor":false,"challengeFiles":[{"fileKey":"scriptjs","ext":"js","name":"script","contents":"const myList = [];","head":null,"tail":null,"editableRegionBoundaries":[],"history":["script.js"]}],"saveSubmissionToDB":null,"tests":[{"text":"<p><code>myList</code> treba da bude niz.</p>","testString":"assert(Array.isArray(myList));"},{"text":"<p>Prvi elementi u svakom podnizu treba da budu stringovi.</p>","testString":"assert(myList.every(elem => elem && typeof elem[0] === 'string'));"},{"text":"<p>Drugi elementi u svakom podnizu treba da budu brojevi.</p>","testString":"assert(myList.every(elem => elem && typeof elem[1] === 'number'));"},{"text":"<p>Treba da imate najmanje 5 stavki na listi.</p>","testString":"assert(myList.length > 4);"}]}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/javascript-algorithms-and-data-structures/#basic-javascript","dashedName":"shopping-list","certification":"javascript-algorithms-and-data-structures","disableLoopProtectTests":false,"disableLoopProtectPreview":false,"superBlock":"javascript-algorithms-and-data-structures","chapter":null,"module":null,"block":"basic-javascript","isFirstStep":false,"template":null,"required":[],"isLastChallengeInBlock":false,"nextChallengePath":"/learn/javascript-algorithms-and-data-structures/basic-javascript/write-reusable-javascript-with-functions","prevChallengePath":"/learn/javascript-algorithms-and-data-structures/basic-javascript/manipulate-arrays-with-unshift","id":"56533eb9ac21ba0edf2244bc","saveSubmissionToDB":null},"projectPreview":{"challengeData":{"challengeType":1,"challengeFiles":[{"name":"script","ext":"js","contents":"function rangeOfNumbers(startNum, endNum) {\n  if (endNum - startNum === 0) {\n    return [startNum];\n  } else {\n    const numbers = rangeOfNumbers(startNum, endNum - 1);\n    numbers.push(endNum);\n    return numbers;\n  }\n}","history":["script.js"],"fileKey":"scriptjs"}]}},"id":"/learn/javascript-algorithms-and-data-structures/basic-javascript/shopping-list"}},"staticQueryHashes":["3858520367"],"slicesMap":{}}