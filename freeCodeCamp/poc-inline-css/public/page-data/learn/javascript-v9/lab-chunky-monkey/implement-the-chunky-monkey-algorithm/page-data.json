{"componentChunkName":"component---src-templates-challenges-classic-show-tsx","path":"/learn/javascript-v9/lab-chunky-monkey/implement-the-chunky-monkey-algorithm","result":{"data":{"challengeNode":{"challenge":{"block":"lab-chunky-monkey","demoType":null,"title":"Tekeleza algoritam za Chunky Monkey","description":"<section id=\"description\">\n<p><strong>Cilj:</strong> Popunite korisničke priče ispod i prođite sve testove kako biste završili laboratoriju.</p>\n<p><strong>Priče korisnika:</strong></p>\n<ol>\n<li>Napišite funkciju pod nazivom <code>chunkArrayInGroups</code> koja prima niz podataka kao prvi argument i broj kao drugi argument. Funkcija treba da podeli niz podataka na manje nizove čija je dužina jednaka drugom argumentu i da vrati te manje nizove kao dvodimenzionalni niz podataka.</li>\n</ol>\n</section>","id":"a9bd25c716030ec90084d8a1","hasEditableBoundaries":false,"instructions":"","notes":null,"challengeType":26,"helpCategory":"JavaScript","videoUrl":null,"superBlock":"javascript-v9","translationPending":false,"forumTopicId":null,"hooks":null,"fields":{"slug":"/learn/javascript-v9/lab-chunky-monkey/implement-the-chunky-monkey-algorithm"},"required":[],"usesMultifileEditor":true,"challengeFiles":[{"fileKey":"scriptjs","ext":"js","name":"script","contents":"","head":null,"tail":null,"editableRegionBoundaries":[],"history":["script.js"]}],"saveSubmissionToDB":null,"tests":[{"text":"<p><code>chunkArrayInGroups([\"a\", \"b\", \"c\", \"d\"], 2)</code> treba da vrati <code>[[\"a\", \"b\"], [\"c\", \"d\"]]</code>.</p>","testString":"assert.deepEqual(chunkArrayInGroups(['a', 'b', 'c', 'd'], 2), [\r\n  ['a', 'b'],\r\n  ['c', 'd']\r\n]);"},{"text":"<p><code>chunkArrayInGroups([0, 1, 2, 3, 4, 5], 3)</code> treba vratiti <code>[[0, 1, 2], [3, 4, 5]]</code>.</p>","testString":"assert.deepEqual(chunkArrayInGroups([0, 1, 2, 3, 4, 5], 3), [\r\n  [0, 1, 2],\r\n  [3, 4, 5]\r\n]);"},{"text":"<p><code>chunkArrayInGroups([0, 1, 2, 3, 4, 5], 2)</code> treba da vrati <code>[[0, 1], [2, 3], [4, 5]]</code>.</p>","testString":"assert.deepEqual(chunkArrayInGroups([0, 1, 2, 3, 4, 5], 2), [\r\n  [0, 1],\r\n  [2, 3],\r\n  [4, 5]\r\n]);"},{"text":"<p><code>chunkArrayInGroups([0, 1, 2, 3, 4, 5], 4)</code> trebalo bi vratiti <code>[[0, 1, 2, 3], [4, 5]]</code>.</p>","testString":"assert.deepEqual(chunkArrayInGroups([0, 1, 2, 3, 4, 5], 4), [\r\n  [0, 1, 2, 3],\r\n  [4, 5]\r\n]);"},{"text":"<p><code>chunkArrayInGroups([0, 1, 2, 3, 4, 5, 6], 3)</code> treba da vrati <code>[[0, 1, 2], [3, 4, 5], [6]]</code>.</p>","testString":"assert.deepEqual(chunkArrayInGroups([0, 1, 2, 3, 4, 5, 6], 3), [\r\n  [0, 1, 2],\r\n  [3, 4, 5],\r\n  [6]\r\n]);"},{"text":"<p><code>chunkArrayInGroups([0, 1, 2, 3, 4, 5, 6, 7, 8], 4)</code> treba vratiti <code>[[0, 1, 2, 3], [4, 5, 6, 7], [8]]</code>.</p>","testString":"assert.deepEqual(chunkArrayInGroups([0, 1, 2, 3, 4, 5, 6, 7, 8], 4), [\r\n  [0, 1, 2, 3],\r\n  [4, 5, 6, 7],\r\n  [8]\r\n]);"},{"text":"<p><code>chunkArrayInGroups([0, 1, 2, 3, 4, 5, 6, 7, 8], 2)</code> treba vratiti <code>[[0, 1], [2, 3], [4, 5], [6, 7], [8]]</code>.</p>","testString":"assert.deepEqual(chunkArrayInGroups([0, 1, 2, 3, 4, 5, 6, 7, 8], 2), [\r\n  [0, 1],\r\n  [2, 3],\r\n  [4, 5],\r\n  [6, 7],\r\n  [8]\r\n]);"}]}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/javascript-v9/#lab-chunky-monkey","dashedName":"implement-the-chunky-monkey-algorithm","certification":"javascript-v9","disableLoopProtectTests":false,"disableLoopProtectPreview":false,"superBlock":"javascript-v9","chapter":"javascript","module":"javascript-loops","block":"lab-chunky-monkey","isFirstStep":true,"template":null,"required":[],"isLastChallengeInBlock":true,"nextChallengePath":"/learn/javascript-v9/lab-profile-lookup/lab-profile-lookup","prevChallengePath":"/learn/javascript-v9/lab-mutations/implement-the-mutations-algorithm","id":"a9bd25c716030ec90084d8a1","saveSubmissionToDB":null},"projectPreview":{"challengeData":{"challengeType":26,"challengeFiles":[{"name":"script","ext":"js","contents":"function chunkArrayInGroups(arr, size) {\r\n  let out = [];\r\n\r\n  for (let i = 0; i < arr.length; i += size) {\r\n    out.push(arr.slice(i, i + size));\r\n  }\r\n\r\n  return out;\r\n}\r\n\r\nchunkArrayInGroups(['a', 'b', 'c', 'd'], 2);","history":["script.js"],"fileKey":"scriptjs"}]}},"id":"/learn/javascript-v9/lab-chunky-monkey/implement-the-chunky-monkey-algorithm"}},"staticQueryHashes":["3858520367"],"slicesMap":{}}