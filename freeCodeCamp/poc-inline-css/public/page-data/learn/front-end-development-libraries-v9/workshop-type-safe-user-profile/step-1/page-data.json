ode> mora imati svojstvo od <code>age</code>.</p>","testString":"assert.property(profile, \"age\");"},{"text":"<p>Tvoja vrednost <code>age</code> bi trebalo da bude <code>25</code>.</p>","testString":"assert.propertyVal(profile, \"age\", 25);"},{"text":"<p>Vaš predmet sa <code>profile</code> mora imati svojstvo <code>isLoggedIn</code>.</p>","testString":"assert.property(profile, \"isLoggedIn\");"},{"text":"<p>Tvoja vrednost za <code>isLoggedIn</code> bi trebalo da bude <code>false</code>.</p>","testString":"assert.propertyVal(profile, \"isLoggedIn\", false);"}]}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/front-end-development-libraries-v9/#workshop-type-safe-user-profile","dashedName":"step-1","certification":"front-end-development-libraries-v9","disableLoopProtectTests":false,"disableLoopProtectPreview":false,"superBlock":"front-end-development-libraries-v9","chapter":"front-end-development-libraries","module":"typescript-fundamentals","block":"workshop-type-safe-user-profile","isFirstStep":true,"template":null,"required":[],"isLastChallengeInBlock":false,"nextChallengePath":"/learn/front-end-development-libraries-v9/workshop-type-safe-user-profile/step-2","prevChallengePath":"/learn/front-end-development-libraries-v9/lecture-introduction-to-typescript/how-do-function-types-work","id":"699b4e284291adcfcb90df47","saveSubmissionToDB":null},"projectPreview":{"challengeData":{"challengeType":1,"challengeFiles":[{"name":"index","ext":"ts","contents":"const profile: {\n  username: string;\n  age: number;\n  isLoggedIn: boolean;\n  bio?: string;\n  programmingLanguages: string[];\n} = {\n  username: \"codeLearner\",\n  age: 25,\n  isLoggedIn: false,\n  programmingLanguages: [\"JavaScript\", \"Python\", \"C++\"]\n};\n\nconsole.log(profile);\n\nconst userRoles: Record<string, string> = {\n  admin: \"full-access\",\n  editor: \"limited-access\",\n  viewer: \"read-only\",\n  moderator: \"medium-access\",\n  guest: \"read-only\"\n};\n\nconsole.log(userRoles);","