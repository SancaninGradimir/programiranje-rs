      "text": "<p>Treba da imate uredjenu listu za <code>Top 3 things cats hate:</code></p>",
      "testString": "const previousElement = document.querySelector('ol').previousElementSibling; \nassert.match(previousElement.textContent,/Top 3 things cats hate:/i);"
    },
    {
      "text": "<p>Treba da imate neuredjenu listu za <code>Things cats love:</code></p>",
      "testString": "const previousElement = document.querySelector('ul').previousElementSibling; \nassert.match(previousElement.textContent,/Things cats love:/i);"
    },
    {
      "text": "<p>Treba da imate samo jedan <code>ul</code> element.</p>",
      "testString": "assert.lengthOf(document.querySelectorAll('ul'), 1);"
    },
    {
      "text": "<p>Treba da imate samo jedan <code>ol</code> element.</p>",
      "testString": "assert.lengthOf(document.querySelectorAll('ol'), 1);"
    },
    {
      "text": "<p>Treba da imate tri <code>li</code> elementa unutar vaseg <code>ul</code> elementa.</p>",
      "testString": "assert.lengthOf(document.querySelectorAll('ul li'), 3);"
    },
    {
      "text": "<p>Treba da imate tri <code>li</code> elementa unutar vaseg <code>ol</code> elementa.</p>",
      "testString": "assert.lengthOf(document.querySelectorAll('ol li'), 3);"
    },
    {
      "text": "<p>Vas <code>ul</code> element treba da ima zatvarajuci tag.</p>",
      "testString": "assert.match(code,/<\\/ul>/g);\nassert.strictEqual(code.match(/<\\/ul>/g).length ,code.match(/<ul>/g).length);"
