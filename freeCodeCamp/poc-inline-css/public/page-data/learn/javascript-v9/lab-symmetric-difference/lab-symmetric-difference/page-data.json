ter(item => !arr2.includes(item))\r\n    .concat(arr2.filter(item => !arr1.includes(item)));\r\n}","history":["script.js"],"fileKey":"scriptjs"}]}},"id":"/learn/javascript-v9/lab-symmetric-difference/lab-symmetric-difference"}},"staticQueryHashes":["3858520367"],"slicesMap":{}}