    {
      "text": "<p>Trebalo bi da imate element <code>td</code> sa tekstom <code>Davis</code> unutar elementa <code>tr</code>.</p>",
      "testString": "assert.strictEqual(document.querySelector('tbody tr td')?.textContent.trim(), 'Davis');"
