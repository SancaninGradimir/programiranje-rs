    {
      "text": "<p>Prvi checkboks u vasoj formi treba da bude podrazumevano selektovan.</p>",
      "testString": "assert.isTrue(document.querySelector('input[type=\"checkbox\"]').checked);"
    },
    {
      "text": "<p>Ne treba da menjate tekst unutar labele <code>Indoor</code>.</p>",
