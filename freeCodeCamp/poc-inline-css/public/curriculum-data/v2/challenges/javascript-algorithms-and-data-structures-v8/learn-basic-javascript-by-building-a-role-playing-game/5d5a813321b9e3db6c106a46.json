  "tests": [
    {
      "text": "<p>Vaš kod treba da ima referencu na <code>DOCTYPE</code>.</p>",
      "testString": "assert(code.match(/<!DOCTYPE/gi));"
    },
    {
      "text": "<p>Treba da uključite razmak nakon referencije <code>DOCTYPE</code>.</p>",
      "testString": "assert(code.match(/<!DOCTYPE\\s+/gi));"
    },
    {
      "text": "<p>Trebalo bi da definišete tip dokumenta kao <code>html</code>.</p>",
      "testString": "assert(code.match(/<!DOCTYPE\\s+html/gi));"
    },
    {
      "text": "<p>Morate zatvoriti deklaraciju za <code>DOCTYPE</code> za <code>></code> nakon tipa.</p>",
      "testString": "assert(code.match(/<!DOCTYPE\\s+html\\s*>/gi));"
    },
    {
      "text": "<p>Element vašeg <code>html</code> mora imati oznaku za otvaranje. Ne zaboravite atribut <code>lang</code>.</p>",
      "testString": "assert(code.match(/<html\\s+lang\\s*=\\s*('|\")en\\1\\s*>/gi));"
    },
    {
      "text": "<p>Element vašeg <code>html</code> mora imati zatvarajući tag.</p>",
      "testString": "assert(code.match(/<\\/html\\s*>/));"
    },
    {
      "text": "<p>Tvoje saopštenje za <code>DOCTYPE</code> trebalo bi biti na početku tvog HTML.</p>",
      "testString": "assert(__helpers.removeHtmlComments(code).match(/^\\s*<!DOCTYPE\\s+html\\s*>/i));"
    },
    {
      "text": "<p>Trebalo bi da imate etiketu za otvaranje <code>head</code>.</p>",
      "testString": "assert(code.match(/<head\\s*>/i));"
    },
    {
      "text": "<p>Trebalo bi da imaš oznaku za zatvaranje <code>head</code>.</p>",
      "testString": "assert(code.match(/<\\/head\\s*>/i));"
    },
    {
      "text": "<p>Trebalo bi da imaš oznaku za otvaranje <code>body</code>.</p>",
      "testString": "assert(code.match(/<body\\s*>/i));"
    },
    {
      "text": "<p>Trebalo bi da imaš oznaku za zatvaranje <code>body</code>.</p>",
      "testString": "assert(code.match(/<\\/body\\s*>/i));"
    },
    {
      "text": "<p>Elementi za <code>head</code> i <code>body</code> bi trebalo da budu sestrinski elementi.</p>",
      "testString": "assert.match(code, /<head\\s*>.*<\\/head\\s*>.*<body\\s*>.*<\\/body\\s*>/s)"
    },
    {
      "text": "<p>Element <code>head</code> treba da bude unutar elementa <code>html</code>.</p>",
      "testString": "assert.match(code, /<html[^>]*>.*<head\\s*>.*<\\/head\\s*>.*<\\/html\\s*>/s);"
    },
    {
      "text": "<p>Element za <code>body</code> treba da bude unutar elementa <code>html</code>.</p>",
      "testString": "assert.match(code, /<html[^>]*>.*<body\\s*>.*<\\/body\\s*>.*<\\/html\\s*>/s);"
    },
    {
      "text": "<p>Твој код мора имати елемент <code>meta</code>.</p>",
      "testString": "const meta = document.querySelector('meta');\nassert.exists(meta);"
    },
    {
      "text": "<p>Vaše polje <code>meta</code> mora imati atribut <code>charset</code> sa vrednošću <code>UTF-8</code>.</p>",
      "testString": "assert.match(code, /<meta[\\s\\S]+?charset=('|\"|`)UTF-8\\1/i)"
