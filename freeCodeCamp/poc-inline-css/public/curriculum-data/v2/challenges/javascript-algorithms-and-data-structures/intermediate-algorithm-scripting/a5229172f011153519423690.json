        "fileKey": "scriptjs",
        "contents": "function sumFibs(num) {\r\n  var a = 1;\r\n  var b = 1;\r\n  var s = 0;\r\n  while (a <= num) {\r\n    if (a % 2 !== 0) {\r\n      s += a;\r\n    }\r\n    a = [b, b=b+a][0];\r\n  }\r\n  return s;\r\n}",
        "error": null,
        "seed": "function sumFibs(num) {\r\n  var a = 1;\r\n  var b = 1;\r\n  var s = 0;\r\n  while (a <= num) {\r\n    if (a % 2 !== 0) {\r\n      s += a;\r\n    }\r\n    a = [b, b=b+a][0];\r\n  }\r\n  return s;\r\n}"
