{"componentChunkName":"component---src-templates-challenges-classic-show-tsx","path":"/learn/rosetta-code/rosetta-code-challenges/sorting-algorithmsbead-sort","result":{"data":{"challengeNode":{"challenge":{"block":"rosetta-code-challenges","demoType":null,"title":"Algoritmi za sortiranje / niz podataka Bead Sort-om","description":"<section id=\"description\">\n<p><em>Bead sort</em> počinje kreiranjem matrice nula čija dužina je jednaka vrednosti najvećeg elementa u ulaznom nizu podataka. Matrica se modifikuje dodavanjem jedinice svim elementima između nulte indeksa i indeksa navedenog trenutnim elementom. Ovaj proces se ponavlja dok matrica nije popunjena.</p>\n<p>Izračunavanjem broja elemenata u matrici koji su veći od nule, a zatim oduzimanjem jedinice od vrednosti svakog elementa, dobija se organizovani red podataka.</p>\n<p><strong>Napomena:</strong> Svaki element u redu ulaznih podataka je jedinstven.</p>\n<p>Sorteovanje niza podataka pozitivnih celobrojnika korišćenjem Bead Sort algoritma.</p>\n</section>","id":"5a23c84252665b21eecc8001","hasEditableBoundaries":false,"instructions":"","notes":null,"challengeType":1,"helpCategory":"Rosetta","videoUrl":null,"superBlock":"rosetta-code","translationPending":false,"forumTopicId":302310,"hooks":null,"fields":{"slug":"/learn/rosetta-code/rosetta-code-challenges/sorting-algorithmsbead-sort"},"required":[],"usesMultifileEditor":false,"challengeFiles":[{"fileKey":"scriptjs","ext":"js","name":"script","contents":"function beadSort(arr) {\n\n}","head":null,"tail":null,"editableRegionBoundaries":[],"history":["script.js"]}],"saveSubmissionToDB":null,"tests":[{"text":"<p><code>beadSort</code> Trebalo bi da bude funkcija.</p>","testString":"assert(typeof beadSort == 'function');"},{"text":"<p><code>beadSort([25, 32, 12, 7, 20])</code> trebalo bi da vrati red podataka.</p>","testString":"assert(Array.isArray(beadSort([25, 32, 12, 7, 20])));"},{"text":"<p><code>beadSort([25, 32, 12, 7, 20])</code> treba da vrati <code>[7, 12, 20, 25, 32]</code>.</p>","testString":"assert.deepEqual(beadSort([25, 32, 12, 7, 20]), [7, 12, 20, 25, 32]);"},{"text":"<p><code>beadSort([38, 45, 35, 8, 13])</code> trebalo bi da vrati <code>[8, 13, 35, 38, 45]</code>.</p>","testString":"assert.deepEqual(beadSort([38, 45, 35, 8, 13]), [8, 13, 35, 38, 45]);"},{"text":"<p><code>beadSort([43, 36, 20, 34, 24])</code> trebalo bi da vrati <code>[20, 24, 34, 36, 43]</code>.</p>","testString":"assert.deepEqual(beadSort([43, 36, 20, 34, 24]), [20, 24, 34, 36, 43]);"},{"text":"<p><code>beadSort([12, 33, 26, 18, 1, 16, 38])</code> treba da vrati <code>[1, 12, 16, 18, 26, 33, 38]</code>.</p>","testString":"assert.deepEqual(beadSort([12, 33, 26, 18, 1, 16, 38]), [\n  1,\n  12,\n  16,\n  18,\n  26,\n  33,\n  38\n]);"},{"text":"<p><code>beadSort([3, 39, 48, 16, 1, 4, 29])</code> treba da vrati <code>[1, 3, 4, 16, 29, 39, 48]</code>.</p>","testString":"assert.deepEqual(beadSort([3, 39, 48, 16, 1, 4, 29]), [\n  1,\n  3,\n  4,\n  16,\n  29,\n  39,\n  48\n]);"}]}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/rosetta-code/#rosetta-code-challenges","dashedName":"sorting-algorithmsbead-sort","certification":"rosetta-code","disableLoopProtectTests":true,"disableLoopProtectPreview":false,"superBlock":"rosetta-code","chapter":null,"module":null,"block":"rosetta-code-challenges","isFirstStep":false,"template":null,"required":[],"isLastChallengeInBlock":false,"nextChallengePath":"/learn/rosetta-code/rosetta-code-challenges/sorting-algorithmsbogosort","prevChallengePath":"/learn/rosetta-code/rosetta-code-challenges/sort-using-a-custom-comparator","id":"5a23c84252665b21eecc8001","saveSubmissionToDB":null},"projectPreview":{"challengeData":{"challengeType":1,"challengeFiles":[{"name":"script","ext":"js","contents":"function ZigZagMatrix(n) {\n  const mtx = [];\n  for (let i = 0; i < n; i++) {\n    mtx[i] = [];\n  }\n\n  let i = 1;\n  let j = 1;\n  for (let e = 0; e < n * n; e++) {\n    mtx[i - 1][j - 1] = e;\n    if ((i + j) % 2 === 0) {\n      // Even stripes\n      if (j < n) j++;\n      else i += 2;\n      if (i > 1) i--;\n    } else {\n      // Odd stripes\n      if (i < n) i++;\n      else j += 2;\n      if (j > 1) j--;\n    }\n  }\n  return mtx;\n}","history":["script.js"],"fileKey":"scriptjs"}]}},"id":"/learn/rosetta-code/rosetta-code-challenges/sorting-algorithmsbead-sort"}},"staticQueryHashes":["3858520367"],"slicesMap":{}}