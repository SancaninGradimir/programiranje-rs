equal(sumDigits('254'), 11);"},{"text":"<p><code>sumDigits(\"fe\")</code> trebalo bi da vrati <code>29</code>.</p>","testString":"assert.equal(sumDigits('fe'), 29);"},{"text":"<p><code>sumDigits(\"f0e\")</code> treba da vrati <code>29</code>.</p>","testString":"assert.equal(sumDigits('f0e'), 29);"},{"text":"<p><code>sumDigits(\"999ABCXYZ\")</code> treba da vrati <code>162</code>.</p>","testString":"assert.equal(sumDigits('999ABCXYZ'), 162);"}]}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/rosetta-code/#rosetta-code-challenges","dashedName":"sum-digits-of-an-integer","certification":"rosetta-code","disableLoopProtectTests":true,"disableLoopProtectPreview":false,"superBlock":"rosetta-code","chapter":null,"module":null,"block":"rosetta-code-challenges","isFirstStep":false,"template":null,"required":[],"isLastChallengeInBlock":false,"nextChallengePath":"/learn/rosetta-code/rosetta-code-challenges/sum-multiples-of-3-and-5","prevChallengePath":"/learn/rosetta-code/rosetta-code-challenges/sudoku","id":"5a23c84252665b21eecc803f","saveSubmissionToDB":null},"projectPreview":{"challengeData":{"challengeType":1,"challengeFiles":[{"name":"script","ext":"js","contents":"function ZigZagMatrix(n) {\n  const mtx = [];\n  for (let i = 0; i < n; i++) {\n    mtx[i] = [];\n  }\n\n  let i = 1;\n  let j = 1;\n  for (let e = 0; e < n * n; e++) {\n    mtx[i - 1][j - 1] = e;\n    if ((i + j) % 2 === 0) {\n      // Even stripes\n      if (j < n) j++;\n      else i += 2;\n      if (i > 1) i--;\n    } else {\n      // Odd stripes\n      if (i < n) i++;\n      else j += 2;\n      if (j > 1) j--;\n    }\n  }\n  return mtx;\n}","history":["script.js"],"fileKey":"scriptjs"}]}},"id":"/learn/rosetta-code/rosetta-code-challenges/sum-digits-of-an-integer"}},"staticQueryHashes":["3858520367"],"slicesMap":{}}