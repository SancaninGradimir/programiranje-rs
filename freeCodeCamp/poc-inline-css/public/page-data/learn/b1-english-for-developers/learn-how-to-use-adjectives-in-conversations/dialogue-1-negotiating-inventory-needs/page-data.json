{"componentChunkName":"component---src-templates-challenges-generic-show-tsx","path":"/learn/b1-english-for-developers/learn-how-to-use-adjectives-in-conversations/dialogue-1-negotiating-inventory-needs","result":{"data":{"challengeNode":{"challenge":{"assignments":["<p>Gledaj video.</p>"],"bilibiliIds":null,"block":"learn-how-to-use-adjectives-in-conversations","challengeType":21,"description":"<section id=\"description\">\n<p>Pogledajte video dole/ispod kako biste razumeli kontekst predstojećih lekcija.</p>\n</section>","nodules":null,"explanation":null,"helpCategory":"English","instructions":"","fields":{"slug":"/learn/b1-english-for-developers/learn-how-to-use-adjectives-in-conversations/dialogue-1-negotiating-inventory-needs"},"questions":[],"scene":{"setup":{"background":"company3-reception.png","characters":[{"character":"Sarah","position":{"x":-25,"y":0,"z":1},"opacity":null},{"character":"Josh","position":{"x":125,"y":0,"z":1},"opacity":null}],"audio":{"filename":"B1_19-1.mp3","startTime":1,"startTimestamp":null,"finishTimestamp":null},"alwaysShowDialogue":true},"commands":[{"background":null,"character":"Sarah","position":{"x":25,"y":0,"z":1},"opacity":null,"startTime":0,"finishTime":null,"dialogue":null},{"background":null,"character":"Josh","position":{"x":70,"y":0,"z":1},"opacity":null,"startTime":0.5,"finishTime":null,"dialogue":null},{"background":null,"character":"Sarah","position":null,"opacity":null,"startTime":1,"finishTime":5.98,"dialogue":{"text":"Thanks for meeting with me today. We need to wrap up the list of components for our next product batch.","align":"left"}},{"background":null,"character":"Sarah","position":null,"opacity":null,"startTime":6.52,"finishTime":8.48,"dialogue":{"text":"This list here shows what we're looking at.","align":"left"}},{"background":null,"character":"Josh","position":null,"opacity":null,"startTime":8.8,"finishTime":14.22,"dialogue":{"text":"No problem at all. I see this item at the top. Do you need many of these or just a few?","align":"right"}},{"background":null,"character":"Sarah","position":null,"opacity":null,"startTime":14.82,"finishTime":18.62,"dialogue":{"text":"We're actually looking for quite a few of those. They're crucial for our new design.","align":"left"}},{"background":null,"character":"Sarah","position":null,"opacity":null,"startTime":19.14,"finishTime":22.18,"dialogue":{"text":"Last time we ordered 20. This time we might need double that.","align":"left"}},{"background":null,"character":"Josh","position":null,"opacity":null,"startTime":22.54,"finishTime":27.82,"dialogue":{"text":"Got it. Those resistors right there, are they the same ones you needed last time or something better?","align":"right"}},{"background":null,"character":"Sarah","position":null,"opacity":null,"startTime":28.3,"finishTime":33.68,"dialogue":{"text":"Those are the ones, but we found something even better in your catalog. These high capacity ones here.","align":"left"}},{"background":null,"character":"Sarah","position":null,"opacity":null,"startTime":34.3,"finishTime":36.96,"dialogue":{"text":"Could we get a sample of those first before we make a large order?","align":"left"}},{"background":null,"character":"Josh","position":null,"opacity":null,"startTime":37.44,"finishTime":43.24,"dialogue":{"text":"Certainly. I can send those over by next week. How about these cables? You mentioned needing more than usual.","align":"right"}},{"background":null,"character":"Sarah","position":null,"opacity":null,"startTime":43.92,"finishTime":49.6,"dialogue":{"text":"Yes, those cables were a bit short last time. We need something longer, maybe twice as long as the ones we got before.","align":"left"}},{"background":null,"character":"Josh","position":null,"opacity":null,"startTime":50.1,"finishTime":52.52,"dialogue":{"text":"Understood. I'll check what lengths we have in stock.","align":"right"}},{"background":null,"character":"Josh","position":null,"opacity":null,"startTime":52.98,"finishTime":58.64,"dialogue":{"text":"For these connectors, are these standard types sufficient or do you need the highest quality that we offer?","align":"right"}},{"background":null,"character":"Sarah","position":null,"opacity":null,"startTime":59.24,"finishTime":64.04,"dialogue":{"text":"We'd prefer the highest quality for those connectors since they impact the product's performance significantly.","align":"left"}},{"background":null,"character":"Sarah","position":null,"opacity":null,"startTime":64.64,"finishTime":67.74,"dialogue":{"text":"Also, could you ensure we receive all the materials by the end of the month?","align":"left"}},{"background":null,"character":"Josh","position":null,"opacity":null,"startTime":68.52,"finishTime":70.8,"dialogue":{"text":"Absolutely. I'll prioritize these orders.","align":"right"}},{"background":null,"character":"Josh","position":null,"opacity":null,"startTime":71.14,"finishTime":76.94,"dialogue":{"text":"I'll draft a new quote with these specifics and send it over to you by tomorrow. Does that work for you?","align":"right"}},{"background":null,"character":"Sarah","position":null,"opacity":null,"startTime":77.32,"finishTime":81.1,"dialogue":{"text":"Perfect, Josh. Thank you for the quick turnaround. Let's touch base once I review the quote.","align":"left"}},{"background":null,"character":"Josh","position":{"x":125,"y":0,"z":1},"opacity":null,"startTime":81.6,"finishTime":null,"dialogue":null},{"background":null,"character":"Sarah","position":{"x":-25,"y":0,"z":1},"opacity":null,"startTime":82.1,"finishTime":null,"dialogue":null}]},"superBlock":"b1-english-for-developers","tests":[],"title":"Dialog 1: Negocijisanje potreba za inventarom","transcript":null,"translationPending":false,"videoId":null,"videoLocaleIds":null}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/b1-english-for-developers/#learn-how-to-use-adjectives-in-conversations","dashedName":"dialogue-1-negotiating-inventory-needs","certification":"b1-english-for-developers","disableLoopProtectTests":false,"disableLoopProtectPreview":false,"superBlock":"b1-english-for-developers","chapter":null,"module":null,"block":"learn-how-to-use-adjectives-in-conversations","isFirstStep":true,"template":null,"required":[],"isLastChallengeInBlock":false,"nextChallengePath":"/learn/b1-english-for-developers/learn-how-to-use-adjectives-in-conversations/task-1","prevChallengePath":"/learn/b1-english-for-developers/en-b1-quiz-adverbial-phrases/en-b1-quiz-adverbial-phrases","id":"680505e55719e4680b0923b3","saveSubmissionToDB":null},"projectPreview":{"challengeData":{"challengeType":19,"challengeFiles":[]}},"id":"/learn/b1-english-for-developers/learn-how-to-use-adjectives-in-conversations/dialogue-1-negotiating-inventory-needs"}},"staticQueryHashes":["3858520367"],"slicesMap":{}}