{"componentChunkName":"component---src-templates-challenges-generic-show-tsx","path":"/learn/b1-english-for-developers/learn-how-to-describe-places-and-events/dialogue-3-struggling-with-ides","result":{"data":{"challengeNode":{"challenge":{"assignments":["<p>Gledaj video.</p>"],"bilibiliIds":null,"block":"learn-how-to-describe-places-and-events","challengeType":21,"description":"<section id=\"description\">\n<p>Pogledajte video ispod da biste razumeli kontekst sledećih lekcija.</p>\n</section>","nodules":null,"explanation":null,"helpCategory":"English","instructions":"","fields":{"slug":"/learn/b1-english-for-developers/learn-how-to-describe-places-and-events/dialogue-3-struggling-with-ides"},"questions":[],"scene":{"setup":{"background":"company2-center.png","characters":[{"character":"Tom","position":{"x":-25,"y":0,"z":1},"opacity":null},{"character":"Sarah","position":{"x":125,"y":0,"z":1},"opacity":null}],"audio":{"filename":"B1_1-3.mp3","startTime":1,"startTimestamp":null,"finishTimestamp":null},"alwaysShowDialogue":true},"commands":[{"background":null,"character":"Tom","position":{"x":25,"y":0,"z":1},"opacity":null,"startTime":0,"finishTime":null,"dialogue":null},{"background":null,"character":"Sarah","position":{"x":70,"y":0,"z":1},"opacity":null,"startTime":0.5,"finishTime":null,"dialogue":null},{"background":null,"character":"Tom","position":null,"opacity":null,"startTime":1,"finishTime":5.14,"dialogue":{"text":"Hey Sarah, do you have a moment? I'm struggling with these IDEs.","align":"left"}},{"background":null,"character":"Sarah","position":null,"opacity":null,"startTime":5.54,"finishTime":7.5,"dialogue":{"text":"Sure, I'm not busy. What's the problem?","align":"right"}},{"background":null,"character":"Tom","position":null,"opacity":null,"startTime":7.72,"finishTime":13.16,"dialogue":{"text":"The live preview isn't showing in Visual Studio Code. Isn't it supposed to support that feature?","align":"left"}},{"background":null,"character":"Sarah","position":null,"opacity":null,"startTime":13.62,"finishTime":17.66,"dialogue":{"text":"It should, but it's not displaying because the live server extension might not be running.","align":"right"}},{"background":null,"character":"Sarah","position":null,"opacity":null,"startTime":18,"finishTime":20.2,"dialogue":{"text":"Are you using that extension for realtime previews?","align":"right"}},{"background":null,"character":"Tom","position":null,"opacity":null,"startTime":20.64,"finishTime":23.22,"dialogue":{"text":"I think we are, but maybe it's not set up right.","align":"left"}},{"background":null,"character":"Tom","position":null,"opacity":null,"startTime":23.6,"finishTime":30.46,"dialogue":{"text":"Also, in IntelliJ IDEA, the code autocompletion isn't popping up. Isn't it automatic?","align":"left"}},{"background":null,"character":"Sarah","position":null,"opacity":null,"startTime":31.3,"finishTime":35.6,"dialogue":{"text":"It usually is, but it doesn't work if the project isn't set up right. Have you checked the settings?","align":"right"}},{"background":null,"character":"Tom","position":null,"opacity":null,"startTime":35.96,"finishTime":37.1,"dialogue":{"text":"I'll have to check again.","align":"left"}},{"background":null,"character":"Tom","position":null,"opacity":null,"startTime":37.32,"finishTime":41.76,"dialogue":{"text":"And in Eclipse, it's not showing the Git tools. Are they built in?","align":"left"}},{"background":null,"character":"Sarah","position":null,"opacity":null,"startTime":42.28,"finishTime":45.56,"dialogue":{"text":"Yes, they are, but they're not visible if the project isn't linked to Git.","align":"right"}},{"background":null,"character":"Sarah","position":null,"opacity":null,"startTime":45.82,"finishTime":47.8,"dialogue":{"text":"Is your project connected to Git in Eclipse?","align":"right"}},{"background":null,"character":"Tom","position":null,"opacity":null,"startTime":48.3,"finishTime":53.12,"dialogue":{"text":"It's supposed to be. This is frustrating. Are these IDEs always this tricky?","align":"left"}},{"background":null,"character":"Sarah","position":null,"opacity":null,"startTime":53.72,"finishTime":56.28,"dialogue":{"text":"Not always, but they can be when they're not set up properly.","align":"right"}},{"background":null,"character":"Sarah","position":null,"opacity":null,"startTime":56.5,"finishTime":58.2,"dialogue":{"text":"Do you want a walkthrough on setting them up?","align":"right"}},{"background":null,"character":"Tom","position":null,"opacity":null,"startTime":58.88,"finishTime":60.8,"dialogue":{"text":"Yes, please. That would be great.","align":"left"}},{"background":null,"character":"Sarah","position":{"x":125,"y":0,"z":1},"opacity":null,"startTime":61.3,"finishTime":null,"dialogue":null},{"background":null,"character":"Tom","position":{"x":-25,"y":0,"z":1},"opacity":null,"startTime":61.8,"finishTime":null,"dialogue":null}]},"superBlock":"b1-english-for-developers","tests":[],"title":"Dijalog 3: Borba sa IDE-ovima","transcript":null,"translationPending":false,"videoId":null,"videoLocaleIds":null}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/b1-english-for-developers/#learn-how-to-describe-places-and-events","dashedName":"dialogue-3-struggling-with-ides","certification":"b1-english-for-developers","disableLoopProtectTests":false,"disableLoopProtectPreview":false,"superBlock":"b1-english-for-developers","chapter":null,"module":null,"block":"learn-how-to-describe-places-and-events","isFirstStep":false,"template":null,"required":[],"isLastChallengeInBlock":false,"nextChallengePath":"/learn/b1-english-for-developers/learn-how-to-describe-places-and-events/task-99","prevChallengePath":"/learn/b1-english-for-developers/learn-how-to-describe-places-and-events/task-98","id":"66bbacad1dfc231609e3a512","saveSubmissionToDB":null},"projectPreview":{"challengeData":{"challengeType":19,"challengeFiles":[]}},"id":"/learn/b1-english-for-developers/learn-how-to-describe-places-and-events/dialogue-3-stru