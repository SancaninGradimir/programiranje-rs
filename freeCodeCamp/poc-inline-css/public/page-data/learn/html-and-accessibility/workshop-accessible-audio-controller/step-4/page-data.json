{"componentChunkName":"component---src-templates-challenges-classic-show-tsx","path":"/learn/html-and-accessibility/workshop-accessible-audio-controller/step-4","result":{"data":{"challengeNode":{"challenge":{"block":"workshop-accessible-audio-controller","demoType":null,"title":"Korak 4","description":"<section id=\"description\">\n<p>Sada je vreme da dodamo još jednu funkciju od <code>span</code>.</p>\n<p>Ovaj element sa <code>span</code> treba da ima svojstvo polja od <code>id</code> postavljeno na <code>volume-description</code>.\nTakođe, tekst ovog elementa sa <code>span</code> treba da bude <code>Adjust the sound level</code>.</p>\n<p>Kao što je slučaj sa prethodnim elementom <code>span</code>, referenca na <code>id</code> od <code>span</code> će biti prikazana kasnije sa ARIA atributima kako bi asistivne tehnologije mogle da prepoznaju ovaj tekst kao opis kontrole zvuka.</p>\n</section>","id":"68ec0a48c9d6db3594d768c3","hasEditableBoundaries":true,"instructions":"","notes":null,"challengeType":0,"helpCategory":"HTML-CSS","videoUrl":null,"superBlock":"html-and-accessibility","translationPending":false,"forumTopicId":null,"hooks":null,"fields":{"slug":"/learn/html-and-accessibility/workshop-accessible-audio-controller/step-4"},"required":[],"usesMultifileEditor":true,"challengeFiles":[{"fileKey":"indexhtml","ext":"html","name":"index","contents":"<!DOCTYPE html>\n<html lang=\"en\">\n  <head>\n    <meta charset=\"UTF-8\">\n    <title>Accessible Controls</title>\n  </head>\n  <body>\n\n    <h1>Audio Controls</h1>\n\n    <button type=\"button\">Play</button>\n\n    <div>\n      <span id=\"volume-label\">Volume</span>\n    \n    </div>\n\n  </body>\n</html>","head":null,"tail":null,"editableRegionBoundaries":[14,16],"history":["index.html"]}],"saveSubmissionToDB":null,"tests":[{"text":"<p>Trebalo bi da imaš dva elementa <code>span</code> unutar elementa <code>div</code>.</p>","testString":"const spans = document.querySelectorAll('div > span');\nassert.lengthOf(spans, 2);"},{"text":"<p>Tvoja druga komponenta iz <code>span</code> treba da ima svojstvo komponente <code>id</code>.</p>","testString":"const secondSpanEl = document.querySelector('div > span:nth-of-type(2)');\nassert.isTrue(secondSpanEl?.hasAttribute('id'));"},{"text":"<p>Vaš drugi element od <code>span</code> treba da ima svojstvo atributa <code>id</code> sa vrednošću <code>volume-description</code>.</p>","testString":"const secondSpanEl = document.querySelector('div > span:nth-of-type(2)');\nassert.equal(secondSpanEl?.getAttribute('id'), 'volume-description');"},{"text":"<p>Vaš drugi element za <code>span</code> mora imati tekst od <code>Adjust the sound level</code>.</p>","testString":"const secondSpanEl = document.querySelector('div > span:nth-of-type(2)');\nassert.equal(secondSpanEl?.innerText.trim(), 'Adjust the sound level');"}]}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/html-and-accessibility/#workshop-accessible-audio-controller","dashedName":"step-4","certification":"html-and-accessibility","disableLoopProtectTests":false,"disableLoopProtectPreview":false,"superBlock":"html-and-accessibility","chapter":null,"module":null,"block":"workshop-accessible-audio-controller","isFirstStep":false,"template":null,"required":[],"isLastChallengeInBlock":false,"nextChallengePath":"/learn/html-and-accessibility/workshop-accessible-audio-controller/step-5","prevChallengePath":"/learn/html-and-accessibility/workshop-accessible-audio-controller/step-3","id":"68ec0a48c9d6db3594d768c3","saveSubmissionToDB":null},"projectPreview":{"challengeData":{"challengeType":0,"challengeFiles":[{"name":"index","ext":"html","contents":"<!DOCTYPE html>\n<html lang=\"en\">\n  <head>\n    <meta charset=\"UTF-8\">\n    <title>Accessible Controls</title>\n  </head>\n  <body>\n\n    <h1>Audio Controls</h1>\n\n    <button type=\"button\">Play</button>\n\n    <div>\n      <span id=\"volume-label\">Volume</span>\n      <span id=\"volume-description\">Adjust the sound level</span>\n  