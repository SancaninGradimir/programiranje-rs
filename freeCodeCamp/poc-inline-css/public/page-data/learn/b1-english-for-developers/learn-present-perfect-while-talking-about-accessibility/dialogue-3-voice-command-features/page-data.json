{"componentChunkName":"component---src-templates-challenges-generic-show-tsx","path":"/learn/b1-english-for-developers/learn-present-perfect-while-talking-about-accessibility/dialogue-3-voice-command-features","result":{"data":{"challengeNode":{"challenge":{"assignments":["<p>Gledaj video.</p>"],"bilibiliIds":null,"block":"learn-present-perfect-while-talking-about-accessibility","challengeType":21,"description":"<section id=\"description\">\n<p>Pogledajte video dole/ispod kako biste razumeli kontekst predstojećih lekcija.</p>\n</section>","nodules":null,"explanation":null,"helpCategory":"English","instructions":"","fields":{"slug":"/learn/b1-english-for-developers/learn-present-perfect-while-talking-about-accessibility/dialogue-3-voice-command-features"},"questions":[],"scene":{"setup":{"background":"company2-boardroom.png","characters":[{"character":"Bob","position":{"x":-25,"y":0,"z":1},"opacity":null},{"character":"Linda","position":{"x":125,"y":0,"z":1},"opacity":null}],"audio":{"filename":"B1_4-3.mp3","startTime":1,"startTimestamp":null,"finishTimestamp":null},"alwaysShowDialogue":true},"commands":[{"background":null,"character":"Bob","position":{"x":25,"y":0,"z":1},"opacity":null,"startTime":0,"finishTime":null,"dialogue":null},{"background":null,"character":"Linda","position":{"x":70,"y":0,"z":1},"opacity":null,"startTime":0.5,"finishTime":null,"dialogue":null},{"background":null,"character":"Bob","position":null,"opacity":null,"startTime":1,"finishTime":4.3,"dialogue":{"text":"Hi Linda have you been working on the new voice command features?","align":"left"}},{"background":null,"character":"Linda","position":null,"opacity":null,"startTime":4.8,"finishTime":7.42,"dialogue":{"text":"Yes, I've been testing them since the latest software update.","align":"right"}},{"background":null,"character":"Linda","position":null,"opacity":null,"startTime":7.42,"finishTime":10.78,"dialogue":{"text":"We've had some positive feedback, but there are still a few bugs to fix.","align":"right"}},{"background":null,"character":"Bob","position":null,"opacity":null,"startTime":10.78,"finishTime":13.34,"dialogue":{"text":"How long have you been focusing on this evaluation?","align":"left"}},{"background":null,"character":"Linda","position":null,"opacity":null,"startTime":13.34,"finishTime":18.92,"dialogue":{"text":"For the past couple weeks. I've been trying to cover all scenarios to ensure that the commands work consistently.","align":"right"}},{"background":null,"character":"Bob","position":null,"opacity":null,"startTime":18.92,"finishTime":21.38,"dialogue":{"text":"Have you had any problems with voice recognition?","align":"left"}},{"background":null,"character":"Linda","position":null,"opacity":null,"startTime":21.38,"finishTime":25.02,"dialogue":{"text":"A few. The system hasn't been responding well to certain accents,","align":"right"}},{"background":null,"character":"Linda","position":null,"opacity":null,"startTime":25.02,"finishTime":28.36,"dialogue":{"text":"and it struggles with background noise. We need to improve its accuracy.","align":"right"}},{"background":null,"character":"Bob","position":null,"opacity":null,"startTime":28.66,"finishTime":31.96,"dialogue":{"text":"What about the integration with other systems? Has it been seamless?","align":"left"}},{"background":null,"character":"Linda","position":null,"opacity":null,"startTime":32.5,"finishTime":36.94,"dialogue":{"text":"Not entirely. It's had issues connecting with our older devices, but we're working on it.","align":"right"}},{"background":null,"character":"Linda","position":null,"opacity":null,"startTime":37,"finishTime":39.24,"dialogue":{"text":"The development team has been brainstorming solutions","align":"right"}},{"background":null,"character":"Bob","position":null,"opacity":null,"startTime":39.24,"finishTime":44.08,"dialogue":{"text":"That's a good start. By the way, have we tested it with real users yet?","align":"left"}},{"background":null,"character":"Linda","posit