{"componentChunkName":"component---src-templates-challenges-classic-show-tsx","path":"/learn/javascript-v9/lab-unique-sorted-union/implement-a-unique-sorted-union","result":{"data":{"challengeNode":{"challenge":{"block":"lab-unique-sorted-union","demoType":null,"title":"Implementiraj jedinstveno konfigurisanu vezu","description":"<section id=\"description\">\n<p><strong>Cilj:</strong> Popunite priče korisnika ispod i prođite sve testove kako biste završili laboratoriju.</p>\n<p><strong>Priče korisnika:</strong></p>\n<ol>\n<li>Trebalo bi da ima funkciju nazvanu <code>uniteUnique</code>.</li>\n<li>Funkcija <code>uniteUnique</code> bi trebalo da primi dva ili više redova podataka kao argumente.</li>\n<li>Funkcija bi trebalo da vrati novi red podataka koji uključuje jedinstvene vrednosti iz argumentnih redova podataka, u redosledu njihovog prvog pojavljivanja u argumentima. Na primer, unos kao <code>[1, 2, 4], [2, 3, 5]</code> imaće rezultat <code>[1, 2, 4, 3, 5]</code>.</li>\n</ol>\n</section>","id":"a105e963526e7de52b219be9","hasEditableBoundaries":false,"instructions":"","notes":null,"challengeType":26,"helpCategory":"JavaScript","videoUrl":null,"superBlock":"javascript-v9","translationPending":false,"forumTopicId":null,"hooks":null,"fields":{"slug":"/learn/javascript-v9/lab-unique-sorted-union/implement-a-unique-sorted-union"},"required":[],"usesMultifileEditor":true,"challengeFiles":[{"fileKey":"scriptjs","ext":"js","name":"script","contents":"","head":null,"tail":null,"editableRegionBoundaries":[],"history":["script.js"]}],"saveSubmissionToDB":null,"tests":[{"text":"<p>Trebalo bi da imaš funkciju <code>uniteUnique</code>.</p>","testString":"assert.isFunction(uniteUnique);"},{"text":"<p><code>uniteUnique([1, 3, 2], [5, 2, 1, 4], [2, 1])</code> trebalo bi da vrati <code>[1, 3, 2, 5, 4]</code>.</p>","testString":"assert.deepEqual(uniteUnique([1, 3, 2], [5, 2, 1, 4], [2, 1]), [1, 3, 2, 5, 4]);"},{"text":"<p><code>uniteUnique([1, 2, 3], [5, 2, 1])</code> trebalo bi da vrati <code>[1, 2, 3, 5]</code>.</p>","testString":"assert.deepEqual(uniteUnique([1, 2, 3], [5, 2, 1]), [1, 2, 3, 5]);"},{"text":"<p><code>uniteUnique([1, 2, 3], [5, 2, 1, 4], [2, 1], [6, 7, 8])</code> trebalo bi da vrati <code>[1, 2, 3, 5, 4, 6, 7, 8]</code>.</p>","testString":"assert.deepEqual(uniteUnique([1, 2, 3], [5, 2, 1, 4], [2, 1], [6, 7, 8]), [\n  1,\n  2,\n  3,\n  5,\n  4,\n  6,\n  7,\n  8\n]);"},{"text":"<p><code>uniteUnique([1, 3, 2], [5, 4], [5, 6])</code> trebao bi da vrati <code>[1, 3, 2, 5, 4, 6]</code>.</p>","testString":"assert.deepEqual(uniteUnique([1, 3, 2], [5, 4], [5, 6]), [1, 3, 2, 5, 4, 6]);"},{"text":"<p><code>uniteUnique([1, 3, 2, 3], [5, 2, 1, 4], [2, 1])</code> trebalo bi da vrati <code>[1, 3, 2, 5, 4]</code>.</p>","testString":"assert.deepEqual(uniteUnique([1, 3, 2, 3], [5, 2, 1, 4], [2, 1]), [1, 3, 2, 5, 4]);"}]}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/javascript-v9/#lab-unique-sorted-union","dashedName":"implement-a-unique-sorted-union","certification":"javascript-v9","disableLoopProtectTests":false,"disableLoopProtectPreview":false,"superBlock":"javascript-v9","chapter":"javascript","module":"review-javascript-fundamentals","block":"lab-unique-sorted-union","isFirstStep":true,"template":null,"required":[],"isLastChallengeInBlock":true,"nextChallengePath":"/learn/javascript-v9/lab-password-generator/lab-password-generator","prevChallengePath":"/learn/javascript-v9/lecture-working-with-the-arguments-object-and-rest-parameters/what-are-rest-parameters-and-how-do-they-differ-from-the-arguments-object","id":"a105e963526e7de52b219be9","saveSubmissionToDB":null},"projectPreview":{"challengeData":{"challengeType":26,"challengeFiles":[{"name":"script","ext":"js","contents":"const uniteUnique = (...arrays) => {\n  return arrays.reduce((a, b) => {\n    return [\n      ...a,\n      ...b.filter((e, currentIndex) => b.indexOf(e) === currentIndex && a.indexOf(e) === -1)\n    ];\n  }, []);\n};","history":["script.js"],"fileKey":"scriptjs"}]}},"id":"/learn/javascript-v9/lab-unique-sorted-union/implement-a-unique-sorted-union"}},"staticQueryHashes":["3858520367"],"slicesMap":{}}