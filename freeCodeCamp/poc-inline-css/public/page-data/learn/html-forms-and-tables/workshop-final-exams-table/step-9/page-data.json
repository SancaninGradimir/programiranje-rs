{"componentChunkName":"component---src-templates-challenges-classic-show-tsx","path":"/learn/html-forms-and-tables/workshop-final-exams-table/step-9","result":{"data":{"challengeNode":{"challenge":{"block":"workshop-final-exams-table","demoType":null,"title":"Korak 9","description":"<section id=\"description\">\n<p>Poslednji deo koji treba dodati tabeli biće element <code>&#x3C;dfn>podnožje tabele&#x3C;/dfn></code>, <code>tfoot</code>. Element podnožja tabele će se koristiti za prikaz prosečne ocene svih učenika u tabeli.</p>\n<p>Dodajte element <code>tfoot</code> u tabelu.</p>\n<p>Unutar elementa <code>tfoot``, dodajte element ``tr</code>.</p>\n<p>Unutar elementa <code>tr``, dodajte dva elementa ``td</code>.</p>\n<p>Prvi element <code>td</code> treba da sadrži tekst <code>Average Grade</code>. Drugi element <code>td</code> treba da sadrži tekst <code>78.8</code>.</p>\n</section>","id":"66a9cb26ec6bd41cf6c82bc5","hasEditableBoundaries":true,"instructions":"","notes":null,"challengeType":0,"helpCategory":"HTML-CSS","videoUrl":null,"superBlock":"html-forms-and-tables","translationPending":false,"forumTopicId":null,"hooks":null,"fields":{"slug":"/learn/html-forms-and-tables/workshop-final-exams-table/step-9"},"required":[],"usesMultifileEditor":true,"challengeFiles":[{"fileKey":"indexhtml","ext":"html","name":"index","contents":"<!DOCTYPE html>\n<html lang=\"en\">\n  <head>\n    <title>Calculus Final Exams Table</title>\n    <meta charset=\"UTF-8\" />\n  </head>\n  <body>\n    <table>\n      <caption>\n        Calculus Final Exam Grades\n      </caption>\n\n      <thead>     \n        <tr>\n          <th>Last Name</th>\n          <th>First Name</th>\n          <th>Grade</th>\n        </tr>\n      </thead>\n\n      <tbody>\n        <tr>\n          <td>Davis</td>\n          <td>Alex</td>\n          <td>54</td>\n        </tr>\n\n        <tr>\n          <td>Doe</td>\n          <td>Samantha</td>\n          <td>92</td>\n        </tr>\n\n        <tr>\n          <td>Rodriguez</td>\n          <td>Marcus</td>\n          <td>88</td>\n        </tr>\n\n        <tr>\n          <td>Thompson</td>\n          <td>Jane</td>\n          <td>77</td>\n        </tr>\n\n        <tr>\n          <td>Williams</td>\n          <td>Natalie</td>\n          <td>83</td>\n        </tr>\n      </tbody>\n      \n      \n    </table>\n  </body>\n</html>","head":null,"tail":null,"editableRegionBoundaries":[52,54],"history":["index.html"]}],"saveSubmissionToDB":null,"tests":[{"text":"<p>Trebalo bi da imate otvarajući tag <code>tfoot</code>.</p>","testString":"assert.match(code, /<tfoot>/);"},{"text":"<p>Trebalo bi da imate zatvarajući <code>tfoot</code> tag.</p>","testString":"assert.match(code, /<\\/tfoot>/);"},{"text":"<p>Trebalo bi da imate element <code>tr</code> unutar vašeg elementa <code>tfoot</code>.</p>","testString":"assert.isNotNull(document.querySelector('tfoot tr'));"},{"text":"<p>Vaš prvi <code>td</code> element treba da sadrži tekst <code>Average Grade</code>. Uverite se da je unutar elementa <code>tr</code>.</p>","testString":"assert.strictEqual(document.querySelector('tfoot tr td:first-child')?.textContent.trim(), 'Average Grade');"},{"text":"<p>Vaš drugi <code>td</code> element treba da sadrži tekst <code>78.8</code>. Uverite se da je unutar <code>tr</code> elementa.</p>","testString":"assert.strictEqual(document.querySelector('tfoot tr td:nth-of-type(2)')?.textContent.trim(), '78.8');"},{"text":"<p>Vaš <code>tr</code> element bi trebalo da ima dva <code>td</code> elementa unutar sebe.</p>","testString":"assert.strictEqual(document.querySelectorAll('tfoot tr td').length, 2);"}]}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/html-forms-and-tables/#workshop-final-exams-table","dashedName":"step-9","certification":"html-forms-and-tables","disableLoopProtectTests":false,"disableLoopProtectPreview":false,"superBlock":"html-forms-and-tables","chapter":null,"module":null,"block":"workshop-final-exams-table","isFirstStep":false,"template":null,"re