{"componentChunkName":"component---src-templates-challenges-generic-show-tsx","path":"/learn/a1-professional-spanish/es-a1-learn-meet-luna/task-9","result":{"data":{"challengeNode":{"challenge":{"assignments":[],"bilibiliIds":null,"block":"es-a1-learn-meet-luna","challengeType":19,"description":"<section id=\"description\">\n<p>Luna kaže zbogom i nada se da će vas/te uskoro videti.</p>\n<p>Izraz je veoma često korišćen u španskom jeziku, u formalnim i neformalnim kontekstima, da bi se izrazio privremeni oproštaj.</p>\n</section>","nodules":null,"explanation":"<section id=\"explanation\">\n<p><span class=\"highlighted-text\">Hasta luego</span> znači <strong>\"hadi baadaye\"</strong> i koristi se za reći <strong>\"tutaonana baadaye\"</strong>.</p>\n<p>To je prijateljski i uobičajen način za oproštaj kada očekujete da ćete nekoga uskoro ponovo videti. Primer:</p>\n<ul>\n<li>\n<p><span class=\"highlighted-text\">Hasta luego, nos vemos en la reunión.</span> – Vidimo se kasnije, sastaćemo se na sastanku.</p>\n</li>\n<li>\n<p><span class=\"highlighted-text\">Adiós, hasta luego.</span> – Doviđenja, vidimo se kasnije.</p>\n</li>\n<li>\n<p><span class=\"highlighted-text\">Hasta mañana.</span> – Vidimo se sutra (različito za sledeći dan).</p>\n</li>\n</ul>\n</section>","helpCategory":"Spanish Curriculum","instructions":"<section id=\"instructions\">\n<p>Slušajte audio i odgovorite na pitanje ispod.</p>\n</section>","fields":{"slug":"/learn/a1-professional-spanish/es-a1-learn-meet-luna/task-9"},"questions":[{"text":"<p>Šta znači Luna kada kaže <span class=\"highlighted-text\">Hasta luego</span>?</p>","answers":[{"answer":"<p>Kaže laku noć.</p>","feedback":"<p>Ovaj izraz se ne koristi za željanje laku noć ljudima. Koristi se za oproštaj na sada, ali sa očekivanjem da ćemo se uskoro ponovo sresti.</p>","audioId":null},{"answer":"<p>Nadam se da će te videti kasnije.</p>","feedback":null,"audioId":null},{"answer":"<p>Predstavlja se.</p>","feedback":"<p>Ovaj izraz se ne koristi za identifikaciju. Koristi se za oproštaj.</p>","audioId":null},{"answer":"<p>Pita o tvom stanju.</p>","feedback":"<p>Ovo nije pitanje. Luna završava razgovor sa poštovanjem.</p>","audioId":null}],"solution":2}],"scene":{"setup":{"background":"desk.png","characters":[{"character":"Luna","position":{"x":50,"y":25,"z":1.5},"opacity":0}],"audio":{"filename":"ES_A1_spanish_meet_luna.mp3","startTime":1,"startTimestamp":8.79,"finishTimestamp":10.57},"alwaysShowDialogue":null},"commands":[{"background":null,"character":"Luna","position":null,"opacity":1,"startTime":0,"finishTime":null,"dialogue":null},{"background":null,"character":"Luna","position":null,"opacity":null,"startTime":1,"finishTime":1.92,"dialogue":{"text":"Hasta luego.","align":"center"}},{"background":null,"character":"Luna","position":null,"opacity":null,"startTime":2.09,"finishTime":2.78,"dialogue":{"text":"Adiós.","align":"center"}},{"background":null,"character":"Luna","position":null,"opacity":0,"startTime":3.28,"finishTime":null,"dialogue":null}]},"superBlock":"a1-professional-spanish","tests":[],"title":"Vežba 9","transcript":null,"translationPending":false,"videoId":null,"videoLocaleIds":null}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/a1-professional-spanish/#es-a1-learn-meet-luna","dashedName":"task-9","certification":"a1-professional-spanish","disableLoopProtectTests":false,"disableLoopProtectPreview":false,"superBlock":"a1-professional-spanish","chapter":"es-a1-chapter-greetings-and-introductions","module":"es-a1-module-introducing-yourself","block":"es-a1-learn-meet-luna","isFirstStep":false,"template":null,"required":[],"isLastChallengeInBlock":false,"nextChallengePath":"/learn/a1-professional-spanish/es-a1-learn-meet-luna/task-10","prevChallengePath":"/learn/a1-professional-spanish/es-a1-learn-meet-luna/task-8","id":"6914af61cb72593f7ad505cf","saveSubmissionToDB":null},"projectPreview":{"challengeData":{"challengeType":22,"challengeFiles":[]}},"id":"/learn/a1-professional-spanish/es