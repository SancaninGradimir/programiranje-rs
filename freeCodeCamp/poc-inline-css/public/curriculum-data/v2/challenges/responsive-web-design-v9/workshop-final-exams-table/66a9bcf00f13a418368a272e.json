    {
      "text": "<p>Vaš prvi <code>th</code> element bi trebalo da ima tekst od <code>Last Name</code>.</p>",
      "testString": "const thEl = document.querySelectorAll('th')[0];\nassert.strictEqual(thEl?.textContent.trim(), 'Last Name');"
