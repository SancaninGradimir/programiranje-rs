{"componentChunkName":"component---src-templates-challenges-classic-show-tsx","path":"/learn/2022/responsive-web-design/learn-basic-css-by-building-a-cafe-menu/step-21","result":{"data":{"challengeNode":{"challenge":{"block":"learn-basic-css-by-building-a-cafe-menu","demoType":null,"title":"Korak 21","description":"<section id=\"description\">\n<p>Cilj je sada da <code>div</code> ne zauzme celu širinu stranice. Svojstvo CSS <code>width</code> je savršeno za ovo.</p>\n<p>Možete koristiti selektor <code>id</code> da biste ciljali specifičan element sa atributom <code>id</code>. Selektor <code>id</code> je definisan postavljanjem haš znaka (hash #) <code>#</code> direktno ispred vrednosti <code>id</code> elementa. Na primer, ako element ima <code>id</code> sa <code>cat</code>, onda biste želeli da ciljate taj element ovako:</p>\n<pre><code class=\"language-css\">#cat {\n  width: 250px;\n}\n</code></pre>\n<p>Koristite alat <code>#menu</code> da dodate vašu širinu <code>300px</code>.</p>\n</section>","id":"5f356ed63c7807a4f1e6d054","hasEditableBoundaries":true,"instructions":"","notes":null,"challengeType":0,"helpCategory":"HTML-CSS","videoUrl":null,"superBlock":"2022/responsive-web-design","translationPending":false,"forumTopicId":null,"hooks":null,"fields":{"slug":"/learn/2022/responsive-web-design/learn-basic-css-by-building-a-cafe-menu/step-21"},"required":[],"usesMultifileEditor":true,"challengeFiles":[{"fileKey":"indexhtml","ext":"html","name":"index","contents":"<!DOCTYPE html>\n<html lang=\"en\">\n  <head>\n    <meta charset=\"utf-8\" />\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" />\n    <title>Cafe Menu</title>\n    <link href=\"styles.css\" rel=\"stylesheet\"/>\n  </head>\n  <body>\n    <div id=\"menu\">\n      <main>\n        <h1>CAMPER CAFE</h1>\n        <p>Est. 2020</p>\n        <section>\n          <h2>Coffee</h2>\n        </section>\n      </main>\n    </div>\n  </body>\n</html>","head":null,"tail":null,"editableRegionBoundaries":[],"history":["index.html"]},{"fileKey":"stylescss","ext":"css","name":"styles","contents":"body {\n  background-color: burlywood;\n}\n\nh1, h2, p {\n  text-align: center;\n}\n","head":null,"tail":null,"editableRegionBoundaries":[0,8],"history":["styles.css"]}],"saveSubmissionToDB":null,"tests":[{"text":"<p>Trebalo bi da imaš selektor za <code>#menu</code>.</p>","testString":"const hasDiv = new __helpers.CSSHelp(document).getStyle(\"#menu\");\nassert(hasDiv);"},{"text":"<p>Treba da postaviš vrednost za <code>width</code> na <code>300px</code>.</p>","testString":"const hasWidth = new __helpers.CSSHelp(document).getCSSRules().some(x => x.style.width === '300px');\nassert(hasWidth);"},{"text":"<p><code>div</code> Vaša širina mora biti 300px.</p>","testString":"const divWidth = new __helpers.CSSHelp(document).getStyle(\"#menu\")?.getPropertyValue('width');\nassert(divWidth === '300px');"}]}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/2022/responsive-web-design/#learn-basic-css-by-building-a-cafe-menu","dashedName":"step-21","certification":"responsive-web-design","disableLoopProtectTests":false,"disableLoopProtectPreview":false,"superBlock":"2022/responsive-web-design","chapter":null,"module":null,"block":"learn-basic-css-by-building-a-cafe-menu","isFirstStep":false,"template":null,"required":[],"isLastChallengeInBlock":false,"nextChallengePath":"/learn/2022/responsive-web-design/learn-basic-css-by-building-a-cafe-menu/step-22","prevChallengePath":"/learn/2022/responsive-web-design/learn-basic-css-by-building-a-cafe-menu/step-20","id":"5f356ed63c7807a4f1e6d054","saveSubmissionToDB":null},"projectPreview":{"challengeData":{"challengeType":0,"challengeFiles":[{"name":"index","ext":"html","contents":"<!DOCTYPE html>\n<html lang=\"en\">\n  <head>\n    <meta charset=\"utf-8\" />\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" />\n    <title>Cafe Menu</title>\n    <link href=\"styles.css\" rel=\"stylesheet\"/>\n  </head>\n  <body>\n    <div class=\"menu\">\n      <main>\n        <h1>CAMPER CAFE</h1>\n        <p class=\"established\">Est. 2020</p>\n        <hr>\n        <section>\n          <h2>Coffee</h2>\n          <img src=\"https://cdn.freecodecamp.org/curriculum/css-cafe/coffee.jpg\" alt=\"coffee icon\"/>\n          <article class=\"item\">\n            <p class=\"flavor\">French Vanilla</p><p class=\"price\">3.00</p>\n          </article>\n          <article class=\"item\">\n            <p class=\"flavor\">Caramel Macchiato</p><p class=\"price\">3.75</p>\n          </article>\n          <article class=\"item\">\n            <p class=\"flavor\">Pumpkin Spice</p><p class=\"price\">3.50</p>\n          </article>\n          <article class=\"item\">\n            <p class=\"flavor\">Hazelnut</p><p class=\"price\">4.00</p>\n          </article>\n          <article class=\"item\">\n            <p class=\"flavor\">Mocha</p><p class=\"price\">4.50</p>\n          </article>\n        </section>\n        <section>\n          <h2>Desserts</h2>\n          <img src=\"https://cdn.freecodecamp.org/curriculum/css-cafe/pie.jpg\" alt=\"pie icon\"/>\n          <article class=\"item\">\n            <p class=\"dessert\">Donut</p><p class=\"price\">1.50</p>\n          </article>\n          <article class=\"item\">\n            <p class=\"dessert\">Cherry Pie</p><p class=\"price\">2.75</p>\n          </article>\n          <article class=\"item\">\n            <p class=\"dessert\">Cheesecake</p><p class=\"price\">3.00</p>\n          </article>\n          <article class=\"item\">\n            <p class=\"dessert\">Cinnamon Roll</p><p class=\"price\">2.50</p>\n          </article>\n        </section>\n      </main>\n      <hr class=\"bottom-line\">\n      <footer>\n        <p>\n          <a href=\"https://www.freecodecamp.org\" target=\"_blank\">Visit our website</a>\n        </p>\n        <p class=\"address\">123 Free Code Camp Drive</p>\n      </footer>\n    </div>\n  </body>\n</html>","history":["index.html"],"fileKey":"indexhtml"},{"name":"styles","ext":"css","contents":"body {\n  background-image: url(https://cdn.freecodecamp.org/curriculum/css-cafe/beans.jpg);\n  font-family: sans-serif;\n  padding: 20px;\n}\n\nh1 {\n  font-size: 40px;\n  margin-top: 0;\n  margin-bottom: 15px;\n}\n\nh2 {\n  font-size: 30px;\n}\n\n.established {\n  font-style: italic;\n}\n\nh1, h2, p {\n  text-align: center;\n}\n\n.menu {\n  width: 80%;\n  background-color: burlywood;\n  margin-left: auto;\n  margin-right: auto;\n  padding: 20px;\n  max-width: 500px;\n}\n\nimg {\n  display: block;\n  margin-left: auto;\n  margin-right: auto;\n  margin-top: -25px;\n}\n\nhr {\n  height: 2px;\n  background-color: brown;\n  border-color: brown;\n}\n\n.bottom-line {\n  margin-top: 25px;\n}\n\nh1, h2 {\n  font-family: Impact, serif;\n}\n\n.item p {\n  display: inline-block;\n  margin-top: 5px;\n  margin-bottom: 5px;\n  font-size: 18px;\n}\n\n.flavor, .dessert {\n  text-align: left;\n  width: 75%;\n}\n\n.price {\n  text-align: right;\n  width: 25%;\n}\n\n/* FOOTER */\n\nfooter {\n  font-size: 14px;\n}\n\n.address {\n  margin-bottom: 5px;\n}\n\na {\n  color: black;\n}\n\na:visited {\n  color: black;\n}\n\na:hover {\n  color: brown;\n}\n\na:active {\n  color: brown;\n}","history":["styles.css"],"fileKey":"stylescss"}]}},"id":"/learn/2022/responsive-web-design/learn-basic-css-by-building-a-cafe-menu/step-21"}},"staticQueryHashes":["3858520367"],"slicesMap":{}}