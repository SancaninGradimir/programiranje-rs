    {
      "text": "<p>Vaš drugi <code>th</code> element treba da ima tekst od <code>First Name</code>.</p>",
      "testString": "const thEl = document.querySelectorAll('th')[1];\nassert.strictEqual(thEl?.textContent.trim(), 'First Name');"
    },
    {
      "text": "<p>Vaš treći <code>th</code> element bi trebalo da ima tekst od <code>Grade</code>.</p>",
      "testString": "const thEl = document.querySelectorAll('th')[2];\nassert.strictEqual(thEl?.textContent.trim(), 'Grade');"
