      "text": "<p><code>destroyer([\"possum\", \"trollo\", 12, \"safari\", \"hotdog\", 92, 65, \"grandma\", \"bugati\", \"trojan\", \"yacht\"], \"yacht\", \"possum\", \"trollo\", \"safari\", \"hotdog\", \"grandma\", \"bugati\", \"trojan\")</code> trebalo bi da vrati <code>[12,92,65]</code>.</p>",
      "testString": "assert.deepEqual(\r\n  destroyer(\r\n    [\r\n      'possum',\r\n      'trollo',\r\n      12,\r\n      'safari',\r\n      'hotdog',\r\n      92,\r\n      65,\r\n      'grandma',\r\n      'bugati',\r\n      'trojan',\r\n      'yacht'\r\n    ],\r\n    'yacht',\r\n    'possum',\r\n    'trollo',\r\n    'safari',\r\n    'hotdog',\r\n    'grandma',\r\n    'bugati',\r\n    'trojan'\r\n  ),\r\n  [12, 92, 65]\r\n);"
