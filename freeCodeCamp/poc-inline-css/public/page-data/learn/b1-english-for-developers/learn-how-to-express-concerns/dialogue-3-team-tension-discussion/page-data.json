{"componentChunkName":"component---src-templates-challenges-generic-show-tsx","path":"/learn/b1-english-for-developers/learn-how-to-express-concerns/dialogue-3-team-tension-discussion","result":{"data":{"challengeNode":{"challenge":{"assignments":["<p>Gledaj video.</p>"],"bilibiliIds":null,"block":"learn-how-to-express-concerns","challengeType":21,"description":"<section id=\"description\">\n<p>Pogledajte video ispod da biste razumeli kontekst sledećih lekcija.</p>\n</section>","nodules":null,"explanation":null,"helpCategory":"English","instructions":"","fields":{"slug":"/learn/b1-english-for-developers/learn-how-to-express-concerns/dialogue-3-team-tension-discussion"},"questions":[],"scene":{"setup":{"background":"company2-boardroom.png","characters":[{"character":"Bob","position":{"x":-25,"y":0,"z":1},"opacity":null},{"character":"Maria","position":{"x":125,"y":0,"z":1},"opacity":null}],"audio":{"filename":"B1_12-3.mp3","startTime":1,"startTimestamp":null,"finishTimestamp":null},"alwaysShowDialogue":true},"commands":[{"background":null,"character":"Bob","position":{"x":25,"y":0,"z":1},"opacity":null,"startTime":0,"finishTime":null,"dialogue":null},{"background":null,"character":"Maria","position":{"x":70,"y":0,"z":1},"opacity":null,"startTime":0.5,"finishTime":null,"dialogue":null},{"background":null,"character":"Bob","position":null,"opacity":null,"startTime":1,"finishTime":6.02,"dialogue":{"text":"Hi, Maria. I heard there was some tension in the last team meeting. Can we talk about it?","align":"left"}},{"background":null,"character":"Maria","position":null,"opacity":null,"startTime":6.38,"finishTime":9.94,"dialogue":{"text":"Sure, Bob. It's about the new deadline. The team is really worried it's too tight.","align":"right"}},{"background":null,"character":"Maria","position":null,"opacity":null,"startTime":10.04,"finishTime":12.24,"dialogue":{"text":"They're feeling quite overwhelmed with the extra workload.","align":"right"}},{"background":null,"character":"Bob","position":null,"opacity":null,"startTime":12.78,"finishTime":15.54,"dialogue":{"text":"I see. Did they mention why they think it's too tight?","align":"left"}},{"background":null,"character":"Maria","position":null,"opacity":null,"startTime":16.3,"finishTime":21.38,"dialogue":{"text":"Yes, they said they're already putting in extra hours. If we add more tasks, it could lead to burnout.","align":"right"}},{"background":null,"character":"Bob","position":null,"opacity":null,"startTime":22.12,"finishTime":24.1,"dialogue":{"text":"So did they say how we could fix it?","align":"left"}},{"background":null,"character":"Maria","position":null,"opacity":null,"startTime":24.5,"finishTime":27.92,"dialogue":{"text":"They mentioned a couple of things. First, they really need more support.","align":"right"}},{"background":null,"character":"Maria","position":null,"opacity":null,"startTime":28.12,"finishTime":31.82,"dialogue":{"text":"We're quite short on a few roles, which makes it really hard to meet the new deadline.","align":"right"}},{"background":null,"character":"Bob","position":null,"opacity":null,"startTime":32.32,"finishTime":34.48,"dialogue":{"text":"Okay. Is there anything else we should consider?","align":"left"}},{"background":null,"character":"Maria","position":null,"opacity":null,"startTime":35.9,"finishTime":41.12,"dialogue":{"text":"They also said the communication isn't great because they often don't hear about changes until it's too late.","align":"right"}},{"background":null,"character":"Maria","position":null,"opacity":null,"startTime":41.62,"finishTime":43.58,"dialogue":{"text":"It'd be helpful if we had more regular check-ins.","align":"right"}},{"background":null,"character":"Bob","position":null,"opacity":null,"startTime":44.3,"finishTime":49.18,"dialogue":{"text":"That makes sense. Could you set up a weekly meeting to discuss progress and keep everyone in the loop?","align":"left"}},{"background":null,"character":"Bob","position":null,"opacity":null,"startTime":49.42,"finishTime":52.44,"dialogue":{"text":"It might help reduce stress and avoid misunderstandings.","align":"left"}},{"background":null,"character":"Maria","position":null,"opacity":null,"startTime":52.72,"finishTime":57.02,"dialogue":{"text":"Sure, I can do that. But to really ease the pressure, we might need to adjust the deadline","align":"right"}},{"background":null,"character":"Maria","position":null,"opacity":null,"startTime":57.02,"finishTime":60.38,"dialogue":{"text":"even if it's just a few days. This would give the team some breathing room.","align":"right"}},{"background":null,"character":"Bob","position":null,"opacity":null,"startTime":60.64,"finishTime":65.08,"dialogue":{"text":"I'll look into it. Could you also find out how much extra time they really need?","align":"left"}},{"background":null,"character":"Maria","position":null,"opacity":null,"startTime":65.56,"finishTime":67.78,"dialogue":{"text":"Sure. I'll talk to the team and let you know what they say.","align":"right"}},{"background":null,"character":"Maria","position":null,"opacity":null,"startTime":68.06,"finishTime":70.54,"dialogue":{"text":"Let's also plan a meeting to discuss resources with HR.","align":"right"}},{"background":null,"character":"Maria","position":{"x":125,"y":0,"z":1},"opacity":null,"startTime":71.04,"finishTime":null,"dialogue":null},{"background":null,"character":"Bob","position":{"x":-25,"y":0,"z":1},"opacity":null,"startTime":71.54,"finishTime":null,"dialogue":null}]},"superBlock":"b1-english-for-developers","tests":[],"title":"Dijalog 3: Diskusija o napetosti tima","transcript":null,"translationPending":false,"videoId":null,"videoLocaleIds":null}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/b1-english-for-developers/#learn-how-to-express-concerns","dashedName":"dialogue-3-team-tension-discussion","certification":"b1-english-for-developers","disableLoopProtectTests":false,"disableLoopProtectPreview":false,"superBlock":"b1-english-for-developers",