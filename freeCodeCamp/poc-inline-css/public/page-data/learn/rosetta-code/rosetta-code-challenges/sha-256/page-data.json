{"componentChunkName":"component---src-templates-challenges-classic-show-tsx","path":"/learn/rosetta-code/rosetta-code-challenges/sha-256","result":{"data":{"challengeNode":{"challenge":{"block":"rosetta-code-challenges","demoType":null,"title":"SHA-256","description":"<section id=\"description\">\n<p>Porodica <code>SHA-2</code> je jača alternativa od <code>SHA-1</code>. Glavna razlika između njih je dužina heš-a.\nTo znači da <code>SHA-1</code> generiše kratak kod sa niskom verovatnoćom jedinstvene kombinacije. <code>SHA-2</code> ili <code>SHA-256</code> kreiraju duži i stoga jači heš sa većom verovatnoćom.</p>\n</section>","id":"5eb3e4c3a894c333d2811a3f","hasEditableBoundaries":false,"instructions":"<section id=\"instructions\">\n<p>Izvršite istraživanje o detaljima implementacije i napišite funkciju koja prima niz znakova kao parametar i vraća heš koristeći <code>SHA-256</code></p>\n</section>","notes":null,"challengeType":1,"helpCategory":"Rosetta","videoUrl":null,"superBlock":"rosetta-code","translationPending":false,"forumTopicId":385328,"hooks":null,"fields":{"slug":"/learn/rosetta-code/rosetta-code-challenges/sha-256"},"required":[],"usesMultifileEditor":false,"challengeFiles":[{"fileKey":"scriptjs","ext":"js","name":"script","contents":"function SHA256(input) {\n\n}","head":null,"tail":null,"editableRegionBoundaries":[],"history":["script.js"]}],"saveSubmissionToDB":null,"tests":[{"text":"<p><code>SHA256</code> Trebalo bi da bude funkcija.</p>","testString":"assert(typeof SHA256 === 'function');"},{"text":"<p><code>SHA256(\"Rosetta code\")</code> Trebalo bi da vrati niz znakova.</p>","testString":"assert(typeof SHA256('Rosetta code') === 'string');"},{"text":"<p><code>SHA256(\"Rosetta code\")</code> treba da vrati <code>\"764faf5c61ac315f1497f9dfa542713965b785e5cc2f707d6468d7d1124cdfcf\"</code>.</p>","testString":"assert.equal(\n  SHA256('Rosetta code'),\n  '764faf5c61ac315f1497f9dfa542713965b785e5cc2f707d6468d7d1124cdfcf'\n);"},{"text":"<p><code>SHA256(\"SHA-256 Hash\")</code> trebalo bi da vrati <code>\"bee8c0cabdcf8c7835f40217dd35a8b0dba9134520e633f1c57285f35ca7ee3e\"</code>.</p>","testString":"assert.equal(\n  SHA256('SHA-256 Hash'),\n  'bee8c0cabdcf8c7835f40217dd35a8b0dba9134520e633f1c57285f35ca7ee3e'\n);"},{"text":"<p><code>SHA256(\"implementation\")</code> treba da vrati <code>\"da31012c40330e7e21538e7dd57503b16e8a0839159e96137090cccc9910b171\"</code>.</p>","testString":"assert.equal(\n  SHA256('implementation'),\n  'da31012c40330e7e21538e7dd57503b16e8a0839159e96137090cccc9910b171'\n);"},{"text":"<p><code>SHA256(\"algorithm\")</code> treba vratiti <code>\"b1eb2ec8ac9f31ff7918231e67f96e6deda83a9ff33ed2c67443f1df81e5ed14\"</code>.</p>","testString":"assert.equal(\n  SHA256('algorithm'),\n  'b1eb2ec8ac9f31ff7918231e67f96e6deda83a9ff33ed2c67443f1df81e5ed14'\n);"},{"text":"<p><code>SHA256(\"language\")</code> treba da vrati <code>\"a4ef304ba42a200bafd78b046e0869af9183f6eee5524aead5dcb3a5ab5f8f3f\"</code>.</p>","testString":"assert.equal(\n  SHA256('language'),\n  'a4ef304ba42a200bafd78b046e0869af9183f6eee5524aead5dcb3a5ab5f8f3f'\n);"}]}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/rosetta-code/#rosetta-code-challenges","dashedName":"sha-256","certification":"rosetta-code","disableLoopProtectTests":true,"disableLoopProtectPreview":false,"superBlock":"rosetta-code","chapter":null,"module":null,"block":"rosetta-code-challenges","isFirstStep":false,"template":null,"required":[],"isLastChallengeInBlock":false,"nextChallengePath":"/learn/rosetta-code/rosetta-code-challenges/sort-an-array-of-composite-structures","prevChallengePath":"/learn/rosetta-code/rosetta-code-challenges/sha-1","id":"5eb3e4c3a894c333d2811a3f","saveSubmissionToDB":null},"projectPreview":{"challengeData":{"challengeType":1,"challengeFiles":[{"name":"script","ext":"js","contents":"function ZigZagMatrix(n) {\n  const mtx = [];\n  for (let i = 0; i < n; i++) {\n    mtx[i] = [];\n  }\n\n  let i = 1;\n  let j = 1;\n  for (let e = 0; e < n * n; e++) {\n    mtx[i - 1][j - 1] = e;\n    if ((i + j) % 2 === 0) {\n      // Even stripes\n      if (j < n) j++;\n      else i += 2;\n      if (i > 1) i--;\n    } else {\n      // Odd stripes\n      if (i < n) i++;\n      else j += 2;\n      if (j > 1) j--;\n    }\n  }\n  return mtx;\n}","history":["script.js"],"fileKey":"scriptjs"}]}},"id":"/learn/rosetta-code/rosetta-code-challenges/sha-256"}},"staticQueryHashes":["3858520367"],"slicesMap":{}}