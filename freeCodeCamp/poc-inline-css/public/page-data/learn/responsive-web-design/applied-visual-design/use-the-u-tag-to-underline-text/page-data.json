{"componentChunkName":"component---src-templates-challenges-classic-show-tsx","path":"/learn/responsive-web-design/applied-visual-design/use-the-u-tag-to-underline-text","result":{"data":{"challengeNode":{"challenge":{"block":"applied-visual-design","demoType":null,"title":"Koristite u tag za podvlačenje teksta","description":"<section id=\"description\">\n<p>Da biste podvukli tekst, možete koristiti <code>u</code> tag. Ovo se često koristi da označi da je deo teksta važan ili nešto što treba zapamtiti. Sa <code>u</code> tagom, pretraživač primenjuje CSS <code>text-decoration: underline;</code> na taj element.</p>\n</section>","id":"587d781a367417b2b2512ab8","hasEditableBoundaries":false,"instructions":"<section id=\"instructions\">\n<p>Omotajte <code>u</code> tag samo oko teksta <code>Ph.D. students</code>.</p>\n<p><strong>Napomena:</strong> Pokušajte da izbegnete korišćenje <code>u</code> taga kada može biti zamijenjen sa linkom. Sidreni tagovi takođe imaju podvučen stil po defaultu.</p>\n</section>","notes":null,"challengeType":0,"helpCategory":"HTML-CSS","videoUrl":"https://scrimba.com/c/cN6aQCL","superBlock":"responsive-web-design","translationPending":false,"forumTopicId":301082,"hooks":null,"fields":{"slug":"/learn/responsive-web-design/applied-visual-design/use-the-u-tag-to-underline-text"},"required":[],"usesMultifileEditor":false,"challengeFiles":[{"fileKey":"indexhtml","ext":"html","name":"index","contents":"<style>\n  h4 {\n    text-align: center;\n    height: 25px;\n  }\n  p {\n    text-align: justify;\n  }\n  .links {\n    text-align: left;\n    color: black;\n  }\n  .fullCard {\n    width: 245px;\n    border: 1px solid #ccc;\n    border-radius: 5px;\n    margin: 10px 5px;\n    padding: 4px;\n  }\n  .cardContent {\n    padding: 10px;\n  }\n  .cardText {\n    margin-bottom: 30px;\n  }\n</style>\n<div class=\"fullCard\">\n  <div class=\"cardContent\">\n    <div class=\"cardText\">\n      <h4>Google</h4>\n      <p>Google was founded by Larry Page and Sergey Brin while they were Ph.D. students at <strong>Stanford University</strong>.</p>\n    </div>\n    <div class=\"cardLinks\">\n      <a href=\"https://en.wikipedia.org/wiki/Larry_Page\" target=\"_blank\" class=\"links\">Larry Page</a><br><br>\n      <a href=\"https://en.wikipedia.org/wiki/Sergey_Brin\" target=\"_blank\" class=\"links\">Sergey Brin</a>\n    </div>\n  </div>\n</div>","head":null,"tail":null,"editableRegionBoundaries":[],"history":["index.html"]}],"saveSubmissionToDB":null,"tests":[{"text":"<p>Vaš kod treba da doda <code>u</code> tag u oznake.</p>","testString":"assert.lengthOf(document.querySelectorAll('u'), 1);"},{"text":"<p><code>u</code> tag treba da okružuje tekst <code>Ph.D. students</code>.</p>","testString":"assert.equal(document.querySelector('u')?.textContent , 'Ph.D. students');"}]}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/responsive-web-design/#applied-visual-design","dashedName":"use-the-u-tag-to-underline-text","certification":"responsive-web-design","disableLoopProtectTests":false,"disableLoopProtectPreview":false,"superBlock":"responsive-web-design","chapter":null,"module":null,"block":"applied-visual-design","isFirstStep":false,"template":null,"required":[],"isLastChallengeInBlock":false,"nextChallengePath":"/learn/responsive-web-design/applied-visual-design/use-the-em-tag-to-italicize-text","prevChallengePath":"/learn/responsive-web-design/applied-visual-design/use-the-strong-tag-to-make-text-bold","id":"587d781a367417b2b2512ab8","saveSubmissionToDB":null},"projectPreview":{"challengeData":{"challengeType":0,"challengeFiles":[{"name":"index","ext":"html","contents":"<style>\n  .balls {\n    border-radius: 50%;\n    position: fixed;\n    width: 50px;\n    height: 50px;\n    top: 60%;\n    animation-name: jump;\n    animation-duration: 2s;\n    animation-iteration-count: infinite;\n  }\n  #red {\n    background: red;\n    left: 25%;\n    animation-timing-function: linear;\n  }\n  #blue {\n    background: blue;\n    lef