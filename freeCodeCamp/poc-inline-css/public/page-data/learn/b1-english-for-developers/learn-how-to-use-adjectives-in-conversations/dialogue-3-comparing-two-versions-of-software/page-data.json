{"componentChunkName":"component---src-templates-challenges-generic-show-tsx","path":"/learn/b1-english-for-developers/learn-how-to-use-adjectives-in-conversations/dialogue-3-comparing-two-versions-of-software","result":{"data":{"challengeNode":{"challenge":{"assignments":["<p>Gledaj video.</p>"],"bilibiliIds":null,"block":"learn-how-to-use-adjectives-in-conversations","challengeType":21,"description":"<section id=\"description\">\n<p>Pogledajte video dole/ispod kako biste razumeli kontekst predstojećih lekcija.</p>\n</section>","nodules":null,"explanation":null,"helpCategory":"English","instructions":"","fields":{"slug":"/learn/b1-english-for-developers/learn-how-to-use-adjectives-in-conversations/dialogue-3-comparing-two-versions-of-software"},"questions":[],"scene":{"setup":{"background":"company2-center.png","characters":[{"character":"Jessica","position":{"x":-25,"y":0,"z":1},"opacity":null},{"character":"James","position":{"x":125,"y":0,"z":1},"opacity":null}],"audio":{"filename":"B1_19-3.mp3","startTime":1,"startTimestamp":null,"finishTimestamp":null},"alwaysShowDialogue":true},"commands":[{"background":null,"character":"Jessica","position":{"x":25,"y":0,"z":1},"opacity":null,"startTime":0,"finishTime":null,"dialogue":null},{"background":null,"character":"James","position":{"x":70,"y":0,"z":1},"opacity":null,"startTime":0.5,"finishTime":null,"dialogue":null},{"background":null,"character":"Jessica","position":null,"opacity":null,"startTime":1,"finishTime":5.14,"dialogue":{"text":"Good morning, James. Today we need to compare two versions of our software.","align":"left"}},{"background":null,"character":"Jessica","position":null,"opacity":null,"startTime":5.64,"finishTime":10.06,"dialogue":{"text":"Let's start with how they look. The new one seems easier to use and cleaner than the old one.","align":"left"}},{"background":null,"character":"James","position":null,"opacity":null,"startTime":10.34,"finishTime":17.9,"dialogue":{"text":"Yes, Jessica. I agree. The new version not only looks better, but also works better. It's faster and responds quicker when we do things on it.","align":"right"}},{"background":null,"character":"Jessica","position":null,"opacity":null,"startTime":18.6,"finishTime":23.36,"dialogue":{"text":"That's good to hear. What about how stable they are? Does the new version work without stopping or crashing?","align":"left"}},{"background":null,"character":"James","position":null,"opacity":null,"startTime":23.82,"finishTime":29.28,"dialogue":{"text":"The new version is much more stable. We've seen fewer problems and it doesn't stop working as much.","align":"right"}},{"background":null,"character":"James","position":null,"opacity":null,"startTime":29.28,"finishTime":32.58,"dialogue":{"text":"It can handle more data now, which is much better.","align":"right"}},{"background":null,"character":"Jessica","position":null,"opacity":null,"startTime":33.58,"finishTime":39.2,"dialogue":{"text":"Great. How about adjusting to different screen sizes? The old version was quite good at this, but the new one is even better, right?","align":"left"}},{"background":null,"character":"James","position":null,"opacity":null,"startTime":39.54,"finishTime":48.02,"dialogue":{"text":"Yes, it changes size really well. It works great on different devices. Everything adjusts by itself and looks good, which makes it nicer to use.","align":"right"}},{"background":null,"character":"Jessica","position":null,"opacity":null,"startTime":48.52,"finishTime":50.94,"dialogue":{"text":"That's good. And installing it, is it faster now?","align":"left"}},{"background":null,"character":"James","position":null,"opacity":null,"startTime":51.42,"finishTime":59.42,"dialogue":{"text":"Yes, it now installs much quicker. It's easier for users to start using it immediately after they download it. The setup is simple, which helps a lot.","align":"right"}},{"background":null,"character":"Jessica","position":null,"opacity":null,"startTime":60.68,"finishTime":64.28,"dialogue":{"text":"That's a good improvement. Have people reported fewer problems with this new version?","align":"left"}},{"background":null,"character":"James","position":null,"opacity":null,"startTime":64.68,"finishTime":72.64,"dialogue":{"text":"Yes, there are fewer big problems now. Most issues are small and not so serious. It looks like we fixed many of the big problems from before.","align":"right"}},{"background":null,"character":"Jessica","position":null,"opacity":null,"startTime":73.18,"finishTime":77.34,"dialogue":{"text":"That sounds good. Lastly, can the new version handle more users than the old one?","align":"left"}},{"background":null,"character":"James","position":null,"opacity":null,"startTime":77.66,"finishTime":87.08,"dialogue":{"text":"Definitely. The new version can support more users and handle more actions at once. We've made sure it can grow as more users join without slowing down.","align":"right"}},{"background":null,"character":"Jessica","position":null,"opacity":null,"startTime":87.76,"finishTime":94.52,"dialogue":{"text":"Fantastic, James. I'll put all this information into a report and talk about it with the team tomorrow. This feedback should help us know what to do next.","align":"left"}},{"background":null,"character":"James","position":null,"opacity":null,"startTime":94.94,"finishTime":98.46,"dialogue":{"text":"I'm glad to help. Let me know if you need any more information for the report.","align":"right"}},{"background":null,"character":"James","position":{"x":125,"y":0,"z":1},"opacity":null,"startTime":98.96,"finishTime":null,"dialogue":null},{"background":null,"character":"Jessica","position":{"x":-25,"y":0,"z":1},"opacity":null,"startTime":99.46,"finishTime":null,"dialogue":null}]},"superBlock":"b1-english-for-developers","tests":[],"title":"Dijalog 3: Poređenje dve verzije softvera","transcript":null,"translationPending":false,"videoId":null,"videoLocaleIds":null}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/b1-english-for-developers/#learn-how-to-use-adjectives-in-conversations","dashedName":"dialogue-3-comparing-two-versions-of-software","certification":"b1-english-for-developers","disableLoopProtectTests":false,"disableLoopProtectPreview":false,"superBlock":"b1-english-for-developers","chapter":null,"module":null,"block":"learn-how-to-use-adjectives-in-conversations","isFirstStep":false,"template":null,"required":[],"isLastChallengeInBlock":false,"nextChallengePath":"/learn/b1-english-for-developers/learn-how-to-use-adjectives-in-conversations/task-107","prevChallengePath":"/learn/b1-english-for-developers/learn-how-to-use-adjectives-in-conversations/task-106","id":"6821ee36e2f3b566c32cb11a","saveSubmissionToDB":null},"projectPreview":{"challengeData":{"challengeType":19,"challengeFiles":[]}},"id":"/learn/b1-english-for-developers/learn-how-to-use-adjectives-in-conversations/dialogue-3-comparing-two-versions-of-software"}},"staticQueryHashes":["3858520367"],"slicesMap":{}}