        "path": "script.js",
        "fileKey": "scriptjs",
        "contents": "function largestOfFour(arr) {\n  return arr.map(subArr => Math.max.apply(null, subArr));\n}\n\nlargestOfFour([\n  [4, 5, 1, 3],\n  [13, 27, 18, 26],\n  [32, 35, 37, 39],\n  [1000, 1001, 857, 1]\n]);",
        "error": null,
        "seed": "function largestOfFour(arr) {\n  return arr.map(subArr => Math.max.apply(null, subArr));\n}\n\nlargestOfFour([\n  [4, 5, 1, 3],\n  [13, 27, 18, 26],\n  [32, 35, 37, 39],\n  [1000, 1001, 857, 1]\n]);"
      }
    ]
  ],
