{"componentChunkName":"component---src-templates-challenges-generic-show-tsx","path":"/learn/b1-english-for-developers/learn-how-to-express-decisions-based-on-comparisons/dialogue-1-comparing-software-features","result":{"data":{"challengeNode":{"challenge":{"assignments":["<p>Gledaj video.</p>"],"bilibiliIds":null,"block":"learn-how-to-express-decisions-based-on-comparisons","challengeType":21,"description":"<section id=\"description\">\n<p>Pogledajte video ispod da biste razumeli kontekst sledećih lekcija.</p>\n</section>","nodules":null,"explanation":null,"helpCategory":"English","instructions":"","fields":{"slug":"/learn/b1-english-for-developers/learn-how-to-express-decisions-based-on-comparisons/dialogue-1-comparing-software-features"},"questions":[],"scene":{"setup":{"background":"company2-center.png","characters":[{"character":"Sophie","position":{"x":-25,"y":0,"z":1},"opacity":null},{"character":"Jake","position":{"x":125,"y":0,"z":1},"opacity":null}],"audio":{"filename":"B1_13-1.mp3","startTime":1,"startTimestamp":null,"finishTimestamp":null},"alwaysShowDialogue":true},"commands":[{"background":null,"character":"Sophie","position":{"x":25,"y":0,"z":1},"opacity":null,"startTime":0,"finishTime":null,"dialogue":null},{"background":null,"character":"Jake","position":{"x":70,"y":0,"z":1},"opacity":null,"startTime":0.5,"finishTime":null,"dialogue":null},{"background":null,"character":"Sophie","position":null,"opacity":null,"startTime":1,"finishTime":4.62,"dialogue":{"text":"Hey Jake, I'm looking at two software tools for our next project.","align":"left"}},{"background":null,"character":"Sophie","position":null,"opacity":null,"startTime":5,"finishTime":7.12,"dialogue":{"text":"Can you help me decide which one is better for security?","align":"left"}},{"background":null,"character":"Jake","position":null,"opacity":null,"startTime":7.54,"finishTime":9.4,"dialogue":{"text":"Sure Sophie, what are the options?","align":"right"}},{"background":null,"character":"Sophie","position":null,"opacity":null,"startTime":9.88,"finishTime":12.76,"dialogue":{"text":"The first one is SecureSoft and the other is Safeguard.","align":"left"}},{"background":null,"character":"Sophie","position":null,"opacity":null,"startTime":13.32,"finishTime":17.4,"dialogue":{"text":"SecureSoft seems more user-friendly, but I'm not sure about its security features.","align":"left"}},{"background":null,"character":"Jake","position":null,"opacity":null,"startTime":18.32,"finishTime":24.28,"dialogue":{"text":"I know SecureSoft. It's a bit easier to use, but I think Safeguard is more robust when it comes to security.","align":"right"}},{"background":null,"character":"Jake","position":null,"opacity":null,"startTime":24.56,"finishTime":28.06,"dialogue":{"text":"It has stronger encryption and better protection against vulnerabilities.","align":"right"}},{"background":null,"character":"Sophie","position":null,"opacity":null,"startTime":28.06,"finishTime":33.62,"dialogue":{"text":"That makes sense. SecureSoft does have a nicer interface, but if Safeguard is more secure,","align":"left"}},{"background":null,"character":"Sophie","position":null,"opacity":null,"startTime":33.78,"finishTime":37.36,"dialogue":{"text":"it's probably the better choice. What about performance? Which one is faster?","align":"left"}},{"background":null,"character":"Jake","position":null,"opacity":null,"startTime":37.74,"finishTime":45.22,"dialogue":{"text":"From my experience, Safeguard is slightly faster. It has more efficient processing, so it doesn't slow down the system as much.","align":"right"}},{"background":null,"character":"Jake","position":null,"opacity":null,"startTime":45.76,"finishTime":49.98,"dialogue":{"text":"SecureSoft is good, but it can be a bit sluggish when handling large datasets.","align":"right"}},{"background":null,"character":"Sophie","position":null,"opacity":null,"startTime":50.78,"finishTime":57.22,"dialogue":{"text":"Thanks for pointing that out. I noticed that SecureSoft has more integration options with other tools. Is Safeguard as flexible?","align":"left"}},{"background":null,"character":"Jake","position":null,"opacity":null,"startTime":57.88,"finishTime":63.58,"dialogue":{"text":"Not really. Safeguard is more focused on security, so it might not integrate as easily with other platforms.","align":"right"}},{"background":null,"character":"Jake","position":null,"opacity":null,"startTime":64.08,"finishTime":68.4,"dialogue":{"text":"If integration is crucial, you might have to do some extra work with Safeguard.","align":"right"}},{"background":null,"character":"Sophie","position":null,"opacity":null,"startTime":68.98,"finishTime":72.9,"dialogue":{"text":"That's good to know. I think I'll go with Safeguard since security is our top priority,","align":"left"}},{"background":null,"character":"Sophie","position":null,"opacity":null,"startTime":73.14,"finishTime":76.32,"dialogue":{"text":"but I'll keep in mind the integration challenges. Thanks for your help, Jake.","align":"left"}},{"background":null,"character":"Jake","position":null,"opacity":null,"startTime":76.74,"finishTime":79.84,"dialogue":{"text":"No problem, Sophie. If you have any other questions, just let me know.","align":"right"}},{"background":null,"character":"Jake","position":{"x":125,"y":0,"z":1},"opacity":null,"startTime":80.34,"finishTime":null,"dialogue":null},{"background":null,"character":"Sophie","position":{"x":-25,"y":0,"z":1},"opacity":null,"startTime":80.84,"finishTime":null,"dialogue":null}]},"superBlock":"b1-english-for-developers","tests":[],"title":"Dijalog 1: Poređenje funkcija softvera","transcript":null,"translationPending":false,"videoId":null,"videoLocaleIds":null}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/b1-english-for-developers/#learn-how-to-express-decisions-based-on-comparisons","dashedName":"dialogue-1-comparing-software-features","certification":"b1-english-for-developers","disableLoopProtectTests":false,"disableLoopProtec