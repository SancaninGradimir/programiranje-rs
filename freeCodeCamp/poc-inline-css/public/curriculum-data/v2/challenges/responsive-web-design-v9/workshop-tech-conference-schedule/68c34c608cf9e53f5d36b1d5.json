    {
      "text": "<p>Treba da imaš treći element <code>tr</code> unutar elementa <code>tbody</code>.</p>",
      "testString": "assert.lengthOf(document.querySelectorAll(\"tbody tr\"), 3);"
    },
    {
      "text": "<p>Trebalo bi da imaš element <code>th</code> unutar trećeg elementa <code>tr</code>.</p>",
      "testString": "assert.isNotNull(document.querySelectorAll(\"tbody tr\")[2].querySelector(\"th\"));"
    },
    {
      "text": "<p>Vaše polje <code>th</code> trebalo bi da sadrži tekst iz/od <code>11:00 AM</code>.</p>",
      "testString": "assert.strictEqual(document.querySelectorAll(\"tbody tr\")[2].querySelector(\"th\")?.textContent.trim(), \"11:00 AM\");"
    },
    {
      "text": "<p>Vaše polje <code>th</code> mora imati svojstvo <code>scope</code> postavljeno na <code>\"row\"</code>.</p>",
      "testString": "assert.strictEqual(document.querySelectorAll(\"tbody tr\")[2].querySelector(\"th\")?.getAttribute(\"scope\"), \"row\");"
    },
    {
      "text": "<p>Trebalo bi da imaš element <code>td</code> unutar trećeg elementa <code>tr</code>.</p>",
      "testString": "assert.isNotNull(document.querySelectorAll(\"tbody tr\")[2].querySelector(\"td\"));"
    },
    {
      "text": "<p>Vaš element za <code>td</code> treba da sadrži tekst od <code>Break</code>.</p>",
