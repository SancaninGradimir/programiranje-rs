{"componentChunkName":"component---src-templates-challenges-classic-show-tsx","path":"/learn/html-forms-and-tables/workshop-hotel-feedback-form/step-6","result":{"data":{"challengeNode":{"challenge":{"block":"workshop-hotel-feedback-form","demoType":null,"title":"Korak 6","description":"<section id=\"description\">\n<p>U prethodnim lekcijama, naučili ste kako da povežete element <code>label</code> sa elementom <code>input</code> na ovaj način:</p>\n<pre><code class=\"language-html\">&#x3C;label for=\"name\">Name:&#x3C;/label>\n&#x3C;input type=\"text\" id=\"name\" name=\"name\">\n</code></pre>\n<p>Atribut <code>for</code> na elementu <code>label</code> treba da odgovara atributu <code>id</code> na elementu <code>input</code>. Ovo se naziva eksplicitna asocijacija.</p>\n<p>Ispod vašeg elementa <code>legend</code>, dodajte element <code>label</code> sa tekstom <code>Name (required):</code>. Postavite njegov atribut <code>for</code> na vrednost <code>\"full-name\"</code>.</p>\n<p>Zatim ispod vašeg elementa <code>label</code>, dodajte element <code>input</code> bez atributa. U sledećim koracima, dodaćete potrebne atribute.</p>\n</section>","id":"66a84111965a0c46df6bbd0a","hasEditableBoundaries":true,"instructions":"","notes":null,"challengeType":0,"helpCategory":"HTML-CSS","videoUrl":null,"superBlock":"html-forms-and-tables","translationPending":false,"forumTopicId":null,"hooks":null,"fields":{"slug":"/learn/html-forms-and-tables/workshop-hotel-feedback-form/step-6"},"required":[],"usesMultifileEditor":true,"challengeFiles":[{"fileKey":"indexhtml","ext":"html","name":"index","contents":"<!DOCTYPE html>\n<html lang=\"en\">\n  <head>\n    <meta charset=\"UTF-8\" />\n    <title>Hotel Feedback Form</title>\n  </head>\n  <body>\n    <header>\n      <h1>Hotel Feedback Form</h1>\n      <p>\n        Thank you for staying with us. Please provide feedback on your recent\n        stay.\n      </p>\n    </header>\n    <main>\n      <form method=\"POST\" action=\"https://hotel-feedback.freecodecamp.org\">\n        <fieldset>\n          <legend>Personal Information</legend>\n          \n        </fieldset>\n      </form>\n    </main>\n  </body>\n</html>","head":null,"tail":null,"editableRegionBoundaries":[18,20],"history":["index.html"]}],"saveSubmissionToDB":null,"tests":[{"text":"<p>You should have an opening <code>label</code> tag.</p>","testString":"assert.match(code, /<label.*>/);"},{"text":"<p>You should have a closing <code>label</code> tag.</p>","testString":"assert.match(code, /<\\/label>/);"},{"text":"<p>Your <code>label</code> element should be placed below your <code>legend</code> inside the <code>fieldset</code> element.</p>","testString":"assert.isNotNull(document.querySelector('fieldset legend + label'));"},{"text":"<p>Your <code>label</code> element should have a <code>for</code> attribute with the value of <code>\"full-name\"</code>.</p>","testString":"const label = document.querySelector('fieldset legend + label');\nassert.strictEqual(label?.getAttribute('for'), 'full-name');"},{"text":"<p>Your <code>label</code> element should have the text of <code>Name (required):</code>.</p>","testString":"const label = document.querySelector('fieldset legend + label');\nassert.strictEqual(label?.innerText.trim(), 'Name (required):');"},{"text":"<p>You should have an <code>input</code> element below your <code>label</code> element.</p>","testString":"assert.isNotNull(document.querySelector('fieldset label + input'));"}]}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/html-forms-and-tables/#workshop-hotel-feedback-form","dashedName":"step-6","certification":"html-forms-and-tables","disableLoopProtectTests":false,"disableLoopProtectPreview":false,"superBlock":"html-forms-and-tables","chapter":null,"module":null,"block":"workshop-hotel-feedback-form","isFirstStep":false,"template":null,"required":[],"isLastChallengeInBlock":false,"nextChallengePath":"/learn/html-forms-and-tables/workshop-hotel-feedback-form/step-7","prevChallengePath":"/learn/html-forms-and-tables/workshop-hotel-feedback-form/step-5","id":"66a84111965a0c46df6bbd0a","saveSubmissionToDB":null},"projectPreview":{"challengeData":{"challengeType":0,"challengeFiles":[{"name":"index","ext":"html","contents":"<!DOCTYPE html>\n<html lang=\"en\">\n  <head>\n    <meta charset=\"UTF-8\" />\n    <title>Hotel Feedback Form</title>\n  </head>\n  <body>\n    <header>\n      <h1>Hotel Feedback Form</h1>\n      <p>\n        Thank you for staying with us. Please provide feedback on your recent\n        stay.\n      </p>\n    </header>\n    <main>\n      <form method=\"POST\" action=\"https://hotel-feedback.freecodecamp.org\">\n        <fieldset>\n          <legend>Personal Information</legend>\n          <label for=\"full-name\">Name (required):</label>\n          <input type=\"text\" id=\"full-name\" name=\"name\" placeholder=\"e.g., John Doe\" required>\n\n          <label for=\"email\">Email address (required):</label>\n          <input\n            placeholder=\"example@email.com\"\n            required\n            id=\"email\"\n            type=\"email\"\n            name=\"email\"\n          />\n          <label for=\"age\">Age (optional):</label>\n          <input type=\"number\" name=\"age\" id=\"age\" min=\"3\" max=\"100\" />\n        </fieldset>\n\n        <fieldset>\n          <legend>Was this your first time at our hotel?</legend>\n          <input id=\"yes-option\" type=\"radio\" name=\"hotel-stay\" value=\"yes\" />\n          <label for=\"yes-option\">Yes</label>\n          <input id=\"no-option\" type=\"radio\" name=\"hotel-stay\" value=\"no\" />\n          <label for=\"no-option\">No</label>\n        </fieldset>\n\n        <fieldset>\n          <legend>\n            Why did you choose to stay at our hotel? (Check all that apply)\n          </legend>\n\n          <input type=\"checkbox\" id=\"ads\" name=\"choice\" value=\"ads\" />\n          <label for=\"ads\">Social Media Ads</label>\n\n          <input\n            type=\"checkbox\"\n            id=\"recommendation\"\n            name=\"choice\"\n            value=\"recommendation\"\n          />\n          <label for=\"recommendation\">Personal Recommendation</label>\n          \n          <input type=\"checkbox\" id=\"location\" name=\"choice\" value=\"location\" />\n          <label for=\"location\">Location</label>\n\n          <input\n            checked\n            type=\"checkbox\"\n            id=\"reputation\"\n            name=\"choice\"\n            value=\"reputation\"\n          />\n          <label for=\"reputation\">Reputation</label>\n          \n          <input type=\"checkbox\" id=\"price\" name=\"choice\" value=\"price\" />\n          <label for=\"price\">Price</label>\n        </fieldset>\n\n        <fieldset>\n          <legend>Ratings</legend>\n\n          <label for=\"service\">How was the service?</label>\n\n          <select name=\"service\" id=\"service\">\n            <option value=\"poor\">Poor</option>\n            <option value=\"satisfactory\">Satisfactory</option>\n            <option value=\"good\">Good</option>\n            <option value=\"very-good\">Very Good</option>\n            <option selected value=\"excellent\">Excellent</option>\n          </select>\n\n          <label for=\"food\">How was the food?</label>\n\n          <select name=\"food\" id=\"food\">\n            <option value=\"poor\">Poor</option>\n            <option value=\"satisfactory\">Satisfactory</option>\n            <option value=\"good\">Good</option>\n            <option value=\"very-good\">Very Good</option>\n            <option selected value=\"excellent\">Excellent</option>\n          </select>\n        </fieldset>\n\n        <label for=\"comments\">Other Comments?</label>\n        <textarea cols=\"30\" rows=\"10\" name=\"comments\" id=\"comments\"></textarea>\n\n        <button type=\"submit\">Submit</button>\n      </form>\n    </main>\n  </body>\n</html>","history":["index.html"],"fileKey":"indexhtml"}]}},"id":"/learn/html-forms-and-tables/workshop-hotel-feedback-form/step-6"}},"staticQueryHashes":["3858520367"],"slicesMap":{}}