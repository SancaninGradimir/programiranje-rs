  "tests": [
    {
      "text": "<p>You should have a total of two <code>label</code> elements on the page.</p>",
      "testString": "assert.lengthOf(document.querySelectorAll(\"label\"), 2);"
    },
    {
      "text": "<p>Your second <code>label</code> element should have the text <code>Student Grade: </code>. Don't forget the space after the colon.</p>",
      "testString": "assert.match(code, /Student\\s+Grade:\\s+<\\/label>/);"
    },
    {
      "text": "<p>Your second <code>label</code> element should have a <code>for</code> attribute.</p>",
      "testString": "assert.isTrue(document.querySelector(\"label:last-of-type\")?.hasAttribute(\"for\"));"
    },
    {
      "text": "<p>Your second <code>label</code> element's <code>for</code> attribute should have the value <code>\"grade\"</code>.</p>",
      "testString": "assert.strictEqual(document.querySelector(\"label:last-of-type\")?.getAttribute(\"for\"), \"grade\");"
    },
    {
      "text": "<p>You should have two <code>input</code> elements on the page.</p>",
      "testString": "assert.lengthOf(document.querySelectorAll(\"input\"), 2);"
    },
    {
      "text": "<p>Your second <code>input</code> element should be below your second <code>label</code> element.</p>",
      "testString": "const fieldsetChildren = [...document.querySelector(\"fieldset\")?.children];\nconst inputEl = document.querySelector(\"fieldset input:last-of-type\");\nconst labelEl = document.querySelector(\"label:last-of-type\");\n\nassert.isBelow(fieldsetChildren.indexOf(labelEl), fieldsetChildren.indexOf(inputEl));"
    },
    {
      "text": "<p>Your second <code>input</code> element should have a <code>type</code> attribute set to <code>\"number\"</code>.</p>",
      "testString": "const inputEl = document.querySelector(\"fieldset input:last-of-type\");\nassert.strictEqual(inputEl?.getAttribute(\"type\"), \"number\");"
    },
    {
      "text": "<p>Your second <code>input</code> element should have a <code>name</code> attribute set to <code>\"grade\"</code>.</p>",
      "testString": "const inputEl = document.querySelector(\"fieldset input:last-of-type\");\nassert.strictEqual(inputEl?.getAttribute(\"name\"), \"grade\");"
    },
    {
      "text": "<p>Your second <code>input</code> element should have an <code>id</code> attribute set to <code>\"grade\"</code>.</p>",
      "testString": "const inputEl = document.querySelector(\"fieldset input:last-of-type\");\nassert.strictEqual(inputEl?.getAttribute(\"id\"), \"grade\");"
    },
    {
      "text": "<p>Your second <code>input</code> element should have a <code>placeholder</code> attribute set to <code>\"E.g., 4\"</code>.</p>",
      "testString": "const inputEl = document.querySelector(\"fieldset input:last-of-type\");\nassert.strictEqual(inputEl?.getAttribute(\"placeholder\"), \"E.g., 4\");"
    },
    {
      "text": "<p>Your second <code>input</code> element should have a <code>required</code> attribute.</p>",
      "testString": "const inputEl = document.querySelector(\"fieldset input:last-of-type\");\nassert.isTrue(inputEl?.hasAttribute(\"required\"));"
    }
