        "path": "script.js",
        "fileKey": "scriptjs",
        "contents": "const distinctPowers = (n) => {\n  let list = [];\n  for (let a=2; a<=n; a++) {\n    for (let b=2; b<=n; b++) {\n      let term = Math.pow(a, b);\n      if (list.indexOf(term)===-1) list.push(term);\n    }\n  }\n  return list.length;\n};",
        "error": null,
