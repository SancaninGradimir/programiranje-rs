  "tests": [
    {
      "text": "<p>Trebalo bi da imaš element <code>input</code> ispod svog drugog elementa <code>span</code>.</p>",
      "testString": "const inputEl = document.querySelector('div > span:nth-of-type(2) + input');\nassert.exists(inputEl);"
    },
    {
      "text": "<p>Vaše polje za <code>input</code> treba da ima svojstvo elementa od <code>type</code>.</p>",
      "testString": "const inputEl = document.querySelector('div > span:nth-of-type(2) + input');\nassert.isTrue(inputEl?.hasAttribute('type'));"
    },
    {
      "text": "<p>Vaš element <code>input</code> mora imati atribut elementa <code>type</code> sa vrednošću <code>range</code>.</p>",
      "testString": "const inputEl = document.querySelector('div > span:nth-of-type(2) + input');\nassert.equal(inputEl?.getAttribute('type'), 'range');"
    },
    {
      "text": "<p>Vaše polje <code>input</code> mora imati svojstvo elementa <code>min</code>.</p>",
      "testString": "const inputEl = document.querySelector('div > span:nth-of-type(2) + input');\nassert.exists(inputEl?.getAttribute('min'));"
    },
    {
      "text": "<p>Element vašeg <code>input</code> treba da ima svojstvo elementa <code>min</code> sa vrednošću <code>0</code>.</p>",
      "testString": "const inputEl = document.querySelector('div > span:nth-of-type(2) + input');\nassert.equal(inputEl?.getAttribute('min'), '0');"
    },
    {
      "text": "<p>Vaš element <code>input</code> mora imati svojstvo elemenata/komponente <code>max</code>.</p>",
      "testString": "const inputEl = document.querySelector('div > span:nth-of-type(2) + input');\nassert.isTrue(inputEl?.hasAttribute('max'));"
    },
    {
      "text": "<p>Vaš element <code>input</code> mora imati svojstvo elemenata <code>max</code> sa vrednošću <code>100</code>.</p>",
      "testString": "const inputEl = document.querySelector('div > span:nth-of-type(2) + input');\nassert.equal(inputEl?.getAttribute('max'), '100');"
    },
    {
      "text": "<p>Vaš element za <code>input</code> mora imati svojstvo elementa <code>value</code>.</p>",
      "testString": "const inputEl = document.querySelector('div > span:nth-of-type(2) + input');\nassert.isTrue(inputEl?.hasAttribute('value'));"
    },
    {
      "text": "<p>Vaš element <code>input</code> mora imati svojstvo polja <code>value</code> sa vrednošću <code>50</code>.</p>",
