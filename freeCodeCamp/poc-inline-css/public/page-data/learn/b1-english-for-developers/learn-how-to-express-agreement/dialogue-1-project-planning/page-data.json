{"componentChunkName":"component---src-templates-challenges-generic-show-tsx","path":"/learn/b1-english-for-developers/learn-how-to-express-agreement/dialogue-1-project-planning","result":{"data":{"challengeNode":{"challenge":{"assignments":["<p>Gledaj video.</p>"],"bilibiliIds":null,"block":"learn-how-to-express-agreement","challengeType":21,"description":"<section id=\"description\">\n<p>Pogledajte video ispod da biste razumeli kontekst sledećih lekcija.</p>\n</section>","nodules":null,"explanation":null,"helpCategory":"English","instructions":"","fields":{"slug":"/learn/b1-english-for-developers/learn-how-to-express-agreement/dialogue-1-project-planning"},"questions":[],"scene":{"setup":{"background":"company2-boardroom.png","characters":[{"character":"Bob","position":{"x":-25,"y":0,"z":1},"opacity":null},{"character":"Linda","position":{"x":125,"y":0,"z":1},"opacity":null}],"audio":{"filename":"B1_10-1.mp3","startTime":1,"startTimestamp":null,"finishTimestamp":null},"alwaysShowDialogue":true},"commands":[{"background":null,"character":"Bob","position":{"x":25,"y":0,"z":1},"opacity":null,"startTime":0,"finishTime":null,"dialogue":null},{"background":null,"character":"Linda","position":{"x":70,"y":0,"z":1},"opacity":null,"startTime":0.5,"finishTime":null,"dialogue":null},{"background":null,"character":"Bob","position":null,"opacity":null,"startTime":1,"finishTime":4.98,"dialogue":{"text":"We need to start planning our new mobile app project. Let's discuss the timeline.","align":"left"}},{"background":null,"character":"Bob","position":null,"opacity":null,"startTime":5.48,"finishTime":9.3,"dialogue":{"text":"I was thinking we should aim to have the initial prototype ready in four weeks.","align":"left"}},{"background":null,"character":"Bob","position":null,"opacity":null,"startTime":9.5,"finishTime":10.56,"dialogue":{"text":"Does that sound reasonable?","align":"left"}},{"background":null,"character":"Linda","position":null,"opacity":null,"startTime":11.22,"finishTime":15.5,"dialogue":{"text":"I think that's doable. We can work on the design sketches this week and then move on to wireframes.","align":"right"}},{"background":null,"character":"Bob","position":null,"opacity":null,"startTime":15.96,"finishTime":21.52,"dialogue":{"text":"Exactly. Once we have the wireframes, we can start collaborating with the developers to implement the front-end design.","align":"left"}},{"background":null,"character":"Linda","position":null,"opacity":null,"startTime":22.16,"finishTime":27.68,"dialogue":{"text":"Absolutely. And I can also prepare some user scenarios for testing so we can ensure a smooth user experience.","align":"right"}},{"background":null,"character":"Bob","position":null,"opacity":null,"startTime":27.86,"finishTime":31.6,"dialogue":{"text":"Good idea. By the way, we need to allocate tasks among the team.","align":"left"}},{"background":null,"character":"Bob","position":null,"opacity":null,"startTime":31.78,"finishTime":35.82,"dialogue":{"text":"I was thinking that you could lead the UX design and I'll coordinate with the developers.","align":"left"}},{"background":null,"character":"Bob","position":null,"opacity":null,"startTime":75.88,"finishTime":76.94,"dialogue":{"text":"Does that work for you?","align":"left"}},{"background":null,"character":"Linda","position":null,"opacity":null,"startTime":37.54,"finishTime":40.72,"dialogue":{"text":"That's a good plan. I'll also keep you updated on the design process","align":"right"}},{"background":null,"character":"Linda","position":null,"opacity":null,"startTime":40.72,"finishTime":43.14,"dialogue":{"text":"and we can schedule regular meetings to stay on track.","align":"right"}},{"background":null,"character":"Bob","position":null,"opacity":null,"startTime":43.52,"finishTime":48.02,"dialogue":{"text":"Perfect. Let's set a weekly meeting to review our progress. Would Friday morning work for you?","align":"left"}},{"background":null,"character":"Linda","position":null,"opacity":null,"startTime":48.5,"finishTime":53.22,"dialogue":{"text":"Sure. Friday mornings are great. It gives me a chance to review the week's work and plan for the next week.","align":"right"}},{"background":null,"character":"Bob","position":null,"opacity":null,"startTime":53.44,"finishTime":59.22,"dialogue":{"text":"Great. I'll send out a meeting invite and share the project timeline with everyone. Thanks for your input, Linda.","align":"left"}},{"background":null,"character":"Linda","position":null,"opacity":null,"startTime":59.92,"finishTime":62.3,"dialogue":{"text":"No problem, Bob. I'm looking forward to working on this project.","align":"right"}},{"background":null,"character":"Linda","position":{"x":125,"y":0,"z":1},"opacity":null,"startTime":62.8,"finishTime":null,"dialogue":null},{"background":null,"character":"Bob","position":{"x":-25,"y":0,"z":1},"opacity":null,"startTime":63.3,"finishTime":null,"dialogue":null}]},"superBlock":"b1-english-for-developers","tests":[],"title":"Dialog 1: Planiranje projekta","transcript":null,"translationPending":false,"videoId":null,"videoLocaleIds":null}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/b1-english-for-developers/#learn-how-to-express-agreement","dashedName":"dialogue-1-project-planning","certification":"b1-english-for-developers","disableLoopProtectTests":false,"disableLoopProtectPreview":false,"superBlock":"b1-english-for-developers","chapter":null,"module":null,"block":"learn-how-to-express-agreement","isFirstStep":true,"template":null,"required":[],"isLastChallengeInBlock":false,"nextChallengePath":"/learn/b1-english-for-developers/learn-how-to-express-agreement/task-1","prevChallengePath":"/learn/b1-english-for-developers/en-b1-quiz-share-opinions/en-b1-quiz-share-opinions","id":"6660a04ec4ec815eb81ede7c","saveSubmissionToDB":null},"projectPreview":{"challengeData":{"challengeType":19,"challengeFiles":[]}},"id":"/learn/b1-english-for-developers/learn-how-to-express-agreement/dialogue-1-project-planning"}},"s