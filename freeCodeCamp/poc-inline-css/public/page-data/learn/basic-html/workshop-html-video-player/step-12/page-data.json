{"componentChunkName":"component---src-templates-challenges-classic-show-tsx","path":"/learn/basic-html/workshop-html-video-player/step-12","result":{"data":{"challengeNode":{"challenge":{"block":"workshop-html-video-player","demoType":null,"title":"Korak 12","description":"<section id=\"description\">\n<p>Drugi uobičajeni MIME tip je MIME tip <code>video/ogg</code>.</p>\n<p>Ogg je digitalni multimedijalni kontejnerski format dizajniran za efikasno strimovanje i manipulaciju digitalnim multimedijima. Održava ga Xiph.Org Foundation i on je slobodan i otvoren, neograničen softverskim patentima. Naziv potiče od \"ogging\", žargona iz računarske igre Netrek.</p>\n<p>Ispod vašeg drugog <code>source</code> elementa, dodajte treći <code>source</code> element i dajte mu atribut <code>src</code> sa vrednošću <code>https://cdn.freecodecamp.org/curriculum/labs/mapmethod.ogg</code> i atribut <code>type</code> sa vrednošću <code>video/ogg</code>.</p>\n</section>","id":"68f2701b2160c765f23b60f8","hasEditableBoundaries":true,"instructions":"","notes":null,"challengeType":0,"helpCategory":"HTML-CSS","videoUrl":null,"superBlock":"basic-html","translationPending":false,"forumTopicId":null,"hooks":null,"fields":{"slug":"/learn/basic-html/workshop-html-video-player/step-12"},"required":[],"usesMultifileEditor":true,"challengeFiles":[{"fileKey":"indexhtml","ext":"html","name":"index","contents":"<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Working with the HTML Video Element</title>\n</head>\n<body>\n  <h1>Working with the HTML Video Element</h1>\n  <video\n    width=\"640\"\n    loop\n    controls\n    muted\n    poster=\"https://cdn.freecodecamp.org/curriculum/labs/past-event2.jpg\"\n  >\n    <source\n      src=\"https://cdn.freecodecamp.org/curriculum/labs/what-is-the-map-method-and-how-does-it-work.mp4\"\n      type=\"video/mp4\"\n    >\n    <source\n      src=\"https://cdn.freecodecamp.org/curriculum/labs/mapmethod.webm\"\n      type=\"video/webm\"\n    >\n    \n  </video>\n</body>\n</html>","head":null,"tail":null,"editableRegionBoundaries":[24,26],"history":["index.html"]}],"saveSubmissionToDB":null,"tests":[{"text":"<p>You should have a third <code>source</code> element.</p>","testString":"assert.exists(document.querySelector('video > source:nth-of-type(3)'));"},{"text":"<p>Your third <code>source</code> element should have a <code>src</code> attribute.</p>","testString":"const source = document.querySelector('source:nth-of-type(3)');\nassert.isTrue(source?.hasAttribute('src'));"},{"text":"<p>Your third <code>source</code> element should have a <code>src</code> attribute with a value of <code>https://cdn.freecodecamp.org/curriculum/labs/mapmethod.ogg</code>.</p>","testString":"const source = document.querySelector('source:nth-of-type(3)');\nassert.strictEqual(source?.getAttribute('src'), 'https://cdn.freecodecamp.org/curriculum/labs/mapmethod.ogg');"},{"text":"<p>Your third <code>source</code> element should have a <code>type</code> attribute.</p>","testString":"const source = document.querySelector('source:nth-of-type(3)');\nassert.isTrue(source?.hasAttribute('type'));"},{"text":"<p>Your third <code>source</code> element should have a <code>type</code> attribute with a value of <code>video/ogg</code>.</p>","testString":"const source = document.querySelector('source:nth-of-type(3)');\nassert.strictEqual(source?.getAttribute('type'), 'video/ogg');"}]}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/basic-html/#workshop-html-video-player","dashedName":"step-12","certification":"basic-html","disableLoopProtectTests":false,"disableLoopProtectPreview":false,"superBlock":"basic-html","chapter":null,"module":null,"block":"workshop-html-video-player","isFirstStep":false,"template":null,"required":[],"isLastChallengeInBlock":false,"nextChallengePath":"/learn/basic-html/workshop-html-video-player/step-13","prevChallengePath":"