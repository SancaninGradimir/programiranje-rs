    {
      "text": "<p>Vaš element <code>script</code> mora da dođe na kraju vašeg elementa <code>body</code>.</p>",
      "testString": "const script = document.querySelector('script[data-src$=\"script.js\"]');\nconst lastChild = document.querySelector('body').lastElementChild;\nassert.equal(script, lastChild);"
    }
