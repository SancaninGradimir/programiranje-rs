      "text": "<p>Tvoja druga tabela treba da sadrži element <code>caption</code>.</p>",
      "testString": "assert.strictEqual(\n  document.querySelectorAll('table')?.[1]?.children?.[0]?.localName,\n  'caption'\n);"
