      "text": "<p>Vaš kod bi trebalo da koristi dostupne podatke za modifikovanje internog HTML</p>",
      "testString": "const catData = 'dummy data';\r\nconst ref = fetch;\r\nfetch = () => Promise.resolve({ json: () => catData });\r\n\r\n  try {\r\n    document.getElementById('getMessage').click();\r\n    await new Promise((resolve, reject) => setTimeout(() => resolve(), 250));\r\n  } catch (error) {\r\n    console.log(error);\r\n  } finally {\r\n    fetch = ref;\r\n    assert.equal(\r\n      document.getElementById('message').textContent,\r\n      JSON.stringify(catData)\r\n    );\r\n  }\r\n"
    },
    {
      "text": "<p>Vaš kod bi trebalo da pošalje zahtev za <code>GET</code> ka <code>fetch</code>.</p>",
      "testString": "assert.match(code, /fetch\\s*\\(\\s*('|\")\\/json\\/cats\\.json\\1\\s*\\)/g);"
    },
    {
      "text": "<p>Vaš kod mora da koristi <code>then</code> da promeni odgovor u JSON.</p>",
      "testString": "assert.match(\r\n  code,\r\n  /\\.then\\s*\\(\\s*\\(?(?<var>\\w+)\\)?\\s*=>\\s*\\k<var>\\s*\\.json\\s*\\(\\s*\\)\\s*\\)/g\r\n);"
    },
    {
      "text": "<p>Vaš kod bi trebalo da koristi <code>then</code> za obradu podataka konvertovanih u JSON i drugog tipa, <code>then</code>.</p>",
      "testString": "assert.match(__helpers.removeWhiteSpace(code), /\\.then\\(\\(?\\w+\\)?=>{[^}]*}\\)/g);"
    },
    {
      "text": "<p>Vaš kod mora da dobije element sa identifikatorom <code>message</code> i modifikuje svoj interni HTML u sekvencu podataka za JSON.</p>",
      "testString": "assert.match(\r\n  __helpers.removeWhiteSpace(code),\r\n  /document\\.getElementById\\(('|\")message\\1\\)\\.innerHTML=JSON\\.stringify\\(?\\w+\\)/g\r\n);"
    }
