{"componentChunkName":"component---src-templates-challenges-classic-show-tsx","path":"/learn/html-forms-and-tables/workshop-hotel-feedback-form/step-24","result":{"data":{"challengeNode":{"challenge":{"block":"workshop-hotel-feedback-form","demoType":null,"title":"Korak 24","description":"<section id=\"description\">\n<p>Sledeći deo obrasca će korisnicima omogućiti da ostave ocenu za hotel.</p>\n<p>Počnite dodavanjem novog <code>fieldset</code> elementa sa <code>legend</code> elementom ugnježdjenim unutra. <code>legend</code> treba da ima tekst <code>Ratings</code>.</p>\n<p>Ispod <code>legend</code> elementa, dodajte <code>label</code> element sa tekstom <code>How was the service?</code>. Atribut <code>for</code> treba da bude postavljen na <code>\"service\"</code>.</p>\n</section>","id":"66a969951120be7818d8ee49","hasEditableBoundaries":true,"instructions":"","notes":null,"challengeType":0,"helpCategory":"HTML-CSS","videoUrl":null,"superBlock":"html-forms-and-tables","translationPending":false,"forumTopicId":null,"hooks":null,"fields":{"slug":"/learn/html-forms-and-tables/workshop-hotel-feedback-form/step-24"},"required":[],"usesMultifileEditor":true,"challengeFiles":[{"fileKey":"indexhtml","ext":"html","name":"index","contents":"<!DOCTYPE html>\n<html lang=\"en\">\n  <head>\n    <meta charset=\"UTF-8\" />\n    <title>Hotel Feedback Form</title>\n  </head>\n  <body>\n    <header>\n      <h1>Hotel Feedback Form</h1>\n      <p>\n        Thank you for staying with us. Please provide feedback on your recent\n        stay.\n      </p>\n    </header>\n    <main>\n      <form method=\"POST\" action=\"https://hotel-feedback.freecodecamp.org\">\n        <fieldset>\n          <legend>Personal Information</legend>\n          <label for=\"full-name\">Name (required):</label>\n          <input type=\"text\" id=\"full-name\" name=\"name\" placeholder=\"e.g., John Doe\" required size=\"20\">\n\n          <label for=\"email\">Email address (required):</label>\n          <input\n            placeholder=\"example@email.com\"\n            required\n            id=\"email\"\n            type=\"email\"\n            name=\"email\"\n            size=\"20\"\n          />\n          <label for=\"age\">Age (optional):</label>\n          <input type=\"number\" name=\"age\" id=\"age\" min=\"3\" max=\"100\" />\n        </fieldset>\n\n        <fieldset>\n          <legend>Was this your first time at our hotel?</legend>\n          <input id=\"yes-option\" type=\"radio\" name=\"hotel-stay\" value=\"yes\" />\n          <label for=\"yes-option\">Yes</label>\n          <input id=\"no-option\" type=\"radio\" name=\"hotel-stay\" value=\"no\" />\n          <label for=\"no-option\">No</label>\n        </fieldset>\n\n        <fieldset>\n          <legend>\n            Why did you choose to stay at our hotel? (Check all that apply)\n          </legend>\n\n          <input type=\"checkbox\" id=\"ads\" name=\"choice\" value=\"ads\" />\n          <label for=\"ads\">Social Media Ads</label>\n\n          <input\n            type=\"checkbox\"\n            id=\"recommendation\"\n            name=\"choice\"\n            value=\"recommendation\"\n          />\n          <label for=\"recommendation\">Personal Recommendation</label>\n          \n          <input type=\"checkbox\" id=\"location\" name=\"choice\" value=\"location\" />\n          <label for=\"location\">Location</label>\n\n          <input\n            checked\n            type=\"checkbox\"\n            id=\"reputation\"\n            name=\"choice\"\n            value=\"reputation\"\n          />\n          <label for=\"reputation\">Reputation</label>\n          \n          <input type=\"checkbox\" id=\"price\" name=\"choice\" value=\"price\" />\n          <label for=\"price\">Price</label>\n        </fieldset>\n\n        \n      </form>\n    </main>\n  </body>\n</html>","head":null,"tail":null,"editableRegionBoundaries":[74,76],"history":["index.html"]}],"saveSubmissionToDB":null,"tests":[{"text":"<p>You should 