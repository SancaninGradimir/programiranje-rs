  "tests": [
    {
      "text": "<p>You should have two <code>label</code> elements in the last <code>fieldset</code>.</p>",
      "testString": "assert.lengthOf(document.querySelectorAll(\"fieldset:last-of-type label\"), 2);"
    },
    {
      "text": "<p>The <code>label</code> element should have a class of <code>\"contact-method\"</code>.</p>",
      "testString": "assert.exists(document.querySelector(\"fieldset:last-of-type label.contact-method\"));"
    },
    {
      "text": "<p>The <code>label</code> element's <code>for</code> attribute should be set to <code>\"phone\"</code>.</p>",
      "testString": "assert.exists(document.querySelector(\"fieldset:last-of-type label[for='phone']\"));"
    },
    {
      "text": "<p>The <code>label</code> element should have the text <code>Phone: </code>.</p>",
      "testString": "const label = document.querySelector(\"fieldset:last-of-type label[for='phone']\");\nassert.match(label?.innerText, /Phone:\\s?/);"
    },
    {
      "text": "<p>You should have two <code>input</code> elements inside the last <code>fieldset</code>.</p>",
      "testString": "assert.lengthOf(document.querySelectorAll(\"fieldset:last-of-type input\"), 2);"
    },
    {
      "text": "<p>Your <code>input</code> element should have a <code>type</code> attribute set to <code>radio</code>.</p>",
      "testString": "const input = document.querySelector(\"fieldset:last-of-type input:last-of-type\");\nassert.strictEqual(input?.getAttribute(\"type\"), \"radio\");"
    },
    {
      "text": "<p>The <code>input</code> element should have an <code>id</code> attribute set to <code>\"phone\"</code>.</p>",
      "testString": "const input = document.querySelector(\"fieldset:last-of-type input:last-of-type\");\nassert.strictEqual(input?.getAttribute(\"id\"), \"phone\");"
