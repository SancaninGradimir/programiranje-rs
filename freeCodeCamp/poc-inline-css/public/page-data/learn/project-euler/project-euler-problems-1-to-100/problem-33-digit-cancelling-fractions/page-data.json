{"componentChunkName":"component---src-templates-challenges-classic-show-tsx","path":"/learn/project-euler/project-euler-problems-1-to-100/problem-33-digit-cancelling-fractions","result":{"data":{"challengeNode":{"challenge":{"block":"project-euler-problems-1-to-100","demoType":null,"title":"Vežba 33: Sekcija za brisanje brojeva","description":"<section id=\"description\">\n<p>Sehemu <sup>49</sup>/<sub>98</sub> je iznenađujući deo, jer neiskusan fizičar kada pokuša da ga pojednostavi može pogrešno pretpostaviti da <sup>49</sup>/<sub>98</sub> = <sup>4</sup>/<sub>8</sub>, što je tačno, nalazi se eliminacijom broja 9.</p>\n<p>Razmotrićemo delove kao, <sup>30</sup>/<sub>50</sub> = <sup>3</sup>/<sub>5</sub>, da budu jednostavni primeri.</p>\n<p>Postoje samo četiri primera ovoga tipa komponente, koje su komplikovane, imaju vrijednost manju od jednog, i sadrže dva broja u lancu i podjelama.</p>\n<p>Ako proizvod ovih četiri dela bude pušten u svom najnižem stanju, pronađi vrednost podela.</p>\n</section>","id":"5900f38d1000cf542c50fea0","hasEditableBoundaries":false,"instructions":"","notes":null,"challengeType":1,"helpCategory":"Euler","videoUrl":null,"superBlock":"project-euler","translationPending":false,"forumTopicId":301987,"hooks":null,"fields":{"slug":"/learn/project-euler/project-euler-problems-1-to-100/problem-33-digit-cancelling-fractions"},"required":[],"usesMultifileEditor":false,"challengeFiles":[{"fileKey":"scriptjs","ext":"js","name":"script","contents":"function digitCancellingFractions() {\n\n  return true;\n}\n\ndigitCancellingFractions();","head":null,"tail":null,"editableRegionBoundaries":[],"history":["script.js"]}],"saveSubmissionToDB":null,"tests":[{"text":"<p><code>digitCancellingFractions()</code> Trebalo bi da vrati broj.</p>","testString":"assert(typeof digitCancellingFractions() === 'number');"},{"text":"<p><code>digitCancellingFractions()</code> Trebalo bi da vrati 100.</p>","testString":"assert.strictEqual(digitCancellingFractions(), 100);"}]}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/project-euler/#project-euler-problems-1-to-100","dashedName":"problem-33-digit-cancelling-fractions","certification":"project-euler","disableLoopProtectTests":true,"disableLoopProtectPreview":false,"superBlock":"project-euler","chapter":null,"module":null,"block":"project-euler-problems-1-to-100","isFirstStep":false,"template":null,"required":[],"isLastChallengeInBlock":false,"nextChallengePath":"/learn/project-euler/project-euler-problems-1-to-100/problem-34-digit-factorials","prevChallengePath":"/learn/project-euler/project-euler-problems-1-to-100/problem-32-pandigital-products","id":"5900f38d1000cf542c50fea0","saveSubmissionToDB":null},"projectPreview":{"challengeData":{"challengeType":1,"challengeFiles":[{"name":"script","ext":"js","contents":"function arrangedProbability(limit) {\n  // Based on https://www.mathblog.dk/project-euler-100-blue-discs-two-blue/\n  let blue = 15;\n  let discs = 21;\n\n  while (discs < limit) {\n    const nextBlue = 3 * blue + 2 * discs - 2;\n    const nextDiscs = 4 * blue + 3 * discs - 3;\n\n    blue = nextBlue;\n    discs = nextDiscs;\n  }\n  return blue;\n}","history":["script.js"],"fileKey":"scriptjs"}]}},"id":"/learn/project-euler/project-euler-problems-1-to-100/problem-33-digit-cancelling-fractions"}},"staticQueryHashes":["3858520367"],"slicesMap":{}}