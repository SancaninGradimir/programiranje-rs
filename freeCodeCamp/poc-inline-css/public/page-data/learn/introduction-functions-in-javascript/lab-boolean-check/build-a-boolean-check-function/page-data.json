{"componentChunkName":"component---src-templates-challenges-classic-show-tsx","path":"/learn/introduction-functions-in-javascript/lab-boolean-check/build-a-boolean-check-function","result":{"data":{"challengeNode":{"challenge":{"block":"lab-boolean-check","demoType":null,"title":"Kreiraj funkciju za proveru tačne ili netačne vrednosti","description":"<section id=\"description\">\n<p>U ovoj laboratoriji, kreiraćeš funkciju koja proverava da li je vrednost definisana kao tačno ili netačno.</p>\n<p>Osnovne vrednosti koje su tačne ili netačne su <code>true</code> i <code>false</code>.</p>\n<p><strong>Cilj:</strong> Popunite korisničke priče navedene ispod i prođite sve testove da biste završili laboratoriju.</p>\n<p><strong>Priče korisnika:</strong></p>\n<ol>\n<li>Trebalo bi da postoji funkcija nazvana <code>booWho</code> koja prima jedan argument.</li>\n<li>Ako je primljeni argument osnovna booleanska vrednost (tačno ili netačno), funkcija bi trebalo da vrati <code>true</code>.</li>\n<li>Ako je argument bilo koja druga vrednost, funkcija bi trebalo da vrati <code>false</code>.</li>\n</ol>\n</section>","id":"a77dbc43c33f39daa4429b4f","hasEditableBoundaries":false,"instructions":"","notes":null,"challengeType":26,"helpCategory":"JavaScript","videoUrl":null,"superBlock":"introduction-functions-in-javascript","translationPending":false,"forumTopicId":null,"hooks":null,"fields":{"slug":"/learn/introduction-functions-in-javascript/lab-boolean-check/build-a-boolean-check-function"},"required":[],"usesMultifileEditor":true,"challengeFiles":[{"fileKey":"scriptjs","ext":"js","name":"script","contents":"","head":null,"tail":null,"editableRegionBoundaries":[],"history":["script.js"]}],"saveSubmissionToDB":null,"tests":[{"text":"<p>Trebalo bi da imate funkciju <code>booWho</code>.</p>","testString":"assert.isFunction(booWho);"},{"text":"<p><code>booWho(true)</code> treba da vrati <code>true</code>.</p>","testString":"assert.isTrue(booWho(true));"},{"text":"<p><code>booWho(false)</code> trebalo bi da vrati <code>true</code>.</p>","testString":"assert.isTrue(booWho(false));"},{"text":"<p><code>booWho([1, 2, 3])</code> treba da vrati <code>false</code>.</p>","testString":"assert.isFalse(booWho([1, 2, 3]));"},{"text":"<p><code>booWho([].slice)</code> treba da vrati <code>false</code>.</p>","testString":"assert.isFalse(booWho([].slice));"},{"text":"<p><code>booWho({ \"a\": 1 })</code> treba da vrati <code>false</code>.</p>","testString":"assert.isFalse(booWho({ a: 1 }));"},{"text":"<p><code>booWho(1)</code> trebalo bi da vrati <code>false</code>.</p>","testString":"assert.isFalse(booWho(1));"},{"text":"<p><code>booWho(NaN)</code> treba vratiti <code>false</code>.</p>","testString":"assert.isFalse(booWho(NaN));"},{"text":"<p><code>booWho(\"a\")</code> trebalo bi da vrati <code>false</code>.</p>","testString":"assert.isFalse(booWho('a'));"},{"text":"<p><code>booWho(\"true\")</code> treba da vrati <code>false</code>.</p>","testString":"assert.isFalse(booWho('true'));"},{"text":"<p><code>booWho(\"false\")</code> trebalo bi da vrati <code>false</code>.</p>","testString":"assert.isFalse(booWho('false'));"}]}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/introduction-functions-in-javascript/#lab-boolean-check","dashedName":"build-a-boolean-check-function","certification":"introduction-functions-in-javascript","disableLoopProtectTests":false,"disableLoopProtectPreview":false,"superBlock":"introduction-functions-in-javascript","chapter":null,"module":null,"block":"lab-boolean-check","isFirstStep":true,"template":null,"required":[],"isLastChallengeInBlock":true,"nextChallengePath":"/learn/introduction-functions-in-javascript/lab-email-masker/build-an-email-masker","prevChallengePath":"/learn/introduction-functions-in-javascript/workshop-calculator/step-19","id":"a77dbc43c33f39daa4429b4f","saveSubmissionToDB":null},"projectPreview":{"challengeData":{"challengeType":26,"challengeFiles":[{"name":"script","ext":"js","contents":"function booWho(bool) {\r\n  return typeof bool === 'boolean';\r\n}\r\n","history":["script.js"],"fileKey":"scriptjs"}]}},"id":"/learn/introduction-functions-in-javascript/lab-boolean-check/build-a-boolean-check-function"}},"staticQueryHashes":["3858520367"],"slicesMap":{}}