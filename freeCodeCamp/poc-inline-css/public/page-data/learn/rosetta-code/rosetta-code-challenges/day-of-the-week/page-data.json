{"componentChunkName":"component---src-templates-challenges-classic-show-tsx","path":"/learn/rosetta-code/rosetta-code-challenges/day-of-the-week","result":{"data":{"challengeNode":{"challenge":{"block":"rosetta-code-challenges","demoType":null,"title":"Siku ya wiki","description":"<section id=\"description\">\n<p>Kompanija je odlučila da svaki put kada Božić padne u nedelju zaposlenima odobri dodatne plaćene slobodne dane, tako da zajedno sa državnim praznicima ne moraju da rade naredne sedmice (između 25. decembra i 1. januara).</p>\n</section>","id":"5966f99c45e8976909a85575","hasEditableBoundaries":false,"instructions":"<section id=\"instructions\">\n<p>Napišite funkciju koja prima početnu i krajnju godinu i vraća niz podataka svih godina u kojima će datum 25. decembra biti nedelja.</p>\n</section>","notes":null,"challengeType":1,"helpCategory":"Rosetta","videoUrl":null,"superBlock":"rosetta-code","translationPending":false,"forumTopicId":302245,"hooks":{"beforeAll":null,"beforeEach":"const firstSolution = [1977, 1983, 1988, 1994, 2005, 2011, 2016];\nconst secondSolution = [2011, 2016, 2022, 2033, 2039, 2044, 2050, 2061, 2067, 2072, 2078, 2089, 2095, 2101, 2107, 2112, 2118];","afterEach":null,"afterAll":null},"fields":{"slug":"/learn/rosetta-code/rosetta-code-challenges/day-of-the-week"},"required":[],"usesMultifileEditor":false,"challengeFiles":[{"fileKey":"scriptjs","ext":"js","name":"script","contents":"function findXmasSunday(start, end) {\n\n  return true;\n}","head":null,"tail":null,"editableRegionBoundaries":[],"history":["script.js"]}],"saveSubmissionToDB":null,"tests":[{"text":"<p><code>findXmasSunday</code> treba da bude funkcija.</p>","testString":"assert(typeof findXmasSunday === 'function');"},{"text":"<p><code>findXmasSunday(2000, 2100)</code> Trebalo bi da vrati red podataka.</p>","testString":"assert(typeof findXmasSunday(2000, 2100) === 'object');"},{"text":"<p><code>findXmasSunday(1970, 2017)</code> treba da vrati <code>[1977, 1983, 1988, 1994, 2005, 2011, 2016]</code></p>","testString":"assert.deepEqual(findXmasSunday(1970, 2017), firstSolution);"},{"text":"<p><code>findXmasSunday(2008, 2121)</code> treba da vrati <code>[2011, 2016, 2022, 2033, 2039, 2044, 2050, 2061, 2067, 2072, 2078, 2089, 2095, 2101, 2107, 2112, 2118]</code></p>","testString":"assert.deepEqual(findXmasSunday(2008, 2121), secondSolution);"}]}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/rosetta-code/#rosetta-code-challenges","dashedName":"day-of-the-week","certification":"rosetta-code","disableLoopProtectTests":true,"disableLoopProtectPreview":false,"superBlock":"rosetta-code","chapter":null,"module":null,"block":"rosetta-code-challenges","isFirstStep":false,"template":null,"required":[],"isLastChallengeInBlock":false,"nextChallengePath":"/learn/rosetta-code/rosetta-code-challenges/deal-cards-for-freecell","prevChallengePath":"/learn/rosetta-code/rosetta-code-challenges/date-manipulation","id":"5966f99c45e8976909a85575","saveSubmissionToDB":null},"projectPreview":{"challengeData":{"challengeType":1,"challengeFiles":[{"name":"script","ext":"js","contents":"function ZigZagMatrix(n) {\n  const mtx = [];\n  for (let i = 0; i < n; i++) {\n    mtx[i] = [];\n  }\n\n  let i = 1;\n  let j = 1;\n  for (let e = 0; e < n * n; e++) {\n    mtx[i - 1][j - 1] = e;\n    if ((i + j) % 2 === 0) {\n      // Even stripes\n      if (j < n) j++;\n      else i += 2;\n      if (i > 1) i--;\n    } else {\n      // Odd stripes\n      if (i < n) i++;\n      else j += 2;\n      if (j > 1) j--;\n    }\n  }\n  return mtx;\n}","history":["script.js"],"fileKey":"scriptjs"}]}},"id":"/learn/rosetta-code/rosetta-code-challenges/day-of-the-week"}},"staticQueryHashes":["3858520367"],"slicesMap":{}}