      "text": "<p>Treba da mu dodeliš atribut elementa za lozinku <code>input</code> sa atributom elementa <code>pattern</code>.</p>",
      "testString": "assert.isNotEmpty(document.querySelector('input[type=\"password\"]')?.pattern);"
    },
    {
      "text": "<p>Trebalo bi da mu dodeliš atribut elementu <code>pattern</code> vrednost <code>[a-z0-5]{8,}</code>.</p>",
      "testString": "assert.equal(document.querySelector('input[type=\"password\"]')?.pattern, '[a-z0-5]{8,}');"
    },
    {
      "text": "<p>Morate ukloniti atribut elementa <code>minlength</code> iz polja za lozinku <code>input</code>.</p>",
      "testString": "assert.equal(document.querySelector('input[type=\"password\"]')?.minLength, -1);"
