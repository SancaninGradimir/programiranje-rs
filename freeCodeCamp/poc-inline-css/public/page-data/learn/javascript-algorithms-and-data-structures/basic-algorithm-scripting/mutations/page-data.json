{"componentChunkName":"component---src-templates-challenges-classic-show-tsx","path":"/learn/javascript-algorithms-and-data-structures/basic-algorithm-scripting/mutations","result":{"data":{"challengeNode":{"challenge":{"block":"basic-algorithm-scripting","demoType":null,"title":"Mutacije","description":"<section id=\"description\">\n<p>Vratite <code>true</code> ako string u prvom elementu niza sadrzi sva slova stringa iz drugog elementa niza.</p>\n<p>Na primer, <code>[\"hello\", \"Hello\"]</code> treba da vrati <code>true</code>, jer su sva slova drugog stringa prisutna u prvom, bez obzira na velika i mala slova.</p>\n<p>Par <code>[\"hello\", \"hey\"]</code> treba da vrati <code>false</code>, jer string <code>hello</code> ne sadrzi <code>y</code>.</p>\n<p>Na kraju, <code>[\"Alien\", \"line\"]</code> treba da vrati <code>true</code>, jer su sva slova iz <code>line</code> prisutna u <code>Alien</code>.</p>\n</section>","id":"af2170cad53daa0770fabdea","hasEditableBoundaries":false,"instructions":"","notes":null,"challengeType":1,"helpCategory":"JavaScript","videoUrl":null,"superBlock":"javascript-algorithms-and-data-structures","translationPending":false,"forumTopicId":16025,"hooks":null,"fields":{"slug":"/learn/javascript-algorithms-and-data-structures/basic-algorithm-scripting/mutations"},"required":[],"usesMultifileEditor":false,"challengeFiles":[{"fileKey":"scriptjs","ext":"js","name":"script","contents":"function mutation(arr) {\n  return arr;\n}\n\nmutation(['hello', 'hey']);","head":null,"tail":null,"editableRegionBoundaries":[],"history":["script.js"]}],"saveSubmissionToDB":null,"tests":[{"text":"<p><code>mutation([\"hello\", \"hey\"])</code> treba da vrati <code>false</code>.</p>","testString":"assert.isFalse(mutation(['hello', 'hey']));"},{"text":"<p><code>mutation([\"hello\", \"Hello\"])</code> treba da vrati <code>true</code>.</p>","testString":"assert.isTrue(mutation(['hello', 'Hello']));"},{"text":"<p><code>mutation([\"zyxwvutsrqponmlkjihgfedcba\", \"qrstu\"])</code> treba da vrati <code>true</code>.</p>","testString":"assert.isTrue(mutation(['zyxwvutsrqponmlkjihgfedcba', 'qrstu']));"},{"text":"<p><code>mutation([\"Mary\", \"Army\"])</code> treba da vrati <code>true</code>.</p>","testString":"assert.isTrue(mutation(['Mary', 'Army']));"},{"text":"<p><code>mutation([\"Mary\", \"Aarmy\"])</code> treba da vrati <code>true</code>.</p>","testString":"assert.isTrue(mutation(['Mary', 'Aarmy']));"},{"text":"<p><code>mutation([\"Alien\", \"line\"])</code> treba da vrati <code>true</code>.</p>","testString":"assert.isTrue(mutation(['Alien', 'line']));"},{"text":"<p><code>mutation([\"floor\", \"for\"])</code> treba da vrati <code>true</code>.</p>","testString":"assert.isTrue(mutation(['floor', 'for']));"},{"text":"<p><code>mutation([\"hello\", \"neo\"])</code> treba da vrati <code>false</code>.</p>","testString":"assert.isFalse(mutation(['hello', 'neo']));"},{"text":"<p><code>mutation([\"voodoo\", \"no\"])</code> treba da vrati <code>false</code>.</p>","testString":"assert.isFalse(mutation(['voodoo', 'no']));"},{"text":"<p><code>mutation([\"ate\", \"date\"])</code> treba da vrati <code>false</code>.</p>","testString":"assert.isFalse(mutation(['ate', 'date']));"},{"text":"<p><code>mutation([\"Tiger\", \"Zebra\"])</code> treba da vrati <code>false</code>.</p>","testString":"assert.isFalse(mutation(['Tiger', 'Zebra']));"},{"text":"<p><code>mutation([\"Noel\", \"Ole\"])</code> treba da vrati <code>true</code>.</p>","testString":"assert.isTrue(mutation(['Noel', 'Ole']));"}]}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/javascript-algorithms-and-data-structures/#basic-algorithm-scripting","dashedName":"mutations","certification":"javascript-algorithms-and-data-structures","disableLoopProtectTests":false,"disableLoopProtectPreview":false,"superBlock":"javascript-algorithms-and-data-structures","chapter":null,"module":null,"block":"basic-algorithm-scripting","isFirstStep":false,"template":null,"required":[],"isLastChallengeInBlock":false,"nextChallengePath":"/learn/javascript-algorithms-and-data-structures/basic-algorithm-scripting/chunky-monkey","prevChallengePath":"/learn/javascript-algorithms-and-data-structures/basic-algorithm-scripting/where-do-i-belong","id":"af2170cad53daa0770fabdea","saveSubmissionToDB":null},"projectPreview":{"challengeData":{"challengeType":1,"challengeFiles":[{"name":"script","ext":"js","contents":"function chunkArrayInGroups(arr, size) {\n  let out = [];\n\n  for (let i = 0; i < arr.length; i += size) {\n    out.push(arr.slice(i, i + size));\n  }\n\n  return out;\n}\n\nchunkArrayInGroups(['a', 'b', 'c', 'd'], 2);","history":["script.js"],"fileKey":"scriptjs"}]}},"id":"/learn/javascript-algorithms-and-data-structures/basic-algorithm-scripting/mutations"}},"staticQueryHashes":["3858520367"],"slicesMap":{}}