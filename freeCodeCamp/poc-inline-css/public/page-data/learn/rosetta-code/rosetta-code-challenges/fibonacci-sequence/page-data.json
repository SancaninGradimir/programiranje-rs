{"componentChunkName":"component---src-templates-challenges-classic-show-tsx","path":"/learn/rosetta-code/rosetta-code-challenges/fibonacci-sequence","result":{"data":{"challengeNode":{"challenge":{"block":"rosetta-code-challenges","demoType":null,"title":"Fibonaccijev niz","description":"<section id=\"description\">\n<p>Napišite funkciju koja generiše N-ti broj <code>n<sup>th</sup></code> u Fibonaccijevoj sekvenci.</p>\n<p>Broj <code>n<sup>th</sup></code> u Fibonaccijevoj sekvenci se dobija sa:</p>\n<p><code>F<sub>n</sub> = F<sub>n-1</sub> + F<sub>n-2</sub></code></p>\n<p>Prva dva elementa serije su 0 i 1.</p>\n<p>Dakle, niz je: 0, 1, 1, 2, 3, 5, 8, 13...</p>\n</section>","id":"597f24c1dda4e70f53c79c81","hasEditableBoundaries":false,"instructions":"","notes":null,"challengeType":1,"helpCategory":"Rosetta","videoUrl":null,"superBlock":"rosetta-code","translationPending":false,"forumTopicId":302268,"hooks":null,"fields":{"slug":"/learn/rosetta-code/rosetta-code-challenges/fibonacci-sequence"},"required":[],"usesMultifileEditor":false,"challengeFiles":[{"fileKey":"scriptjs","ext":"js","name":"script","contents":"function fibonacci(n) {\n\n}","head":null,"tail":null,"editableRegionBoundaries":[],"history":["script.js"]}],"saveSubmissionToDB":null,"tests":[{"text":"<p><code>fibonacci</code> Trebalo bi da bude funkcionalno.</p>","testString":"assert(typeof fibonacci === 'function');"},{"text":"<p><code>fibonacci(2)</code> trebalo bi da vrati broj.</p>","testString":"assert(typeof fibonacci(2) == 'number');"},{"text":"<p><code>fibonacci(3)</code> Trebalo bi da vrati 2.</p>","testString":"assert.equal(fibonacci(3), 2);"},{"text":"<p><code>fibonacci(5)</code> Trebalo bi da vrati 5.</p>","testString":"assert.equal(fibonacci(5), 5);"},{"text":"<p><code>fibonacci(10)</code> trebalo bi da vrati 55.</p>","testString":"assert.equal(fibonacci(10), 55);"}]}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/rosetta-code/#rosetta-code-challenges","dashedName":"fibonacci-sequence","certification":"rosetta-code","disableLoopProtectTests":true,"disableLoopProtectPreview":false,"superBlock":"rosetta-code","chapter":null,"module":null,"block":"rosetta-code-challenges","isFirstStep":false,"template":null,"required":[],"isLastChallengeInBlock":false,"nextChallengePath":"/learn/rosetta-code/rosetta-code-challenges/fibonacci-word","prevChallengePath":"/learn/rosetta-code/rosetta-code-challenges/fibonacci-n-step-number-sequences","id":"597f24c1dda4e70f53c79c81","saveSubmissionToDB":null},"projectPreview":{"challengeData":{"challengeType":1,"challengeFiles":[{"name":"script","ext":"js","contents":"function ZigZagMatrix(n) {\n  const mtx = [];\n  for (let i = 0; i < n; i++) {\n    mtx[i] = [];\n  }\n\n  let i = 1;\n  let j = 1;\n  for (let e = 0; e < n * n; e++) {\n    mtx[i - 1][j - 1] = e;\n    if ((i + j) % 2 === 0) {\n      // Even stripes\n      if (j < n) j++;\n      else i += 2;\n      if (i > 1) i--;\n    } else {\n      // Odd stripes\n      if (i < n) i++;\n      else j += 2;\n      if (j > 1) j--;\n    }\n  }\n  return mtx;\n}","history":["script.js"],"fileKey":"scriptjs"}]}},"id":"/learn/rosetta-code/rosetta-code-challenges/fibonacci-sequence"}},"staticQueryHashes":["3858520367"],"slicesMap":{}}