{"componentChunkName":"component---src-templates-challenges-classic-show-tsx","path":"/learn/project-euler/project-euler-problems-1-to-100/problem-100-arranged-probability","result":{"data":{"challengeNode":{"challenge":{"block":"project-euler-problems-1-to-100","demoType":null,"title":"Vežba 100: Planirana mogućnost","description":"<section id=\"description\">\n<p>Ako kutija ima dvadeset i jedan bojenih diskova, sa petnaest plavih i šest crvenih diskova, a ako se slučajno izaberu dva diskova, verovatnoća da će biti odabrana dva plava diskova je:</p>\n<p>$${P(BB)} = \\frac{15}{21}×\\frac{14}{20} = \\frac{1}{2}$$</p>\n<p>Sledeći aranžman ovakvog tipa, koji ima tačno 50 procenat šanse da se slučajno izvuče dve plave ploče, je kutija sa osamdeset pet plavih ploča i trideset pet crvenih ploča.</p>\n<p>Da biste dobili prvu konfiguraciju sa više od <code>limit</code> diskova ukupno, odredite broj plavih diskova koje bi ta kutija imala.</p>\n</section>","id":"5900f3d01000cf542c50fee3","hasEditableBoundaries":false,"instructions":"","notes":null,"challengeType":1,"helpCategory":"Euler","videoUrl":null,"superBlock":"project-euler","translationPending":false,"forumTopicId":301724,"hooks":null,"fields":{"slug":"/learn/project-euler/project-euler-problems-1-to-100/problem-100-arranged-probability"},"required":[],"usesMultifileEditor":false,"challengeFiles":[{"fileKey":"scriptjs","ext":"js","name":"script","contents":"function arrangedProbability(limit) {\n\n  return true;\n}\n\narrangedProbability(20);","head":null,"tail":null,"editableRegionBoundaries":[],"history":["script.js"]}],"saveSubmissionToDB":null,"tests":[{"text":"<p><code>arrangedProbability(20)</code> Trebalo bi da vrati broj.</p>","testString":"assert(typeof arrangedProbability(10) === 'number');"},{"text":"<p><code>arrangedProbability(20)</code> treba da vrati <code>15</code>.</p>","testString":"assert.strictEqual(arrangedProbability(20), 15);"},{"text":"<p><code>arrangedProbability(100)</code> treba da vrati <code>85</code>.</p>","testString":"assert.strictEqual(arrangedProbability(100), 85);"},{"text":"<p><code>arrangedProbability(100000)</code> treba da vrati <code>97513</code>.</p>","testString":"assert.strictEqual(arrangedProbability(100000), 97513);"},{"text":"<p><code>arrangedProbability(1000000000)</code> trebalo bi da vrati <code>3822685023</code>.</p>","testString":"assert.strictEqual(arrangedProbability(1000000000), 3822685023);"},{"text":"<p><code>arrangedProbability(1000000000000)</code> trebalo bi da vrati <code>756872327473</code>.</p>","testString":"assert.strictEqual(arrangedProbability(1000000000000), 756872327473);"}]}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/project-euler/#project-euler-problems-1-to-100","dashedName":"problem-100-arranged-probability","certification":"project-euler","disableLoopProtectTests":true,"disableLoopProtectPreview":false,"superBlock":"project-euler","chapter":null,"module":null,"block":"project-euler-problems-1-to-100","isFirstStep":false,"template":null,"required":[],"isLastChallengeInBlock":true,"nextChallengePath":"/learn/project-euler/project-euler-problems-101-to-200/problem-101-optimum-polynomial","prevChallengePath":"/learn/project-euler/project-euler-problems-1-to-100/problem-99-largest-exponential","id":"5900f3d01000cf542c50fee3","saveSubmissionToDB":null},"projectPreview":{"challengeData":{"challengeType":1,"challengeFiles":[{"name":"script","ext":"js","contents":"function arrangedProbability(limit) {\n  // Based on https://www.mathblog.dk/project-euler-100-blue-discs-two-blue/\n  let blue = 15;\n  let discs = 21;\n\n  while (discs < limit) {\n    const nextBlue = 3 * blue + 2 * discs - 2;\n    const nextDiscs = 4 * blue + 3 * discs - 3;\n\n    blue = nextBlue;\n    discs = nextDiscs;\n  }\n  return blue;\n}","history":["script.js"],"fileKey":"scriptjs"}]}},"id":"/learn/project-euler/project-euler-problems-1-to-100/problem-100-arranged-probability"}},"staticQueryHashes":["3858520367"],"slicesMap":{}}