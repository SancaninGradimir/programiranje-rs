{"componentChunkName":"component---src-templates-challenges-classic-show-tsx","path":"/learn/rosetta-code/rosetta-code-challenges/spiral-matrix","result":{"data":{"challengeNode":{"challenge":{"block":"rosetta-code-challenges","demoType":null,"title":"Red ciklične matrice","description":"<section id=\"description\">\n<p>Napravite kružni red. <em>Kružni red</em> je raspored kvadratnih prirodnih brojeva N<sup>2</sup>, počevši od prvog, gde se brojevi povećavaju sekvencijalno dok prolaze kroz granice tog reda krećući se kružno unutra. Na primer, ako dobijete <strong>5</strong>, napravite ovaj red:</p>\n<pre>\n0  1  2  3  4\n15 16 17 18 5\n14 23 24 19 6\n13 22 21 20 7\n12 11 10  9 8\n</pre>\n</section>","id":"5a23c84252665b21eecc801c","hasEditableBoundaries":false,"instructions":"","notes":null,"challengeType":1,"helpCategory":"Rosetta","videoUrl":null,"superBlock":"rosetta-code","translationPending":false,"forumTopicId":302321,"hooks":null,"fields":{"slug":"/learn/rosetta-code/rosetta-code-challenges/spiral-matrix"},"required":[],"usesMultifileEditor":false,"challengeFiles":[{"fileKey":"scriptjs","ext":"js","name":"script","contents":"function spiralArray(n) {\n\n}","head":null,"tail":null,"editableRegionBoundaries":[],"history":["script.js"]}],"saveSubmissionToDB":null,"tests":[{"text":"<p><code>spiralArray</code> Trebalo bi da bude funkcija.</p>","testString":"assert(typeof spiralArray == 'function');"},{"text":"<p><code>spiralArray(3)</code> Trebalo bi da vrati red podataka.</p>","testString":"assert(Array.isArray(spiralArray(3)));"},{"text":"<p><code>spiralArray(3)</code> treba da vrati <code>[[0, 1, 2],[7, 8, 3],[6, 5, 4]]</code>.</p>","testString":"assert.deepEqual(spiralArray(3), [\n  [0, 1, 2],\n  [7, 8, 3],\n  [6, 5, 4]\n]);"},{"text":"<p><code>spiralArray(4)</code> treba da vrati <code>[[0, 1, 2, 3],[11, 12, 13, 4],[10, 15, 14, 5],[9, 8, 7, 6]]</code>.</p>","testString":"assert.deepEqual(spiralArray(4), [\n  [0, 1, 2, 3],\n  [11, 12, 13, 4],\n  [10, 15, 14, 5],\n  [9, 8, 7, 6]\n]);"},{"text":"<p><code>spiralArray(5)</code> treba da vrati <code>[[0, 1, 2, 3, 4],[15, 16, 17, 18, 5],[14, 23, 24, 19, 6],[13, 22, 21, 20, 7],[12, 11, 10, 9, 8]]</code>.</p>","testString":"assert.deepEqual(spiralArray(5), [\n  [0, 1, 2, 3, 4],\n  [15, 16, 17, 18, 5],\n  [14, 23, 24, 19, 6],\n  [13, 22, 21, 20, 7],\n  [12, 11, 10, 9, 8]\n]);"}]}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/rosetta-code/#rosetta-code-challenges","dashedName":"spiral-matrix","certification":"rosetta-code","disableLoopProtectTests":true,"disableLoopProtectPreview":false,"superBlock":"rosetta-code","chapter":null,"module":null,"block":"rosetta-code-challenges","isFirstStep":false,"template":null,"required":[],"isLastChallengeInBlock":false,"nextChallengePath":"/learn/rosetta-code/rosetta-code-challenges/split-a-character-string-based-on-change-of-character","prevChallengePath":"/learn/rosetta-code/rosetta-code-challenges/soundex","id":"5a23c84252665b21eecc801c","saveSubmissionToDB":null},"projectPreview":{"challengeData":{"challengeType":1,"challengeFiles":[{"name":"script","ext":"js","contents":"function ZigZagMatrix(n) {\n  const mtx = [];\n  for (let i = 0; i < n; i++) {\n    mtx[i] = [];\n  }\n\n  let i = 1;\n  let j = 1;\n  for (let e = 0; e < n * n; e++) {\n    mtx[i - 1][j - 1] = e;\n    if ((i + j) % 2 === 0) {\n      // Even stripes\n      if (j < n) j++;\n      else i += 2;\n      if (i > 1) i--;\n    } else {\n      // Odd stripes\n      if (i < n) i++;\n      else j += 2;\n      if (j > 1) j--;\n    }\n  }\n  return mtx;\n}","history":["script.js"],"fileKey":"scriptjs"}]}},"id":"/learn/rosetta-code/rosetta-code-challenges/spiral-matrix"}},"staticQueryHashes":["3858520367"],"slicesMap":{}}