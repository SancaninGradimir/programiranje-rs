      "fileKey": "indexhtml",
      "contents": "<!DOCTYPE html>\n<html lang=\"en\">\n\n<head>\n  <meta charset=\"utf-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Parent Teacher Conference Form</title>\n  <link rel=\"stylesheet\" href=\"./styles.css\" />\n</head>\n\n<body>\n  <main class=\"container\">\n    <h1 class=\"title center\">Parent Teacher Conference Form</h1>\n    <p class=\"description center\">Please fill out the form below to help schedule your parent-teacher conference.</p>\n\n    <form>\n      <fieldset>\n        <legend>Student Information</legend>\n        <label for=\"student-name\">Full Name: </label>\n        <input\n            type=\"text\"\n            name=\"student-name\"\n            id=\"student-name\"\n            required\n            placeholder=\"E.g., Jane Doe\"\n          />\n\n\n        <label for=\"grade\">Student Grade: </label>\n        <input\n            type=\"number\"\n            name=\"grade\"\n            id=\"grade\"\n            required\n            placeholder=\"E.g., 4\"\n          />\n      </fieldset>\n\n      <fieldset>\n        <legend>Parent/Guardian Information</legend>\n        <label for=\"parent-name\">Parent/Guardian Name: </label>\n        <input\n            type=\"text\"\n            name=\"parent-name\"\n            id=\"parent-name\"\n            required\n            placeholder=\"E.g., Nancy Doe\"\n          />\n      </fieldset>\n\n      <fieldset>\n        <legend>Preferred Contact Method</legend>\n        <label class=\"contact-method\" for=\"email\">Email: </label>\n        <input\n            id=\"email\"\n            class=\"contact-method-radio-btn\"\n            type=\"radio\"\n            name=\"contact-method\"\n            value=\"email\"\n            checked\n          />\n        \n      </fieldset>\n    </form>\n  </main>\n</body>\n\n</html>",
      "error": null,
      "seed": "<!DOCTYPE html>\n<html lang=\"en\">\n\n<head>\n  <meta charset=\"utf-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Parent Teacher Conference Form</title>\n  <link rel=\"stylesheet\" href=\"./styles.css\" />\n</head>\n\n<body>\n  <main class=\"container\">\n    <h1 class=\"title center\">Parent Teacher Conference Form</h1>\n    <p class=\"description center\">Please fill out the form below to help schedule your parent-teacher conference.</p>\n\n    <form>\n      <fieldset>\n        <legend>Student Information</legend>\n        <label for=\"student-name\">Full Name: </label>\n        <input\n            type=\"text\"\n            name=\"student-name\"\n            id=\"student-name\"\n            required\n            placeholder=\"E.g., Jane Doe\"\n          />\n\n\n        <label for=\"grade\">Student Grade: </label>\n        <input\n            type=\"number\"\n            name=\"grade\"\n            id=\"grade\"\n            required\n            placeholder=\"E.g., 4\"\n          />\n      </fieldset>\n\n      <fieldset>\n        <legend>Parent/Guardian Information</legend>\n        <label for=\"parent-name\">Parent/Guardian Name: </label>\n        <input\n            type=\"text\"\n            name=\"parent-name\"\n            id=\"parent-name\"\n            required\n            placeholder=\"E.g., Nancy Doe\"\n          />\n      </fieldset>\n\n      <fieldset>\n        <legend>Preferred Contact Method</legend>\n        <label class=\"contact-method\" for=\"email\">Email: </label>\n        <input\n            id=\"email\"\n            class=\"contact-method-radio-btn\"\n            type=\"radio\"\n            name=\"contact-method\"\n            value=\"email\"\n            checked\n          />\n        \n      </fieldset>\n    </form>\n  </main>\n</body>\n\n</html>"
