{"componentChunkName":"component---src-templates-challenges-classic-show-tsx","path":"/learn/rosetta-code/rosetta-code-challenges/split-a-character-string-based-on-change-of-character","result":{"data":{"challengeNode":{"challenge":{"block":"rosetta-code-challenges","demoType":null,"title":"Razdvoj niz slova prema promenama slova","description":"<section id=\"description\">\n<p>Podeli string u niz stringova razdvojenih zarezom (uz razmak), prema promenama karaktera (sleva nadesno). Razmaci treba da se tretiraju kao bilo koji drugi karakter (iako ih je teže prikazati). Isto važi i za zareze. Na primer, string:</p>\n<pre>\n\"gHHH5YY++///\\\\\"\n</pre>\n<p>Trebalo bi se podeliti kao:</p>\n<pre>\n[\"g\", \"HHH\", \"5\", \"YY\", \"++\", \"///\", \"\\\\\" ];\n</pre>\n</section>","id":"5a23c84252665b21eecc801d","hasEditableBoundaries":false,"instructions":"","notes":null,"challengeType":1,"helpCategory":"Rosetta","videoUrl":null,"superBlock":"rosetta-code","translationPending":false,"forumTopicId":302322,"hooks":null,"fields":{"slug":"/learn/rosetta-code/rosetta-code-challenges/split-a-character-string-based-on-change-of-character"},"required":[],"usesMultifileEditor":false,"challengeFiles":[{"fileKey":"scriptjs","ext":"js","name":"script","contents":"function split(str) {\n\n}","head":null,"tail":null,"editableRegionBoundaries":[],"history":["script.js"]}],"saveSubmissionToDB":null,"tests":[{"text":"<p><code>split</code> Trebalo bi da bude funkcija.</p>","testString":"assert(typeof split == 'function');"},{"text":"<p><code>split(\"hello\")</code> Trebalo bi da vrati red podataka.</p>","testString":"assert(Array.isArray(split('hello')));"},{"text":"<p><code>split(\"hello\")</code> trebalo bi da vrati <code>[\"h\", \"e\", \"ll\", \"o\"]</code>.</p>","testString":"assert.deepEqual(split('hello'), ['h', 'e', 'll', 'o']);"},{"text":"<p><code>split(\"commission\")</code> inapaswa kurudisha <code>[\"c\", \"o\", \"mm\", \"i\", \"ss\", \"i\", \"o\", \"n\"]</code>.</p>","testString":"assert.deepEqual(split('commission'), [\n  'c',\n  'o',\n  'mm',\n  'i',\n  'ss',\n  'i',\n  'o',\n  'n'\n]);"},{"text":"<p><code>split(\"ssss----====llloooo\")</code> inapaswa kurudisha <code>[\"ssss\", \"----\", \"====\", \"lll\", \"oooo\"]</code>.</p>","testString":"assert.deepEqual(split('ssss----====llloooo'), [\n  'ssss',\n  '----',\n  '====',\n  'lll',\n  'oooo'\n]);"},{"text":"<p><code>split(\"sssmmmaaammmaaat\")</code> inapaswa kurudisha <code>[\"sss\", \"mmm\", \"aaa\", \"mmm\", \"aaa\", \"t\"]</code>.</p>","testString":"assert.deepEqual(split('sssmmmaaammmaaat'), [\n  'sss',\n  'mmm',\n  'aaa',\n  'mmm',\n  'aaa',\n  't'\n]);"},{"text":"<p><code>split(\"gHHH5YY++///\\\\\")</code> trebalo bi da vrati <code>[\"g\", \"HHH\", \"5\", \"YY\", \"++\", \"///\", \"\\\\\"]</code>.</p>","testString":"assert.deepEqual(split('gHHH5YY++///\\\\'), [\n  'g',\n  'HHH',\n  '5',\n  'YY',\n  '++',\n  '///',\n  '\\\\'\n]);"}]}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/rosetta-code/#rosetta-code-challenges","dashedName":"split-a-character-string-based-on-change-of-character","certification":"rosetta-code","disableLoopProtectTests":true,"disableLoopProtectPreview":false,"superBlock":"rosetta-code","chapter":null,"module":null,"block":"rosetta-code-challenges","isFirstStep":false,"template":null,"required":[],"isLastChallengeInBlock":false,"nextChallengePath":"/learn/rosetta-code/rosetta-code-challenges/state-name-puzzle","prevChallengePath":"/learn/rosetta-code/rosetta-code-challenges/spiral-matrix","id":"5a23c84252665b21eecc801d","saveSubmissionToDB":null},"projectPreview":{"challengeData":{"challengeType":1,"challengeFiles":[{"name":"script","ext":"js","contents":"function ZigZagMatrix(n) {\n  const mtx = [];\n  for (let i = 0; i < n; i++) {\n    mtx[i] = [];\n  }\n\n  let i = 1;\n  let j = 1;\n  for (let e = 0; e < n * n; e++) {\n    mtx[i - 1][j - 1] = e;\n    if ((i + j) % 2 === 0) {\n      // Even stripes\n      if (j < n) j++;\n      else i += 2;\n      if (i > 1) i--;\n    } else {\n      // Odd stripes\n      if (i < n) i++;\n      else j += 2;\n      if (j > 1) j--;\n    }\n  }\n  return mtx;\n}","history":["script.js"],"fileKey":"scriptjs"}]}},"id":"/learn/rosetta-code/rosetta-code-challenges/split-a-character-string-based-on-change-of-character"}},"staticQueryHashes":["3858520367"],"slicesMap":{}}