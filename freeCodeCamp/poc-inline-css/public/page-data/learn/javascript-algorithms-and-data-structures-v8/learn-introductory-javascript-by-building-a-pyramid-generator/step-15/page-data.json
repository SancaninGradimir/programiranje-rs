{"componentChunkName":"component---src-templates-challenges-classic-show-tsx","path":"/learn/javascript-algorithms-and-data-structures-v8/learn-introductory-javascript-by-building-a-pyramid-generator/step-15","result":{"data":{"challengeNode":{"challenge":{"block":"learn-introductory-javascript-by-building-a-pyramid-generator","demoType":null,"title":"Korak 15","description":"<section id=\"description\">\n<p>Koristi <code>let</code> da objaviš varijablu <code>count</code>. Postavi vrednost <dfn>broj</dfn> <code>8</code>. Kada koristiš numeričku vrednost, ne koristi navodnike. Primer:</p>\n<pre><code class=\"language-js\">let money = 100;\n</code></pre>\n</section>","id":"660ef5c1904955978a986a5c","hasEditableBoundaries":true,"instructions":"","notes":null,"challengeType":1,"helpCategory":"JavaScript","videoUrl":null,"superBlock":"javascript-algorithms-and-data-structures-v8","translationPending":false,"forumTopicId":null,"hooks":null,"fields":{"slug":"/learn/javascript-algorithms-and-data-structures-v8/learn-introductory-javascript-by-building-a-pyramid-generator/step-15"},"required":[],"usesMultifileEditor":true,"challengeFiles":[{"fileKey":"scriptjs","ext":"js","name":"script","contents":"let character = 'Hello';\n","head":null,"tail":null,"editableRegionBoundaries":[0,3],"history":["script.js"]}],"saveSubmissionToDB":null,"tests":[{"text":"<p>Trebalo bi da imaš ključnu reč <code>let</code> drugog u tvom kodu.</p>","testString":"assert.lengthOf(__helpers.removeJSComments(code).match(/let/g), 2);"},{"text":"<p>Trebalo bi da koristite <code>let</code> za deklarisanje varijable <code>count</code>.</p>","testString":"assert.match(__helpers.removeJSComments(code), /let\\s+count/);"},{"text":"<p>Treba da postaviš vrednost broja <code>8</code> za svoju varijablu <code>count</code>.</p>","testString":"assert.equal(count, 8);"}]}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/javascript-algorithms-and-data-structures-v8/#learn-introductory-javascript-by-building-a-pyramid-generator","dashedName":"step-15","certification":"javascript-algorithms-and-data-structures-v8","disableLoopProtectTests":false,"disableLoopProtectPreview":false,"superBlock":"javascript-algorithms-and-data-structures-v8","chapter":null,"module":null,"block":"learn-introductory-javascript-by-building-a-pyramid-generator","isFirstStep":false,"template":null,"required":[],"isLastChallengeInBlock":false,"nextChallengePath":"/learn/javascript-algorithms-and-data-structures-v8/learn-introductory-javascript-by-building-a-pyramid-generator/step-16","prevChallengePath":"/learn/javascript-algorithms-and-data-structures-v8/learn-introductory-javascript-by-building-a-pyramid-generator/step-14","id":"660ef5c1904955978a986a5c","saveSubmissionToDB":null},"projectPreview":{"challengeData":{"challengeType":1,"challengeFiles":[{"name":"script","ext":"js","contents":"const character = \"!\";\nconst count = 10;\nconst rows = [];\nlet inverted = false;\n\nfunction padRow(rowNumber, rowCount) {\n  return \" \".repeat(rowCount - rowNumber) + character.repeat(2 * rowNumber - 1) + \" \".repeat(rowCount - rowNumber);\n}\n\nfor (let i = 1; i <= count; i++) {\n  if (inverted) {\n    rows.unshift(padRow(i, count));\n  } else {\n    rows.push(padRow(i, count));\n  }\n}\n\nlet result = \"\"\n\nfor (const row of rows) {\n  result = result + row + \"\\n\";\n}\n\nconsole.log(result);","history":["script.js"],"fileKey":"scriptjs"}]}},"id":"/learn/javascript-algorithms-and-data-structures-v8/learn-introductory-javascript-by-building-a-pyramid-generator/step-15"}},"staticQueryHashes":["3858520367"],"slicesMap":{}}