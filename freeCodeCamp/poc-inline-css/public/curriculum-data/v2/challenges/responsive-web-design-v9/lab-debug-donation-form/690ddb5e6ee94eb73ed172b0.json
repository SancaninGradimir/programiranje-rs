    {
      "text": "<p>Potrebno je da imate zatvarajući tagove za <code>&#x3C;/input></code> u vašem kodu.</p>",
      "testString": "assert.notMatch(code, /<\\/input>/);"
    },
    {
      "text": "<p>Trebalo bi da imaš četiri elementa <code>input</code> u svom formularu.</p>",
      "testString": "assert.lengthOf(document.querySelectorAll(\"input\"), 5);"
    },
    {
      "text": "<p>Trebalo bi da imaš četiri elementa <code>label</code> u tvom formularu.</p>",
      "testString": "assert.lengthOf(document.querySelectorAll(\"label\"), 4);"
    },
    {
      "text": "<p><code>label</code> Vaš prvi treba da ima tekst od <code>Full Name:</code>.</p>",
      "testString": "const labels = document.querySelectorAll(\"label\");\nassert.match(labels[0]?.textContent, /Full\\s*Name\\s*:/i);"
    },
    {
      "text": "<p>Tvoj prvi element <code>input</code> treba da ima atribut <code>required</code>.</p>",
      "testString": "const firstInput = document.querySelector(\"input[name='name']\");\nassert.isTrue(firstInput?.hasAttribute(\"required\"));"
    },
    {
      "text": "<p>Tvoj drugi element <code>label</code> treba da sadrži tekst <code>Email Address:</code>.</p>",
      "testString": "const labels = document.querySelectorAll(\"label\");\nassert.match(labels[1]?.textContent, /Email\\s*Address\\s*:/i);"
    },
    {
      "text": "<p>Tvoj drugi element <code>input</code> treba da ima atribut <code>required</code>.</p>",
      "testString": "const secondInput = document.querySelector(\"input[name='email']\");\nassert.isTrue(secondInput?.hasAttribute(\"required\"));"
    },
    {
