    {
      "text": "<p>Trebalo bi da imaš element <code>div</code>.</p>",
      "testString": "const div = document.querySelector('div');\nassert.exists(div);"
    },
    {
      "text": "<p>Tvoj element <code>div</code> mora imati svojstvo <code>id</code> sa vrednošću <code>game</code>.</p>",
      "testString": "const div = document.querySelector('div');\nassert.equal(div?.id, 'game');"
