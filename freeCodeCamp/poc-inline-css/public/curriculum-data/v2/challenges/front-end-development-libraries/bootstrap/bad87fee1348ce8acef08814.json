    {
      "text": "<p>Sva Bootstrap dugmad treba da imaju klase <code>btn</code> i <code>btn-block</code>.</p>",
      "testString": "assert.lengthOf(document.querySelectorAll('button.btn-block.btn'),3);"
    },
    {
      "text": "<p>Vaše novo dugme treba da ima klasu <code>btn-danger</code>.</p>",
      "testString": "const deleteButton = document.querySelectorAll('button')?.[2]; \r\nassert.isTrue(deleteButton?.classList?.contains('btn-danger'));"
    },
    {
      "text": "<p>Svi elementi <code>button</code> treba da imaju zatvarajuće tagove.</p>",
      "testString": "assert.match(code,/<\\/button>/g);\r\nassert.match(code,/<button/g);\r\nassert.equal(code.match(/<\\/button>/g).length,code.match(/<button/g).length);"
