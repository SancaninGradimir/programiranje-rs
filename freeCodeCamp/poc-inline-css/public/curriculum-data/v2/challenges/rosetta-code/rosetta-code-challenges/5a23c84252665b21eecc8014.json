        "contents": "function stableSort(arr) {\n  arr.sort(function(a, b) {\n    return a[1] < b[1] ? -1 : a[1] > b[1] ? 1 : 0;\n  });\n  return arr;\n}",
        "error": null,
        "seed": "function stableSort(arr) {\n  arr.sort(function(a, b) {\n    return a[1] < b[1] ? -1 : a[1] > b[1] ? 1 : 0;\n  });\n  return arr;\n}"
      }
