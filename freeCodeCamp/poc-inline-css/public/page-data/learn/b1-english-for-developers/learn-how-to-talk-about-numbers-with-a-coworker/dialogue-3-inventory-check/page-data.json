{"componentChunkName":"component---src-templates-challenges-generic-show-tsx","path":"/learn/b1-english-for-developers/learn-how-to-talk-about-numbers-with-a-coworker/dialogue-3-inventory-check","result":{"data":{"challengeNode":{"challenge":{"assignments":["<p>Gledaj video.</p>"],"bilibiliIds":null,"block":"learn-how-to-talk-about-numbers-with-a-coworker","challengeType":21,"description":"<section id=\"description\">\n<p>Pogledajte video dole/ispod kako biste razumeli kontekst predstojećih lekcija.</p>\n</section>","nodules":null,"explanation":null,"helpCategory":"English","instructions":"","fields":{"slug":"/learn/b1-english-for-developers/learn-how-to-talk-about-numbers-with-a-coworker/dialogue-3-inventory-check"},"questions":[],"scene":{"setup":{"background":"company2-center.png","characters":[{"character":"Sophie","position":{"x":-25,"y":0,"z":1},"opacity":null},{"character":"Tom","position":{"x":125,"y":0,"z":1},"opacity":null}],"audio":{"filename":"B1_23-3.mp3","startTime":1,"startTimestamp":null,"finishTimestamp":null},"alwaysShowDialogue":true},"commands":[{"background":null,"character":"Sophie","position":{"x":25,"y":0,"z":1},"opacity":null,"startTime":0,"finishTime":null,"dialogue":null},{"background":null,"character":"Tom","position":{"x":70,"y":0,"z":1},"opacity":null,"startTime":0.5,"finishTime":null,"dialogue":null},{"background":null,"character":"Sophie","position":null,"opacity":null,"startTime":1,"finishTime":7.96,"dialogue":{"text":"Hey Tom, we need to go through our software tools inventory today. Let's start with the licenses. How many do we currently have in total?","align":"left"}},{"background":null,"character":"Tom","position":null,"opacity":null,"startTime":8.26,"finishTime":13.94,"dialogue":{"text":"We have about 50 licenses right now. Most of them, around 30, are allocated to the design team.","align":"right"}},{"background":null,"character":"Sophie","position":null,"opacity":null,"startTime":14.58,"finishTime":17.76,"dialogue":{"text":"Okay, and where are these licenses stored? I need to update our records.","align":"left"}},{"background":null,"character":"Tom","position":null,"opacity":null,"startTime":18.22,"finishTime":27.2,"dialogue":{"text":"They're mainly on the central server under the Licensed Software folder. A few are also in the cloud storage, specifically in the Backup Licenses section.","align":"right"}},{"background":null,"character":"Sophie","position":null,"opacity":null,"startTime":27.84,"finishTime":33.02,"dialogue":{"text":"Got it. Next, let's count the graphic tablets. I saw some in the storage room. How many are there?","align":"left"}},{"background":null,"character":"Tom","position":null,"opacity":null,"startTime":33.52,"finishTime":40.7,"dialogue":{"text":"There are 10 tablets in the storage room, right between the spare monitors and the old project files. We should have another 5 in the workshop area.","align":"right"}},{"background":null,"character":"Sophie","position":null,"opacity":null,"startTime":41.36,"finishTime":46.42,"dialogue":{"text":"Perfect. That makes 15 in total. Now, about the design software updates, do we have any pending?","align":"left"}},{"background":null,"character":"Tom","position":null,"opacity":null,"startTime":46.9,"finishTime":53.64,"dialogue":{"text":"Yes, there are updates pending for 5 of our main design tools. These updates are critical and should be installed by next week.","align":"right"}},{"background":null,"character":"Sophie","position":null,"opacity":null,"startTime":54.28,"finishTime":62.62,"dialogue":{"text":"Alright, I'll schedule those updates. Can we review the usage stats for our main design platform? I'm interested in the average usage over the past month.","align":"left"}},{"background":null,"character":"Tom","position":null,"opacity":null,"startTime":63.34,"finishTime":72.24,"dialogue":{"text":"Of course. The platform was used an average of about 60 hours per week by the team. The peak usage was around 80 hours two weeks ago.","align":"right"}},{"background":null,"character":"Sophie","position":null,"opacity":null,"startTime":72.74,"finishTime":79,"dialogue":{"text":"Thanks, Tom. This information helps a lot. I'll compile everything and send a summary to the team so we can discuss any further needs.","align":"left"}},{"background":null,"character":"Tom","position":null,"opacity":null,"startTime":79.38,"finishTime":83.16,"dialogue":{"text":"Sounds good, Sophie. Let me know if you need any more details for the summary.","align":"right"}},{"background":null,"character":"Tom","position":{"x":125,"y":0,"z":1},"opacity":null,"startTime":83.66,"finishTime":null,"dialogue":null},{"background":null,"character":"Sophie","position":{"x":-25,"y":0,"z":1},"opacity":null,"startTime":84.16,"finishTime":null,"dialogue":null}]},"superBlock":"b1-english-for-developers","tests":[],"title":"Dialog 3: Inventarni pregled","transcript":null,"translationPending":false,"videoId":null,"videoLocaleIds":null}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/b1-english-for-developers/#learn-how-to-talk-about-numbers-with-a-coworker","dashedName":"dialogue-3-inventory-check","certification":"b1-english-for-developers","disableLoopProtectTests":false,"disableLoopProtectPreview":false,"superBlock":"b1-english-for-developers","chapter":null,"module":null,"block":"learn-how-to-talk-about-numbers-with-a-coworker","isFirstStep":false,"template":null,"required":[],"isLastChallengeInBlock":false,"nextChallengePath":"/learn/b1-english-for-developers/learn-how-to-talk-about-numbers-with-a-coworker/task-102","prevChallengePath":"/learn/b1-english-for-developers/learn-how-to-talk-about-numbers-with-a-coworker/task-101","id":"684927c9a5c9087177685c46","saveSubmissionToDB":null},"projectPreview":{"challengeData":{"challengeType":19,"challengeFiles":[]}},"id":"/learn/b1-english-for-developers/learn-how-to-talk-about-numbers-with-a-coworker/dialogue-3-inventory-check"}},"staticQueryHashes":["3858520367"],"slicesMap":{}}