p><code>maxCombine([1, 34, 3, 98, 9, 76, 45, 4])</code> treba da vrati <code>998764543431</code>.</p>","testString":"assert.equal(maxCombine([1, 34, 3, 98, 9, 76, 45, 4]), 998764543431);"},{"text":"<p><code>maxCombine([54, 546, 548, 60])</code> trebalo bi da vrati <code>6054854654</code>.</p>","testString":"assert.equal(maxCombine([54, 546, 548, 60]), 6054854654);"}]}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/rosetta-code/#rosetta-code-challenges","dashedName":"largest-int-from-concatenated-ints","certification":"rosetta-code","disableLoopProtectTests":true,"disableLoopProtectPreview":false,"superBlock":"rosetta-code","chapter":null,"module":null,"block":"rosetta-code-challenges","isFirstStep":false,"template":null,"required":[],"isLastChallengeInBlock":false,"nextChallengePath":"/learn/rosetta-code/rosetta-code-challenges/last-letter-first-letter","prevChallengePath":"/learn/rosetta-code/rosetta-code-challenges/knights-tour","id":"5a23c84252665b21eecc7edb","saveSubmissionToDB":null},"projectPreview":{"challengeData":{"challengeType":1,"challengeFiles":[{"name":"script","ext":"js","contents":"function ZigZagMatrix(n) {\n  const mtx = [];\n  for (let i = 0; i < n; i++) {\n    mtx[i] = [];\n  }\n\n  let i = 1;\n  let j = 1;\n  for (let e = 0; e < n * n; e++) {\n    mtx[i - 1][j - 1] = e;\n    if ((i + j) % 2 === 0) {\n      // Even stripes\n      if (j < n) j++;\n      else i += 2;\n      if (i > 1) i--;\n    } else {\n      // Odd stripes\n      if (i < n) i++;\n      else j += 2;\n      if (j > 1) j--;\n    }\n  }\n  return mtx;\n}","history":["script.js"],"fileKey":"scriptjs"}]}},"id":"/learn/rosetta-code/rosetta-code-challenges/largest-int-from-concatenated-ints"}},"staticQueryHashes":["3858520367"],"slicesMap":{}}