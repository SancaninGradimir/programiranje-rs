{"componentChunkName":"component---src-templates-challenges-generic-show-tsx","path":"/learn/b1-english-for-developers/learn-how-to-use-prepositions-according-to-context/dialogue-3-a-new-workstation","result":{"data":{"challengeNode":{"challenge":{"assignments":["<p>Gledaj video.</p>"],"bilibiliIds":null,"block":"learn-how-to-use-prepositions-according-to-context","challengeType":21,"description":"<section id=\"description\">\n<p>Pogledajte video dole/ispod kako biste razumeli kontekst predstojećih lekcija.</p>\n</section>","nodules":null,"explanation":null,"helpCategory":"English","instructions":"","fields":{"slug":"/learn/b1-english-for-developers/learn-how-to-use-prepositions-according-to-context/dialogue-3-a-new-workstation"},"questions":[],"scene":{"setup":{"background":"company2-center.png","characters":[{"character":"Sarah","position":{"x":-25,"y":0,"z":1},"opacity":null},{"character":"James","position":{"x":125,"y":0,"z":1},"opacity":null}],"audio":{"filename":"B1_22-3.mp3","startTime":1,"startTimestamp":null,"finishTimestamp":null},"alwaysShowDialogue":true},"commands":[{"background":null,"character":"Sarah","position":{"x":25,"y":0,"z":1},"opacity":null,"startTime":0,"finishTime":null,"dialogue":null},{"background":null,"character":"James","position":{"x":70,"y":0,"z":1},"opacity":null,"startTime":0.5,"finishTime":null,"dialogue":null},{"background":null,"character":"Sarah","position":null,"opacity":null,"startTime":1,"finishTime":5.14,"dialogue":{"text":"Good morning, James. I heard you're setting up your new workstation today. Need help finding anything?","align":"left"}},{"background":null,"character":"James","position":null,"opacity":null,"startTime":5.5,"finishTime":10.3,"dialogue":{"text":"Hi, Sarah. Yes, that would be great. I'm trying to find an extra monitor. Do you know where they've moved them?","align":"right"}},{"background":null,"character":"Sarah","position":null,"opacity":null,"startTime":10.88,"finishTime":13.52,"dialogue":{"text":"Sure. They've placed them outside of the IT room now.","align":"left"}},{"background":null,"character":"Sarah","position":null,"opacity":null,"startTime":13.68,"finishTime":18.92,"dialogue":{"text":"If you head straight down this corridor and turn left at the break area, you'll see them stored right across from the coffee machine.","align":"left"}},{"background":null,"character":"James","position":null,"opacity":null,"startTime":19.36,"finishTime":23.14,"dialogue":{"text":"Got it. And what about the new keyboards? I heard we received a shipment last week.","align":"right"}},{"background":null,"character":"Sarah","position":null,"opacity":null,"startTime":23.74,"finishTime":28.86,"dialogue":{"text":"Yes, they're in a small storage room. Go back towards the main entrance, but before you get there, take a right.","align":"left"}},{"background":null,"character":"Sarah","position":null,"opacity":null,"startTime":29.08,"finishTime":31.72,"dialogue":{"text":"It's the second door on your left opposite the mailroom.","align":"left"}},{"background":null,"character":"James","position":null,"opacity":null,"startTime":32.16,"finishTime":37.86,"dialogue":{"text":"Perfect. Thanks. Lastly, I need some Ethernet cables. Any idea where those ended up?","align":"right"}},{"background":null,"character":"Sarah","position":null,"opacity":null,"startTime":38.42,"finishTime":44.98,"dialogue":{"text":"Actually, yes. They're a bit out of the way. Go to the server room, but instead of going inside, turn right just before the door.","align":"left"}},{"background":null,"character":"Sarah","position":null,"opacity":null,"startTime":45.18,"finishTime":48.6,"dialogue":{"text":"There's a closet there where we're keeping all cables and related accessories.","align":"left"}},{"background":null,"character":"James","position":null,"opacity":null,"startTime":49.2,"finishTime":52,"dialogue":{"text":"That's a bit of a trek. Thanks for helping me, Sarah.","align":"right"}},{"background":null,"character":"James","p