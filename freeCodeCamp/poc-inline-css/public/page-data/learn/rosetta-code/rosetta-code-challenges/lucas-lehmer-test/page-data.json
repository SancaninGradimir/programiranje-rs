{"componentChunkName":"component---src-templates-challenges-classic-show-tsx","path":"/learn/rosetta-code/rosetta-code-challenges/lucas-lehmer-test","result":{"data":{"challengeNode":{"challenge":{"block":"rosetta-code-challenges","demoType":null,"title":"Lucas-Lehmer test","description":"<section id=\"description\">\n<p>Test Lucas-Lehmera: za nepar primbroj $p$, broj Mersena $2^p-1$ je prim brojište ako i samo ako $2^p-1$ deli $S(p-1)$ gde $S(n+1)=(S(n))^2-2$, i $S(1)=4$.</p>\n</section>","id":"5e6dee7749a0b85a3f1fc7d5","hasEditableBoundaries":false,"instructions":"<section id=\"instructions\">\n<p>Napišite funkciju koja vraća da li je dat Mersenov broj premij ili nije.</p>\n</section>","notes":null,"challengeType":1,"helpCategory":"Rosetta","videoUrl":null,"superBlock":"rosetta-code","translationPending":false,"forumTopicId":385281,"hooks":null,"fields":{"slug":"/learn/rosetta-code/rosetta-code-challenges/lucas-lehmer-test"},"required":[],"usesMultifileEditor":false,"challengeFiles":[{"fileKey":"scriptjs","ext":"js","name":"script","contents":"function lucasLehmer(p) {\n\n}","head":null,"tail":null,"editableRegionBoundaries":[],"history":["script.js"]}],"saveSubmissionToDB":null,"tests":[{"text":"<p><code>lucasLehmer</code> Trebalo bi da bude funkcija.</p>","testString":"assert(typeof lucasLehmer == 'function');"},{"text":"<p><code>lucasLehmer(11)</code> Trebalo bi da vrati vrednost istina ili laž.</p>","testString":"assert(typeof lucasLehmer(11) == 'boolean');"},{"text":"<p><code>lucasLehmer(11)</code> treba da restaurira <code>false</code>.</p>","testString":"assert.equal(lucasLehmer(11), false);"},{"text":"<p><code>lucasLehmer(15)</code> trebalo bi da vrati <code>false</code>.</p>","testString":"assert.equal(lucasLehmer(15), false);"},{"text":"<p><code>lucasLehmer(13)</code> trebalo bi da vrati <code>true</code>.</p>","testString":"assert.equal(lucasLehmer(13), true);"},{"text":"<p><code>lucasLehmer(17)</code> treba da restaura <code>true</code>.</p>","testString":"assert.equal(lucasLehmer(17), true);"},{"text":"<p><code>lucasLehmer(19)</code> inapaswa kurejesha <code>true</code>.</p>","testString":"assert.equal(lucasLehmer(19), true);"},{"text":"<p><code>lucasLehmer(21)</code> trebalo bi da vrati <code>false</code>.</p>","testString":"assert.equal(lucasLehmer(21), false);"}]}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/rosetta-code/#rosetta-code-challenges","dashedName":"lucas-lehmer-test","certification":"rosetta-code","disableLoopProtectTests":true,"disableLoopProtectPreview":false,"superBlock":"rosetta-code","chapter":null,"module":null,"block":"rosetta-code-challenges","isFirstStep":false,"template":null,"required":[],"isLastChallengeInBlock":false,"nextChallengePath":"/learn/rosetta-code/rosetta-code-challenges/ludic-numbers","prevChallengePath":"/learn/rosetta-code/rosetta-code-challenges/lu-decomposition","id":"5e6dee7749a0b85a3f1fc7d5","saveSubmissionToDB":null},"projectPreview":{"challengeData":{"challengeType":1,"challengeFiles":[{"name":"script","ext":"js","contents":"function ZigZagMatrix(n) {\n  const mtx = [];\n  for (let i = 0; i < n; i++) {\n    mtx[i] = [];\n  }\n\n  let i = 1;\n  let j = 1;\n  for (let e = 0; e < n * n; e++) {\n    mtx[i - 1][j - 1] = e;\n    if ((i + j) % 2 === 0) {\n      // Even stripes\n      if (j < n) j++;\n      else i += 2;\n      if (i > 1) i--;\n    } else {\n      // Odd stripes\n      if (i < n) i++;\n      else j += 2;\n      if (j > 1) j--;\n    }\n  }\n  return mtx;\n}","history":["script.js"],"fileKey":"scriptjs"}]}},"id":"/learn/rosetta-code/rosetta-code-challenges/lucas-lehmer-test"}},"staticQueryHashes":["3858520367"],"slicesMap":{}}