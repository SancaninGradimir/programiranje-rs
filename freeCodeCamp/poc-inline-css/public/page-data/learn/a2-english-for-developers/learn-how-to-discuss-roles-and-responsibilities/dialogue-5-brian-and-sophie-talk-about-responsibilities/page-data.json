aracter":"Brian","position":null,"opacity":null,"startTime":10.3,"finishTime":12.8,"dialogue":{"text":"Tell me about your responsibilities beyond work.","align":"left"}},{"background":null,"character":"Sophie","position":null,"opacity":null,"startTime":13.6,"finishTime":15.6,"dialogue":{"text":"Well, I have to make time for my family","align":"right"}},{"background":null,"character":"Sophie","position":null,"opacity":null,"startTime":15.6,"finishTime":17.6,"dialogue":{"text":"- that's really important to me.","align":"right"}},{"background":null,"character":"Sophie","position":null,"opacity":null,"startTime":17.6,"finishTime":19.3,"dialogue":{"text":"I also don't want to neglect my health,","align":"right"}},{"background":null,"character":"Sophie","position":null,"opacity":null,"startTime":19.3,"finishTime":21.8,"dialogue":{"text":"so two months ago I started jogging regularly.","align":"right"}},{"background":null,"character":"Sophie","position":null,"opacity":null,"startTime":21.8,"finishTime":23.4,"dialogue":{"text":"It helps me relax and stay fit.","align":"right"}},{"background":null,"character":"Brian","position":null,"opacity":null,"startTime":24.4,"finishTime":26.5,"dialogue":{"text":"It sounds like you're doing great dealing with work","align":"left"}},{"background":null,"character":"Brian","position":null,"opacity":null,"startTime":26.5,"finishTime":28.5,"dialogue":{"text":"and life responsibilities at the same time.","align":"left"}},{"background":null,"character":"Sophie","position":null,"opacity":null,"startTime":29,"finishTime":31.9,"dialogue":{"text":"Thank you. It's all about finding the right balance","align":"right"}},{"background":null,"character":"Sophie","position":null,"opacity":null,"startTime":31.9,"finishTime":33.5,"dialogue":{"text":"for you and your well-being.","align":"right"}},{"background":null,"character":"Sophie","position":null,"opacity":null,"startTime":33.5,"finishTime":36.6,"dialogue":{"text":"And you don't have to search for expensive solutions for that.","align":"right"}},{"background":null,"character":"Sophie","position":null,"opacity":null,"startTime":36.6,"finishTime":38.6,"dialogue":{"text":"Sometimes, it's the simple and free things","align":"right"}},{"background":null,"character":"Sophie","position":null,"opacity":null,"startTime":38.6,"finishTime":41.6,"dialogue":{"text":"that bring us the result we're looking for.","align":"right"}},{"background":null,"character":"Sophie","position":{"x":125,"y":0,"z":1},"opacity":null,"startTime":42.1,"finishTime":null,"dialogue":null},{"background":null,"character":"Brian","position":{"x":-25,"y":0,"z":1},"opacity":null,"startTime":42.6,"finishTime":null,"dialogue":null}]},"superBlock":"a2-english-for-developers","tests":[],"title":"Dijalog 5: Brian i Sofija razgovaraju o odgovornostima","transcript":null,"translationPending":false,"videoId":null,"videoLocaleIds":null}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/a2-english-for-developers/#learn-how-to-discuss-roles-and-responsibilities","dashedName":"dialogue-5-brian-and-sophie-talk-about-responsibilities","certification":"a2-english-for-developers","disableLoopProtectTests":false,"disableLoopProtectPreview":false,"superBlock":"a2-english-for-developers","chapter":null,"module":null,"block":"learn-how-to-discuss-roles-and-responsibilities","isFirstStep":false,"template":null,"required":[],"isLastChallengeInBlock":false,"nextChallengePath":"/learn/a2-english-for-developers/learn-how-to-discuss-roles-and-responsibilities/task-92","prevChallengePath":"/learn/a2-english-for-developers/learn-how-to-discuss-roles-and-responsibilities/task-91","id":"65d9633ff2cc710bd3e18c03","saveSubmissionToDB":null},"projectPreview":{"challengeData":{"challengeType":22,"challengeFiles":[]}},"id":"/learn/a2-english-for-developers/learn-how-to-discuss-roles-and-responsibilities/dialogue-5-brian-and-sophie-talk-about-responsibilities"}},"staticQueryHashes":["3858520367"],"slicesMap":{}}