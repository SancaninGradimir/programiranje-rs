{"componentChunkName":"component---src-templates-challenges-classic-show-tsx","path":"/learn/rosetta-code/rosetta-code-challenges/compare-a-list-of-strings","result":{"data":{"challengeNode":{"challenge":{"block":"rosetta-code-challenges","demoType":null,"title":"Uporedite listu sekvenci slova","description":"<section id=\"description\">\n<p>Lista je uređeni skup vrednosti koji može imati duplikate. Evo primera:</p>\n<pre><code class=\"language-js\">const list = [['AA',  'BB', 'CC'], ['AA', 'ACB', 'AA'], [], ['AA']];\n</code></pre>\n<p>Ako ti je data lista stringova bilo koje dužine, implementiraj funkciju za svaki od sledećih uslova:</p>\n<ul>\n  <li>Proveriti da li su sve jednake po matematičkom stilu sekvence karaktera</li>\n  <li>Proveriti da li je svaka sekvenca karaktera matematički manja od sledeće (što znači ako je lista u striktno rastućem redosledu)</li>\n</ul>\n</section>","id":"596e457071c35c882915b3e4","hasEditableBoundaries":false,"instructions":"","notes":null,"challengeType":1,"helpCategory":"Rosetta","videoUrl":null,"superBlock":"rosetta-code","translationPending":false,"forumTopicId":302235,"hooks":{"beforeAll":null,"beforeEach":"const testCases = [['AA', 'AA', 'AA', 'AA'], ['AA', 'ACB', 'BB', 'CC'], [], ['AA'], ['BB', 'AA']];","afterEach":null,"afterAll":null},"fields":{"slug":"/learn/rosetta-code/rosetta-code-challenges/compare-a-list-of-strings"},"required":[],"usesMultifileEditor":false,"challengeFiles":[{"fileKey":"scriptjs","ext":"js","name":"script","contents":"function allEqual(arr) {\n\n  return true;\n}\n\nfunction azSorted(arr) {\n\n  return true;\n}","head":null,"tail":null,"editableRegionBoundaries":[],"history":["script.js"]}],"saveSubmissionToDB":null,"tests":[{"text":"<p><code>allEqual</code> Trebalo bi da bude funkcija.</p>","testString":"assert(typeof allEqual === 'function');"},{"text":"<p><code>azSorted</code> treba da bude funkcija.</p>","testString":"assert(typeof azSorted === 'function');"},{"text":"<p><code>allEqual([\"AA\", \"AA\", \"AA\", \"AA\"])</code> inapaswa kurudisha true.</p>","testString":"assert(allEqual(testCases[0]));"},{"text":"<p><code>azSorted([\"AA\", \"AA\", \"AA\", \"AA\"])</code> inapaswa kurudisha false.</p>","testString":"assert(!azSorted(testCases[0]));"},{"text":"<p><code>allEqual([\"AA\", \"ACB\", \"BB\", \"CC\"])</code> trebalo bi vratiti false.</p>","testString":"assert(!allEqual(testCases[1]));"},{"text":"<p><code>azSorted([\"AA\", \"ACB\", \"BB\", \"CC\"])</code> trebalo bi da vrati true.</p>","testString":"assert(azSorted(testCases[1]));"},{"text":"<p><code>allEqual([])</code> inapaswa kurudisha true.</p>","testString":"assert(allEqual(testCases[2]));"},{"text":"<p><code>azSorted([])</code> trebalo bi da vrati true.</p>","testString":"assert(azSorted(testCases[2]));"},{"text":"<p><code>allEqual([\"AA\"])</code> trebalo bi da vrati true.</p>","testString":"assert(allEqual(testCases[3]));"},{"text":"<p><code>azSorted([\"AA\"])</code> treba da vrati true.</p>","testString":"assert(azSorted(testCases[3]));"},{"text":"<p><code>allEqual([\"BB\", \"AA\"])</code> trebalo bi da vrati false.</p>","testString":"assert(!allEqual(testCases[4]));"},{"text":"<p><code>azSorted([\"BB\", \"AA\"])</code> trebalo bi da vrati false.</p>","testString":"assert(!azSorted(testCases[4]));"}]}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/rosetta-code/#rosetta-code-challenges","dashedName":"compare-a-list-of-strings","certification":"rosetta-code","disableLoopProtectTests":true,"disableLoopProtectPreview":false,"superBlock":"rosetta-code","chapter":null,"module":null,"block":"rosetta-code-challenges","isFirstStep":false,"template":null,"required":[],"isLastChallengeInBlock":false,"nextChallengePath":"/learn/rosetta-code/rosetta-code-challenges/convert-seconds-to-compound-duration","prevChallengePath":"/learn/rosetta-code/rosetta-code-challenges/comma-quibbling","id":"596e457071c35c882915b3e4","saveSubmissionToDB":null},"projectPreview":{"challengeData":{"challengeType":1,"challengeFiles":[{"name":"script","ext":"js","contents":"function ZigZagMatrix(n) {\n  const mtx = [];\n  for (let i = 0; i < n; i++) {\n    mtx[i] = [];\n  }\n\n  let i = 1;\n  let j = 1;\n  for (let e = 0; e < n * n; e++) {\n    mtx[i - 1][j - 1] = e;\n    if ((i + j) % 2 === 0) {\n      // Even stripes\n      if (j < n) j++;\n      else i += 2;\n      if (i > 1) i--;\n    } else {\n      // Odd stripes\n      if (i < n) i++;\n      else j += 2;\n      if (j > 1) j--;\n    }\n  }\n  return mtx;\n}","history":["script.js"],"fileKey":"scriptjs"}]}},"id":"/learn/rosetta-code/rosetta-code-challenges/compare-a-list-of-strings"}},"staticQueryHashes":["3858520367"],"slicesMap":{}}