{"componentChunkName":"component---src-templates-challenges-classic-show-tsx","path":"/learn/introduction-to-higher-order-functions-and-callbacks-in-javascript/lab-value-remover-function/implement-a-value-remover-function","result":{"data":{"challengeNode":{"challenge":{"block":"lab-value-remover-function","demoType":null,"title":"Izvršiti funkciju za uklanjanje vrednosti","description":"<section id=\"description\">\n<p>U ovom laboratoriju, kreiraćeš funkciju koja prima inicijalni niz podataka kao svoj prvi argument, praćen jedan ili više argumenata koji predstavljaju vrednosti za uklanjanje.</p>\n<p><strong>Cilj</strong>: Popunite priče korisnika ispod i prođite sve testove kako biste završili ovaj rad.</p>\n<p><strong>Priče korisnika:</strong></p>\n<ol>\n<li>Mora da ima funkciju <code>destroyer</code> koja prima niz podataka i jedan ili više dodatnih argumenata.</li>\n<li>Funkcija <code>destroyer</code> bi trebalo da vrati novi niz koji ne sadrži sve elemente iz prvog argumenta koji odgovaraju bilo kojim naknadnim argumentima.</li>\n<li>Funkcija mora da prihvati nepoznat broj argumenata.</li>\n</ol>\n</section>","id":"a39963a4c10bc8b4d4f06d7e","hasEditableBoundaries":false,"instructions":"","notes":null,"challengeType":26,"helpCategory":"JavaScript","videoUrl":null,"superBlock":"introduction-to-higher-order-functions-and-callbacks-in-javascript","translationPending":false,"forumTopicId":null,"hooks":null,"fields":{"slug":"/learn/introduction-to-higher-order-functions-and-callbacks-in-javascript/lab-value-remover-function/implement-a-value-remover-function"},"required":[],"usesMultifileEditor":true,"challengeFiles":[{"fileKey":"scriptjs","ext":"js","name":"script","contents":"","head":null,"tail":null,"editableRegionBoundaries":[],"history":["script.js"]}],"saveSubmissionToDB":null,"tests":[{"text":"<p>Trebalo bi da imaš funkciju <code>destroyer</code>.</p>","testString":"assert.isFunction(destroyer);"},{"text":"<p><code>destroyer([1, 2, 3, 1, 2, 3], 2, 3)</code> treba da vrati <code>[1, 1]</code>.</p>","testString":"assert.deepEqual(destroyer([1, 2, 3, 1, 2, 3], 2, 3), [1, 1]);"},{"text":"<p><code>destroyer([1, 2, 3, 5, 1, 2, 3], 2, 3)</code> treba vratiti <code>[1, 5, 1]</code>.</p>","testString":"assert.deepEqual(destroyer([1, 2, 3, 5, 1, 2, 3], 2, 3), [1, 5, 1]);"},{"text":"<p><code>destroyer([3, 5, 1, 2, 2], 2, 3, 5)</code> treba vratiti <code>[1]</code>.</p>","testString":"assert.deepEqual(destroyer([3, 5, 1, 2, 2], 2, 3, 5), [1]);"},{"text":"<p><code>destroyer([2, 3, 2, 3], 2, 3)</code> trebalo bi vratiti <code>[]</code>.</p>","testString":"assert.deepEqual(destroyer([2, 3, 2, 3], 2, 3), []);"},{"text":"<p><code>destroyer([\"tree\", \"hamburger\", 53], \"tree\", 53)</code> trebalo bi da vrati <code>[\"hamburger\"]</code>.</p>","testString":"assert.deepEqual(destroyer([\"tree\", \"hamburger\", 53], \"tree\", 53), [\"hamburger\"]);"},{"text":"<p><code>destroyer( [\"possum\", \"trollo\", 12, \"safari\", \"hotdog\", 92, 65, \"grandma\", \"bugati\", \"trojan\", \"yacht\"], \"yacht\", \"possum\", \"trollo\", \"safari\", \"hotdog\", \"grandma\", \"bugati\", \"trojan\" )</code> bi trebalo da vrati <code>[12, 92, 65]</code>.</p>","testString":"assert.deepEqual(\n  destroyer(\n    [\"possum\", \"trollo\", 12, \"safari\", \"hotdog\", 92, 65, \"grandma\", \"bugati\", \"trojan\", \"yacht\"],\n    \"yacht\", \"possum\", \"trollo\", \"safari\", \"hotdog\", \"grandma\", \"bugati\", \"trojan\"\n  ),\n  [12, 92, 65]\n);"}]}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/introduction-to-higher-order-functions-and-callbacks-in-javascript/#lab-value-remover-function","dashedName":"implement-a-value-remover-function","certification":"introduction-to-higher-order-functions-and-callbacks-in-javascript","disableLoopProtectTests":false,"disableLoopProtectPreview":false,"superBlock":"introduction-to-higher-order-functions-and-callbacks-in-javascript","chapter":null,"module":null,"block":"lab-value-remover-function","isFirstStep":true,"template":null,"required":[],"isLastChallengeInBlock":true,"nextChallengePath":"/learn/introduction-to-higher-order-functions-and-callbacks-in-javascript/lab-matching-object-filter/implement-a-matching-object-filter","prevChallengePath":"/learn/introduction-to-higher-order-functions-and-callbacks-in-javascript/lab-symmetric-difference/lab-symmetric-difference","id":"a39963a4c10bc8b4d4f06d7e","saveSubmissionToDB":null},"projectPreview":{"challengeData":{"challengeType":26,"challengeFiles":[{"name":"script","ext":"js","contents":"function destroyer(arr, ...valsToRemove) {\n  return arr.filter(item => !valsToRemove.includes(item));\n}","history":["script.js"],"fileKey":"scriptjs"}]}},"id":"/learn/introduction-to-higher-order-functions-and-callbacks-in-javascript/lab-value-remover-function/implement-a-value-remover-function"}},"staticQueryHashes":["3858520367"],"slicesMap":{}}