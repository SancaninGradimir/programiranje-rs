{"componentChunkName":"component---src-templates-challenges-classic-show-tsx","path":"/learn/basic-html/workshop-bookstore-page/step-7","result":{"data":{"challengeNode":{"challenge":{"block":"workshop-bookstore-page","demoType":null,"title":"Korak 7","description":"<section id=\"description\">\n<p>Svojstvo elementa <code>class</code> koristi se za identifikovanje jednog ili više elemenata u svrhu stilizovanja. Za razliku od svojstva elementa <code>id</code>, imena klasa elemenata ne moraju biti jedinstvena: više elemenata može da deli jednu klasu.</p>\n<p>Evo primera:</p>\n<pre><code class=\"language-html\">&#x3C;p class=\"example\">example paragraph&#x3C;/p>\n</code></pre>\n<p>Dodaj svojstvo elemenata <code>class</code> na tvoj element <code>div</code> i postavi mu vrednost na <code>card-container</code>.</p>\n</section>","id":"68ec6d9a315221aa31e54816","hasEditableBoundaries":true,"instructions":"","notes":null,"challengeType":0,"helpCategory":"HTML-CSS","videoUrl":null,"superBlock":"basic-html","translationPending":false,"forumTopicId":null,"hooks":null,"fields":{"slug":"/learn/basic-html/workshop-bookstore-page/step-7"},"required":[],"usesMultifileEditor":true,"challengeFiles":[{"fileKey":"indexhtml","ext":"html","name":"index","contents":"<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\" />\n  <title>XYZ Bookstore Page</title>\n</head>\n\n<body>\n  <h1>XYZ Bookstore</h1>\n  <p>Browse our collection of amazing books!</p>\n  \n  <div>\n    \n  </div>\n</body>\n\n</html>","head":null,"tail":null,"editableRegionBoundaries":[11,13],"history":["index.html"]}],"saveSubmissionToDB":null,"tests":[{"text":"<p>Element [<code>div</code>] treba da ima svojstvo elementa [<code>class</code>] .</p>","testString":"assert.isTrue(document.querySelector('div')?.hasAttribute('class'));"},{"text":"<p>Tvoj element za <code>div</code> mora imati svojstvo elementa <code>class</code> sa vrednošću <code>card-container</code>.</p>","testString":"assert.equal(document.querySelector('div')?.className, 'card-container');"}]}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/basic-html/#workshop-bookstore-page","dashedName":"step-7","certification":"basic-html","disableLoopProtectTests":false,"disableLoopProtectPreview":false,"superBlock":"basic-html","chapter":null,"module":null,"block":"workshop-bookstore-page","isFirstStep":false,"template":null,"required":[],"isLastChallengeInBlock":false,"nextChallengePath":"/learn/basic-html/workshop-bookstore-page/step-8","prevChallengePath":"/learn/basic-html/workshop-bookstore-page/step-6","id":"68ec6d9a315221aa31e54816","saveSubmissionToDB":null},"projectPreview":{"challengeData":{"challengeType":0,"challengeFiles":[{"name":"index","ext":"html","contents":"<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\" />\n  <title>XYZ Bookstore Page</title>\n</head>\n\n<body>\n  <h1>XYZ Bookstore</h1>\n  <p>Browse our collection of amazing books!</p>\n\n  <div class=\"card-container\">\n     <div class=\"card\" id=\"sally-adventure-book\">\n     <h2>Sally's SciFi Adventure</h2>\n     <p>\n          This is an epic story of Sally and her dog Rex as they navigate\n          through other worlds.\n     </p>\n     <button class=\"btn\">Buy Now</button>\n     </div>\n\n     <div class=\"card\" id=\"dave-cooking-book\">\n     <h2>Dave's Cooking Adventure</h2>\n     <p>\n          This is the story of Dave as he learns to cook everything from\n          pancakes to pasta, one recipe at a time.\n     </p>\n     <button class=\"btn\">Buy Now</button>\n     </div>\n  </div>\n\n  <p>Review your selections and continue to checkout.</p>\n\n  <div class=\"btn-container\">\n     <button id=\"view-cart-btn\" class=\"btn\">View Cart</button>\n     <button id=\"checkout-btn\" class=\"btn\">Checkout</button>\n  </div>\n</body>\n\n</html>","history":["index.html"],"fileKey":"indexhtml"}]}},"id":"/learn/basic-html/workshop-bookstore-page/step-7"}},"staticQueryHashes":["3858520367"],"slicesMap"