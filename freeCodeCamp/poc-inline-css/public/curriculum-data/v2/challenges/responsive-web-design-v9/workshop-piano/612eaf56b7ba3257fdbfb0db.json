      "text": "<p>You should add a new <code>img</code> element.</p>",
      "testString": "assert.lengthOf(document.querySelectorAll('img'), 1);"
    },
    {
      "text": "<p>Your <code>img</code> element should come before your first <code>.keys</code> element.</p>",
      "testString": "const img = document.querySelector('img');\nassert.equal(img?.nextElementSibling?.className, 'keys');\nassert.isNull(img?.previousElementSibling);"
    },
    {
      "text": "<p>Your <code>img</code> element should have a <code>class</code> set to <code>logo</code>.</p>",
      "testString": "const img = document.querySelector('img');\nassert.equal(img?.className, 'logo');"
    },
    {
      "text": "<p>Your <code>img</code> element should have a <code>src</code> set to <code>https://cdn.freecodecamp.org/platform/universal/fcc_primary.svg</code>.</p>",
      "testString": "const img = document.querySelector('img');\nassert.equal(img?.getAttribute('src'), 'https://cdn.freecodecamp.org/platform/universal/fcc_primary.svg');"
