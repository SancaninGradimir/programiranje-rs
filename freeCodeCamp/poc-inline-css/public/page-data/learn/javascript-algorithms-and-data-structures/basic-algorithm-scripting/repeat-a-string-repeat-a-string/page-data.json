{"componentChunkName":"component---src-templates-challenges-classic-show-tsx","path":"/learn/javascript-algorithms-and-data-structures/basic-algorithm-scripting/repeat-a-string-repeat-a-string","result":{"data":{"challengeNode":{"challenge":{"block":"basic-algorithm-scripting","demoType":null,"title":"Ponovi String Ponovi String","description":"<section id=\"description\">\n<p>Ponovite dati string <code>str</code> (prvi argument) <code>num</code> puta (drugi argument). Vratite prazan string ako <code>num</code> nije pozitivan broj. Za potrebe ovog izazova nemojte koristiti ugradjeni <code>.repeat()</code> metod.</p>\n</section>","id":"afcc8d540bea9ea2669306b6","hasEditableBoundaries":false,"instructions":"","notes":null,"challengeType":1,"helpCategory":"JavaScript","videoUrl":null,"superBlock":"javascript-algorithms-and-data-structures","translationPending":false,"forumTopicId":16041,"hooks":null,"fields":{"slug":"/learn/javascript-algorithms-and-data-structures/basic-algorithm-scripting/repeat-a-string-repeat-a-string"},"required":[],"usesMultifileEditor":false,"challengeFiles":[{"fileKey":"scriptjs","ext":"js","name":"script","contents":"function repeatStringNumTimes(str, num) {\n  return str;\n}\n\nrepeatStringNumTimes('abc', 3);","head":null,"tail":null,"editableRegionBoundaries":[],"history":["script.js"]}],"saveSubmissionToDB":null,"tests":[{"text":"<p><code>repeatStringNumTimes(\"*\", 3)</code> treba da vrati string <code>***</code>.</p>","testString":"assert.strictEqual(repeatStringNumTimes('*', 3), '***');"},{"text":"<p><code>repeatStringNumTimes(\"abc\", 3)</code> treba da vrati string <code>abcabcabc</code>.</p>","testString":"assert.strictEqual(repeatStringNumTimes('abc', 3), 'abcabcabc');"},{"text":"<p><code>repeatStringNumTimes(\"abc\", 4)</code> treba da vrati string <code>abcabcabcabc</code>.</p>","testString":"assert.strictEqual(repeatStringNumTimes('abc', 4), 'abcabcabcabc');"},{"text":"<p><code>repeatStringNumTimes(\"abc\", 1)</code> treba da vrati string <code>abc</code>.</p>","testString":"assert.strictEqual(repeatStringNumTimes('abc', 1), 'abc');"},{"text":"<p><code>repeatStringNumTimes(\"*\", 8)</code> treba da vrati string <code>********</code>.</p>","testString":"assert.strictEqual(repeatStringNumTimes('*', 8), '********');"},{"text":"<p><code>repeatStringNumTimes(\"abc\", -2)</code> treba da vrati prazan string (<code>\"\"</code>).</p>","testString":"assert.isEmpty(repeatStringNumTimes('abc', -2));"},{"text":"<p>Ugradjeni <code>repeat()</code> metod ne treba koristiti.</p>","testString":"assert.notMatch(__helpers.removeJSComments(code), /\\.repeat/g);"},{"text":"<p><code>repeatStringNumTimes(\"abc\", 0)</code> treba da vrati <code>\"\"</code>.</p>","testString":"assert.isEmpty(repeatStringNumTimes('abc', 0));"}]}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/javascript-algorithms-and-data-structures/#basic-algorithm-scripting","dashedName":"repeat-a-string-repeat-a-string","certification":"javascript-algorithms-and-data-structures","disableLoopProtectTests":false,"disableLoopProtectPreview":false,"superBlock":"javascript-algorithms-and-data-structures","chapter":null,"module":null,"block":"basic-algorithm-scripting","isFirstStep":false,"template":null,"required":[],"isLastChallengeInBlock":false,"nextChallengePath":"/learn/javascript-algorithms-and-data-structures/basic-algorithm-scripting/truncate-a-string","prevChallengePath":"/learn/javascript-algorithms-and-data-structures/basic-algorithm-scripting/confirm-the-ending","id":"afcc8d540bea9ea2669306b6","saveSubmissionToDB":null},"projectPreview":{"challengeData":{"challengeType":1,"challengeFiles":[{"name":"script","ext":"js","contents":"function chunkArrayInGroups(arr, size) {\n  let out = [];\n\n  for (let i = 0; i < arr.length; i += size) {\n    out.push(arr.slice(i, i + size));\n  }\n\n  return out;\n}\n\nchunkArrayInGroups(['a', 'b', 'c', 'd'], 2);","history":["script.js"],"fileKey":"scriptjs"}]}},"id":"/learn/javascript-algorithms-a