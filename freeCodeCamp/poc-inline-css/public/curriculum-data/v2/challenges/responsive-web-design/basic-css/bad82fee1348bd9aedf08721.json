  "tests": [
    {
      "text": "<p>Vas <code>h1</code> element sa tekstom <code>I am red!</code> treba da ima crvenu <code>color</code> vrednost.</p>",
      "testString": "const redText = document.querySelector('.red-text');\nconst color = window.getComputedStyle(redText)['color']; \nassert.strictEqual(color, 'rgb(255, 0, 0)');"
    },
    {
      "text": "<p>Treba da koristite <code>rgb</code> za crvenu boju.</p>",
      "testString": "assert.match(code, /\\.red-text\\s*{\\s*color\\s*:\\s*rgb\\(\\s*255\\s*,\\s*0\\s*,\\s*0\\s*\\)\\s*;?\\s*}/gi);"
    },
    {
      "text": "<p>Vas <code>h1</code> element sa tekstom <code>I am orchid!</code> treba da ima <code>orchid</code> <code>color</code> vrednost.</p>",
      "testString": "const orchidText = document.querySelector('.orchid-text');\nconst color = window.getComputedStyle(orchidText)['color']; \nassert.strictEqual(color, 'rgb(218, 112, 214)');"
    },
    {
      "text": "<p>Treba da koristite <code>rgb</code> za orchid boju.</p>",
      "testString": "assert.match(__helpers.removeCssComments(code), /\\.orchid-text\\s*{\\s*color\\s*:\\s*rgb\\(\\s*218\\s*,\\s*112\\s*,\\s*214\\s*\\)\\s*;?\\s*}/gi);"
    },
    {
      "text": "<p>Vas <code>h1</code> element sa tekstom <code>I am blue!</code> treba da ima plavu <code>color</code> vrednost.</p>",
      "testString": "const blueText = document.querySelector('.blue-text');\nconst color = window.getComputedStyle(blueText)['color']; \nassert.strictEqual(color, 'rgb(0, 0, 255)');"
    },
