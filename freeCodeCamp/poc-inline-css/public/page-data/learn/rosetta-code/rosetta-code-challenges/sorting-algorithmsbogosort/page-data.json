{"componentChunkName":"component---src-templates-challenges-classic-show-tsx","path":"/learn/rosetta-code/rosetta-code-challenges/sorting-algorithmsbogosort","result":{"data":{"challengeNode":{"challenge":{"block":"rosetta-code-challenges","demoType":null,"title":"Algoritmi za sortiranje/sorting Bogosort","description":"<section id=\"description\">\n<p>Sortiraj koristeći Bogosort na niz brojeva.</p>\n<p>Bogosort je metoda za nasumično mešanje kolekcije sve dok se ne sortira.</p>\n<p>\"Bogosort\" je potpuno beskoristan algoritam koji se koristi samo kao šala.</p>\n<p>Njegovo prosečno vreme izvršavanja je O(n!) jer je verovatnoća da bilo koja kombinacija skupa završi u ispravnom redosledu približno jedna od faktoriela <em>n</em>, a najgori slučaj je beskonačan jer nema garancije da će nasumična kombinacija proizvesti poretan niz.</p>\n<p>Najbolji slučaj je O(n) jer jedan prolaz kroz elemente može biti dovoljan da ih poređane (ili: sortiraju).</p>\n<p>Lažni kod:</p>\n<pre><b>kada nije</b> InOrder(list) <b>uraditi</b>\n  Shuffle(list)\n<b>završiti</b>\n</pre>\n</section>","id":"5a23c84252665b21eecc8002","hasEditableBoundaries":false,"instructions":"","notes":null,"challengeType":1,"helpCategory":"Rosetta","videoUrl":null,"superBlock":"rosetta-code","translationPending":false,"forumTopicId":302311,"hooks":null,"fields":{"slug":"/learn/rosetta-code/rosetta-code-challenges/sorting-algorithmsbogosort"},"required":[],"usesMultifileEditor":false,"challengeFiles":[{"fileKey":"scriptjs","ext":"js","name":"script","contents":"function bogosort(v) {\n\n}","head":null,"tail":null,"editableRegionBoundaries":[],"history":["script.js"]}],"saveSubmissionToDB":null,"tests":[{"text":"<p><code>bogosort</code> Trebalo bi da bude funkcija.</p>","testString":"assert(typeof bogosort == 'function');"},{"text":"<p><code>bogosort([25, 32, 12, 7, 20])</code> trebalo bi da vrati red podataka.</p>","testString":"assert(Array.isArray(bogosort([25, 32, 12, 7, 20])));"},{"text":"<p><code>bogosort([25, 32, 12, 7, 20])</code> trebalo bi da vrati <code>[7, 12, 20, 25, 32]</code>.</p>","testString":"assert.deepEqual(bogosort([25, 32, 12, 7, 20]), [7, 12, 20, 25, 32]);"},{"text":"<p><code>bogosort([38, 45, 35, 8, 13])</code> treba da vrati <code>[8, 13, 35, 38, 45]</code>.</p>","testString":"assert.deepEqual(bogosort([38, 45, 35, 8, 13]), [8, 13, 35, 38, 45]);"},{"text":"<p><code>bogosort([43, 36, 20, 34, 24])</code> trebalo bi da vrati <code>[20, 24, 34, 36, 43]</code>.</p>","testString":"assert.deepEqual(bogosort([43, 36, 20, 34, 24]), [20, 24, 34, 36, 43]);"},{"text":"<p><code>bogosort([12, 33, 26, 18, 1, 16, 38])</code> trebalo bi da vrati <code>[1, 12, 16, 18, 26, 33, 38]</code>.</p>","testString":"assert.deepEqual(bogosort([12, 33, 26, 18, 1, 16, 38]), [\n  1,\n  12,\n  16,\n  18,\n  26,\n  33,\n  38\n]);"},{"text":"<p><code>bogosort([3, 39, 48, 16, 1, 4, 29])</code> treba da vrati <code>[1, 3, 4, 16, 29, 39, 48]</code>.</p>","testString":"assert.deepEqual(bogosort([3, 39, 48, 16, 1, 4, 29]), [\n  1,\n  3,\n  4,\n  16,\n  29,\n  39,\n  48\n]);"}]}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/rosetta-code/#rosetta-code-challenges","dashedName":"sorting-algorithmsbogosort","certification":"rosetta-code","disableLoopProtectTests":true,"disableLoopProtectPreview":false,"superBlock":"rosetta-code","chapter":null,"module":null,"block":"rosetta-code-challenges","isFirstStep":false,"template":null,"required":[],"isLastChallengeInBlock":false,"nextChallengePath":"/learn/rosetta-code/rosetta-code-challenges/sorting-algorithmscocktail-sort","prevChallengePath":"/learn/rosetta-code/rosetta-code-challenges/sorting-algorithmsbead-sort","id":"5a23c84252665b21eecc8002","saveSubmissionToDB":null},"projectPreview":{"challengeData":{"challengeType":1,"challengeFiles":[{"name":"script","ext":"js","contents":"function ZigZagMatrix(n) {\n  const mtx = [];\n  for (let i = 0; i < n; i++) {\n    mtx[i] = [];\n  }\n\n  let i = 1;\n  let j = 1;\n  for (let e = 0; e < n * n; e++) {\n    mtx[i - 1][j - 1] = e;\n    if ((i + j) % 2 === 0) {\n      // Even stripes\n      if (j < n) j++;\n      else i += 2;\n      if (i > 1) i--;\n    } else {\n      // Odd stripes\n      if (i < n) i++;\n      else j += 2;\n      if (j > 1) j--;\n    }\n  }\n  return mtx;\n}","history":["script.js"],"fileKey":"scriptjs"}]}},"id":"/learn/rosetta-code/rosetta-code-challenges/sorting-algorithmsbogosort"}},"staticQueryHashes":["3858520367"],"slicesMap":{}}