{"componentChunkName":"component---src-templates-challenges-classic-show-tsx","path":"/learn/basic-html/workshop-cat-photo-app/step-25","result":{"data":{"challengeNode":{"challenge":{"block":"workshop-cat-photo-app","demoType":null,"title":"Korak 25","description":"<section id=\"description\">\n<p>Element <code>figure</code> predstavlja samostalan sadržaj i omogućava povezivanje slike sa opisom slike.</p>\n<p>Ugnjezdi sliku koju si nedavno dodao unutar elementa <code>figure</code>.</p>\n</section>","id":"5dfb655eeacea3f48c6300b3","hasEditableBoundaries":true,"instructions":"","notes":null,"challengeType":0,"helpCategory":"HTML-CSS","videoUrl":null,"superBlock":"basic-html","translationPending":false,"forumTopicId":null,"hooks":null,"fields":{"slug":"/learn/basic-html/workshop-cat-photo-app/step-25"},"required":[],"usesMultifileEditor":true,"challengeFiles":[{"fileKey":"indexhtml","ext":"html","name":"index","contents":"<html>\n  <body>\n    <main>\n      <h1>CatPhotoApp</h1>\n      <section>\n        <h2>Cat Photos</h2>\n        <p>Everyone loves <a href=\"https://cdn.freecodecamp.org/curriculum/cat-photo-app/running-cats.jpg\">cute cats</a> online!</p>\n        <p>See more <a target=\"_blank\" href=\"https://freecatphotoapp.com\">cat photos</a> in our gallery.</p>\n        <a href=\"https://freecatphotoapp.com\"><img src=\"https://cdn.freecodecamp.org/curriculum/cat-photo-app/relaxing-cat.jpg\" alt=\"A cute orange cat lying on its back.\"></a>\n      </section>\n      <section>\n        <h2>Cat Lists</h2>\n        <h3>Things cats love:</h3>\n        <ul>\n          <li>catnip</li>\n          <li>laser pointers</li>\n          <li>lasagna</li>\n        </ul>\n        \n        <img src=\"https://cdn.freecodecamp.org/curriculum/cat-photo-app/lasagna.jpg\" alt=\"A slice of lasagna on a plate.\">\n        \n      </section>\n    </main>\n\n  </body>\n</html>","head":null,"tail":null,"editableRegionBoundaries":[18,22],"history":["index.html"]}],"saveSubmissionToDB":null,"tests":[{"text":"<p>Tvoj <code>figure</code> element treba da ima početnu oznaku. Početne oznake imaju sledeću sintaksu: <code>&#x3C;elementName></code>.</p>","testString":"assert.exists(document.querySelector('figure'));"},{"text":"<p>Tvoj <code>figure</code> element treba da ima završnu oznaku. Završne oznake imaju <code>/</code> odmah nakon znaka <code>&#x3C;</code>.</p>","testString":"assert.match(code, /<\\/figure\\>/);"},{"text":"<p>Element <code>figure</code> treba da se nalazi odmah iznad završne oznake drugog <code>section</code> elementa.</p>","testString":"assert.equal(document.querySelectorAll('section')[1]?.lastElementChild.nodeName, 'FIGURE');"},{"text":"<p><code>img</code> element za lazanje treba da bude ugnježden unutar elementa <code>figure</code>.</p>","testString":"assert.exists(document.querySelector('figure > img'));\nassert.equal(\n    document.querySelector('figure > img').getAttribute('src').toLowerCase(),\n      'https://cdn.freecodecamp.org/curriculum/cat-photo-app/lasagna.jpg'\n);"}]}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/basic-html/#workshop-cat-photo-app","dashedName":"step-25","certification":"basic-html","disableLoopProtectTests":false,"disableLoopProtectPreview":false,"superBlock":"basic-html","chapter":null,"module":null,"block":"workshop-cat-photo-app","isFirstStep":false,"template":null,"required":[],"isLastChallengeInBlock":false,"nextChallengePath":"/learn/basic-html/workshop-cat-photo-app/step-26","prevChallengePath":"/learn/basic-html/workshop-cat-photo-app/step-24","id":"5dfb655eeacea3f48c6300b3","saveSubmissionToDB":null},"projectPreview":{"challengeData":{"challengeType":0,"challengeFiles":[{"name":"index","ext":"html","contents":"<!DOCTYPE html>\n<html lang=\"en\">\n  <head>\n    <meta charset=\"UTF-8\">\n    <title>CatPhotoApp</title>\n  </head>\n  <body>\n    <main>\n      <h1>CatPhotoApp</h1>\n      <section>\n        <h2>Cat Photos</h2>\n        <p>Everyone loves <a href=\"https://cdn.freecodecamp.org/curriculum/cat-photo-app/running-cats.jpg\">cute cats</a> online!</p>\n        <p>See more <a target=\"_blank\" href=\"https://freecatphotoapp.com\">cat photos</a> in our gallery.</p>\n        <a href=\"https://freecatphotoapp.com\"><img src=\"https://cdn.freecodecamp.org/curriculum/cat-photo-app/relaxing-cat.jpg\" alt=\"A cute orange cat lying on its back.\"></a>\n      </section>\n      <section>\n        <h2>Cat Lists</h2>\n        <h3>Things cats love:</h3>\n        <ul>\n          <li>catnip</li>\n          <li>laser pointers</li>\n          <li>lasagna</li>\n        </ul>\n        <figure>\n          <img src=\"https://cdn.freecodecamp.org/curriculum/cat-photo-app/lasagna.jpg\" alt=\"A slice of lasagna on a plate.\">\n          <figcaption>Cats <em>love</em> lasagna.</figcaption>  \n        </figure>\n        <h3>Top 3 things cats hate:</h3>\n        <ol>\n          <li>flea treatment</li>\n          <li>thunder</li>\n          <li>other cats</li>\n        </ol>\n        <figure>\n          <img src=\"https://cdn.freecodecamp.org/curriculum/cat-photo-app/cats.jpg\" alt=\"Two tabby kittens sleeping together on a couch.\">\n          <figcaption>Cats <strong>hate</strong> other cats.</figcaption>  \n        </figure>\n      </section>\n    </main>\n    <footer>\n      <p>\n        No Copyright - <a href=\"https://www.freecodecamp.org\">freeCodeCamp.org</a>\n      </p>\n    </footer>\n  </body>\n</html>","history":["index.html"],"fileKey":"indexhtml"}]}},"id":"/learn/basic-html/workshop-cat-photo-app/step-25"}},"staticQueryHashes":["3858520367"],"slicesMap":{}}