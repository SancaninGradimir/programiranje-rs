{"componentChunkName":"component---src-templates-challenges-generic-show-tsx","path":"/learn/b1-english-for-developers/learn-about-adverbial-phrases/dialogue-3-evaluating-marketing-impact","result":{"data":{"challengeNode":{"challenge":{"assignments":["<p>Gledaj video.</p>"],"bilibiliIds":null,"block":"learn-about-adverbial-phrases","challengeType":21,"description":"<section id=\"description\">\n<p>Pogledajte video ispod da biste razumeli kontekst sledećih lekcija.</p>\n</section>","nodules":null,"explanation":null,"helpCategory":"English","instructions":"","fields":{"slug":"/learn/b1-english-for-developers/learn-about-adverbial-phrases/dialogue-3-evaluating-marketing-impact"},"questions":[],"scene":{"setup":{"background":"company1-boardroom.png","characters":[{"character":"Riker","position":{"x":-25,"y":0,"z":1},"opacity":null},{"character":"Maria","position":{"x":125,"y":0,"z":1},"opacity":null}],"audio":{"filename":"B1_18-3.mp3","startTime":1,"startTimestamp":null,"finishTimestamp":null},"alwaysShowDialogue":true},"commands":[{"background":null,"character":"Riker","position":{"x":25,"y":0,"z":1},"opacity":null,"startTime":0,"finishTime":null,"dialogue":null},{"background":null,"character":"Maria","position":{"x":70,"y":0,"z":1},"opacity":null,"startTime":0.5,"finishTime":null,"dialogue":null},{"background":null,"character":"Riker","position":null,"opacity":null,"startTime":1,"finishTime":6.34,"dialogue":{"text":"Good morning, Maria. I've prepared the final report on our recent social media campaign.","align":"left"}},{"background":null,"character":"Riker","position":null,"opacity":null,"startTime":6.52,"finishTime":10.36,"dialogue":{"text":"It really helped increase our engagement levels, especially in Europe.","align":"left"}},{"background":null,"character":"Maria","position":null,"opacity":null,"startTime":10.98,"finishTime":14.62,"dialogue":{"text":"That's great. How much did our engagement improve? Did we reach our targets?","align":"right"}},{"background":null,"character":"Riker","position":null,"opacity":null,"startTime":15.38,"finishTime":19.4,"dialogue":{"text":"Yes, our engagement went up by about 40%. That's a big increase.","align":"left"}},{"background":null,"character":"Riker","position":null,"opacity":null,"startTime":19.62,"finishTime":24.1,"dialogue":{"text":"The UK and Germany saw the most improvement, even more than we expected.","align":"left"}},{"background":null,"character":"Maria","position":null,"opacity":null,"startTime":24.66,"finishTime":27.82,"dialogue":{"text":"That's impressive. What about our budget? Did we stay within it?","align":"right"}},{"background":null,"character":"Riker","position":null,"opacity":null,"startTime":27.82,"finishTime":33.46,"dialogue":{"text":"We went over budget by just 5%, which isn't too much. The ads cost more than we thought they would.","align":"left"}},{"background":null,"character":"Maria","position":null,"opacity":null,"startTime":34.2,"finishTime":38.26,"dialogue":{"text":"I see. Where could we do better? Which areas didn't meet our expectations completely?","align":"right"}},{"background":null,"character":"Riker","position":null,"opacity":null,"startTime":38.9,"finishTime":46.46,"dialogue":{"text":"Our campaign did well in Europe, but not as much in Asia. The impact there was quite low. We need better content that fits each local market.","align":"left"}},{"background":null,"character":"Maria","position":null,"opacity":null,"startTime":47.12,"finishTime":53.8,"dialogue":{"text":"Right. We should improve our strategies in areas where they weren't very effective. And for our next campaign, how can we manage our budget better?","align":"right"}},{"background":null,"character":"Riker","position":null,"opacity":null,"startTime":54.58,"finishTime":57.82,"dialogue":{"text":"I think we should plan our budget based on different regions' costs.","align":"left"}},{"background":null,"character":"Riker","position":null,"opacity":null,"startTime":58.54,"finishTime":61.84,"dialogue":{"text":"We need to spread our funds more wisely to avoid going over budget.","align":"left"}},{"background":null,"character":"Maria","position":null,"opacity":null,"startTime":62.44,"finishTime":66.56,"dialogue":{"text":"Excellent. Can you write a new strategy based on our talk today and share it at our next team meeting?","align":"right"}},{"background":null,"character":"Maria","position":null,"opacity":null,"startTime":66.92,"finishTime":69,"dialogue":{"text":"It's important that we use what we've learned to improve.","align":"right"}},{"background":null,"character":"Riker","position":null,"opacity":null,"startTime":69.76,"finishTime":74.44,"dialogue":{"text":"Okay Maria, I'll get a detailed plan ready and go over it with the team to get their thoughts.","align":"left"}},{"background":null,"character":"Maria","position":{"x":125,"y":0,"z":1},"opacity":null,"startTime":74.94,"finishTime":null,"dialogue":null},{"background":null,"character":"Riker","position":{"x":-25,"y":0,"z":1},"opacity":null,"startTime":75.44,"finishTime":null,"dialogue":null}]},"superBlock":"b1-english-for-developers","tests":[],"title":"Dijalog 3: Evaluacija marketinškog uticaja","transcript":null,"translationPending":false,"videoId":null,"videoLocaleIds":null}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/b1-english-for-developers/#learn-about-adverbial-phrases","dashedName":"dialogue-3-evaluating-marketing-impact","certification":"b1-english-for-developers","disableLoopProtectTests":false,"disableLoopProtectPreview":false,"superBlock":"b1-english-for-developers","chapter":null,"module":null,"block":"learn-about-adverbial-phrases","isFirstStep":false,"template":null,"required":[],"isLastChallengeInBlock":false,"nextChallengePath":"/learn/b1-english-for-developers/learn-about-adverbial-phrases/task-79","prevChallengePath":"/learn/b1-english-for-developers/learn-about-adverbial-phrases/task-78","id":"680a7a930df68b565d3ec6d9","saveSubmissionToDB":null},"projectPreview":{"ch