{"componentChunkName":"component---src-templates-challenges-classic-show-tsx","path":"/learn/basic-html/workshop-cat-photo-app/step-7","result":{"data":{"challengeNode":{"challenge":{"block":"workshop-cat-photo-app","demoType":null,"title":"Korak 7","description":"<section id=\"description\">\n<p>Možete dodati sliku na vašu veb stranicu koristeći element <code>img</code>. Elementi za <code>img</code> imaju otvarajući tag bez zatvarajućeg taga. Element koji nema zatvarajući tag poznat je kao <dfn>prazan element</dfn>.</p>\n<p>Dodajte funkciju <code>img</code> ispod funkcije <code>p</code>. Trenutno, slika se neće prikazati u pretraživaču.</p>\n</section>","id":"5dc23f9bf86c76b9248c6eba","hasEditableBoundaries":true,"instructions":"","notes":null,"challengeType":0,"helpCategory":"HTML-CSS","videoUrl":null,"superBlock":"basic-html","translationPending":false,"forumTopicId":null,"hooks":null,"fields":{"slug":"/learn/basic-html/workshop-cat-photo-app/step-7"},"required":[],"usesMultifileEditor":true,"challengeFiles":[{"fileKey":"indexhtml","ext":"html","name":"index","contents":"<html>\n  <body>\n    <main>\n      <h1>CatPhotoApp</h1>\n      <h2>Cat Photos</h2>\n      <!-- TODO: Add link to cat photos -->\n      <p>Everyone loves cute cats online!</p>\n      \n    </main>\n  </body>\n</html>","head":null,"tail":null,"editableRegionBoundaries":[7,9],"history":["index.html"]}],"saveSubmissionToDB":null,"tests":[{"text":"<p>Tvoj <code>img</code> element treba da ima početnu oznaku. Početne oznake imaju sledeću sintaksu: <code>&#x3C;elementName></code>.</p>","testString":"assert.exists(document.querySelector('img'));"},{"text":"<p>Vaš element za <code>img</code> ne sme imati zatvorni tag <code>&#x3C;/img></code>.</p>","testString":"assert.notMatch(code, /<\\/img\\>/);"},{"text":"<p>Trebalo bi da ima samo jedan element <code>img</code>. Uklonite sve suvišne stvari.</p>","testString":"assert.lengthOf(document.querySelectorAll('img'), 1);"},{"text":"<p>Vaš element <code>img</code> treba da bude ispod elementa <code>p</code>. Postavljen je u pogrešan redosled.</p>","testString":"const collection = [...document.querySelectorAll('p,img')].map(\n  (node) => node.nodeName\n);\nassert.isBelow(collection.indexOf('P'), collection.indexOf('IMG'));"}]}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/basic-html/#workshop-cat-photo-app","dashedName":"step-7","certification":"basic-html","disableLoopProtectTests":false,"disableLoopProtectPreview":false,"superBlock":"basic-html","chapter":null,"module":null,"block":"workshop-cat-photo-app","isFirstStep":false,"template":null,"required":[],"isLastChallengeInBlock":false,"nextChallengePath":"/learn/basic-html/workshop-cat-photo-app/step-8","prevChallengePath":"/learn/basic-html/workshop-cat-photo-app/step-6","id":"5dc23f9bf86c76b9248c6eba","saveSubmissionToDB":null},"projectPreview":{"challengeData":{"challengeType":0,"challengeFiles":[{"name":"index","ext":"html","contents":"<!DOCTYPE html>\n<html lang=\"en\">\n  <head>\n    <meta charset=\"UTF-8\">\n    <title>CatPhotoApp</title>\n  </head>\n  <body>\n    <main>\n      <h1>CatPhotoApp</h1>\n      <section>\n        <h2>Cat Photos</h2>\n        <p>Everyone loves <a href=\"https://cdn.freecodecamp.org/curriculum/cat-photo-app/running-cats.jpg\">cute cats</a> online!</p>\n        <p>See more <a target=\"_blank\" href=\"https://freecatphotoapp.com\">cat photos</a> in our gallery.</p>\n        <a href=\"https://freecatphotoapp.com\"><img src=\"https://cdn.freecodecamp.org/curriculum/cat-photo-app/relaxing-cat.jpg\" alt=\"A cute orange cat lying on its back.\"></a>\n      </section>\n      <section>\n        <h2>Cat Lists</h2>\n        <h3>Things cats love:</h3>\n        <ul>\n          <li>catnip</li>\n          <li>laser pointers</li>\n          <li>lasagna</li>\n        </ul>\n        <figure>\n          <img src=\"https://cdn.freecodecamp.org/curriculum/cat-photo-app/lasagna.jpg\" alt=\"A slice of lasagna on a plate.\">\n          <figcaption>Cats <em>love</em> lasagna.</figcaption>  \n        </figure>\n        <h3>Top 3 things cats hate:</h3>\n        <ol>\n          <li>flea treatment</li>\n          <li>thunder</li>\n          <li>other cats</li>\n        </ol>\n        <figure>\n          <img src=\"https://cdn.freecodecamp.org/curriculum/cat-photo-app/cats.jpg\" alt=\"Two tabby kittens sleeping together on a couch.\">\n          <figcaption>Cats <strong>hate</strong> other cats.</figcaption>  \n        </figure>\n      </section>\n    </main>\n    <footer>\n      <p>\n        No Copyright - <a href=\"https://www.freecodecamp.org\">freeCodeCamp.org</a>\n      </p>\n    </footer>\n  </body>\n</html>","history":["index.html"],"fileKey":"indexhtml"}]}},"id":"/learn/basic-html/workshop-cat-photo-app/step-7"}},"staticQueryHashes":["3858520367"],"slicesMap":{}}