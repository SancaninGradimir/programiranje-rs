{"componentChunkName":"component---src-templates-challenges-classic-show-tsx","path":"/learn/javascript-algorithms-and-data-structures/intermediate-algorithm-scripting/pig-latin","result":{"data":{"challengeNode":{"challenge":{"block":"intermediate-algorithm-scripting","demoType":null,"title":"Pig Latin","description":"<section id=\"description\">\n<p>Pig Latin je način za menjanje engleskih reči. Pravila su sledeća:</p>\n<p>- Ako reč počinje sa konsonantom, uzmi prvu konsonantu ili grupu konsonanti, premesti je na kraj reči, a zatim dodaj <code>ay</code>.</p>\n<p>- Ako reč počinje samoglasnikom, samo dodaj <code>way</code> na kraju.</p>\n</section>","id":"aa7697ea2477d1316795783b","hasEditableBoundaries":false,"instructions":"<section id=\"instructions\">\n<p>Prevedite dati niz slova u Pig Latina. Ulazni niz slova je garantovan da su sve mala engleska reči.</p>\n</section>","notes":null,"challengeType":1,"helpCategory":"JavaScript","videoUrl":null,"superBlock":"javascript-algorithms-and-data-structures","translationPending":false,"forumTopicId":16039,"hooks":null,"fields":{"slug":"/learn/javascript-algorithms-and-data-structures/intermediate-algorithm-scripting/pig-latin"},"required":[],"usesMultifileEditor":false,"challengeFiles":[{"fileKey":"scriptjs","ext":"js","name":"script","contents":"function translatePigLatin(str) {\r\n  return str;\r\n}\r\n\r\ntranslatePigLatin(\"consonant\");","head":null,"tail":null,"editableRegionBoundaries":[],"history":["script.js"]}],"saveSubmissionToDB":null,"tests":[{"text":"<p><code>translatePigLatin(\"california\")</code> treba da vrati sekvencu slova <code>aliforniacay</code>.</p>","testString":"assert.deepEqual(translatePigLatin('california'), 'aliforniacay');"},{"text":"<p><code>translatePigLatin(\"paragraphs\")</code> bi trebalo da vrati sekvencu slova <code>aragraphspay</code>.</p>","testString":"assert.deepEqual(translatePigLatin('paragraphs'), 'aragraphspay');"},{"text":"<p><code>translatePigLatin(\"glove\")</code> treba vratiti sekvencu karaktera <code>oveglay</code>.</p>","testString":"assert.deepEqual(translatePigLatin('glove'), 'oveglay');"},{"text":"<p><code>translatePigLatin(\"algorithm\")</code> mora vratiti sekvencu karaktera <code>algorithmway</code>.</p>","testString":"assert.deepEqual(translatePigLatin('algorithm'), 'algorithmway');"},{"text":"<p><code>translatePigLatin(\"eight\")</code> treba da vrati sekvencu karaktera <code>eightway</code>.</p>","testString":"assert.deepEqual(translatePigLatin('eight'), 'eightway');"},{"text":"<p>Trebalo bi da se obrade reči gde je prva vokala na sredini reči. <code>translatePigLatin(\"schwartz\")</code> treba da vrati niz znakova <code>artzschway</code>.</p>","testString":"assert.deepEqual(translatePigLatin('schwartz'), 'artzschway');"},{"text":"<p>Trebalo bi da se obrađuju reči bez vokala. <code>translatePigLatin(\"rhythm\")</code> treba da vrati nizu slova <code>rhythmay</code>.</p>","testString":"assert.deepEqual(translatePigLatin('rhythm'), 'rhythmay');"}]}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/javascript-algorithms-and-data-structures/#intermediate-algorithm-scripting","dashedName":"pig-latin","certification":"javascript-algorithms-and-data-structures","disableLoopProtectTests":false,"disableLoopProtectPreview":false,"superBlock":"javascript-algorithms-and-data-structures","chapter":null,"module":null,"block":"intermediate-algorithm-scripting","isFirstStep":false,"template":null,"required":[],"isLastChallengeInBlock":false,"nextChallengePath":"/learn/javascript-algorithms-and-data-structures/intermediate-algorithm-scripting/search-and-replace","prevChallengePath":"/learn/javascript-algorithms-and-data-structures/intermediate-algorithm-scripting/spinal-tap-case","id":"aa7697ea2477d1316795783b","saveSubmissionToDB":null},"projectPreview":{"challengeData":{"challengeType":1,"challengeFiles":[{"name":"script","ext":"js","contents":"function orbitalPeriod(arr) {\n  const GM = 398600.4418;\n  const earthRadius = 6367.4447;\n  const TAU = 2 * Math.PI;\n  return arr.map(function(obj) {\n    return {\n      name: obj.name,\n      orbitalPeriod: Math.round(TAU * Math.sqrt(Math.pow(obj.avgAlt+earthRadius, 3)/GM))\n    };\n  });\n}","history":["script.js"],"fileKey":"scriptjs"}]}},"id":"/learn/javascript-algorithms-and-data-structures/intermediate-algorithm-scripting/pig-latin"}},"staticQueryHashes":["3858520367"],"slicesMap":{}}