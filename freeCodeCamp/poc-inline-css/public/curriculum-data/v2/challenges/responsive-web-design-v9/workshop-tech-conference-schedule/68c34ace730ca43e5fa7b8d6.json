  "tests": [
    {
      "text": "<p>Trebalo bi da imaš element <code>tr</code> unutar elementa <code>tbody</code>.</p>",
      "testString": "assert.lengthOf(document.querySelectorAll(\"tbody tr\"), 2);"
    },
    {
      "text": "<p>Trebalo bi da imaš element <code>th</code> unutar drugog elementa <code>tr</code>.</p>",
      "testString": "assert.isNotNull(document.querySelectorAll(\"tbody tr\")[1].querySelector(\"th\"));"
    },
    {
      "text": "<p>Vaše polje za <code>th</code> treba da ima tekst sa <code>10:00 AM</code>.</p>",
      "testString": "assert.strictEqual(document.querySelectorAll(\"tbody tr\")[1].querySelector(\"th\")?.textContent.trim(), \"10:00 AM\");"
    },
    {
      "text": "<p>Vaše polje <code>th</code> trebalo bi imati atribut polja <code>scope</code> postavljen na <code>\"row\"</code>.</p>",
      "testString": "assert.strictEqual(document.querySelectorAll(\"tbody tr\")[1].querySelector(\"th\")?.getAttribute(\"scope\"), \"row\");"
    },
    {
      "text": "<p>Vaš drugi element vezan za <code>tr</code> bi trebalo da ima tri komponente od <code>td</code>.</p>",
      "testString": "assert.lengthOf(document.querySelectorAll(\"tbody tr\")[1].querySelectorAll(\"td\"), 3);"
    },
    {
      "text": "<p>Vaš element <code>td</code> prvi treba da sadrži tekst <code>Accessibility Deep Dive</code>.</p>",
      "testString": "assert.strictEqual(document.querySelectorAll(\"tbody tr\")[1].querySelectorAll(\"td\")[0]?.textContent.trim(), \"Accessibility Deep Dive\");"
    },
    {
      "text": "<p>Vaše drugo polje za <code>td</code> mora da sadrži tekst od <code>CSS for Beginners</code>.</p>",
      "testString": "assert.strictEqual(document.querySelectorAll(\"tbody tr\")[1].querySelectorAll(\"td\")[1]?.textContent.trim(), \"CSS for Beginners\");"
    },
    {
      "text": "<p>Treći element vašeg <code>td</code> treba da ima tekst <code>Inclusive Design Principles</code>.</p>",
      "testString": "assert.strictEqual(document.querySelectorAll(\"tbody tr\")[1].querySelectorAll(\"td\")[2]?.textContent.trim(), \"Inclusive Design Principles\");"
    }
