    {
      "text": "<p>Element sa klasom <code>first</code> treba da ima <code>z-index</code> vrednost od 2.</p>",
      "testString": "const firstElement = document.querySelector('.first');\nconst firstStyle = window.getComputedStyle(firstElement); \nassert.equal(firstStyle?.zIndex, '2');"
