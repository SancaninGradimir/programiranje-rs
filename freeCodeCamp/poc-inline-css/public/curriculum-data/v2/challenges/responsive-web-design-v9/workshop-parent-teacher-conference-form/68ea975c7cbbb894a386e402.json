    {
      "text": "<p>This new <code>label</code> element (for email) should have a class of <code>\"contact-method\"</code>.</p>",
      "testString": "assert.exists(document.querySelector(\"fieldset:last-of-type label.contact-method\"));"
    },
    {
      "text": "<p>The new <code>label</code> element's <code>for</code> attribute should be set to <code>\"email\"</code>.</p>",
      "testString": "const label = document.querySelector(\"fieldset:last-of-type label\");\nassert.strictEqual(label?.getAttribute(\"for\"), \"email\");"
