{"componentChunkName":"component---src-templates-challenges-classic-show-tsx","path":"/learn/semantic-html/workshop-quincys-job-tips/step-5","result":{"data":{"challengeNode":{"challenge":{"block":"workshop-quincys-job-tips","demoType":null,"title":"Korak 5","description":"<section id=\"description\">\n<p>Ispod elementa paragrafa, dodajte element <code>main</code> i u njega ugnježđivati tri elementa <code>section</code>.</p>\n</section>","id":"68e96ce52087043b0e999296","hasEditableBoundaries":true,"instructions":"","notes":null,"challengeType":0,"helpCategory":"HTML-CSS","videoUrl":null,"superBlock":"semantic-html","translationPending":false,"forumTopicId":null,"hooks":null,"fields":{"slug":"/learn/semantic-html/workshop-quincys-job-tips/step-5"},"required":[],"usesMultifileEditor":true,"challengeFiles":[{"fileKey":"indexhtml","ext":"html","name":"index","contents":"<!DOCTYPE html>\n<html lang=\"en\">\n  <head>\n    <meta charset=\"UTF-8\" />\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" />\n    <title>Quincy's Tips for Getting a Developer Job</title>\n  </head>\n  <body>\n    <h1>Quincy's Tips for Getting a Developer Job</h1>\n    <p>\n      Learning to code is hard, but as Quincy Larson says,\n      <q cite=\"https://www.freecodecamp.org/news/learn-to-code-book/\">You can become a developer.</q>\n    </p>\n\n    \n  </body>\n</html>","head":null,"tail":null,"editableRegionBoundaries":[14,16],"history":["index.html"]}],"saveSubmissionToDB":null,"tests":[{"text":"<p>You should have a <code>main</code> element below the paragraph element.</p>","testString":"const mainEl = document.querySelector('p + main');\nassert.exists(mainEl);"},{"text":"<p>You should have three <code>section</code> elements inside of your <code>main</code> element.</p>","testString":"const sections = document.querySelectorAll('main > section');\nassert.lengthOf(sections, 3);"}]}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/semantic-html/#workshop-quincys-job-tips","dashedName":"step-5","certification":"semantic-html","disableLoopProtectTests":false,"disableLoopProtectPreview":false,"superBlock":"semantic-html","chapter":null,"module":null,"block":"workshop-quincys-job-tips","isFirstStep":false,"template":null,"required":[],"isLastChallengeInBlock":false,"nextChallengePath":"/learn/semantic-html/workshop-quincys-job-tips/step-6","prevChallengePath":"/learn/semantic-html/workshop-quincys-job-tips/step-4","id":"68e96ce52087043b0e999296","saveSubmissionToDB":null},"projectPreview":{"challengeData":{"challengeType":0,"challengeFiles":[{"name":"index","ext":"html","contents":"<!DOCTYPE html>\n<html lang=\"en\">\n  <head>\n    <meta charset=\"UTF-8\" />\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" />\n    <title>Quincy's Tips for Getting a Developer Job</title>\n  </head>\n  <body>\n    <h1>Quincy's Tips for Getting a Developer Job</h1>\n    <p>\n      Learning to code is hard, but as Quincy Larson says,\n      <q cite=\"https://www.freecodecamp.org/news/learn-to-code-book/\">You can become a developer.</q>\n    </p>\n\n    <main>\n      <section>\n        <h2>Envisioning Success</h2>\n        <blockquote cite=\"https://www.freecodecamp.org/news/learn-to-code-book/\">\n          Can you imagine what it would be like to be a successful developer? To have built software systems that people rely upon?\n        </blockquote>\n        <p>\n          &mdash;Quincy Larson, <cite>How to Learn to Code and Get a Developer Job [Full Book]</cite>\n        </p>\n      </section>\n\n      <section>\n        <h2>Importance of Networking</h2>\n        <blockquote cite=\"https://www.freecodecamp.org/news/learn-to-code-book/\">\n          <p>So much of getting a job is who you know.</p>\n          <p>It's OK to be an introvert, but you do need to push your boundaries.</p>\n          <p>Create GitHub, Twitter, LinkedIn, and Discord accounts.</p>\n          <p>Go to tech meetups and conferences. Travel if you have to.</p>\n        </blockquote>\n      </section>\n\n      <section>\n        <h2>Importance of Building a Reputation</h2>\n        <blockquote cite=\"https://www.freecodecamp.org/news/learn-to-code-book/\">\n          <p>Share short video demos of your projects.</p>\n          <p>Keep applying to speak at bigger and bigger conferences.</p>\n          <p>Hang out at hackerspaces and help people who are even newer to coding than you.</p>\n        </blockquote>\n      </section>\n    </main>\n  </body>\n</html>","history":["index.html"],"fileKey":"indexhtml"}]}},"id":"/learn/semantic-html/workshop-quincys-job-tips/step-5"}},"staticQueryHashes":["3858520367"],"slicesMap":{}}