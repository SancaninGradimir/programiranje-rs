  "tests": [
    {
      "text": "<p>Vas kod treba da doda jedan <code>strong</code> tag u markup.</p>",
      "testString": "assert.lengthOf(document.querySelectorAll('strong'),1);"
    },
    {
      "text": "<p><code>strong</code> tag treba da bude unutar <code>p</code> taga.</p>",
      "testString": "const paragraphElement = document.querySelector('p');\nconst paragraphChildren = paragraphElement?.querySelectorAll(`:scope ${'strong'}`);\nassert.lengthOf(paragraphChildren, 1);"
    },
    {
      "text": "<p><code>strong</code> tag treba da obuhvati reci <code>Stanford University</code>.</p>",
      "testString": "assert.match(document.querySelector('strong')?.textContent, /^Stanford University\\.?$/gi);"
    }
  ],
  "description": "<section id=\"description\">\n<p>Da biste tekst prikazali podebljano, mozete koristiti <code>strong</code> tag. Ovo se cesto koristi da privuce paznju i pokaze da je tekst vazan. Za <code>strong</code> tag pregledač primenjuje CSS <code>font-weight: bold;</code> na element.</p>\n</section>",
  "instructions": "<section id=\"instructions\">\n<p>Obuhvatite tekst <code>Stanford University</code> unutar <code>p</code> taga pomocu <code>strong</code> taga (bez tacke).</p>\n</section>",
