{"componentChunkName":"component---src-templates-challenges-classic-show-tsx","path":"/learn/project-euler/project-euler-problems-1-to-100/problem-94-almost-equilateral-triangles","result":{"data":{"challengeNode":{"challenge":{"block":"project-euler-problems-1-to-100","demoType":null,"title":"Zoezi la 94: Mviringo karibu sawa upande tatu","description":"<section id=\"description\">\n<p>Lako je dokazati da ne postoji trougao čije su sve stranice i površina cele brojeve. Međutim, gotovo izoscelesni trougao sa stranicama 5-5-6 ima površinu od 12 kvadratnih jedinica.</p>\n<p>Definisaćemo <dfn>gotovo jednakostranični trougao</dfn> kao trougao kod kojeg su dve stranice jednake, a treća se razlikuje za najviše jednu jedinicu.</p>\n<p>Pronađi zbir obima svih gotovo jednakostraničnih trouglova sa celobrojnim dužinama stranica i celobrojnom površinom čiji obim ne prelazi <code>limit</code>.</p>\n</section>","id":"5900f3ca1000cf542c50fedd","hasEditableBoundaries":false,"instructions":"","notes":null,"challengeType":1,"helpCategory":"Euler","videoUrl":null,"superBlock":"project-euler","translationPending":false,"forumTopicId":302211,"hooks":null,"fields":{"slug":"/learn/project-euler/project-euler-problems-1-to-100/problem-94-almost-equilateral-triangles"},"required":[],"usesMultifileEditor":false,"challengeFiles":[{"fileKey":"scriptjs","ext":"js","name":"script","contents":"function almostEquilateralTriangles(limit) {\n\n  return true;\n}\n\nalmostEquilateralTriangles(50);","head":null,"tail":null,"editableRegionBoundaries":[],"history":["script.js"]}],"saveSubmissionToDB":null,"tests":[{"text":"<p><code>almostEquilateralTriangles(50)</code> treba da vrati broj.</p>","testString":"assert(typeof almostEquilateralTriangles(50) === 'number');"},{"text":"<p><code>almostEquilateralTriangles(50)</code> inapaswa kurudisha <code>66</code>.</p>","testString":"assert.strictEqual(almostEquilateralTriangles(50), 66);"},{"text":"<p><code>almostEquilateralTriangles(10000)</code> inapaswa kurudisha <code>3688</code>.</p>","testString":"assert.strictEqual(almostEquilateralTriangles(10000), 3688);"},{"text":"<p><code>almostEquilateralTriangles(10000000)</code> trebalo bi da vrati <code>9973078</code>.</p>","testString":"assert.strictEqual(almostEquilateralTriangles(10000000), 9973078);"},{"text":"<p><code>almostEquilateralTriangles(1000000000)</code> inapaswa kurudisha <code>518408346</code>.</p>","testString":"assert.strictEqual(almostEquilateralTriangles(1000000000), 518408346);"}]}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/project-euler/#project-euler-problems-1-to-100","dashedName":"problem-94-almost-equilateral-triangles","certification":"project-euler","disableLoopProtectTests":true,"disableLoopProtectPreview":false,"superBlock":"project-euler","chapter":null,"module":null,"block":"project-euler-problems-1-to-100","isFirstStep":false,"template":null,"required":[],"isLastChallengeInBlock":false,"nextChallengePath":"/learn/project-euler/project-euler-problems-1-to-100/problem-95-amicable-chains","prevChallengePath":"/learn/project-euler/project-euler-problems-1-to-100/problem-93-arithmetic-expressions","id":"5900f3ca1000cf542c50fedd","saveSubmissionToDB":null},"projectPreview":{"challengeData":{"challengeType":1,"challengeFiles":[{"name":"script","ext":"js","contents":"function arrangedProbability(limit) {\n  // Based on https://www.mathblog.dk/project-euler-100-blue-discs-two-blue/\n  let blue = 15;\n  let discs = 21;\n\n  while (discs < limit) {\n    const nextBlue = 3 * blue + 2 * discs - 2;\n    const nextDiscs = 4 * blue + 3 * discs - 3;\n\n    blue = nextBlue;\n    discs = nextDiscs;\n  }\n  return blue;\n}","history":["script.js"],"fileKey":"scriptjs"}]}},"id":"/learn/project-euler/project-euler-problems-1-to-100/problem-94-almost-equilateral-triangles"}},"staticQueryHashes":["3858520367"],"slicesMap":{}}