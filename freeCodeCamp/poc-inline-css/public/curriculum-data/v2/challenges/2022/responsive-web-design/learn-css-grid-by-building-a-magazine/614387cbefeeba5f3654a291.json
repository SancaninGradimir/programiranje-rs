  "tests": [
    {
      "text": "<p>Treba da kreiraš novu komponentu za <code>div</code>.</p>",
      "testString": "assert.exists(document.querySelector('div'));"
    },
    {
      "text": "<p>Vaš element <code>div</code> treba da dođe posle vašeg elementa <code>header</code>.</p>",
      "testString": "assert(document.querySelector('div')?.previousElementSibling?.localName === 'header');"
    },
    {
      "text": "<p>Vaše polje za <code>div</code> mora imati <code>class</code> postavljeno na <code>author</code>.</p>",
      "testString": "assert(document.querySelector('div')?.className === 'author');"
    },
    {
      "text": "<p>Treba ti kreirati dve nove komponente za <code>p</code>.</p>",
      "testString": "assert(document.querySelectorAll('p')?.length === 3);"
    },
    {
      "text": "<p>Tvoja dva nova elementa <code>p</code> treba da budu unutar tvog elementa <code>div</code>.</p>",
      "testString": "assert.exists(document.querySelector('div')?.querySelectorAll('p')?.length === 2);"
    },
    {
      "text": "<p>Tvoj prvi novi element za <code>p</code> treba da ima <code>class</code> postavljen na <code>author-name</code>.</p>",
      "testString": "assert(document.querySelector('div')?.querySelector('p')?.className === 'author-name');"
    },
    {
      "text": "<p>Tvoj prvi novi element <code>p</code> treba da ima tekst <code>By freeCodeCamp</code>.</p>",
      "testString": "assert(document.querySelector('div')?.querySelector('p')?.innerText === 'By freeCodeCamp');"
    },
    {
      "text": "<p>Tvoj drugi novi element za <code>p</code> mora imati <code>class</code> postavljen na <code>publish-date</code>.</p>",
      "testString": "assert(document.querySelector('div')?.querySelectorAll('p')?.[1]?.className === 'publish-date');"
    },
    {
      "text": "<p>Tvoj drugi novi element <code>p</code> treba da ima tekst <code>March 7, 2019</code>.</p>",
      "testString": "assert(document.querySelector('div')?.querySelectorAll('p')?.[1]?.innerText === 'March 7, 2019');"
    },
    {
      "text": "<p>Trebalo bi da napraviš novu komponentu za <code>a</code>.</p>",
      "testString": "assert.exists(document.querySelector('a'));"
    },
    {
      "text": "<p>Vaš element <code>a</code> treba da bude unutar vašeg prvog novog elementa <code>p</code>.</p>",
      "testString": "assert(document.querySelector('div')?.querySelector('p')?.firstElementChild?.localName === 'a');"
    },
    {
      "text": "<p>Vaš element <code>a</code> mora imati <code>href</code> postavljen na <code>https://freecodecamp.org</code>.</p>",
      "testString": "assert(document.querySelector('div')?.querySelector('p')?.firstElementChild?.getAttribute('href') === 'https://freecodecamp.org');"
    },
    {
      "text": "<p>Vaš atribut za <code>a</code> mora imati <code>target</code>, postavljen na <code>_blank</code>.</p>",
      "testString": "assert(document.querySelector('div')?.querySelector('p')?.firstElementChild?.getAttribute('target') === '_blank');"
    },
    {
      "text": "<p>Element vašeg <code>a</code> mora da pokrije tekst od <code>freeCodeCamp</code>.</p>",
      "testString": "assert(document.querySelector('div')?.querySelector('p')?.firstElementChild?.innerText === 'freeCodeCamp');"
    }
  ],
  "description": "<section id=\"description\">\n<p>Nakon vašeg elementa <code>header</code>, kreirajte <code>div</code> koji se postavlja na <code>class</code> kao <code>author</code>.</p>\n<p>Unutar <code>div</code>, kreiraj element za <code>p</code> i <code>class</code> postavi na <code>author-name</code>, a tekstualni sadržaj <code>By freeCodeCamp</code>. Pokrij deo <code>freeCodeCamp</code> unutar elementa <code>a</code> i <code>href</code> da bude postavljen na <code>https://freecodecamp.org</code>, a <code>target</code> da bude postavljen na <code>_blank</code>.</p>\n<p>Ispod toga, dodaj drugi element za <code>p</code> koji ima klasu objekata <code>publish-date</code> i tekst <code>March 7, 2019</code>.</p>\n</section>",
