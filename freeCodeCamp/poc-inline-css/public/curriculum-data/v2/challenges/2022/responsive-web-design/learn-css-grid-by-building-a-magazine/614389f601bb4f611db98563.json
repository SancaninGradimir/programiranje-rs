  "tests": [
    {
      "text": "<p>Trebalo bi da napraviš novu komponentu za <code>div</code>.</p>",
      "testString": "assert(document.querySelectorAll('div')?.length === 2);"
    },
    {
      "text": "<p>Tvoj novi element za <code>div</code> mora da dođe nakon tvog elementa <code>.author</code>.</p>",
      "testString": "assert(document.querySelector('.author')?.nextElementSibling?.localName === 'div');"
    },
    {
      "text": "<p>Vaša nova funkcija za <code>div</code> mora imati klasu <code>social-icons</code>.</p>",
      "testString": "assert(document.querySelector('.author')?.nextElementSibling?.classList?.contains('social-icons'));"
    },
    {
      "text": "<p>Vaš element <code>.social-icons</code> bi trebalo da ima pet komponenti <code>a</code>.</p>",
      "testString": "assert(document.querySelector('.social-icons')?.querySelectorAll('a')?.length === 5);"
    },
    {
      "text": "<p>Prvi atribut vašeg <code>a</code> treba da ima svojstvo atributa <code>href</code> postavljeno na <code>https://www.facebook.com/freecodecamp</code>.</p>",
      "testString": "assert(document.querySelector('.social-icons')?.querySelectorAll('a')?.[0]?.getAttribute('href')?.includes('https://www.facebook.com/freecodecamp'));"
    },
    {
      "text": "<p>Tvoj drugi element od <code>a</code> mora imati svojstvo elementa <code>href</code> postavljeno na <code>https://twitter.com/freecodecamp</code>.</p>",
      "testString": "assert.include(document.querySelector('.social-icons')?.querySelectorAll('a')?.[1]?.getAttribute('href'), 'https://twitter.com/freecodecamp');"
    },
    {
      "text": "<p>Tvoj treći element od <code>a</code> mora imati svojstvo polja <code>href</code> postavljeno na <code>https://instagram.com/freecodecamp</code>.</p>",
      "testString": "assert.include(document.querySelector('.social-icons')?.querySelectorAll('a')?.[2]?.getAttribute('href'), 'https://instagram.com/freecodecamp');"
    },
    {
      "text": "<p>Vaš četvrti element od <code>a</code> treba da ima svojstvo elementa <code>href</code> postavljeno na <code>https://www.linkedin.com/school/free-code-camp</code>.</p>",
      "testString": "assert.include(document.querySelector('.social-icons')?.querySelectorAll('a')?.[3]?.getAttribute('href'), 'https://www.linkedin.com/school/free-code-camp');"
    },
    {
      "text": "<p>Petih vašeg elementa <code>a</code> treba da ima svojstvo elementa <code>href</code> postavljeno na <code>https://www.youtube.com/freecodecamp</code>.</p>",
      "testString": "assert.include(document.querySelector('.social-icons')?.querySelectorAll('a')?.[4]?.getAttribute('href'), 'https://www.youtube.com/freecodecamp');"
    }
  ],
  "description": "<section id=\"description\">\n<p>Ispod vašeg elementa sa <code>.author</code>, kreiraj novi element sa <code>div</code> koji ima klasu objekata <code>social-icons</code>.</p>\n<p>Dodajte pet elemenata iz <code>a</code> unutar novog <code>div</code>, i dodelite im sledeće karakteristike elementa za <code>href</code>.</p>\n<ul>\n<li>Elementat prvi sa <code>a</code> mora imati atribut elementa <code>href</code> postavljen na <code>https://www.facebook.com/freecodecamp</code>.</li>\n<li>Elementat drugi sa <code>a</code> mora imati atribut elementa <code>href</code> postavljen na <code>https://twitter.com/freecodecamp</code>.</li>\n<li>Elementat treći sa <code>a</code> mora imati atribut elementa <code>href</code> postavljen na <code>https://instagram.com/freecodecamp</code>.</li>\n<li>Elementat četvrti sa <code>a</code> mora imati atribut elementa <code>href</code> postavljen na <code>https://www.linkedin.com/school/free-code-camp</code>.</li>\n<li>Elementat peti sa <code>a</code> mora imati atribut elementa <code>href</code> postavljen na <code>https://www.youtube.com/freecodecamp</code>.</li>\n</ul>\n</section>",
