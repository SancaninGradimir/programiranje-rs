ue;\n    discs = nextDiscs;\n  }\n  return blue;\n}","history":["script.js"],"fileKey":"scriptjs"}]}},"id":"/learn/project-euler/project-euler-problems-1-to-100/problem-71-ordered-fractions"}},"staticQueryHashes":["3858520367"],"slicesMap":{}}