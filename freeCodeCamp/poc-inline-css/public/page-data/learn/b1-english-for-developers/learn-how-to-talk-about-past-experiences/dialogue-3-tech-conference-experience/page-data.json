{"componentChunkName":"component---src-templates-challenges-generic-show-tsx","path":"/learn/b1-english-for-developers/learn-how-to-talk-about-past-experiences/dialogue-3-tech-conference-experience","result":{"data":{"challengeNode":{"challenge":{"assignments":["<p>Gledaj video</p>"],"bilibiliIds":null,"block":"learn-how-to-talk-about-past-experiences","challengeType":21,"description":"<section id=\"description\">\n<p>Pogledajte video dole/ispod kako biste razumeli kontekst predstojećih lekcija.</p>\n</section>","nodules":null,"explanation":null,"helpCategory":"English","instructions":"","fields":{"slug":"/learn/b1-english-for-developers/learn-how-to-talk-about-past-experiences/dialogue-3-tech-conference-experience"},"questions":[],"scene":{"setup":{"background":"cafe.png","characters":[{"character":"Maria","position":{"x":-25,"y":0,"z":1},"opacity":null},{"character":"Brian","position":{"x":125,"y":0,"z":1},"opacity":null}],"audio":{"filename":"B1_2-3.mp3","startTime":1,"startTimestamp":null,"finishTimestamp":null},"alwaysShowDialogue":true},"commands":[{"background":null,"character":"Maria","position":{"x":25,"y":0,"z":1},"opacity":null,"startTime":0,"finishTime":null,"dialogue":null},{"background":null,"character":"Brian","position":{"x":70,"y":0,"z":1},"opacity":null,"startTime":0.5,"finishTime":null,"dialogue":null},{"background":null,"character":"Maria","position":null,"opacity":null,"startTime":1,"finishTime":4.38,"dialogue":{"text":"Brian, is that you? What a surprise to see you here at PyCon.","align":"center"}},{"background":null,"character":"Brian","position":null,"opacity":null,"startTime":4.64,"finishTime":7.68,"dialogue":{"text":"Wow, Maria. So nice to see you. Let's catch up.","align":"center"}},{"background":null,"character":"Brian","position":null,"opacity":null,"startTime":7.74,"finishTime":10.86,"dialogue":{"text":"I attended some really interesting sessions these last few days.","align":"center"}},{"background":null,"character":"Maria","position":null,"opacity":null,"startTime":11.28,"finishTime":14.56,"dialogue":{"text":"Yeah, me too. I checked out the latest in Python development.","align":"center"}},{"background":null,"character":"Maria","position":null,"opacity":null,"startTime":14.9,"finishTime":18.1,"dialogue":{"text":"Do you remember how we used to get excited about new tech back at work?","align":"center"}},{"background":null,"character":"Brian","position":null,"opacity":null,"startTime":18.74,"finishTime":23.24,"dialogue":{"text":"Absolutely. We used to spend our lunch breaks chatting about the newest trends in programming.","align":"center"}},{"background":null,"character":"Brian","position":null,"opacity":null,"startTime":23.84,"finishTime":25.74,"dialogue":{"text":"Did you go to the AI workshop yesterday?","align":"center"}},{"background":null,"character":"Maria","position":null,"opacity":null,"startTime":25.74,"finishTime":31.16,"dialogue":{"text":"Yes, I did. While the speaker was going through neural networks, I thought about our project last year.","align":"center"}},{"background":null,"character":"Maria","position":null,"opacity":null,"startTime":31.62,"finishTime":35.4,"dialogue":{"text":"I remember you would often stay late, fine-tuning the code until it was just right.","align":"center"}},{"background":null,"character":"Brian","position":null,"opacity":null,"startTime":36.72,"finishTime":40.24,"dialogue":{"text":"Now I take care of the training so that others can do the same.","align":"center"}},{"background":null,"character":"Brian","position":null,"opacity":null,"startTime":40.74,"finishTime":44.66,"dialogue":{"text":"Speaking of which, did you manage to catch the cyber security talk this morning?","align":"center"}},{"background":null,"character":"Maria","position":null,"opacity":null,"startTime":45.16,"finishTime":47.6,"dialogue":{"text":"I missed it. I was in a design sprint workshop.","align":"center"}},{"background":null,"character":"Maria","position":null,"opacity":null,"startTime":48.04,"finishTime":50.66,"dialogue":{"text":"We brainstormed for two hours straight. How was it?","align":"center"}},{"background":null,"character":"Brian","position":null,"opacity":null,"startTime":50.66,"finishTime":54.2,"dialogue":{"text":"It was eye-opening, especially the parts about protecting data.","align":"center"}},{"background":null,"character":"Brian","position":null,"opacity":null,"startTime":54.54,"finishTime":58.28,"dialogue":{"text":"It made me think of how we handled security in our earlier projects.","align":"center"}},{"background":null,"character":"Brian","position":{"x":125,"y":0,"z":1},"opacity":null,"startTime":58.78,"finishTime":null,"dialogue":null},{"background":null,"character":"Maria","position":{"x":-25,"y":0,"z":1},"opacity":null,"startTime":59.28,"finishTime":null,"dialogue":null}]},"superBlock":"b1-english-for-developers","tests":[],"title":"Dialog 3: Iskustvo sa tehnološke konferencije","transcript":null,"translationPending":false,"videoId":null,"videoLocaleIds":null}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/b1-english-for-developers/#learn-how-to-talk-about-past-experiences","dashedName":"dialogue-3-tech-conference-experience","certification":"b1-english-for-developers","disableLoopProtectTests":false,"disableLoopProtectPreview":false,"superBlock":"b1-english-for-developers","chapter":null,"module":null,"block":"learn-how-to-talk-about-past-experiences","isFirstStep":false,"template":null,"required":[],"isLastChallengeInBlock":false,"nextChallengePath":"/learn/b1-english-for-developers/learn-how-to-talk-about-past-experiences/task-86","prevChallengePath":"/learn/b1-english-for-developers/learn-how-to-talk-about-past-experiences/task-85","id":"671d292ef6180210164c33e8","saveSubmissionToDB":null},"projectPreview":{"challengeData":{"challengeType":19,"challengeFiles":[]}},"id":"/learn/b1-english-for-developers/learn-how-to-talk-about-past-experiences/dialogue-3-tech-conference-experience"}},"staticQueryHashes":["385