{"componentChunkName":"component---src-templates-challenges-classic-show-tsx","path":"/learn/javascript-v9/lab-missing-letter-detector/build-a-missing-letter-detector","result":{"data":{"challengeNode":{"challenge":{"block":"lab-missing-letter-detector","demoType":null,"title":"Izgradnja praćenja nedostajućeg slova","description":"<section id=\"description\">\n<p><strong>Cilj:</strong> Popunite korisničke priče navedene ispod i prođite sve testove da biste završili laboratoriju.</p>\n<p><strong>Priče korisnika:</strong></p>\n<ol>\n<li>Treba da postoji funkcija nazvana <code>fearNotLetter</code>.</li>\n<li>Funkcija za <code>fearNotLetter</code> treba da primi jedan argument: sekvencu karaktera koja predstavlja opseg slova u abecednom redosledu i koji može imati jedno nedostajuće slovo.</li>\n<li>Funkcija treba da pronađe nedostajuće slovo u poslatom opsegu slova i vrati ga.</li>\n<li>Ako su sva slova prisutna u opsegu, funkcija treba da vrati <code>undefined</code>.</li>\n</ol>\n</section>","id":"af7588ade1100bde429baf20","hasEditableBoundaries":false,"instructions":"","notes":null,"challengeType":26,"helpCategory":"JavaScript","videoUrl":null,"superBlock":"javascript-v9","translationPending":false,"forumTopicId":null,"hooks":null,"fields":{"slug":"/learn/javascript-v9/lab-missing-letter-detector/build-a-missing-letter-detector"},"required":[],"usesMultifileEditor":true,"challengeFiles":[{"fileKey":"scriptjs","ext":"js","name":"script","contents":"","head":null,"tail":null,"editableRegionBoundaries":[],"history":["script.js"]}],"saveSubmissionToDB":null,"tests":[{"text":"<p>Trebalo bi da imaš funkciju <code>fearNotLetter</code>.</p>","testString":"assert.isFunction(fearNotLetter);"},{"text":"<p><code>fearNotLetter(\"abce\")</code> trebalo bi da vrati niz znakova <code>d</code>.</p>","testString":"assert.deepEqual(fearNotLetter('abce'), 'd');"},{"text":"<p><code>fearNotLetter(\"abcdefghjklmno\")</code> mora vratiti sekvencu karaktera <code>i</code>.</p>","testString":"assert.deepEqual(fearNotLetter('abcdefghjklmno'), 'i');"},{"text":"<p><code>fearNotLetter(\"stvwx\")</code> trebalo bi da vrati sekvencu karaktera <code>u</code>.</p>","testString":"assert.deepEqual(fearNotLetter('stvwx'), 'u');"},{"text":"<p><code>fearNotLetter(\"bcdf\")</code> treba da vrati niz karaktera <code>e</code>.</p>","testString":"assert.deepEqual(fearNotLetter('bcdf'), 'e');"},{"text":"<p><code>fearNotLetter(\"abcdefghijklmnopqrstuvwxyz\")</code> trebalo bi da vrati <code>undefined</code>.</p>","testString":"assert.isUndefined(fearNotLetter('abcdefghijklmnopqrstuvwxyz'));"}]}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/javascript-v9/#lab-missing-letter-detector","dashedName":"build-a-missing-letter-detector","certification":"javascript-v9","disableLoopProtectTests":false,"disableLoopProtectPreview":false,"superBlock":"javascript-v9","chapter":"javascript","module":"javascript-loops","block":"lab-missing-letter-detector","isFirstStep":true,"template":null,"required":[],"isLastChallengeInBlock":true,"nextChallengePath":"/learn/javascript-v9/lab-smart-pantry-restocker/lab-smart-pantry-restocker","prevChallengePath":"/learn/javascript-v9/workshop-festival-crowd-flow-simulator/step-33","id":"af7588ade1100bde429baf20","saveSubmissionToDB":null},"projectPreview":{"challengeData":{"challengeType":26,"challengeFiles":[{"name":"script","ext":"js","contents":"function fearNotLetter (str) {\r\n  for (var i = str.charCodeAt(0); i <= str.charCodeAt(str.length - 1); i++) {\r\n    let letter = String.fromCharCode(i);\r\n    if (str.indexOf(letter) === -1) {\r\n      return letter;\r\n    }\r\n  }\r\n\r\n  return undefined;\r\n}","history":["script.js"],"fileKey":"scriptjs"}]}},"id":"/learn/javascript-v9/lab-missing-letter-detector/build-a-missing-letter-detector"}},"staticQueryHashes":["3858520367"],"slicesMap":{}}