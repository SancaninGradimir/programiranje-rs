{"componentChunkName":"component---src-templates-challenges-classic-show-tsx","path":"/learn/responsive-web-design/basic-css/prioritize-one-style-over-another","result":{"data":{"challengeNode":{"challenge":{"block":"basic-css","demoType":null,"title":"Daj Jednom Stilu Veci Prioritet od Drugog","description":"<section id=\"description\">\n<p>Ponekad ce vasi HTML elementi dobiti vise stilova koji su u konfliktu.</p>\n<p>Na primer, vas <code>h1</code> element ne moze istovremeno biti i zelen i roze.</p>\n<p>Pogledajmo sta se desava kada napravimo klasu koja boji tekst u roze i zatim je primenimo na element. Da li ce nasa klasa <em>pregaziti</em> <code>body</code> CSS svojstvo <code>color: green;</code>?</p>\n</section>","id":"bad87fee1348bd9aedf08756","hasEditableBoundaries":false,"instructions":"<section id=\"instructions\">\n<p>Napravite CSS klasu pod nazivom <code>pink-text</code> koja daje elementu roze boju.</p>\n<p>Dodelite svom <code>h1</code> elementu klasu <code>pink-text</code>.</p>\n</section>","notes":null,"challengeType":0,"helpCategory":"HTML-CSS","videoUrl":"https://scrimba.com/c/cZ8wnHv","superBlock":"responsive-web-design","translationPending":false,"forumTopicId":18258,"hooks":null,"fields":{"slug":"/learn/responsive-web-design/basic-css/prioritize-one-style-over-another"},"required":[],"usesMultifileEditor":false,"challengeFiles":[{"fileKey":"indexhtml","ext":"html","name":"index","contents":"<style>\n  body {\n    background-color: black;\n    font-family: monospace;\n    color: green;\n  }\n</style>\n<h1>Hello World!</h1>","head":null,"tail":null,"editableRegionBoundaries":[],"history":["index.html"]}],"saveSubmissionToDB":null,"tests":[{"text":"<p>Vas <code>h1</code> element treba da ima klasu <code>pink-text</code>.</p>","testString":"assert.isTrue(document.querySelector('h1').classList.contains('pink-text'));"},{"text":"<p>Vas <code>&#x3C;style></code> treba da ima CSS klasu <code>pink-text</code> koja menja <code>color</code>.</p>","testString":"assert.match(__helpers.removeCssComments(code), /\\.pink-text\\s*\\{\\s*color\\s*:\\s*.+\\s*;?\\s*\\}/g);"},{"text":"<p>Vas <code>h1</code> element treba da bude roze boje.</p>","testString":"const h1Element = document.querySelector('h1');\nconst color = window.getComputedStyle(h1Element)['color']; \nassert.strictEqual(color, 'rgb(255, 192, 203)');"}]}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/responsive-web-design/#basic-css","dashedName":"prioritize-one-style-over-another","certification":"responsive-web-design","disableLoopProtectTests":false,"disableLoopProtectPreview":false,"superBlock":"responsive-web-design","chapter":null,"module":null,"block":"basic-css","isFirstStep":false,"template":null,"required":[],"isLastChallengeInBlock":false,"nextChallengePath":"/learn/responsive-web-design/basic-css/override-styles-in-subsequent-css","prevChallengePath":"/learn/responsive-web-design/basic-css/inherit-styles-from-the-body-element","id":"bad87fee1348bd9aedf08756","saveSubmissionToDB":null},"projectPreview":{"challengeData":{"challengeType":0,"challengeFiles":[{"name":"index","ext":"html","contents":"<style>@media (max-width: 350px) {:root {--penguin-size: 200px; --penguin-skin: black;}}</style>","history":["index.html"],"fileKey":"indexhtml"}]}},"id":"/learn/responsive-web-design/basic-css/prioritize-one-style-over-another"}},"staticQueryHashes":["3858520367"],"slicesMap":{}}