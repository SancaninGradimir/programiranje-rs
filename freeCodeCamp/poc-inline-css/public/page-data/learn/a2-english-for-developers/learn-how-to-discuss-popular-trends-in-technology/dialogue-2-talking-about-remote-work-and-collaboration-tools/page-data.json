ition":null,"opacity":null,"startTime":8.8,"finishTime":11.9,"dialogue":{"text":"with tools like video conference apps and collaboration platforms.","align":"right"}},{"background":null,"character":"Alice","position":null,"opacity":null,"startTime":12.5,"finishTime":15.3,"dialogue":{"text":"They allow teams to work together, no matter where they are.","align":"right"}},{"background":null,"character":"Alice","position":null,"opacity":null,"startTime":15.7,"finishTime":17.8,"dialogue":{"text":"Video conferencing tools also made it possible","align":"right"}},{"background":null,"character":"Alice","position":null,"opacity":null,"startTime":17.8,"finishTime":20,"dialogue":{"text":"for teams to have face-to-face meetings online.","align":"right"}},{"background":null,"character":"Tom","position":null,"opacity":null,"startTime":20.8,"finishTime":22,"dialogue":{"text":"Do you think they're here to stay?","align":"left"}},{"background":null,"character":"Alice","position":null,"opacity":null,"startTime":23.2,"finishTime":24.1,"dialogue":{"text":"Absolutely, Tom.","align":"right"}},{"background":null,"character":"Alice","position":null,"opacity":null,"startTime":24.3,"finishTime":26.7,"dialogue":{"text":"Remote work is likely to remain a big part of our lives.","align":"right"}},{"background":null,"character":"Alice","position":null,"opacity":null,"startTime":27.1,"finishTime":29.2,"dialogue":{"text":"It offers flexibility and can help companies","align":"right"}},{"background":null,"character":"Alice","position":null,"opacity":null,"startTime":29.2,"finishTime":31.5,"dialogue":{"text":"gain access to talent from many parts of the world.","align":"right"}},{"background":null,"character":"Tom","position":null,"opacity":null,"startTime":32,"finishTime":34,"dialogue":{"text":"What other collaboration tools are there?","align":"left"}},{"background":null,"character":"Alice","position":null,"opacity":null,"startTime":34.5,"finishTime":36.4,"dialogue":{"text":"Well, there are project management tools.","align":"right"}},{"background":null,"character":"Alice","position":null,"opacity":null,"startTime":36.7,"finishTime":38.5,"dialogue":{"text":"They help teams to organize tasks.","align":"right"}},{"background":null,"character":"Alice","position":null,"opacity":null,"startTime":39,"finishTime":41.2,"dialogue":{"text":"Also, cloud storage services make it easy","align":"right"}},{"background":null,"character":"Alice","position":null,"opacity":null,"startTime":41.2,"finishTime":42.9,"dialogue":{"text":"to share and collaborate on documents.","align":"right"}},{"background":null,"character":"Alice","position":{"x":125,"y":0,"z":1},"opacity":null,"startTime":43.4,"finishTime":null,"dialogue":null},{"background":null,"character":"Tom","position":{"x":-25,"y":0,"z":1},"opacity":null,"startTime":43.9,"finishTime":null,"dialogue":null}]},"superBlock":"a2-english-for-developers","tests":[],"title":"Dijalog 2: O radu na daljinu i alatima za saradnju","transcript":null,"translationPending":false,"videoId":null,"videoLocaleIds":null}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/a2-english-for-developers/#learn-how-to-discuss-popular-trends-in-technology","dashedName":"dialogue-2-talking-about-remote-work-and-collaboration-tools","certification":"a2-english-for-developers","disableLoopProtectTests":false,"disableLoopProtectPreview":false,"superBlock":"a2-english-for-developers","chapter":null,"module":null,"block":"learn-how-to-discuss-popular-trends-in-technology","isFirstStep":false,"template":null,"required":[],"isLastChallengeInBlock":false,"nextChallengePath":"/learn/a2-english-for-developers/learn-how-to-discuss-popular-trends-in-technology/task-22","prevChallengePath":"/learn/a2-english-for-developers/learn-how-to-discuss-popular-trends-in-technology/task-21","id":"65fdc24bcb89e8162b96d954","saveSubmissionToDB":null},"projectPreview":{"challengeData":{"challengeType":22,"challengeFiles":[]}},"id":"/learn/a2-english-for-developers/learn-ho