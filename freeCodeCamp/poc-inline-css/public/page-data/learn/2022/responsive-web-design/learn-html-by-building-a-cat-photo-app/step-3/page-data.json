{"componentChunkName":"component---src-templates-challenges-classic-show-tsx","path":"/learn/2022/responsive-web-design/learn-html-by-building-a-cat-photo-app/step-3","result":{"data":{"challengeNode":{"challenge":{"block":"learn-html-by-building-a-cat-photo-app","demoType":null,"title":"Korak 3","description":"<section id=\"description\">\n<p>Element <code>p</code> se koristi za kreiranje tekstualnog pasusa na veb stranici. Kreirajte element <code>p</code> ispod vašeg elementa <code>h2</code> koristeći sledeći tekst:</p>\n<p><code>Everyone loves cute cats online!</code></p>\n</section>","id":"5dc17d3bf86c76b9248c6eb4","hasEditableBoundaries":true,"instructions":"","notes":null,"challengeType":0,"helpCategory":"HTML-CSS","videoUrl":null,"superBlock":"2022/responsive-web-design","translationPending":false,"forumTopicId":null,"hooks":null,"fields":{"slug":"/learn/2022/responsive-web-design/learn-html-by-building-a-cat-photo-app/step-3"},"required":[],"usesMultifileEditor":true,"challengeFiles":[{"fileKey":"indexhtml","ext":"html","name":"index","contents":"<html>\n  <body>\n    <h1>CatPhotoApp</h1>\n    <h2>Cat Photos</h2>\n    \n  </body>\n</html>","head":null,"tail":null,"editableRegionBoundaries":[3,6],"history":["index.html"]}],"saveSubmissionToDB":null,"tests":[{"text":"<p>Tvoj element <code>p</code> bi trebalo da ima oznaku otvaranja. Oznake otvaranja imaju sledeću sintaksu: <code>&#x3C;elementName></code>.</p>","testString":"assert(document.querySelector('p'));"},{"text":"<p>Tvoji etikete za <code>p</code> moraju biti u malim slovima. Po ugovoru, sve etikete za HTML se pišu malim slovima.</p>","testString":"assert.notMatch(code, /<\\/?P>/);"},{"text":"<p>Vaša komponenta za <code>p</code> bi trebalo da ima zatvarajući tag. Zatvarajući tagovi su <code>/</code> odmah nakon slova/karaktera <code>&#x3C;</code>.</p>","testString":"assert(code.match(/<\\/p\\>/));"},{"text":"<p>Tekst vašeg polja za <code>p</code> treba da bude <code>Everyone loves cute cats online!</code>. Ostavili ste tekst ili postoje greške u kucanju.</p>","testString":"const extraSpacesRemoved = document\n  .querySelector('p')\n  .innerText.replace(/\\s+/g, ' ');\nassert.match(extraSpacesRemoved, /everyone loves cute cats online!$/i);"},{"text":"<p>Vaš element za <code>p</code> treba da bude ispod elementa za <code>h2</code>. Postavili ste ga u pogrešan redosled.</p>","testString":"const collection = [...document.querySelectorAll('h2,p')].map(\n  (node) => node.nodeName\n);\nassert(collection.indexOf('H2') < collection.indexOf('P'));"}]}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/2022/responsive-web-design/#learn-html-by-building-a-cat-photo-app","dashedName":"step-3","certification":"responsive-web-design","disableLoopProtectTests":false,"disableLoopProtectPreview":false,"superBlock":"2022/responsive-web-design","chapter":null,"module":null,"block":"learn-html-by-building-a-cat-photo-app","isFirstStep":false,"template":null,"required":[],"isLastChallengeInBlock":false,"nextChallengePath":"/learn/2022/responsive-web-design/learn-html-by-building-a-cat-photo-app/step-4","prevChallengePath":"/learn/2022/responsive-web-design/learn-html-by-building-a-cat-photo-app/step-2","id":"5dc17d3bf86c76b9248c6eb4","saveSubmissionToDB":null},"projectPreview":{"challengeData":{"challengeType":0,"challengeFiles":[{"name":"index","ext":"html","contents":"<!DOCTYPE html>\n<html lang=\"en\">\n  <head>\n    <meta charset=\"UTF-8\">\n    <title>CatPhotoApp</title>\n  </head>\n  <body>\n    <main>\n      <h1>CatPhotoApp</h1>\n      <section>\n        <h2>Cat Photos</h2>\n        <p>Everyone loves <a href=\"https://cdn.freecodecamp.org/curriculum/cat-photo-app/running-cats.jpg\">cute cats</a> online!</p>\n        <p>See more <a target=\"_blank\" href=\"https://freecatphotoapp.com\">cat photos</a> in our gallery.</p>\n        <a href=\"https://freecatphotoapp.com\"><img src=\"https://cdn.freecodecamp.org/curriculum/cat-photo-app/relaxing-cat.jpg\" alt=\"A cute orange cat lying on its back.\"></a>\n      </section>\n      <section>\n        <h2>Cat Lists</h2>\n        <h3>Things cats love:</h3>\n        <ul>\n          <li>catnip</li>\n          <li>laser pointers</li>\n          <li>lasagna</li>\n        </ul>\n        <figure>\n          <img src=\"https://cdn.freecodecamp.org/curriculum/cat-photo-app/lasagna.jpg\" alt=\"A slice of lasagna on a plate.\">\n          <figcaption>Cats <em>love</em> lasagna.</figcaption>  \n        </figure>\n        <h3>Top 3 things cats hate:</h3>\n        <ol>\n          <li>flea treatment</li>\n          <li>thunder</li>\n          <li>other cats</li>\n        </ol>\n        <figure>\n          <img src=\"https://cdn.freecodecamp.org/curriculum/cat-photo-app/cats.jpg\" alt=\"Two tabby kittens sleeping together on a couch.\">\n          <figcaption>Cats <strong>hate</strong> other cats.</figcaption>  \n        </figure>\n      </section>\n      <section>\n        <h2>Cat Form</h2>\n        <form action=\"https://freecatphotoapp.com/submit-cat-photo\">\n          <fieldset>\n            <legend>Is your cat an indoor or outdoor cat?</legend>\n            <label><input id=\"indoor\" type=\"radio\" name=\"indoor-outdoor\" value=\"indoor\" checked> Indoor</label>\n            <label><input id=\"outdoor\" type=\"radio\" name=\"indoor-outdoor\" value=\"outdoor\"> Outdoor</label>\n          </fieldset>\n          <fieldset>\n            <legend>What's your cat's personality?</legend>\n            <label for=\"loving\"><input id=\"loving\" type=\"checkbox\" name=\"personality\" value=\"loving\" checked> Loving</label>\n            <label for=\"lazy\"><input id=\"lazy\" type=\"checkbox\" name=\"personality\" value=\"lazy\"> Lazy</label>\n            <label for=\"energetic\"><input id=\"energetic\" type=\"checkbox\" name=\"personality\" value=\"energetic\"> Energetic</label>\n          </fieldset>\n          <input type=\"text\" name=\"catphotourl\" placeholder=\"cat photo URL\" required>\n          <button type=\"submit\">Submit</button>\n        </form>\n      </section>\n    </main>\n    <footer>\n      <p>\n        No Copyright - <a href=\"https://www.freecodecamp.org\">freeCodeCamp.org</a>\n      </p>\n    </footer>\n  </body>\n</html>","history":["index.html"],"fileKey":"indexhtml"}]}},"id":"/learn/2022/responsive-web-design/learn-html-by-building-a-cat-photo-app/step-3"}},"staticQueryHashes":["3858520367"],"slicesMap":{}}