{"componentChunkName":"component---src-templates-challenges-classic-show-tsx","path":"/learn/javascript-fundamentals-review/lab-largest-number-finder/build-the-largest-number-finder","result":{"data":{"challengeNode":{"challenge":{"block":"lab-largest-number-finder","demoType":null,"title":"Ko dobije najveći broj","description":"<section id=\"description\">\n<p>U ovoj laboratoriji, kreiraćeš funkciju koja vraća niz podataka koji sadrži najveći broj iz svakog datoj podnizu.</p>\n<p>Zapamtite, možete iterirati kroz niz podataka koristeći jednostavnu petlju za <code>for</code>, i dohvatiti svaki član sa sintaksom niza podataka <code>arr[i]</code>.</p>\n<p><strong>Cilj:</strong> Popunite korisničke priče ispod i prođite sve testove kako biste završili ovaj laboratorijski rad.</p>\n<p><strong>Priče korisnika:</strong></p>\n<ol>\n<li>Treba da kreirate funkciju <code>largestOfAll</code> koja prima niz niza podataka kao argumente.</li>\n<li>Funkcija treba da vrati niz podataka koji sadrži najveći broj iz svakog unutrašnjeg niza.</li>\n</ol>\n</section>","id":"a789b3483989747d63b0e427","hasEditableBoundaries":false,"instructions":"","notes":null,"challengeType":26,"helpCategory":"JavaScript","videoUrl":null,"superBlock":"javascript-fundamentals-review","translationPending":false,"forumTopicId":null,"hooks":null,"fields":{"slug":"/learn/javascript-fundamentals-review/lab-largest-number-finder/build-the-largest-number-finder"},"required":[],"usesMultifileEditor":true,"challengeFiles":[{"fileKey":"scriptjs","ext":"js","name":"script","contents":"","head":null,"tail":null,"editableRegionBoundaries":[],"history":["script.js"]}],"saveSubmissionToDB":null,"tests":[{"text":"<p>Treba da kreiraš funkciju koja se zove <code>largestOfAll</code>.</p>","testString":"assert.isFunction(largestOfAll);"},{"text":"<p><code>largestOfAll</code> trebalo bi da primi jedan parametar.</p>","testString":"assert.lengthOf(largestOfAll, 1);"},{"text":"<p><code>largestOfAll([[4, 5, 1, 3], [13, 27, 18, 26], [32, 35, 37, 39], [1000, 1001, 857, 1]])</code> Trebalo bi da vrati red podataka.</p>","testString":"assert.isArray(\r\n  largestOfAll([\r\n    [4, 5, 1, 3],\r\n    [13, 27, 18, 26],\r\n    [32, 35, 37, 39],\r\n    [1000, 1001, 857, 1]\r\n  ])\r\n);"},{"text":"<p><code>largestOfAll([[13, 27, 18, 26], [4, 5, 1, 3], [32, 35, 37, 39], [1000, 1001, 857, 1]])</code> treba da vrati <code>[27, 5, 39, 1001]</code>.</p>","testString":"assert.deepEqual(\r\n  largestOfAll([\r\n    [13, 27, 18, 26],\r\n    [4, 5, 1, 3],\r\n    [32, 35, 37, 39],\r\n    [1000, 1001, 857, 1]\r\n  ]),\r\n  [27, 5, 39, 1001]\r\n);"},{"text":"<p><code>largestOfAll([[4, 9, 1, 3], [13, 35, 18, 26], [32, 35, 97, 39], [1000000, 1001, 857, 1]])</code> trebalo bi da vrati <code>[9, 35, 97, 1000000]</code>.</p>","testString":"assert.deepEqual(\r\n  largestOfAll([\r\n    [4, 9, 1, 3],\r\n    [13, 35, 18, 26],\r\n    [32, 35, 97, 39],\r\n    [1000000, 1001, 857, 1]\r\n  ]),\r\n  [9, 35, 97, 1000000]\r\n);"},{"text":"<p><code>largestOfAll([[17, 23, 25, 12], [25, 7, 34, 48], [4, -10, 18, 21], [-72, -3, -17, -10]])</code> trebalo bi da vrati <code>[25, 48, 21, -3]</code>.</p>","testString":"assert.deepEqual(\r\n  largestOfAll([\r\n    [17, 23, 25, 12],\r\n    [25, 7, 34, 48],\r\n    [4, -10, 18, 21],\r\n    [-72, -3, -17, -10]\r\n  ]),\r\n  [25, 48, 21, -3]\r\n);"}]}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/javascript-fundamentals-review/#lab-largest-number-finder","dashedName":"build-the-largest-number-finder","certification":"javascript-fundamentals-review","disableLoopProtectTests":false,"disableLoopProtectPreview":false,"superBlock":"javascript-fundamentals-review","chapter":null,"module":null,"block":"lab-largest-number-finder","isFirstStep":true,"template":null,"required":[],"isLastChallengeInBlock":true,"nextChallengePath":"/learn/javascript-fundamentals-review/lab-first-element-finder/build-a-first-element-finder","prevChallengePath":"/learn/javascript-fundamentals-review/lab-reverse-a-string/build-a-string-inverter","id":"a789b3483989747d63b0e427","saveSubmissionToDB":null},"projectPreview":{"challengeData":{"challengeType":26,"challengeFiles":[{"name":"script","ext":"js","contents":"function largestOfAll(arr) {\r\n  return arr.map(subArr => Math.max.apply(null, subArr));\r\n}\r\n\r\nlargestOfAll([\r\n  [4, 5, 1, 3],\r\n  [13, 27, 18, 26],\r\n  [32, 35, 37, 39],\r\n  [1000, 1001, 857, 1]\r\n]);","history":["script.js"],"fileKey":"scriptjs"}]}},"id":"/learn/javascript-fundamentals-review/lab-largest-number-finder/build-the-largest-number-finder"}},"staticQueryHashes":["3858520367"],"slicesMap":{}}