{"componentChunkName":"component---src-templates-challenges-classic-show-tsx","path":"/learn/front-end-development-libraries/jquery/use-appendto-to-move-elements-with-jquery","result":{"data":{"challengeNode":{"challenge":{"block":"jquery","demoType":null,"title":"Koristite `appendTo` za premeštanje elemenata sa jQuery-ja","description":"<section id=\"description\">\n<p>Sada hajde da pokušamo da prebacimo elemente iz <code>div</code> u drugi.</p>\n<p>jQuery ima funkciju nazvanu <code>appendTo()</code> koja vam omogućava da izaberete elemente HTML i dodelite ih drugom elementu.</p>\n<p>Na primer, ako bismo hteli da prebacimo <code>target4</code> iz desne kolone u levu kolonu, koristili bismo:</p>\n<pre><code class=\"language-js\">$(\"#target4\").appendTo(\"#left-well\");\n</code></pre>\n<p>Premesti svoj element <code>target2</code> iz <code>left-well</code> u <code>right-well</code>.</p>\n</section>","id":"bad87fee1348bd9aed608826","hasEditableBoundaries":false,"instructions":"","notes":null,"challengeType":6,"helpCategory":"JavaScript","videoUrl":null,"superBlock":"front-end-development-libraries","translationPending":false,"forumTopicId":18340,"hooks":null,"fields":{"slug":"/learn/front-end-development-libraries/jquery/use-appendto-to-move-elements-with-jquery"},"required":[{"link":"https://cdnjs.cloudflare.com/ajax/libs/twitter-bootstrap/3.3.7/css/bootstrap.css","src":null},{"link":null,"src":"https://code.jquery.com/jquery-3.6.0.min.js"}],"usesMultifileEditor":false,"challengeFiles":[{"fileKey":"indexhtml","ext":"html","name":"index","contents":"<script>\r\n  $(document).ready(function() {\r\n    $(\"#target1\").css(\"color\", \"red\");\r\n    $(\"#target1\").prop(\"disabled\", true);\r\n    $(\"#target4\").remove();\r\n\r\n  });\r\n</script>\r\n\r\n<!-- Only change code above this line -->\r\n\r\n<div class=\"container-fluid\">\r\n  <h3 class=\"text-primary text-center\">jQuery Playground</h3>\r\n  <div class=\"row\">\r\n    <div class=\"col-xs-6\">\r\n      <h4>#left-well</h4>\r\n      <div class=\"well\" id=\"left-well\">\r\n        <button class=\"btn btn-default target\" id=\"target1\">#target1</button>\r\n        <button class=\"btn btn-default target\" id=\"target2\">#target2</button>\r\n        <button class=\"btn btn-default target\" id=\"target3\">#target3</button>\r\n      </div>\r\n    </div>\r\n    <div class=\"col-xs-6\">\r\n      <h4>#right-well</h4>\r\n      <div class=\"well\" id=\"right-well\">\r\n        <button class=\"btn btn-default target\" id=\"target4\">#target4</button>\r\n        <button class=\"btn btn-default target\" id=\"target5\">#target5</button>\r\n        <button class=\"btn btn-default target\" id=\"target6\">#target6</button>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</div>","head":null,"tail":null,"editableRegionBoundaries":[],"history":["index.html"]}],"saveSubmissionToDB":null,"tests":[{"text":"<p>Tvoj element <code>target2</code> ne sme biti unutar <code>left-well</code>.</p>","testString":"assert($('#left-well').children('#target2').length === 0);"},{"text":"<p>Vaša komponenta za <code>target2</code> mora biti unutar <code>right-well</code>.</p>","testString":"assert($('#right-well').children('#target2').length > 0);"},{"text":"<p>Trebalo bi da koristiš jQuery samo za premeštanje ovih elemenata.</p>","testString":"assert(!code.match(/class.*animated/g));"}]}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/front-end-development-libraries/#jquery","dashedName":"use-appendto-to-move-elements-with-jquery","certification":"front-end-development-libraries","disableLoopProtectTests":false,"disableLoopProtectPreview":false,"superBlock":"front-end-development-libraries","chapter":null,"module":null,"block":"jquery","isFirstStep":false,"template":null,"required":[{"link":"https://cdnjs.cloudflare.com/ajax/libs/twitter-bootstrap/3.3.7/css/bootstrap.css","src":null},{"link":null,"src":"https://code.jquery.com/jquery-3.6.0.min.js"}],"isLastChallengeInBlock":false,"nextChallengePath":"/learn/front-end-development-libraries/jquery/clone-an-element-using-jquery","prevChallengePath":"/learn/front-end-development-libraries/jquery/remove-an-element-using-jquery","id":"bad87fee1348bd9aed608826","saveSubmissionToDB":null},"projectPreview":{"challengeData":{"challengeType":6,"challengeFiles":[{"name":"index","ext":"html","contents":"<script>\r\n  $(document).ready(function() {\r\n    $(\"#target1\").css(\"color\", \"red\");\r\n    $(\"#target1\").prop(\"disabled\", true);\r\n    $(\"#target4\").remove();\r\n    $(\"#target2\").appendTo(\"#right-well\");\r\n    $(\"#target5\").clone().appendTo(\"#left-well\");\r\n    $(\"#target1\").parent().css(\"background-color\", \"red\");\r\n    $(\"#right-well\").children().css(\"color\", \"orange\");\r\n    $(\"#left-well\").children().css(\"color\", \"green\");\r\n    $(\".target:nth-child(2)\").addClass(\"animated bounce\");\r\n    $(\".target:even\").addClass(\"animated shake\");\r\n    $(\"body\").addClass(\"animated hinge\");\r\n  });\r\n</script>\r\n\r\n<!-- Only change code above this line -->\r\n\r\n<div class=\"container-fluid\">\r\n  <h3 class=\"text-primary text-center\">jQuery Playground</h3>\r\n  <div class=\"row\">\r\n    <div class=\"col-xs-6\">\r\n      <h4>#left-well</h4>\r\n      <div class=\"well\" id=\"left-well\">\r\n        <button class=\"btn btn-default target\" id=\"target1\">#target1</button>\r\n        <button class=\"btn btn-default target\" id=\"target2\">#target2</button>\r\n        <button class=\"btn btn-default target\" id=\"target3\">#target3</button>\r\n      </div>\r\n    </div>\r\n    <div class=\"col-xs-6\">\r\n      <h4>#right-well</h4>\r\n      <div class=\"well\" id=\"right-well\">\r\n        <button class=\"btn btn-default target\" id=\"target4\">#target4</button>\r\n        <button class=\"btn btn-default target\" id=\"target5\">#target5</button>\r\n        <button class=\"btn btn-default target\" id=\"target6\">#target6</button>\r\n      </div>\r\n    </div>\r\n  </div>