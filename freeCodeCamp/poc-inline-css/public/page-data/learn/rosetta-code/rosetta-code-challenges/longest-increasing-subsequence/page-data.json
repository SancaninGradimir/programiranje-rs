{"componentChunkName":"component---src-templates-challenges-classic-show-tsx","path":"/learn/rosetta-code/rosetta-code-challenges/longest-increasing-subsequence","result":{"data":{"challengeNode":{"challenge":{"block":"rosetta-code-challenges","demoType":null,"title":"Mfululizo mdogo mrefu unaoongezeka","description":"<section id=\"description\">\n<p>Zadatak pronalaženja najdužeg rastućeg podniza sastoji se u pronalaženju podniza datog niza čiji su elementi poređani u rastućem redosledu, od manjeg ka većem, pri čemu taj podniz treba da bude što duži. Na primer:</p>\n<p>Za sledeći red podataka:</p>\n<pre><code class=\"language-js\">const array = [3, 10, 2, 1, 20];\n</code></pre>\n<p>Mfululizo mrefu unaoongezeka ni:</p>\n<p>$\\{3, 10, 20\\}$</p>\n</section>","id":"5e6dd139859c290b6ab80292","hasEditableBoundaries":false,"instructions":"<section id=\"instructions\">\n<p>Napiši funkciju koja prihvata niz brojeva kao argument i vraća najduži rastući podniz.</p>\n<p>Garantovano je da će svaki testni niz imati najduži rastući podniz.</p>\n</section>","notes":null,"challengeType":1,"helpCategory":"Rosetta","videoUrl":null,"superBlock":"rosetta-code","translationPending":false,"forumTopicId":385272,"hooks":null,"fields":{"slug":"/learn/rosetta-code/rosetta-code-challenges/longest-increasing-subsequence"},"required":[],"usesMultifileEditor":false,"challengeFiles":[{"fileKey":"scriptjs","ext":"js","name":"script","contents":"function findSequence(input) {\n\n}","head":null,"tail":null,"editableRegionBoundaries":[],"history":["script.js"]}],"saveSubmissionToDB":null,"tests":[{"text":"<p><code>findSequence</code> treba da bude funkcija.</p>","testString":"assert(typeof findSequence == 'function');"},{"text":"<p><code>findSequence([3, 10, 2, 1, 20])</code> treba da vrati niz.</p>","testString":"assert(Array.isArray(findSequence([3, 10, 2, 1, 20])));"},{"text":"<p><code>findSequence([3, 10, 2, 1, 20])</code> inapaswa kurudisha <code>[3, 10, 20]</code>.</p>","testString":"assert.deepEqual(findSequence([3, 10, 2, 1, 20]), [3, 10, 20]);"},{"text":"<p><code>findSequence([2, 7, 3, 5, 8])</code> inapaswa kurudisha <code>[2, 3, 5, 8]</code>.</p>","testString":"assert.deepEqual(findSequence([2, 7, 3, 5, 8]), [2, 3, 5, 8]);"},{"text":"<p><code>findSequence([2, 6, 4, 5, 1])</code> inapaswa kurudisha <code>[2, 4, 5]</code>.</p>","testString":"assert.deepEqual(findSequence([2, 6, 4, 5, 1]), [2, 4, 5]);"},{"text":"<p><code>findSequence([10, 22, 9, 33, 21, 50, 60, 80])</code> inapaswa kurudisha <code>[10, 22, 33, 50, 60, 80]</code>.</p>","testString":"assert.deepEqual(findSequence([10, 22, 9, 33, 21, 50, 60, 80]), [\n  10,\n  22,\n  33,\n  50,\n  60,\n  80\n]);"},{"text":"<p><code>findSequence([0, 12, 2, 10, 6, 14, 1, 9, 5, 13, 3, 11, 7, 15])</code> treba da vrati <code>[0, 2, 6, 9, 11, 15</code>.</p>","testString":"assert.deepEqual(\n  findSequence([0, 12, 2, 10, 6, 14, 1, 9, 5, 13, 3, 11, 7, 15]),\n  [0, 2, 6, 9, 11, 15]\n);"}]}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/rosetta-code/#rosetta-code-challenges","dashedName":"longest-increasing-subsequence","certification":"rosetta-code","disableLoopProtectTests":true,"disableLoopProtectPreview":false,"superBlock":"rosetta-code","chapter":null,"module":null,"block":"rosetta-code-challenges","isFirstStep":false,"template":null,"required":[],"isLastChallengeInBlock":false,"nextChallengePath":"/learn/rosetta-code/rosetta-code-challenges/longest-string-challenge","prevChallengePath":"/learn/rosetta-code/rosetta-code-challenges/longest-common-subsequence","id":"5e6dd139859c290b6ab80292","saveSubmissionToDB":null},"projectPreview":{"challengeData":{"challengeType":1,"challengeFiles":[{"name":"script","ext":"js","contents":"function ZigZagMatrix(n) {\n  const mtx = [];\n  for (let i = 0; i < n; i++) {\n    mtx[i] = [];\n  }\n\n  let i = 1;\n  let j = 1;\n  for (let e = 0; e < n * n; e++) {\n    mtx[i - 1][j - 1] = e;\n    if ((i + j) % 2 === 0) {\n      // Even stripes\n      if (j < n) j++;\n      else i += 2;\n      if (i > 1) i--;\n    } else {\n      // Odd stripes\n      if (i < n) i++;\n      else j += 2;\n      if (j > 1) j--;\n    }\n  }\n  return mtx;\n}","history":["script.js"],"fileKey":"scriptjs"}]}},"id":"/learn/rosetta-code/rosetta-code-challenges/longest-increasing-subsequence"}},"staticQueryHashes":["3858520367"],"slicesMap":{}}