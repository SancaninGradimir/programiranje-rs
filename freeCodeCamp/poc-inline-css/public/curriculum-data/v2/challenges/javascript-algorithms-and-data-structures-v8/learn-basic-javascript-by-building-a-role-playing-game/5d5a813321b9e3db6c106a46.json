    {
      "text": "<p>Vaš kod mora imati karakteristiku <code>title</code>.</p>",
      "testString": "const title = document.querySelector('title');\nassert.exists(title);"
    },
    {
      "text": "<p>Trebalo bi da imaš oznaku za zatvaranje <code>title</code>.</p>",
