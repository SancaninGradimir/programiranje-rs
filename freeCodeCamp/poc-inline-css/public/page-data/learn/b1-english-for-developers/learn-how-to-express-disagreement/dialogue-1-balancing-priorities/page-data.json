{"componentChunkName":"component---src-templates-challenges-generic-show-tsx","path":"/learn/b1-english-for-developers/learn-how-to-express-disagreement/dialogue-1-balancing-priorities","result":{"data":{"challengeNode":{"challenge":{"assignments":["<p>Gledaj video.</p>"],"bilibiliIds":null,"block":"learn-how-to-express-disagreement","challengeType":21,"description":"<section id=\"description\">\n<p>Pogledajte video ispod da biste razumeli kontekst sledećih lekcija.</p>\n</section>","nodules":null,"explanation":null,"helpCategory":"English","instructions":"","fields":{"slug":"/learn/b1-english-for-developers/learn-how-to-express-disagreement/dialogue-1-balancing-priorities"},"questions":[],"scene":{"setup":{"background":"company1-boardroom.png","characters":[{"character":"Bob","position":{"x":-25,"y":0,"z":1},"opacity":null},{"character":"Anna","position":{"x":125,"y":0,"z":1},"opacity":null}],"audio":{"filename":"B1_11-1.mp3","startTime":1,"startTimestamp":null,"finishTimestamp":null},"alwaysShowDialogue":true},"commands":[{"background":null,"character":"Bob","position":{"x":25,"y":0,"z":1},"opacity":null,"startTime":0,"finishTime":null,"dialogue":null},{"background":null,"character":"Anna","position":{"x":70,"y":0,"z":1},"opacity":null,"startTime":0.5,"finishTime":null,"dialogue":null},{"background":null,"character":"Bob","position":null,"opacity":null,"startTime":1,"finishTime":5.16,"dialogue":{"text":"Anna, I've been reviewing the survey results for the remote work stipend.","align":"left"}},{"background":null,"character":"Bob","position":null,"opacity":null,"startTime":5.46,"finishTime":11.04,"dialogue":{"text":"It seems most people prefer using it for office furniture. Do you think that's a good idea?","align":"left"}},{"background":null,"character":"Anna","position":null,"opacity":null,"startTime":11.86,"finishTime":16.8,"dialogue":{"text":"I don't think so, Bob. While furniture is important, many people mentioned that their computers need upgrades.","align":"right"}},{"background":null,"character":"Anna","position":null,"opacity":null,"startTime":17.2,"finishTime":19.1,"dialogue":{"text":"This might be more critical for productivity.","align":"right"}},{"background":null,"character":"Bob","position":null,"opacity":null,"startTime":19.9,"finishTime":22.78,"dialogue":{"text":"I understand, but isn't office furniture also a priority?","align":"left"}},{"background":null,"character":"Bob","position":null,"opacity":null,"startTime":23.2,"finishTime":27.26,"dialogue":{"text":"I mean, a lot of people are working from home with makeshift setups.","align":"left"}},{"background":null,"character":"Bob","position":null,"opacity":null,"startTime":27.86,"finishTime":31.5,"dialogue":{"text":"A comfortable desk and a chair can make a big difference.","align":"left"}},{"background":null,"character":"Anna","position":null,"opacity":null,"startTime":32.16,"finishTime":36.46,"dialogue":{"text":"Not necessarily. Having the latest technology can be just as important.","align":"right"}},{"background":null,"character":"Anna","position":null,"opacity":null,"startTime":36.98,"finishTime":40.68,"dialogue":{"text":"If people are working with outdated computers, it can be a setback for productivity.","align":"right"}},{"background":null,"character":"Bob","position":null,"opacity":null,"startTime":41.3,"finishTime":44.52,"dialogue":{"text":"True, but good office furniture can prevent health issues","align":"left"}},{"background":null,"character":"Bob","position":null,"opacity":null,"startTime":44.52,"finishTime":48.34,"dialogue":{"text":"that result from bad posture and make remote work more enjoyable.","align":"left"}},{"background":null,"character":"Anna","position":null,"opacity":null,"startTime":49.04,"finishTime":52.1,"dialogue":{"text":"I agree that comfort is important, but we shouldn't neglect technology.","align":"right"}},{"background":null,"character":"Bob","position":null,"opacity":null,"startTime":53,"finishTime":54.54,"dialogue":{"text":"So maybe we should focus on both.","align":"left"}},{"background":null,"character":"Bob","position":null,"opacity":null,"startTime":54.54,"finishTime":59.24,"dialogue":{"text":"Find a balance between comfort and technology to ensure everyone has what they need.","align":"left"}},{"background":null,"character":"Anna","position":null,"opacity":null,"startTime":59.84,"finishTime":64.52,"dialogue":{"text":"That makes sense. Let's see how we can adjust the stipend to cover both technology and office furniture.","align":"right"}},{"background":null,"character":"Bob","position":null,"opacity":null,"startTime":64.94,"finishTime":67.64,"dialogue":{"text":"Good plan. Thanks for discussing this with me, Anna.","align":"left"}},{"background":null,"character":"Anna","position":null,"opacity":null,"startTime":68.08,"finishTime":69.74,"dialogue":{"text":"No problem, Bob. Let's work on the details.","align":"right"}},{"background":null,"character":"Anna","position":{"x":125,"y":0,"z":1},"opacity":null,"startTime":70.24,"finishTime":null,"dialogue":null},{"background":null,"character":"Bob","position":{"x":-25,"y":0,"z":1},"opacity":null,"startTime":70.74,"finishTime":null,"dialogue":null}]},"superBlock":"b1-english-for-developers","tests":[],"title":"Dijalog 1: Balansiranje prioriteta","transcript":null,"translationPending":false,"videoId":null,"videoLocaleIds":null}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/b1-english-for-developers/#learn-how-to-express-disagreement","dashedName":"dialogue-1-balancing-priorities","certification":"b1-english-for-developers","disableLoopProtectTests":false,"disableLoopProtectPreview":false,"superBlock":"b1-english-for-developers","chapter":null,"module":null,"block":"learn-how-to-express-disagreement","isFirstStep":true,"template":null,"required":[],"isLastChallengeInBlock":false,"nextChallengePath":"/learn/b1-english-for-developers/learn-how-to-express-disagreement/task-1","prevChallengePath":"/learn/b1-english-for-developers/e