  "tests": [
    {
      "text": "<p>Trebalo bi da imaš funkciju <code>uniteUnique</code>.</p>",
      "testString": "assert.isFunction(uniteUnique);"
    },
    {
      "text": "<p><code>uniteUnique([1, 3, 2], [5, 2, 1, 4], [2, 1])</code> trebalo bi da vrati <code>[1, 3, 2, 5, 4]</code>.</p>",
      "testString": "assert.deepEqual(uniteUnique([1, 3, 2], [5, 2, 1, 4], [2, 1]), [1, 3, 2, 5, 4]);"
    },
    {
      "text": "<p><code>uniteUnique([1, 2, 3], [5, 2, 1])</code> trebalo bi da vrati <code>[1, 2, 3, 5]</code>.</p>",
