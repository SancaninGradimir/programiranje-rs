    {
      "text": "<p>Trebalo bi da imaš parametar nazvan <code>userRoles</code>.</p>",
      "testString": "assert.isDefined(userRoles);"
    },
    {
      "text": "<p>Vaš parametar <code>userRoles</code> treba da bude nešto.</p>",
      "testString": "assert.isObject(userRoles);"
