:[{"name":"script","ext":"js","contents":"function rangeOfNumbers(startNum, endNum) {\n  if (endNum - startNum === 0) {\n    return [startNum];\n  } else {\n    const numbers = rangeOfNumbers(startNum, endNum - 1);\n    numbers.push(endNum);\n    return numbers;\n  }\n}","history":["script.js"],"fileKey":"scriptjs"}]}},"id":"/learn/javascript-algorithms-and-data-structures/basic-javascript/comparison-with-the-greater-than-operator"}},"staticQueryHashes":["3858520367"],"slicesMap":{}}