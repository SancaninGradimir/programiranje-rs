{"componentChunkName":"component---src-templates-challenges-classic-show-tsx","path":"/learn/responsive-web-design-v9/workshop-hotel-feedback-form/step-1","result":{"data":{"challengeNode":{"challenge":{"block":"workshop-hotel-feedback-form","demoType":"onLoad","title":"Korak 1","description":"<section id=\"description\">\n<p>U ovoj radionici, veštaćete se sa radom sa HTML formularima kreiranjem obrasca za povratne informacije o hotelu.</p>\n<p>Za uvodni tekst, želite da prikažete glavni naslov praćen kratkom napomenom o ostavljanju povratnih informacija.</p>\n<p>Unutar vašeg <code>body</code> elementa, dodajte <code>header</code> element.</p>\n<p>Unutar <code>header</code> elementa, dodajte <code>h1</code> element. Tekst <code>h1</code> elementa treba da bude <code>Hotel Feedback Form</code>.</p>\n<p>Ispod vašeg <code>h1</code> elementa, dodajte <code>p</code> element. Tekst <code>p</code> elementa treba da bude <code>Thank you for staying with us. Please provide feedback on your recent stay.</code></p>\n</section>","id":"66a83601cd819e37f0dccd14","hasEditableBoundaries":true,"instructions":"","notes":null,"challengeType":0,"helpCategory":"HTML-CSS","videoUrl":null,"superBlock":"responsive-web-design-v9","translationPending":false,"forumTopicId":null,"hooks":null,"fields":{"slug":"/learn/responsive-web-design-v9/workshop-hotel-feedback-form/step-1"},"required":[],"usesMultifileEditor":true,"challengeFiles":[{"fileKey":"indexhtml","ext":"html","name":"index","contents":"<!DOCTYPE html>\n<html lang=\"en\">\n  <head>\n    <meta charset=\"UTF-8\" />\n    <title>Hotel Feedback Form</title>\n  </head>\n  <body>\n    \n  </body>\n</html>","head":null,"tail":null,"editableRegionBoundaries":[7,9],"history":["index.html"]}],"saveSubmissionToDB":null,"tests":[{"text":"<p>You should have an opening <code>header</code> tag.</p>","testString":"assert.match(code, /<header>/i);"},{"text":"<p>You should have a closing <code>header</code> tag.</p>","testString":"assert.match(code, /<\\/header>/i);"},{"text":"<p>You should have an opening <code>h1</code> tag.</p>","testString":"assert.match(code, /<h1>/i);"},{"text":"<p>You should have a closing <code>h1</code> tag.</p>","testString":"assert.match(code, /<\\/h1>/i);"},{"text":"<p>Your <code>h1</code> element should have the text <code>Hotel Feedback Form</code>.</p>","testString":"const h1 = document.querySelector('h1');\nassert.strictEqual(h1?.innerText.trim(), 'Hotel Feedback Form');"},{"text":"<p>Your <code>h1</code> element should be inside the <code>header</code> element.</p>","testString":"const h1 = document.querySelector('h1');\nassert.strictEqual(h1?.parentElement.tagName, 'HEADER');"},{"text":"<p>You should have an opening <code>p</code> tag.</p>","testString":"assert.match(code, /<p>/i);"},{"text":"<p>You should have a closing <code>p</code> tag.</p>","testString":"assert.match(code, /<\\/p>/i);"},{"text":"<p>Your paragraph element should have the text <code>Thank you for staying with us. Please provide feedback on your recent stay.</code></p>","testString":"const pElement = document.querySelector('header p');\nassert.strictEqual(pElement?.innerText.trim(), 'Thank you for staying with us. Please provide feedback on your recent stay.');"},{"text":"<p>Your paragraph element should be inside your <code>header</code>.</p>","testString":"const pElement = document.querySelector('p');\nassert.strictEqual(pElement?.parentElement.tagName, 'HEADER');"},{"text":"<p>Your paragraph element should come after your <code>h1</code>.</p>","testString":"const pElement = document.querySelector('p');\nassert.strictEqual(pElement?.previousElementSibling.tagName, 'H1');"}]}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/responsive-web-design-v9/#workshop-hotel-feedback-form","dashedName":"step-1","certification":"responsive-web-design-v9","disableLoopProtectTests":false,"disableLoopProtectPreview":false,"superBlock":"responsive-web-design-v9","chapter":"html","module":"html-forms-and-tables","block":"workshop-hotel-feedback-form","isFirstStep":true,"template":null,"required":[],"isLastChallengeInBlock":false,"nextChallengePath":"/learn/responsive-web-design-v9/workshop-hotel-feedback-form/step-2","prevChallengePath":"/learn/responsive-web-design-v9/lecture-working-with-forms/what-are-the-different-form-states","id":"66a83601cd819e37f0dccd14","saveSubmissionToDB":null},"projectPreview":{"challengeData":{"challengeType":0,"challengeFiles":[{"name":"index","ext":"html","contents":"<!DOCTYPE html>\n<html lang=\"en\">\n  <head>\n    <meta charset=\"UTF-8\" />\n    <title>Hotel Feedback Form</title>\n  </head>\n  <body>\n    <header>\n      <h1>Hotel Feedback Form</h1>\n      <p>\n        Thank you for staying with us. Please provide feedback on your recent\n        stay.\n      </p>\n    </header>\n    <main>\n      <form method=\"POST\" action=\"https://hotel-feedback.freecodecamp.org\">\n        <fieldset>\n          <legend>Personal Information</legend>\n          <label for=\"full-name\">Name (required):</label>\n          <input type=\"text\" id=\"full-name\" name=\"name\" placeholder=\"e.g., John Doe\" required>\n\n          <label for=\"email\">Email address (required):</label>\n          <input\n            placeholder=\"example@email.com\"\n            required\n            id=\"email\"\n            type=\"email\"\n            name=\"email\"\n          />\n          <label for=\"age\">Age (optional):</label>\n          <input type=\"number\" name=\"age\" id=\"age\" min=\"3\" max=\"100\" />\n        </fieldset>\n\n        <fieldset>\n          <legend>Was this your first time at our hotel?</legend>\n          <input id=\"yes-option\" type=\"radio\" name=\"hotel-stay\" value=\"yes\" />\n          <label for=\"yes-option\">Yes</label>\n          <input id=\"no-option\" type=\"radio\" name=\"hotel-stay\" value=\"no\" />\n          <label for=\"no-option\">No</label>\n        </fieldset>\n\n        <fieldset>\n          <legend>\n            Why did you choose to stay at our hotel? (Check all that apply)\n          </legend>\n\n          <input type=\"checkbox\" id=\"ads\" name=\"choice\" value=\"ads\" />\n          <label for=\"ads\">Social Media Ads</label>\n\n          <input\n            type=\"checkbox\"\n            id=\"recommendation\"\n            name=\"choice\"\n            value=\"recommendation\"\n          />\n          <label for=\"recommendation\">Personal Recommendation</label>\n          \n          <input type=\"checkbox\" id=\"location\" name=\"choice\" value=\"location\" />\n          <label for=\"location\">Location</label>\n\n          <input\n            checked\n            type=\"checkbox\"\n            id=\"reputation\"\n            name=\"choice\"\n            value=\"reputation\"\n          />\n          <label for=\"reputation\">Reputation</label>\n          \n          <input type=\"checkbox\" id=\"price\" name=\"choice\" value=\"price\" />\n          <label for=\"price\">Price</label>\n        </fieldset>\n\n        <fieldset>\n          <legend>Ratings</legend>\n\n          <label for=\"service\">How was the service?</label>\n\n          <select name=\"service\" id=\"service\">\n            <option value=\"poor\">Poor</option>\n            <option value=\"satisfactory\">Satisfactory</option>\n            <option value=\"good\">Good</option>\n            <option value=\"very-good\">Very Good</option>\n            <option selected value=\"excellent\">Excellent</option>\n          </select>\n\n          <label for=\"food\">How was the food?</label>\n\n          <select name=\"food\" id=\"food\">\n            <option value=\"poor\">Poor</option>\n            <option value=\"satisfactory\">Satisfactory</option>\n            <option value=\"good\">Good</option>\n            <option value=\"very-good\">Very Good</option>\n            <option selected value=\"excellent\">Excellent</option>\n          </select>\n        </fieldset>\n\n        <label for=\"comments\">Other Comments?</label>\n        <textarea cols=\"30\" rows=\"10\" name=\"comments\" id=\"comments\"></textarea>\n\n        <button type=\"submit\">Submit</button>\n      </form>\n    </main>\n  </body>\n</html>","history":["index.html"],"fileKey":"indexhtml"}]}},"id":"/learn/responsive-web-design-v9/workshop-hotel-feedback-form/step-1"}},"staticQueryHashes":["3858520367"],"slicesMap":{}}