{"componentChunkName":"component---src-templates-challenges-classic-show-tsx","path":"/learn/javascript-algorithms-and-data-structures/intermediate-algorithm-scripting/seek-and-destroy","result":{"data":{"challengeNode":{"challenge":{"block":"intermediate-algorithm-scripting","demoType":null,"title":"Traži i ukloni","description":"<section id=\"description\">\n<p>Daje vam se početni niz podataka kao prvi argument za funkciju <code>destroyer</code>, praćen jednim ili više argumenata. Uklonite sve elemente iz početnog niza podataka koji imaju vrednost jednaku ovim argumentima.</p>\n<p>Funkcija mora da prihvati nepoznat broj argumenata, takođe poznata kao variadijska funkcija. Možete dobiti dodatne argumente dodavanjem rest parametra u definiciju funkcije ili korišćenjem nečega poput <code>arguments</code>.</p>\n</section>","id":"a39963a4c10bc8b4d4f06d7e","hasEditableBoundaries":false,"instructions":"","notes":null,"challengeType":1,"helpCategory":"JavaScript","videoUrl":null,"superBlock":"javascript-algorithms-and-data-structures","translationPending":false,"forumTopicId":16046,"hooks":null,"fields":{"slug":"/learn/javascript-algorithms-and-data-structures/intermediate-algorithm-scripting/seek-and-destroy"},"required":[],"usesMultifileEditor":false,"challengeFiles":[{"fileKey":"scriptjs","ext":"js","name":"script","contents":"function destroyer(arr) {\r\n  return arr;\r\n}\r\n\r\ndestroyer([1, 2, 3, 1, 2, 3], 2, 3);","head":null,"tail":null,"editableRegionBoundaries":[],"history":["script.js"]}],"saveSubmissionToDB":null,"tests":[{"text":"<p><code>destroyer([1, 2, 3, 1, 2, 3], 2, 3)</code> treba da vrati <code>[1, 1]</code>.</p>","testString":"assert.deepEqual(destroyer([1, 2, 3, 1, 2, 3], 2, 3), [1, 1]);"},{"text":"<p><code>destroyer([1, 2, 3, 5, 1, 2, 3], 2, 3)</code> treba vratiti <code>[1, 5, 1]</code>.</p>","testString":"assert.deepEqual(destroyer([1, 2, 3, 5, 1, 2, 3], 2, 3), [1, 5, 1]);"},{"text":"<p><code>destroyer([3, 5, 1, 2, 2], 2, 3, 5)</code> treba vratiti <code>[1]</code>.</p>","testString":"assert.deepEqual(destroyer([3, 5, 1, 2, 2], 2, 3, 5), [1]);"},{"text":"<p><code>destroyer([2, 3, 2, 3], 2, 3)</code> trebalo bi vratiti <code>[]</code>.</p>","testString":"assert.deepEqual(destroyer([2, 3, 2, 3], 2, 3), []);"},{"text":"<p><code>destroyer([\"tree\", \"hamburger\", 53], \"tree\", 53)</code> trebalo bi da vrati <code>[\"hamburger\"]</code>.</p>","testString":"assert.deepEqual(destroyer(['tree', 'hamburger', 53], 'tree', 53), [\r\n  'hamburger'\r\n]);"},{"text":"<p><code>destroyer([\"possum\", \"trollo\", 12, \"safari\", \"hotdog\", 92, 65, \"grandma\", \"bugati\", \"trojan\", \"yacht\"], \"yacht\", \"possum\", \"trollo\", \"safari\", \"hotdog\", \"grandma\", \"bugati\", \"trojan\")</code> trebalo bi da vrati <code>[12,92,65]</code>.</p>","testString":"assert.deepEqual(\r\n  destroyer(\r\n    [\r\n      'possum',\r\n      'trollo',\r\n      12,\r\n      'safari',\r\n      'hotdog',\r\n      92,\r\n      65,\r\n      'grandma',\r\n      'bugati',\r\n      'trojan',\r\n      'yacht'\r\n    ],\r\n    'yacht',\r\n    'possum',\r\n    'trollo',\r\n    'safari',\r\n    'hotdog',\r\n    'grandma',\r\n    'bugati',\r\n    'trojan'\r\n  ),\r\n  [12, 92, 65]\r\n);"}]}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/javascript-algorithms-and-data-structures/#intermediate-algorithm-scripting","dashedName":"seek-and-destroy","certification":"javascript-algorithms-and-data-structures","disableLoopProtectTests":false,"disableLoopProtectPreview":false,"superBlock":"javascript-algorithms-and-data-structures","chapter":null,"module":null,"block":"intermediate-algorithm-scripting","isFirstStep":false,"template":null,"required":[],"isLastChallengeInBlock":false,"nextChallengePath":"/learn/javascript-algorithms-and-data-structures/intermediate-algorithm-scripting/wherefore-art-thou","prevChallengePath":"/learn/javascript-algorithms-and-data-structures/intermediate-algorithm-scripting/diff-two-arrays","id":"a39963a4c10bc8b4d4f06d7e","saveSubmissionToDB":null},"projectPreview":{"challengeData":{"challengeType":1,"challengeFiles":[{"name":"script","ext":"js","contents":"function orbitalPeriod(arr) {\n  const GM = 398600.4418;\n  const earthRadius = 6367.4447;\n  const TAU = 2 * Math.PI;\n  return arr.map(function(obj) {\n    return {\n      name: obj.name,\n      orbitalPeriod: Math.round(TAU * Math.sqrt(Math.pow(obj.avgAlt+earthRadius, 3)/GM))\n    };\n  });\n}","history":["script.js"],"fileKey":"scriptjs"}]}},"id":"/learn/javascript-algorithms-and-data-structures/intermediate-algorithm-scripting/seek-and-destroy"}},"staticQueryHashes":["3858520367"],"slicesMap":{}}