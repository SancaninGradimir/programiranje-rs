  "tests": [
    {
      "text": "<p>Vaš element za <code>thead</code> treba da ima element za <code>tr</code>.</p>",
      "testString": "assert(document.querySelectorAll('table')?.[2]?.querySelector('thead')?.children?.[0]?.localName === 'tr');"
    },
    {
      "text": "<p>Tvoj element <code>tr</code> treba da ima element <code>td</code> kao prvo dete.</p>",
      "testString": "assert(document.querySelectorAll('table')?.[2]?.querySelector('tr')?.children?.[0]?.localName === 'td');"
    },
    {
      "text": "<p>Tvoj element <code>tr</code> treba da ima tri elementa od <code>th</code>, nakon elementa <code>td</code>.</p>",
      "testString": "assert(document.querySelectorAll('table')?.[2]?.querySelector('tr')?.children?.[1]?.localName === 'th');\nassert(document.querySelectorAll('table')?.[2]?.querySelector('tr')?.children?.[2]?.localName === 'th');\nassert(document.querySelectorAll('table')?.[2]?.querySelector('tr')?.children?.[3]?.localName === 'th');"
    },
    {
      "text": "<p>Svaki element vašeg <code>th</code> mora imati element <code>span</code>.</p>",
      "testString": "const ths = [...document.querySelectorAll('table')?.[2]?.querySelectorAll('th')];\nths?.forEach(th => {\n  assert(th?.children?.length === 1);\n  assert(th?.children?.[0]?.localName === 'span');\n});"
    },
    {
      "text": "<p>Svaki tvoj novi element <code>span</code> mora imati svojstvo elementa <code>class</code> postavljeno na <code>sr-only</code>.</p>",
      "testString": "const ths = [...document.querySelectorAll('table')?.[2]?.querySelectorAll('th')];\nths?.forEach(th => {\n  assert(th?.children?.[0]?.classList?.contains('sr-only'));\n});"
    },
    {
      "text": "<p>Prvi element vašeg <code>span</code> treba da ima tekst <code>2019</code>.</p>",
      "testString": "assert(document.querySelectorAll('table')?.[2]?.querySelectorAll('th')?.[0]?.children?.[0]?.textContent === '2019');"
    },
    {
      "text": "<p>Vaš drugi element za <code>span</code> treba da ima tekst <code>2020</code>.</p>",
      "testString": "assert(document.querySelectorAll('table')?.[2]?.querySelectorAll('th')?.[1]?.children?.[0]?.textContent === '2020');"
    },
    {
      "text": "<p>Tvoje treće polje za <code>span</code> bi trebalo da ima tekst <code>2021</code>.</p>",
      "testString": "assert(document.querySelectorAll('table')?.[2]?.querySelectorAll('th')?.[2]?.children?.[0]?.textContent === '2021');"
    },
    {
      "text": "<p>Vaše polje za <code>td</code> treba da bude prazno.</p>",
      "testString": "assert(document.querySelectorAll('table')?.[2]?.querySelectorAll('td')?.[0]?.textContent === '');\nassert(document.querySelectorAll('table')?.[2]?.querySelectorAll('td')?.[0]?.children?.length === 0);"
    }
  ],
  "description": "<section id=\"description\">\n<p>Unutar <code>thead</code>, kreiraj element od <code>tr</code>. Unutar njega, dodaj <code>td</code> i tri elementa od <code>th</code>. Unutar svakog elementa od <code>th</code>, dodaj element <code>span</code> sa atributom elementa <code>class</code> postavljenog na <code>sr-only</code> i sledeći tekst, u redosledu: <code>2019</code>, <code>2020</code>, i <code>2021</code>.</p>\n</section>",
