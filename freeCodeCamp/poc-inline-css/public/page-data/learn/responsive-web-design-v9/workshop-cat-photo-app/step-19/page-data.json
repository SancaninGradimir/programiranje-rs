{"componentChunkName":"component---src-templates-challenges-classic-show-tsx","path":"/learn/responsive-web-design-v9/workshop-cat-photo-app/step-19","result":{"data":{"challengeNode":{"challenge":{"block":"workshop-cat-photo-app","demoType":null,"title":"Korak 19","description":"<section id=\"description\">\n<p>Vreme je da se doda nova sekcija. Dodajte funkciju <code>section</code> drugi ispod postojećeg elementa/funkcije <code>section</code>.</p>\n</section>","id":"5f07c98cdb9413cbd4b16750","hasEditableBoundaries":true,"instructions":"","notes":null,"challengeType":0,"helpCategory":"HTML-CSS","videoUrl":null,"superBlock":"responsive-web-design-v9","translationPending":false,"forumTopicId":null,"hooks":null,"fields":{"slug":"/learn/responsive-web-design-v9/workshop-cat-photo-app/step-19"},"required":[],"usesMultifileEditor":true,"challengeFiles":[{"fileKey":"indexhtml","ext":"html","name":"index","contents":"<html>\n  <body>\n    <main>\n      <h1>CatPhotoApp</h1>\n      <section>\n        <h2>Cat Photos</h2>\n        <p>Everyone loves <a href=\"https://cdn.freecodecamp.org/curriculum/cat-photo-app/running-cats.jpg\">cute cats</a> online!</p>\n        <p>See more <a target=\"_blank\" href=\"https://freecatphotoapp.com\">cat photos</a> in our gallery.</p>\n        <a href=\"https://freecatphotoapp.com\"><img src=\"https://cdn.freecodecamp.org/curriculum/cat-photo-app/relaxing-cat.jpg\" alt=\"A cute orange cat lying on its back.\"></a>\n      </section>\n      \n    </main>\n  </body>\n</html>","head":null,"tail":null,"editableRegionBoundaries":[10,12],"history":["index.html"]}],"saveSubmissionToDB":null,"tests":[{"text":"<p>Vaš element za <code>section</code> bi trebalo da ima otvorajući label. Otvarajući labeli imaju ovu sintaksu: <code>&#x3C;elementName></code>.</p>","testString":"assert.isAtLeast(document.querySelectorAll('section').length, 2);"},{"text":"<p>Morate dodati samo jedan otvarajući tag <code>section</code>. Molimo vas da uklonite sve suvišnosti.</p>","testString":"assert.lengthOf(document.querySelectorAll('section'), 2);"},{"text":"<p>Vaš element <code>section</code> treba da ima zatvarački tag. Zatvarački tagovi imaju <code>/</code> odmah nakon slova <code>&#x3C;</code>.</p>","testString":"assert.isAtLeast(code.match(/<\\/section>/g)?.length, 2);"},{"text":"<p>Trebalo bi da dodaš samo jednu etiketu za zatvaranje <code>section</code>. Molimo te, ukloni sve viškove.</p>","testString":"assert.lengthOf(code.match(/<\\/section>/g), 2);"},{"text":"<p>Element drugi od <code>section</code> ne bi trebalo da se postavi unutar elementa prvi od <code>section</code>.</p>","testString":"const el = document.querySelector('main > section');\nassert.isNotNull(el);\nconst childrenOf1stSection = [\n  ...el.children\n];\nconst foundElems = childrenOf1stSection.filter((child) => {\n  return child.nodeName === 'SECTION';\n});\nassert.isEmpty(foundElems);"},{"text":"<p>Oba elementa od <code>section</code> bi trebalo da budu između otvarajućeg i zatvarajućeg taga elementa <code>main</code>.</p>","testString":"const el = document.querySelector('main');\nassert.isNotNull(el);\nconst childrenOfMain = [...el.children];\nconst foundElems = childrenOfMain.filter((child) => {\n  return child.nodeName === 'SECTION';\n});\nassert.lengthOf(foundElems, 2);"}]}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/responsive-web-design-v9/#workshop-cat-photo-app","dashedName":"step-19","certification":"responsive-web-design-v9","disableLoopProtectTests":false,"disableLoopProtectPreview":false,"superBlock":"responsive-web-design-v9","chapter":"html","module":"basic-html","block":"workshop-cat-photo-app","isFirstStep":false,"template":null,"required":[],"isLastChallengeInBlock":false,"nextChallengePath":"/learn/responsive-web-design-v9/workshop-cat-photo-app/step-20","prevChallengePath":"/learn/responsive-web-design-v9/workshop-cat-photo-app/step-18","id":"5f07c98cdb9413cbd4b16750","saveSubmissionToDB":null},"projectPreview":{"challengeData":{"challengeType":0,"challengeFiles":[{"name":"index","ext":"html","contents":"<!DOCTYPE html>\n<html lang=\"en\">\n  <head>\n    <meta charset=\"UTF-8\">\n    <title>CatPhotoApp</title>\n  </head>\n  <body>\n    <main>\n      <h1>CatPhotoApp</h1>\n      <section>\n        <h2>Cat Photos</h2>\n        <p>Everyone loves <a href=\"https://cdn.freecodecamp.org/curriculum/cat-photo-app/running-cats.jpg\">cute cats</a> online!</p>\n        <p>See more <a target=\"_blank\" href=\"https://freecatphotoapp.com\">cat photos</a> in our gallery.</p>\n        <a href=\"https://freecatphotoapp.com\"><img src=\"https://cdn.freecodecamp.org/curriculum/cat-photo-app/relaxing-cat.jpg\" alt=\"A cute orange cat lying on its back.\"></a>\n      </section>\n      <section>\n        <h2>Cat Lists</h2>\n        <h3>Things cats love:</h3>\n        <ul>\n          <li>catnip</li>\n          <li>laser pointers</li>\n          <li>lasagna</li>\n        </ul>\n        <figure>\n          <img src=\"https://cdn.freecodecamp.org/curriculum/cat-photo-app/lasagna.jpg\" alt=\"A slice of lasagna on a plate.\">\n          <figcaption>Cats <em>love</em> lasagna.</figcaption>  \n        </figure>\n        <h3>Top 3 things cats hate:</h3>\n        <ol>\n          <li>flea treatment</li>\n          <li>thunder</li>\n          <li>other cats</li>\n        </ol>\n        <figure>\n          <img src=\"https://cdn.freecodecamp.org/curriculum/cat-photo-app/cats.jpg\" alt=\"Two tabby kittens sleeping together on a couch.\">\n          <figcaption>Cats <strong>hate</strong> other cats.</figcaption>  \n        </figure>\n      </section>\n    </main>\n    <footer>\n      <p>\n        No Copyright - <a href=\"https://www.freecodecamp.org\">freeCodeCamp.org</a>\n      </p>\n    </footer>\n  </body>\n</html>","history":["index.html"],"fileKey":"indexhtml"}]}},"id":"/learn/responsive-web-design-v9/workshop-cat-photo-app/step-19"}},"staticQueryHashes":["3858520367"],"slicesMap":{}}