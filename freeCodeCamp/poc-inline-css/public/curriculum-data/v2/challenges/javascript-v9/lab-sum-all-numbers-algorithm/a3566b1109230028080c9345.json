        "fileKey": "scriptjs",
        "contents": "function sumAll(arr) {\r\n  let sum = 0;\r\n  \r\n  arr.sort((a, b) => a - b);\r\n\r\n  for (var i = arr[0]; i <= arr[1]; i++) {\r\n    sum += i;\r\n  }\r\n\r\n  return sum;\r\n}",
        "error": null,
