{"componentChunkName":"component---src-templates-challenges-classic-show-tsx","path":"/learn/javascript-v9/lab-element-skipper/implement-an-element-skipper","result":{"data":{"challengeNode":{"challenge":{"block":"lab-element-skipper","demoType":null,"title":"Implementiraj funkciju za preskakanje elementa","description":"<section id=\"description\">\n<p>U ovoj laboratoriji ćete kreirati funkciju koja iterira elemente u nizu podataka sve dok ne pronađe prihvatljiv element prema specifičnoj funkciji testa.</p>\n<p>Na primer, za red podataka kao <code>[1, 1, 1, 2, 1, 1, 1]</code> i funkciju testiranja <code>function(n) {return n === 2}</code>, prvi prihvatljiv element je onaj iz figure 3, pa bi svi elementi pre njega trebalo da budu uklonjeni, a rezultat bi trebali biti preostali elementi <code>[2, 1, 1, 1]</code>.</p>\n<p><strong>Cilj</strong>: Završite korisničke priče navedene ispod i položite sve testove kako biste završili ovu laboratoriju.</p>\n<p><strong>Priče korisnika:</strong></p>\n<ol>\n<li>Treba da postoji funkcija <code>dropElements</code> koja prima niz podataka (<code>arr</code>) i funkciju (<code>func</code>) kao argumente.</li>\n<li>Funkcija <code>dropElements</code> treba da iterira kroz niz podataka i ukloni elemente od prvog elementa do <code>func</code>, vraćajući <code>true</code> za određeni element.</li>\n<li>Funkcija <code>dropElements</code> treba da vrati preostale elemente u nizu podataka ako je uslov ispavljen.</li>\n<li>Ako uslov nikada nije ispavljen, treba da vrati prazan niz podataka.</li>\n</ol>\n</section>","id":"a5deed1811a43193f9f1c841","hasEditableBoundaries":false,"instructions":"","notes":null,"challengeType":26,"helpCategory":"JavaScript","videoUrl":null,"superBlock":"javascript-v9","translationPending":false,"forumTopicId":null,"hooks":null,"fields":{"slug":"/learn/javascript-v9/lab-element-skipper/implement-an-element-skipper"},"required":[],"usesMultifileEditor":true,"challengeFiles":[{"fileKey":"scriptjs","ext":"js","name":"script","contents":"","head":null,"tail":null,"editableRegionBoundaries":[],"history":["script.js"]}],"saveSubmissionToDB":null,"tests":[{"text":"<p>Trebalo bi da imaš funkciju <code>dropElements</code>.</p>","testString":"assert.isFunction(dropElements);"},{"text":"<p><code>dropElements([1, 2, 3, 4], function(n) {return n >= 3;})</code> trebalo bi vratiti <code>[3, 4]</code>.</p>","testString":"assert.deepEqual(dropElements([1, 2, 3, 4], function(n) {return n >= 3;}), [3, 4]);"},{"text":"<p><code>dropElements([0, 1, 0, 1], function(n) {return n === 1;})</code> treba da vrati <code>[1, 0, 1]</code>.</p>","testString":"assert.deepEqual(dropElements([0, 1, 0, 1], function(n) {return n === 1;}), [1, 0, 1]);"},{"text":"<p><code>dropElements([1, 2, 3], function(n) {return n > 0;})</code> trebalo bi da vrati <code>[1, 2, 3]</code>.</p>","testString":"assert.deepEqual(dropElements([1, 2, 3], function(n) {return n > 0;}), [1, 2, 3]);"},{"text":"<p><code>dropElements([1, 2, 3, 4], function(n) {return n > 5;})</code> treba da vrati <code>[]</code>.</p>","testString":"assert.deepEqual(dropElements([1, 2, 3, 4], function(n) {return n > 5;}), []);"},{"text":"<p><code>dropElements([1, 2, 3, 7, 4], function(n) {return n > 3;})</code> treba da vrati <code>[7, 4]</code>.</p>","testString":"assert.deepEqual(dropElements([1, 2, 3, 7, 4], function(n) {return n > 3;}), [7, 4]);"},{"text":"<p><code>dropElements([1, 2, 3, 9, 2], function(n) {return n > 2;})</code> treba da vrati <code>[3, 9, 2]</code>.</p>","testString":"assert.deepEqual(dropElements([1, 2, 3, 9, 2], function(n) {return n > 2;}), [3, 9, 2]);"}]}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/javascript-v9/#lab-element-skipper","dashedName":"implement-an-element-skipper","certification":"javascript-v9","disableLoopProtectTests":false,"disableLoopProtectPreview":false,"superBlock":"javascript-v9","chapter":"javascript","module":"review-javascript-fundamentals","block":"lab-element-skipper","isFirstStep":true,"template":null,"required":[],"isLastChallengeInBlock":true,"nextChallengePath":"/learn/javascript-v9/lab-playlist-remix-engine/build-a-playlist-remix-engine","prevChallengePath":"/learn/javascript-v9/lab-odd-fibonacci-sum-calculator/build-an-odd-fibonacci-sum-calculator","id":"a5deed1811a43193f9f1c841","saveSubmissionToDB":null},"projectPreview":{"challengeData":{"challengeType":26,"challengeFiles":[{"name":"script","ext":"js","contents":"function dropElements(arr, func) {\r\n  while (arr.length > 0 && !func(arr[0])) {\r\n    arr.shift();\r\n  }\r\n  return arr;\r\n}","history":["script.js"],"fileKey":"scriptjs"}]}},"id":"/learn/javascript-v9/lab-element-skipper/implement-an-element-skipper"}},"staticQueryHashes":["3858520367"],"slicesMap":{}}