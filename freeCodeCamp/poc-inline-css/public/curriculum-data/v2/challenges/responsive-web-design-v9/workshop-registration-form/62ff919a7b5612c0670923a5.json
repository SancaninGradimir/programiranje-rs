    {
      "text": "<p>Prvi element <code>input</code> bi trebalo da ima <code>id</code> od <code>profile-picture</code>.</p>",
      "testString": "assert.isTrue(document.querySelectorAll('fieldset:nth-of-type(3) input')?.[0]?.matches('#profile-picture'))"
    },
    {
      "text": "<p>Drugi element <code>input</code> treba da ima <code>id</code> od <code>age</code>.</p>",
      "testString": "assert.isTrue(document.querySelectorAll('fieldset:nth-of-type(3) input')?.[1]?.matches('#age'))"
    },
    {
      "text": "<p>Element od <code>select</code> treba da ima <code>id</code> iz <code>referrer</code>.</p>",
      "testString": "assert.isTrue(document.querySelector('fieldset:nth-of-type(3) select')?.matches('#referrer'))"
    },
    {
      "text": "<p>Element <code>textarea</code> bi trebalo da ima <code>id</code> od <code>bio</code>.</p>",
      "testString": "assert.isTrue(document.querySelector('fieldset:nth-of-type(3) textarea')?.matches('#bio'))"
    },
    {
      "text": "<p>Prvi element <code>label</code> treba da ima atribut <code>for</code> sa vrednošću <code>profile-picture</code>.</p>",
      "testString": "assert.isTrue(document.querySelectorAll('fieldset:nth-of-type(3) label')?.[0]?.matches('label[for=\"profile-picture\"]'))"
    },
    {
      "text": "<p>Drugi element od <code>label</code> mora imati svojstvo <code>for</code> sa vrednošću <code>age</code>.</p>",
      "testString": "assert.isTrue(document.querySelectorAll('fieldset:nth-of-type(3) label')?.[1]?.matches('label[for=\"age\"]'))"
    },
    {
      "text": "<p>Treći element od <code>label</code> mora imati svojstvo <code>for</code> sa vrednošću <code>referrer</code>.</p>",
      "testString": "assert.isTrue(document.querySelectorAll('fieldset:nth-of-type(3) label')?.[2]?.matches('label[for=\"referrer\"]'))"
    },
    {
      "text": "<p>Četvrti atribut od <code>label</code> mora imati svojstvo <code>for</code> sa vrednošću <code>bio</code>.</p>",
