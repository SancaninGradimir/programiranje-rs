{"componentChunkName":"component---src-templates-challenges-classic-show-tsx","path":"/learn/responsive-web-design/basic-css/style-multiple-elements-with-a-css-class","result":{"data":{"challengeNode":{"challenge":{"block":"basic-css","demoType":null,"title":"Koristi CSS Klasu za Stilizovanje Vise Elemenata","description":"<section id=\"description\">\n<p>Klase vam omogucavaju da primenite isti CSS stil na vise HTML elemenata. To mozete videti tako sto cete svoju <code>red-text</code> klasu primeniti na prvi <code>p</code> element.</p>\n</section>","id":"bad87fee1348bd9aefe08806","hasEditableBoundaries":false,"instructions":"","notes":null,"challengeType":0,"helpCategory":"HTML-CSS","videoUrl":"https://scrimba.com/c/cRkVbsQ","superBlock":"responsive-web-design","translationPending":false,"forumTopicId":18311,"hooks":null,"fields":{"slug":"/learn/responsive-web-design/basic-css/style-multiple-elements-with-a-css-class"},"required":[],"usesMultifileEditor":false,"challengeFiles":[{"fileKey":"indexhtml","ext":"html","name":"index","contents":"<style>\n  .red-text {\n    color: red;\n  }\n</style>\n\n<h2 class=\"red-text\">CatPhotoApp</h2>\n<main>\n  <p>Click here to view more <a href=\"#\">cat photos</a>.</p>\n\n  <a href=\"#\"><img src=\"https://cdn.freecodecamp.org/curriculum/cat-photo-app/relaxing-cat.jpg\" alt=\"A cute orange cat lying on its back.\"></a>\n\n  <div>\n    <p>Things cats love:</p>\n    <ul>\n      <li>catnip</li>\n      <li>laser pointers</li>\n      <li>lasagna</li>\n    </ul>\n    <p>Top 3 things cats hate:</p>\n    <ol>\n      <li>flea treatment</li>\n      <li>thunder</li>\n      <li>other cats</li>\n    </ol>\n  </div>\n\n  <form action=\"https://freecatphotoapp.com/submit-cat-photo\">\n    <label><input type=\"radio\" name=\"indoor-outdoor\" checked> Indoor</label>\n    <label><input type=\"radio\" name=\"indoor-outdoor\"> Outdoor</label><br>\n    <label><input type=\"checkbox\" name=\"personality\" checked> Loving</label>\n    <label><input type=\"checkbox\" name=\"personality\"> Lazy</label>\n    <label><input type=\"checkbox\" name=\"personality\"> Energetic</label><br>\n    <input type=\"text\" placeholder=\"cat photo URL\" required>\n    <button type=\"submit\">Submit</button>\n  </form>\n</main>","head":null,"tail":null,"editableRegionBoundaries":[],"history":["index.html"]}],"saveSubmissionToDB":null,"tests":[{"text":"<p>Vas <code>h2</code> element treba da bude crven.</p>","testString":"const h2Element = document.querySelector('h2');\nconst color = window.getComputedStyle(h2Element)['color']; \nassert.strictEqual(color, 'rgb(255, 0, 0)');"},{"text":"<p>Vas <code>h2</code> element treba da ima klasu <code>red-text</code>.</p>","testString":"assert.isTrue(document.querySelector('h2').classList.contains('red-text'));"},{"text":"<p>Vas prvi <code>p</code> element treba da bude crven.</p>","testString":"const paragraph = document.querySelectorAll('p')[0];\nconst color = window.getComputedStyle(paragraph )['color'];\nassert.strictEqual(color, 'rgb(255, 0, 0)');"},{"text":"<p>Vasi drugi i treci <code>p</code> elementi ne treba da budu crveni.</p>","testString":"const paragraph2 = document.querySelectorAll('p')[1];\nconst paragraph3 = document.querySelectorAll('p')[2];\n\nconst color2 = window.getComputedStyle(paragraph2)['color'];\nconst color3 = window.getComputedStyle(paragraph3)['color'];\n\nassert.notStrictEqual(color2, 'rgb(255, 0, 0)');\nassert.notStrictEqual(color3, 'rgb(255, 0, 0)');"},{"text":"<p>Vas prvi <code>p</code> element treba da ima klasu <code>red-text</code>.</p>","testString":"assert.isTrue(document.querySelectorAll('p')[0].classList.contains('red-text'));"}]}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/responsive-web-design/#basic-css","dashedName":"style-multiple-elements-with-a-css-class","certification":"responsive-web-design","disableLoopProtectTests":false,"disableLoopProtectPreview":false,"superBlock":"responsive-web-design","chapter":null,"module":null,"block":"b