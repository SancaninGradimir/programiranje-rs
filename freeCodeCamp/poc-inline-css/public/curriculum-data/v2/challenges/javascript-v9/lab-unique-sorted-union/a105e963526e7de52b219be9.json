    {
      "text": "<p><code>uniteUnique([1, 2, 3], [5, 2, 1, 4], [2, 1], [6, 7, 8])</code> trebalo bi da vrati <code>[1, 2, 3, 5, 4, 6, 7, 8]</code>.</p>",
      "testString": "assert.deepEqual(uniteUnique([1, 2, 3], [5, 2, 1, 4], [2, 1], [6, 7, 8]), [\n  1,\n  2,\n  3,\n  5,\n  4,\n  6,\n  7,\n  8\n]);"
