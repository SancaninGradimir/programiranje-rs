    {
      "text": "<p>Trebalo bi da dodate tri nova svojstva klasi objekta <code>stat</code> na <code>span</code>.</p>",
      "testString": "assert.lengthOf(document.querySelectorAll('#stats > .stat'), 3);"
    },
    {
      "text": "<p>Vaš prvi element od <code>.stat</code> mora da sadrži tekst koji je dostavljen putem <code>XP: 0</code>.</p>",
      "testString": "assert(document.querySelectorAll('#stats > .stat')?.[0]?.innerText === 'XP: 0');"
    },
