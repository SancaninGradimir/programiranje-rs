        "contents": "function IBeforeExceptC(word)\n{\n    if(word.indexOf(\"c\")==-1 && word.indexOf(\"ie\")!=-1)\n        return true;\n    else if(word.indexOf(\"cei\")!=-1)\n        return true;\n    return false;\n}",
