{"componentChunkName":"component---src-templates-challenges-generic-show-tsx","path":"/learn/b1-english-for-developers/learn-how-to-clarify-misunderstandings/dialogue-2-flickering-glitches","result":{"data":{"challengeNode":{"challenge":{"assignments":["<p>Gledaj video.</p>"],"bilibiliIds":null,"block":"learn-how-to-clarify-misunderstandings","challengeType":21,"description":"<section id=\"description\">\n<p>Pogledajte video ispod da biste razumeli kontekst sledećih lekcija.</p>\n</section>","nodules":null,"explanation":null,"helpCategory":"English","instructions":"","fields":{"slug":"/learn/b1-english-for-developers/learn-how-to-clarify-misunderstandings/dialogue-2-flickering-glitches"},"questions":[],"scene":{"setup":{"background":"company2-center.png","characters":[{"character":"Mark","position":{"x":-25,"y":0,"z":1},"opacity":null},{"character":"Lisa","position":{"x":125,"y":0,"z":1},"opacity":null}],"audio":{"filename":"B1_16-2.mp3","startTime":1,"startTimestamp":null,"finishTimestamp":null},"alwaysShowDialogue":true},"commands":[{"background":null,"character":"Mark","position":{"x":25,"y":0,"z":1},"opacity":null,"startTime":0,"finishTime":null,"dialogue":null},{"background":null,"character":"Lisa","position":{"x":70,"y":0,"z":1},"opacity":null,"startTime":0.5,"finishTime":null,"dialogue":null},{"background":null,"character":"Mark","position":null,"opacity":null,"startTime":1,"finishTime":5.6,"dialogue":{"text":"Hey, Lisa. I need your help with something. There's a strange issue with the software,","align":"left"}},{"background":null,"character":"Mark","position":null,"opacity":null,"startTime":5.6,"finishTime":8.42,"dialogue":{"text":"but I'm not sure how to describe it. Can you take a look?","align":"left"}},{"background":null,"character":"Lisa","position":null,"opacity":null,"startTime":8.92,"finishTime":10.1,"dialogue":{"text":"Sure, Mark. What's going on?","align":"right"}},{"background":null,"character":"Mark","position":null,"opacity":null,"startTime":10.6,"finishTime":14.76,"dialogue":{"text":"Well, when I click on the menu, it sometimes disappears or shows the wrong options.","align":"left"}},{"background":null,"character":"Mark","position":null,"opacity":null,"startTime":15.32,"finishTime":18.22,"dialogue":{"text":"It's like it's glitching or something. Does that make sense?","align":"left"}},{"background":null,"character":"Lisa","position":null,"opacity":null,"startTime":18.7,"finishTime":23.66,"dialogue":{"text":"I think so. It could be a rendering problem. Does it happen every time you click or just sometimes?","align":"right"}},{"background":null,"character":"Mark","position":null,"opacity":null,"startTime":23.9,"finishTime":27.84,"dialogue":{"text":"It's more random. Sometimes it works fine, but other times it acts weird.","align":"left"}},{"background":null,"character":"Mark","position":null,"opacity":null,"startTime":28.06,"finishTime":31.94,"dialogue":{"text":"I tried restarting, but it didn't help. Do you know what might be causing it?","align":"left"}},{"background":null,"character":"Lisa","position":null,"opacity":null,"startTime":32.58,"finishTime":36.2,"dialogue":{"text":"It could be a JavaScript issue. Maybe there's a problem with the event handling.","align":"right"}},{"background":null,"character":"Lisa","position":null,"opacity":null,"startTime":36.66,"finishTime":39.24,"dialogue":{"text":"Does it affect other parts of the software or just the menu?","align":"right"}},{"background":null,"character":"Mark","position":null,"opacity":null,"startTime":39.6,"finishTime":45.1,"dialogue":{"text":"Mostly the menu. Oh, and there's another thing – sometimes the screen flickers when I switch between tabs.","align":"left"}},{"background":null,"character":"Mark","position":null,"opacity":null,"startTime":45.54,"finishTime":49.7,"dialogue":{"text":"It's not consistent, but it happens enough to be annoying. Any ideas?","align":"left"}},{"background":null,"character":"Lisa","position":null,"opacity":null,"startTime":50.56,"finishTime":54.48,"dialogue":{"text":"Flickering could be a graphics driver issue or a problem with the UI framework.","align":"right"}},{"background":null,"character":"Lisa","position":null,"opacity":null,"startTime":54.6,"finishTime":56.5,"dialogue":{"text":"Have you updated the drivers recently?","align":"right"}},{"background":null,"character":"Mark","position":null,"opacity":null,"startTime":56.7,"finishTime":60.16,"dialogue":{"text":"Not that I know of. Should I try updating them to see if that helps?","align":"left"}},{"background":null,"character":"Lisa","position":null,"opacity":null,"startTime":61,"finishTime":63.04,"dialogue":{"text":"Yes, that's a good start. If it doesn't work,","align":"right"}},{"background":null,"character":"Lisa","position":null,"opacity":null,"startTime":63.2,"finishTime":66.78,"dialogue":{"text":"we might need to dig into the code or run some diagnostics. Does that sound okay?","align":"right"}},{"background":null,"character":"Mark","position":null,"opacity":null,"startTime":67.06,"finishTime":70.26,"dialogue":{"text":"Yeah, that sounds good. Thanks for your help, Lisa. I appreciate it.","align":"left"}},{"background":null,"character":"Lisa","position":null,"opacity":null,"startTime":70.52,"finishTime":73.14,"dialogue":{"text":"No problem, Mark. If you run into any other issues, let me know.","align":"right"}},{"background":null,"character":"Lisa","position":{"x":125,"y":0,"z":1},"opacity":null,"startTime":73.64,"finishTime":null,"dialogue":null},{"background":null,"character":"Mark","position":{"x":-25,"y":0,"z":1},"opacity":null,"startTime":74.14,"finishTime":null,"dialogue":null}]},"superBlock":"b1-english-for-developers","tests":[],"title":"Dialog 2: Treperljivi kvarovi","transcript":null,"translationPending":false,"videoId":null,"videoLocaleIds":null}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/b1-english-for-developers/#learn-how-to-clarify-misunderstandings","dashedName":"dialogue-2-flickering-gli