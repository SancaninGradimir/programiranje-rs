{"componentChunkName":"component---src-templates-challenges-classic-show-tsx","path":"/learn/javascript-fundamentals-review/lab-reverse-a-string/build-a-string-inverter","result":{"data":{"challengeNode":{"challenge":{"block":"lab-reverse-a-string","demoType":null,"title":"Napravi Konverter Sekvence Slova","description":"<section id=\"description\">\n<p>U ovoj laboratoriji, napravićete jednostavan konverter za sekvence znakova koji transformiše dati niz znakova.</p>\n<p>Na primer, <code>\"hello\"</code> bi trebalo da bude <code>\"olleh\"</code>.</p>\n<p><strong>Cilj:</strong> Popunite korisničke priče navedene ispod i prođite sve testove kako biste završili laboratorijum.</p>\n<p>Priče o korisniku:</p>\n<ol>\n<li>Treba da kreirate funkciju nazvanu <code>reverseString</code> koja prima niz znakova kao argument.</li>\n<li>Funkcija treba da vrati niz znakova u obrnutom redosledu.</li>\n</ol>\n</section>","id":"a202eed8fc186c8434cb6d61","hasEditableBoundaries":false,"instructions":"","notes":null,"challengeType":26,"helpCategory":"JavaScript","videoUrl":null,"superBlock":"javascript-fundamentals-review","translationPending":false,"forumTopicId":null,"hooks":null,"fields":{"slug":"/learn/javascript-fundamentals-review/lab-reverse-a-string/build-a-string-inverter"},"required":[],"usesMultifileEditor":true,"challengeFiles":[{"fileKey":"scriptjs","ext":"js","name":"script","contents":"","head":null,"tail":null,"editableRegionBoundaries":[],"history":["script.js"]}],"saveSubmissionToDB":null,"tests":[{"text":"<p>Trebalo bi da imate funkciju nazvanu <code>reverseString</code>.</p>","testString":"assert.isFunction(reverseString);"},{"text":"<p><code>reverseString</code> Trebalo bi da primi niz znakova kao argument.</p>","testString":"assert.match(reverseString.toString(), /\\s*function\\s+reverseString\\s*\\(\\s*\\w+\\s*\\)/);"},{"text":"<p><code>reverseString(\"hello\")</code> Trebalo bi da vrati sekvencu slova.</p>","testString":"assert.isString(reverseString('hello'));"},{"text":"<p><code>reverseString(\"hello\")</code> treba da vrati niz znakova <code>olleh</code>.</p>","testString":"assert.strictEqual(reverseString('hello'), 'olleh');"},{"text":"<p><code>reverseString(\"Howdy\")</code> treba da vrati niz karaktera <code>ydwoH</code>.</p>","testString":"assert.strictEqual(reverseString('Howdy'), 'ydwoH');"},{"text":"<p><code>reverseString(\"Greetings from Earth\")</code> treba da vrati sekvencu karaktera <code>htraE morf sgniteerG</code>.</p>","testString":"assert.strictEqual(\r\n  reverseString('Greetings from Earth'),\r\n  'htraE morf sgniteerG'\r\n);"}]}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/javascript-fundamentals-review/#lab-reverse-a-string","dashedName":"build-a-string-inverter","certification":"javascript-fundamentals-review","disableLoopProtectTests":false,"disableLoopProtectPreview":false,"superBlock":"javascript-fundamentals-review","chapter":null,"module":null,"block":"lab-reverse-a-string","isFirstStep":true,"template":null,"required":[],"isLastChallengeInBlock":true,"nextChallengePath":"/learn/javascript-fundamentals-review/lab-largest-number-finder/build-the-largest-number-finder","prevChallengePath":"/learn/javascript-fundamentals-review/lecture-working-with-code-quality-and-execution-concepts/what-are-closures-and-how-do-they-work","id":"a202eed8fc186c8434cb6d61","saveSubmissionToDB":null},"projectPreview":{"challengeData":{"challengeType":26,"challengeFiles":[{"name":"script","ext":"js","contents":"function reverseString(str) {\r\n  return str.split('').reverse().join('');\r\n}\r\n\r\nreverseString('hello');","history":["script.js"],"fileKey":"scriptjs"}]}},"id":"/learn/javascript-fundamentals-review/lab-reverse-a-string/build-a-string-inverter"}},"staticQueryHashes":["3858520367"],"slicesMap":{}}