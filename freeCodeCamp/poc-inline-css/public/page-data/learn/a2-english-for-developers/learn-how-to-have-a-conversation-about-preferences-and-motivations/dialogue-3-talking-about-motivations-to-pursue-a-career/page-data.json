{"componentChunkName":"component---src-templates-challenges-generic-show-tsx","path":"/learn/a2-english-for-developers/learn-how-to-have-a-conversation-about-preferences-and-motivations/dialogue-3-talking-about-motivations-to-pursue-a-career","result":{"data":{"challengeNode":{"challenge":{"assignments":["<p>Gledaj video</p>"],"bilibiliIds":null,"block":"learn-how-to-have-a-conversation-about-preferences-and-motivations","challengeType":21,"description":"<section id=\"description\">\n<p>Pogledajte video ispod da biste razumeli kontekst sledećih lekcija.</p>\n</section>","nodules":null,"explanation":null,"helpCategory":"English","instructions":"","fields":{"slug":"/learn/a2-english-for-developers/learn-how-to-have-a-conversation-about-preferences-and-motivations/dialogue-3-talking-about-motivations-to-pursue-a-career"},"questions":[],"scene":{"setup":{"background":"company2-breakroom.png","characters":[{"character":"Brian","position":{"x":-25,"y":0,"z":1},"opacity":null},{"character":"Lisa","position":{"x":125,"y":0,"z":1},"opacity":null}],"audio":{"filename":"4.1-3.mp3","startTime":1,"startTimestamp":null,"finishTimestamp":null},"alwaysShowDialogue":true},"commands":[{"background":null,"character":"Brian","position":{"x":25,"y":0,"z":1},"opacity":null,"startTime":0,"finishTime":null,"dialogue":null},{"background":null,"character":"Lisa","position":{"x":70,"y":0,"z":1},"opacity":null,"startTime":0.5,"finishTime":null,"dialogue":null},{"background":null,"character":"Brian","position":null,"opacity":null,"startTime":1,"finishTime":5,"dialogue":{"text":"Hey Lisa, what motivated you to choose a career in tech?","align":"left"}},{"background":null,"character":"Lisa","position":null,"opacity":null,"startTime":6,"finishTime":8.5,"dialogue":{"text":"One of my main motivations was the financial stability","align":"right"}},{"background":null,"character":"Lisa","position":null,"opacity":null,"startTime":8.8,"finishTime":10,"dialogue":{"text":"that tech jobs can provide.","align":"right"}},{"background":null,"character":"Lisa","position":null,"opacity":null,"startTime":10.4,"finishTime":12.8,"dialogue":{"text":"It allows me to plan for my future with confidence.","align":"right"}},{"background":null,"character":"Lisa","position":null,"opacity":null,"startTime":13.3,"finishTime":16.3,"dialogue":{"text":"In other fields, it's much more difficult to achieve this stability.","align":"right"}},{"background":null,"character":"Brian","position":null,"opacity":null,"startTime":17.4,"finishTime":19.4,"dialogue":{"text":"Financial stability is certainly important, Lisa.","align":"left"}},{"background":null,"character":"Brian","position":null,"opacity":null,"startTime":19.8,"finishTime":24,"dialogue":{"text":"For me, it was the opportunity to collaborate with experts from many fields","align":"left"}},{"background":null,"character":"Brian","position":null,"opacity":null,"startTime":24,"finishTime":26,"dialogue":{"text":"and have different perspectives.","align":"left"}},{"background":null,"character":"Lisa","position":null,"opacity":null,"startTime":26.8,"finishTime":29.2,"dialogue":{"text":"Collaborating with diverse teams can be exciting, Brian.","align":"right"}},{"background":null,"character":"Lisa","position":null,"opacity":null,"startTime":29.2,"finishTime":32.1,"dialogue":{"text":"Another thing was the chance to be part of projects","align":"right"}},{"background":null,"character":"Lisa","position":null,"opacity":null,"startTime":32.1,"finishTime":34.2,"dialogue":{"text":"that push the limits of innovation and creativity.","align":"right"}},{"background":null,"character":"Brian","position":null,"opacity":null,"startTime":34.9,"finishTime":36,"dialogue":{"text":"I'm with you on that one.","align":"left"}},{"background":null,"character":"Brian","position":null,"opacity":null,"startTime":36.1,"finishTime":39.6,"dialogue":{"text":"I'm also interested in the flexibility that tech roles offer.","align":"left"}},{"background":null,"character":"Brian","position":null,"opacity":null,"startTime":39.7,"finishTime":43.1,"dialogue":{"text":"They allow us to balance our jobs with personal interests and hobbies.","align":"left"}},{"background":null,"character":"Lisa","position":null,"opacity":null,"startTime":44.3,"finishTime":47.3,"dialogue":{"text":"Yeah. Also, the satisfaction of solving complex problems","align":"right"}},{"background":null,"character":"Lisa","position":null,"opacity":null,"startTime":47.3,"finishTime":49.6,"dialogue":{"text":"and finding practical solutions is really thrilling.","align":"right"}},{"background":null,"character":"Brian","position":null,"opacity":null,"startTime":50.3,"finishTime":53,"dialogue":{"text":"Knowing that we solved problems is really exciting, Lisa.","align":"left"}},{"background":null,"character":"Brian","position":null,"opacity":null,"startTime":53.4,"finishTime":56.7,"dialogue":{"text":"I hope we keep getting as much motivation from it as we can.","align":"left"}},{"background":null,"character":"Lisa","position":{"x":125,"y":0,"z":1},"opacity":null,"startTime":57.2,"finishTime":null,"dialogue":null},{"background":null,"character":"Brian","position":{"x":-25,"y":0,"z":1},"opacity":null,"startTime":57.7,"finishTime":null,"dialogue":null}]},"superBlock":"a2-english-for-developers","tests":[],"title":"Dijalog 3: O motivacijama za započinjanje karijere","transcript":null,"translationPending":false,"videoId":null,"videoLocaleIds":null}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/a2-english-for-developers/#learn-how-to-have-a-conversation-about-preferences-and-motivations","dashedName":"dialogue-3-talking-about-motivations-to-pursue-a-career","certification":"a2-english-for-developers","disableLoopProtectTests":false,"disableLoopProtectPreview":false,"superBlock":"a2-english-for-developers","chapter":null,"module":null,"block":"learn-how-to-have-a-conversation-about-preferences-and-motivations","isFirstStep":false,"template":null,"required":[],"isLastChallengeIn