<figure>\n          <img src=\"https://cdn.freecodecamp.org/curriculum/cat-photo-app/lasagna.jpg\" alt=\"A slice of lasagna on a plate.\">\n          <figcaption>Cats <em>love</em> lasagna.</figcaption>  \n        </figure>\n        <h3>Top 3 things cats hate:</h3>\n        <ol>\n          <li>flea treatment</li>\n          <li>thunder</li>\n          <li>other cats</li>\n        </ol>\n        <figure>\n          <img src=\"https://cdn.freecodecamp.org/curriculum/cat-photo-app/cats.jpg\" alt=\"Two tabby kittens sleeping together on a couch.\">\n          <figcaption>Cats <strong>hate</strong> other cats.</figcaption>  \n        </figure>\n      </section>\n    </main>\n    <footer>\n      <p>\n        No Copyright - <a href=\"https://www.freecodecamp.org\">freeCodeCamp.org</a>\n      </p>\n    </footer>\n  </body>\n</html>","head":null,"tail":null,"editableRegionBoundaries":[0,2],"history":["index.html"]}],"saveSubmissionToDB":null,"tests":[{"text":"<p>Vaš kod bi trebalo da počinje sa deklaracijom <code>&#x3C;!DOCTYPE html></code>. Možda ste propustili deklaraciju, postoje greške u pravopisu, ili nije prva linija koda.</p>","testString":"assert.match(code, /<\\s*!doctype\\s+html\\s*>/i);"},{"text":"<p><code>&#x3C;!DOCTYPE html></code> Mora biti na samom vrhu dokumenta.</p>","testString":"const noSpaces = code.replace(/\\s/g, '');\nassert.match(noSpaces, /^<\\!doctypehtml><html/i);"}]}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/responsive-web-design-v9/#workshop-cat-photo-app","dashedName":"step-41","certification":"responsive-web-design-v9","disableLoopProtectTests":false,"disableLoopProtectPreview":false,"superBlock":"responsive-web-design-v9","chapter":"html","module":"basic-html","block":"workshop-cat-photo-app","isFirstStep":false,"template":null,"required":[],"isLastChallengeInBlock":false,"nextChallengePath":"/learn/responsive-web-design-v9/workshop-cat-photo-app/step-42","prevChallengePath":"/learn/responsive-web-design-v9/workshop-cat-photo-a