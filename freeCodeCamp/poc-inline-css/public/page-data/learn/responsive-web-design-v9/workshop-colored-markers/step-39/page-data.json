ubmissionToDB":null},"projectPreview":{"challengeData":{"challengeType":0,"challengeFiles":[{"name":"index","ext":"html","contents":"<!DOCTYPE html>\n<html lang=\"en\">\n  <head>\n    <meta charset=\"utf-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Colored Markers</title>\n    <link rel=\"stylesheet\" href=\"styles.css\">\n  </head>\n  <body>\n    <h1>CSS Color Markers</h1>\n    <div class=\"container\">\n      <div class=\"marker red\">\n        <div class=\"cap\"></div>\n        <div class=\"sleeve\"></div>\n      </div>\n      <div class=\"marker green\">\n        <div class=\"cap\"></div>\n        <div class=\"sleeve\"></div>\n      </div>\n      <div class=\"marker blue\">\n        <div class=\"cap\"></div>\n        <div class=\"sleeve\"></div>\n      </div>\n    </div>\n  </body>\n</html>","history":["index.html"],"fileKey":"indexhtml"},{"name":"styles","ext":"css","contents":"h1 {\n  text-align: center;\n}\n\n.container {\n  background-color: rgb(255, 255, 255);\n  padding: 10px 0;\n}\n\n.marker {\n  width: 200px;\n  height: 25px;\n  margin: 10px auto;\n}\n\n.cap {\n  width: 60px;\n  height: 25px;\n}\n\n.sleeve {\n  width: 110px;\n  height: 25px;\n  background-color: rgba(255, 255, 255, 0.5);\n  border-left: 10px double rgba(0, 0, 0, 0.75);\n}\n\n.cap, .sleeve {\n  display: inline-block;\n}\n\n.red {\n  background: linear-gradient(rgb(122, 74, 14), rgb(245, 62, 113), rgb(162, 27, 27));\n  box-shadow: 0 0 20px 0 rgba(83, 14, 14, 0.8);\n}\n\n.green {\n  background: linear-gradient(#55680D, #71F53E, #116C31);\n  box-shadow: 0 0 20px 0 #3B7E20CC;\n}\n\n.blue {\n  background: linear-gradient(hsl(186, 76%, 16%), hsl(223, 90%, 60%), hsl(240, 56%, 42%));\n  box-shadow: 0 0 20px 0 hsla(223, 59%, 31%, 0.8);\n}\n","history":["styles.css"],"fileKey":"stylescss"}]}},"id":"/learn/responsive-web-design-v9/workshop-colored-markers/step-39"}},"staticQueryHashes":["3858520367"],"slicesMap":{}}