{"componentChunkName":"component---src-templates-challenges-classic-show-tsx","path":"/learn/rosetta-code/rosetta-code-challenges/averagesmode","result":{"data":{"challengeNode":{"challenge":{"block":"rosetta-code-challenges","demoType":null,"title":"Wastani/Mode","description":"<section id=\"description\">\n<p>Napiši funkciju <code>mode</code> koja pronalazi vrednost koja se najčešće pojavljuje u nizu.</p>\n<p>Slučaj prazne kolekcije može se zanemariti. Potrebno je voditi računa o situaciji kada mod nije jedinstven.</p>\n<p>Ako nije prikladno ili moguće podržati opštu kolekciju, koristi vektor (niz). Ako nije prikladno ili moguće podržati neodređen tip vrednosti, koristi cele brojeve.</p>\n</section>","id":"594d8d0ab97724821379b1e6","hasEditableBoundaries":false,"instructions":"","notes":null,"challengeType":1,"helpCategory":"Rosetta","videoUrl":null,"superBlock":"rosetta-code","translationPending":false,"forumTopicId":302226,"hooks":{"beforeAll":null,"beforeEach":"const arr1 = [1, 3, 6, 6, 6, 6, 7, 7, 12, 12, 17];\nconst arr2 = [1, 2, 4, 4, 1];","afterEach":null,"afterAll":null},"fields":{"slug":"/learn/rosetta-code/rosetta-code-challenges/averagesmode"},"required":[],"usesMultifileEditor":false,"challengeFiles":[{"fileKey":"scriptjs","ext":"js","name":"script","contents":"function mode(arr) {\n\n  return true;\n}","head":null,"tail":null,"editableRegionBoundaries":[],"history":["script.js"]}],"saveSubmissionToDB":null,"tests":[{"text":"<p><code>mode</code> treba da bude funkcija.</p>","testString":"assert(typeof mode === 'function');"},{"text":"<p><code>mode([1, 3, 6, 6, 6, 6, 7, 7, 12, 12, 17])</code> treba da bude jednako <code>[6]</code>.</p>","testString":"assert.deepEqual(mode(arr1), [6]);"},{"text":"<p><code>mode([1, 2, 4, 4, 1])</code> treba da bude jednako <code>[1, 4]</code>.</p>","testString":"assert.deepEqual(mode(arr2).sort(), [1, 4]);"}]}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/rosetta-code/#rosetta-code-challenges","dashedName":"averagesmode","certification":"rosetta-code","disableLoopProtectTests":true,"disableLoopProtectPreview":false,"superBlock":"rosetta-code","chapter":null,"module":null,"block":"rosetta-code-challenges","isFirstStep":false,"template":null,"required":[],"isLastChallengeInBlock":false,"nextChallengePath":"/learn/rosetta-code/rosetta-code-challenges/averagespythagorean-means","prevChallengePath":"/learn/rosetta-code/rosetta-code-challenges/amicable-pairs","id":"594d8d0ab97724821379b1e6","saveSubmissionToDB":null},"projectPreview":{"challengeData":{"challengeType":1,"challengeFiles":[{"name":"script","ext":"js","contents":"function ZigZagMatrix(n) {\n  const mtx = [];\n  for (let i = 0; i < n; i++) {\n    mtx[i] = [];\n  }\n\n  let i = 1;\n  let j = 1;\n  for (let e = 0; e < n * n; e++) {\n    mtx[i - 1][j - 1] = e;\n    if ((i + j) % 2 === 0) {\n      // Even stripes\n      if (j < n) j++;\n      else i += 2;\n      if (i > 1) i--;\n    } else {\n      // Odd stripes\n      if (i < n) i++;\n      else j += 2;\n      if (j > 1) j--;\n    }\n  }\n  return mtx;\n}","history":["script.js"],"fileKey":"scriptjs"}]}},"id":"/learn/rosetta-code/rosetta-code-challenges/averagesmode"}},"staticQueryHashes":["3858520367"],"slicesMap":{}}