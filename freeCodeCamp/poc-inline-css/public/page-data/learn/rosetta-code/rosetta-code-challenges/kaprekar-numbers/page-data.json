{"componentChunkName":"component---src-templates-challenges-classic-show-tsx","path":"/learn/rosetta-code/rosetta-code-challenges/kaprekar-numbers","result":{"data":{"challengeNode":{"challenge":{"block":"rosetta-code-challenges","demoType":null,"title":"Brojevi Kaprekara","description":"<section id=\"description\">\n<p>Puni pozitivan broj je Kaprekarov broj ako:</p>\n<ul>\n  <li>Jedan je, ili,</li>\n  <li>Decimalna reprezentacija njegovog kvadrata može se podeliti na dva dela koja sadrže pozitivne cele brojeve čija je suma prirodan broj. </li>\n</ul>\n<p>Zapamtite da podjelu koja rezultira frakcijom sa samo nultom nije prihvatljiva, jer se nula ne smatra pozitivnom.</p>\n<p>Primer brojeva Kaprekara:</p>\n<ul>\n  <li><code>2223</code> je Kaprekarov broj, jer <code>2223 * 2223 = 4941729</code>, <code>4941729</code> može se podeliti na <code>494</code> i <code>1729</code>, a <code>494 + 1729 = 2223</code></li>\n  <li>Niz Kaprekarovih brojeva poznat je kao A006886 i počinje sa <code>1, 9, 45, 55, ...</code></li>\n</ul>\n</section>","id":"5a23c84252665b21eecc7eca","hasEditableBoundaries":false,"instructions":"<section id=\"instructions\">\n<p>Napišite funkciju koja prima broj $n$, bazu $bs$, i vraća <code>true</code> ako je broj Kaprekarov broj za zadatu bazu. Inače, funkcija treba da vrati <code>false</code>.</p>\n</section>","notes":null,"challengeType":1,"helpCategory":"Rosetta","videoUrl":null,"superBlock":"rosetta-code","translationPending":false,"forumTopicId":302296,"hooks":null,"fields":{"slug":"/learn/rosetta-code/rosetta-code-challenges/kaprekar-numbers"},"required":[],"usesMultifileEditor":false,"challengeFiles":[{"fileKey":"scriptjs","ext":"js","name":"script","contents":"function isKaprekar(n, bs) {\n\n}","head":null,"tail":null,"editableRegionBoundaries":[],"history":["script.js"]}],"saveSubmissionToDB":null,"tests":[{"text":"<p><code>isKaprekar</code> trebalo bi da bude funkcija.</p>","testString":"assert(typeof isKaprekar == 'function');"},{"text":"<p><code>isKaprekar(1, 10)</code> trebalo bi da vrati vrednost tačno ili netačno.</p>","testString":"assert(typeof isKaprekar(1, 10) == 'boolean');"},{"text":"<p><code>isKaprekar(1, 10)</code> treba vratiti <code>true</code>.</p>","testString":"assert.equal(isKaprekar(1, 10), true);"},{"text":"<p><code>isKaprekar(9, 10)</code> treba da vrati <code>true</code>.</p>","testString":"assert.equal(isKaprekar(9, 10), true);"},{"text":"<p><code>isKaprekar(2223, 10)</code> treba da vrati <code>true</code>.</p>","testString":"assert.equal(isKaprekar(2223, 10), true);"},{"text":"<p><code>isKaprekar(22823, 10)</code> trebalo bi da vrati <code>false</code>.</p>","testString":"assert.equal(isKaprekar(22823, 10), false);"},{"text":"<p><code>isKaprekar(9, 17)</code> inapaswa kurudisha <code>false</code>.</p>","testString":"assert.equal(isKaprekar(9, 17), false);"},{"text":"<p><code>isKaprekar(225, 17)</code> trebalo bi da vrati <code>true</code>.</p>","testString":"assert.equal(isKaprekar(225, 17), true);"},{"text":"<p><code>isKaprekar(999, 17)</code> trebalo bi da vrati <code>false</code>.</p>","testString":"assert.equal(isKaprekar(999, 17), false);"}]}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/rosetta-code/#rosetta-code-challenges","dashedName":"kaprekar-numbers","certification":"rosetta-code","disableLoopProtectTests":true,"disableLoopProtectPreview":false,"superBlock":"rosetta-code","chapter":null,"module":null,"block":"rosetta-code-challenges","isFirstStep":false,"template":null,"required":[],"isLastChallengeInBlock":false,"nextChallengePath":"/learn/rosetta-code/rosetta-code-challenges/knapsack-problem0-1","prevChallengePath":"/learn/rosetta-code/rosetta-code-challenges/k-d-tree","id":"5a23c84252665b21eecc7eca","saveSubmissionToDB":null},"projectPreview":{"challengeData":{"challengeType":1,"challengeFiles":[{"name":"script","ext":"js","contents":"function ZigZagMatrix(n) {\n  const mtx = [];\n  for (let i = 0; i < n; i++) {\n    mtx[i] = [];\n  }\n\n  let i = 1;\n  let j = 1;\n  for (let e = 0; e < n * n; e++) {\n    mtx[i - 1][j - 1] = e;\n    if ((i + j) % 2 === 0) {\n      // Even stripes\n      if (j < n) j++;\n      else i += 2;\n      if (i > 1) i--;\n    } else {\n      // Odd stripes\n      if (i < n) i++;\n      else j += 2;\n      if (j > 1) j--;\n    }\n  }\n  return mtx;\n}","history":["script.js"],"fileKey":"scriptjs"}]}},"id":"/learn/rosetta-code/rosetta-code-challenges/kaprekar-numbers"}},"staticQueryHashes":["3858520367"],"slicesMap":{}}