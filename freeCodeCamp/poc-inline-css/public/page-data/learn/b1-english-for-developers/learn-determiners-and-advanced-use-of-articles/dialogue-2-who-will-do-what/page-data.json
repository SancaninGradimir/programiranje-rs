{"componentChunkName":"component---src-templates-challenges-generic-show-tsx","path":"/learn/b1-english-for-developers/learn-determiners-and-advanced-use-of-articles/dialogue-2-who-will-do-what","result":{"data":{"challengeNode":{"challenge":{"assignments":["<p>Gledaj video.</p>"],"bilibiliIds":null,"block":"learn-determiners-and-advanced-use-of-articles","challengeType":21,"description":"<section id=\"description\">\n<p>Pogledajte video ispod da biste razumeli kontekst sledećih lekcija.</p>\n</section>","nodules":null,"explanation":null,"helpCategory":"English","instructions":"","fields":{"slug":"/learn/b1-english-for-developers/learn-determiners-and-advanced-use-of-articles/dialogue-2-who-will-do-what"},"questions":[],"scene":{"setup":{"background":"company1-boardroom.png","characters":[{"character":"Bob","position":{"x":-25,"y":0,"z":1},"opacity":null},{"character":"Alice","position":{"x":125,"y":0,"z":1},"opacity":null}],"audio":{"filename":"B1_20-2.mp3","startTime":1,"startTimestamp":null,"finishTimestamp":null},"alwaysShowDialogue":true},"commands":[{"background":null,"character":"Bob","position":{"x":25,"y":0,"z":1},"opacity":null,"startTime":0,"finishTime":null,"dialogue":null},{"background":null,"character":"Alice","position":{"x":70,"y":0,"z":1},"opacity":null,"startTime":0.5,"finishTime":null,"dialogue":null},{"background":null,"character":"Bob","position":null,"opacity":null,"startTime":1,"finishTime":8.06,"dialogue":{"text":"As we start the new mobile app project, we need to decide who will do what. Each developer will have their own tasks.","align":"left"}},{"background":null,"character":"Alice","position":null,"opacity":null,"startTime":8.76,"finishTime":15.14,"dialogue":{"text":"That's a great idea. We have many features to work on, and our developers have different skills. How are we going to assign these tasks?","align":"right"}},{"background":null,"character":"Bob","position":null,"opacity":null,"startTime":15.72,"finishTime":23.04,"dialogue":{"text":"We'll match tasks to each developer's skills. Sarah will take care of user authentication because she has the most experience there.","align":"left"}},{"background":null,"character":"Bob","position":null,"opacity":null,"startTime":23.46,"finishTime":25.32,"dialogue":{"text":"Tom will work on payment integration.","align":"left"}},{"background":null,"character":"Alice","position":null,"opacity":null,"startTime":26.04,"finishTime":29.3,"dialogue":{"text":"What about those new developers we started onboarding a few weeks ago?","align":"right"}},{"background":null,"character":"Bob","position":null,"opacity":null,"startTime":29.3,"finishTime":37.48,"dialogue":{"text":"Each new developer will work with someone more experienced. This way, every new person gets help and no one feels too stressed.","align":"left"}},{"background":null,"character":"Alice","position":null,"opacity":null,"startTime":38.08,"finishTime":41.5,"dialogue":{"text":"That makes sense. Do we have any plans for how often we'll check their progress?","align":"right"}},{"background":null,"character":"Bob","position":null,"opacity":null,"startTime":42.04,"finishTime":51.1,"dialogue":{"text":"Yes. We'll meet every two weeks to talk about how everyone is doing and to solve any problems. It's important that no part of the project gets delayed.","align":"left"}},{"background":null,"character":"Alice","position":null,"opacity":null,"startTime":51.78,"finishTime":55.1,"dialogue":{"text":"I'm not sure we have enough QA people to test all the new features, though.","align":"right"}},{"background":null,"character":"Bob","position":null,"opacity":null,"startTime":55.72,"finishTime":61.56,"dialogue":{"text":"Agreed. We're a little short on testers right now. I'm considering bringing in a couple more people for this project.","align":"left"}},{"background":null,"character":"Bob","position":null,"opacity":null,"startTime":61.94,"finishTime":64.72,"dialogue":{"text":"I'll talk to HR and see if we can get some more help.","align":"left"}},{"background":null,"character":"Alice","position":null,"opacity":null,"startTime":65.08,"finishTime":69.96,"dialogue":{"text":"That would be great. Proper testing is crucial, especially for the more complex parts of the app.","align":"right"}},{"background":null,"character":"Bob","position":null,"opacity":null,"startTime":70.44,"finishTime":77.46,"dialogue":{"text":"Definitely. I'll make sure we have all the resources we need. Let's make sure everyone knows their responsibilities by the end of this week.","align":"left"}},{"background":null,"character":"Alice","position":null,"opacity":null,"startTime":78.24,"finishTime":82.92,"dialogue":{"text":"I'll get started on a list of technical requirements for each part of the project to help us assign tasks correctly.","align":"right"}},{"background":null,"character":"Alice","position":{"x":125,"y":0,"z":1},"opacity":null,"startTime":83.42,"finishTime":null,"dialogue":null},{"background":null,"character":"Bob","position":{"x":-25,"y":0,"z":1},"opacity":null,"startTime":83.92,"finishTime":null,"dialogue":null}]},"superBlock":"b1-english-for-developers","tests":[],"title":"Dialogue 2: Who Will Do What","transcript":null,"translationPending":false,"videoId":null,"videoLocaleIds":null}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/b1-english-for-developers/#learn-determiners-and-advanced-use-of-articles","dashedName":"dialogue-2-who-will-do-what","certification":"b1-english-for-developers","disableLoopProtectTests":false,"disableLoopProtectPreview":false,"superBlock":"b1-english-for-developers","chapter":null,"module":null,"block":"learn-determiners-and-advanced-use-of-articles","isFirstStep":false,"template":null,"required":[],"isLastChallengeInBlock":false,"nextChallengePath":"/learn/b1-english-for-developers/learn-determiners-and-advanced-use-of-articles/task-60","prevChallengePath":"/learn/b1-english-for-developers/learn-determiners-and-advanced-use-of-articles/task-59","id":"6811efd946370