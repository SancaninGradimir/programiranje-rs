{"componentChunkName":"component---src-templates-challenges-classic-show-tsx","path":"/learn/2022/responsive-web-design/learn-html-by-building-a-cat-photo-app/step-10","result":{"data":{"challengeNode":{"challenge":{"block":"learn-html-by-building-a-cat-photo-app","demoType":null,"title":"Korak 10","description":"<section id=\"description\">\n<p>Možete se povezati sa drugom stranicom koristeći anker polje (<code>a</code>).</p>\n<p>Ovo je primer povezivanja sa <code>https://www.freecodecamp.org</code>:</p>\n<pre><code class=\"language-html\">&#x3C;a href=\"https://www.freecodecamp.org\">&#x3C;/a>\n</code></pre>\n<p>Dodajte anker element nakon paragrafa koji se povezuje sa <code>https://freecatphotoapp.com</code>. Trenutno, link neće biti vidljiv u početnom prikazu.</p>\n</section>","id":"5dc24614f86c76b9248c6ebd","hasEditableBoundaries":true,"instructions":"","notes":null,"challengeType":0,"helpCategory":"HTML-CSS","videoUrl":null,"superBlock":"2022/responsive-web-design","translationPending":false,"forumTopicId":null,"hooks":null,"fields":{"slug":"/learn/2022/responsive-web-design/learn-html-by-building-a-cat-photo-app/step-10"},"required":[],"usesMultifileEditor":true,"challengeFiles":[{"fileKey":"indexhtml","ext":"html","name":"index","contents":"<html>\n  <body>\n    <main>\n      <h1>CatPhotoApp</h1>\n      <h2>Cat Photos</h2>\n      <!-- TODO: Add link to cat photos -->\n      <p>Everyone loves cute cats online!</p>\n      \n      <img src=\"https://cdn.freecodecamp.org/curriculum/cat-photo-app/relaxing-cat.jpg\" alt=\"A cute orange cat lying on its back.\">\n    </main>\n  </body>\n</html>","head":null,"tail":null,"editableRegionBoundaries":[6,9],"history":["index.html"]}],"saveSubmissionToDB":null,"tests":[{"text":"<p>Vaš anker element (<code>a</code>) mora imati oznaku za otvaranje. Oznake za otvaranje imaju ovu sintaksu: <code>&#x3C;elementName></code>.</p>","testString":"assert(document.querySelector('a'));"},{"text":"<p>Vaš anker element (<code>a</code>) treba da ima zatvarajući tag. Zatvarajući tagovi imaju <code>/</code> odmah nakon karaktera od <code>&#x3C;</code>.</p>","testString":"assert(code.match(/<\\/a\\>/));"},{"text":"<p>Tvoj element sidra (<code>a</code>) treba da bude ispod elementa <code>p</code>. Postavio si ih pogrešnim redosledom.</p>","testString":"const collection = [...document.querySelectorAll('a, p')].map(\n  (node) => node.nodeName\n);\nassert(collection.indexOf('P') < collection.indexOf('A'));"},{"text":"<p>Vaš jangkorni element (<code>a</code>) nema atribut <code>href</code>. Uverite se da postoji razmak nakon imena otvarajuće oznake i/ili da postoji razmak prije svih imena atributa.</p>","testString":"assert(document.querySelector('a').hasAttribute('href'));"},{"text":"<p>Vaš element sidra (<code>a</code>) treba da vodi na <code>https://freecatphotoapp.com</code>. Ili nedostaje URL ili postoji greška u njegovom pisanju.</p>","testString":"assert(\n  document.querySelector('a').getAttribute('href') ===\n    'https://freecatphotoapp.com'\n);"},{"text":"<p>Iako si postavio atribut <code>href</code> elementa sidra (<code>a</code>) na ispravnu vezu, preporučuje se da vrednosti atributa uvek budu pod navodnicima.</p>","testString":"assert(\n  !/\\<a\\s+href\\s*=\\s*https:\\/\\/www.freecodecamp.org\\/cat-photos/.test(code)\n);"}]}}},"pageContext":{"challengeMeta":{"blockHashSlug":"/learn/2022/responsive-web-design/#learn-html-by-building-a-cat-photo-app","dashedName":"step-10","certification":"responsive-web-design","disableLoopProtectTests":false,"disableLoopProtectPreview":false,"superBlock":"2022/responsive-web-design","chapter":null,"module":null,"block":"learn-html-by-building-a-cat-photo-app","isFirstStep":false,"template":null,"required":[],"isLastChallengeInBlock":false,"nextChallengePath":"/learn/2022/responsive-web-design/learn-html-by-building-a-cat-photo-app/step-11","prevChallengePath":"/learn/2022/responsive-web-design/learn-html-by-building-a-cat-photo-app/step-9","id":"5dc24614f86c76b9248c6ebd","saveSubmissionToDB":null},"projectPreview":{"challengeData":{"challengeType":0,"challengeFiles":[{"name":"index","ext":"html","contents":"<!DOCTYPE html>\n<html lang=\"en\">\n  <head>\n    <meta charset=\"UTF-8\">\n    <title>CatPhotoApp</title>\n  </head>\n  <body>\n    <main>\n      <h1>CatPhotoApp</h1>\n      <section>\n        <h2>Cat Photos</h2>\n        <p>Everyone loves <a href=\"https://cdn.freecodecamp.org/curriculum/cat-photo-app/running-cats.jpg\">cute cats</a> online!</p>\n        <p>See more <a target=\"_blank\" href=\"https://freecatphotoapp.com\">cat photos</a> in our gallery.</p>\n        <a href=\"https://freecatphotoapp.com\"><img src=\"https://cdn.freecodecamp.org/curriculum/cat-photo-app/relaxing-cat.jpg\" alt=\"A cute orange cat lying on its back.\"></a>\n      </section>\n      <section>\n        <h2>Cat Lists</h2>\n        <h3>Things cats love:</h3>\n        <ul>\n          <li>catnip</li>\n          <li>laser pointers</li>\n          <li>lasagna</li>\n        </ul>\n        <figure>\n          <img src=\"https://cdn.freecodecamp.org/curriculum/cat-photo-app/lasagna.jpg\" alt=\"A slice of lasagna on a plate.\">\n          <figcaption>Cats <em>love</em> lasagna.</figcaption>  \n        </figure>\n        <h3>Top 3 things cats hate:</h3>\n        <ol>\n          <li>flea treatment</li>\n          <li>thunder</li>\n          <li>other cats</li>\n        </ol>\n        <figure>\n          <img src=\"https://cdn.freecodecamp.org/curriculum/cat-photo-app/cats.jpg\" alt=\"Two tabby kittens sleeping together on a couch.\">\n          <figcaption>Cats <strong>hate</strong> other cats.</figcaption>  \n        </figure>\n      </section>\n      <section>\n        <h2>Cat Form</h2>\n        <form action=\"https://freecatphotoapp.com/submit-cat-photo\">\n          <fieldset>\n            <legend>Is your cat an indoor or outdoor cat?</legend>\n            <label><input id=\"indoor\" type=\"radio\" name=\"indoor-outdoor\" value=\"indoor\" checked> Indoor</label>\n            <label><input id=\"outdoor\" type=\"radio\" name=\"indoor-outdoor\" value=\"outdoor\"> Outdoor</label>\n          </fieldset>\n          <fieldset>\n            <legend>What's your cat's personality?</legend>\n            <label for=\"loving\"><input id=\"loving\" type=\"checkbox\" name=\"personality\" value=\"loving\" checked> Loving</label>\n            <label for=\"lazy\"><input id=\"lazy\" type=\"checkbox\" name=\"personality\" value=\"lazy\"> Lazy</label>\n            <label for=\"energetic\"><input id=\"energetic\" type=\"checkbox\" name=\"personality\" value=\"energetic\"> Energetic</label>\n          </fieldset>\n          <input type=\"text\" name=\"catphotourl\" placeholder=\"cat photo URL\" required>\n          <button type=\"submit\">Submit</button>\n        </form>\n      </section>\n    </main>\n    <footer>\n      <p>\n        No Copyright - <a href=\"https://www.freecodecamp.org\">freeCodeCamp.org</a>\n      </p>\n    </footer>\n  </body>\n</html>","history":["index.html"],"fileKey":"indexhtml"}]}},"id":"/learn/2022/responsive-web-design/learn-html-by-building-a-cat-photo-app/step-10"}},"staticQueryHashes":["3858520367"],"slicesMap":{}}